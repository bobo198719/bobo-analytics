---
const { title = "Baker OS" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style is:global>
        * { box-sizing: border-box !important; }
        
        html, body {
            width: 100% !important;
            height: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            background: #0b0f1a !important;
            color: white !important;
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            overflow: hidden !important;
        }

        .no-scrollbar::-webkit-scrollbar { display: none !important; }
        .no-scrollbar { -ms-overflow-style: none !important; scrollbar-width: none !important; }

        .nav-link {
            display: flex !important;
            align-items: center !important;
            gap: 16px !important;
            padding: 16px 20px !important;
            color: rgba(255,255,255,0.4) !important;
            text-decoration: none !important;
            font-weight: 800 !important;
            text-transform: uppercase !important;
            font-style: italic !important;
            font-size: 11px !important;
            border-radius: 16px !important;
            transition: all 0.3s ease !important;
        }
        .nav-link:hover {
            background: rgba(255,255,255,0.05) !important;
            color: white !important;
            transform: translateX(4px);
        }
        .nav-link.active {
            background: rgba(99, 102, 241, 0.15) !important;
            color: #fff !important;
            box-shadow: inset 0 0 20px rgba(99, 102, 241, 0.1);
            border: 1px solid rgba(99, 102, 241, 0.2);
        }

        #baker-sidebar {
            width: 280px !important;
            background: #0c0c0d !important;
            border-right: 1px solid rgba(255,255,255,0.05) !important;
            height: 100vh !important;
            display: flex !important;
            flex-direction: column !important;
            z-index: 100 !important;
        }

        #baker-main {
            flex: 1 !important;
            height: 100vh !important;
            overflow-y: auto !important;
            padding: 40px !important;
            background: radial-gradient(circle at 100% 0%, rgba(99, 102, 241, 0.03) 0%, transparent 50%);
        }

        /* Access Denied Overlay */
        #access-denied {
            position: fixed;
            inset: 0;
            background: #000;
            z-index: 9999;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 40px;
        }
        #access-denied h1 { font-size: 3rem; color: #ef4444; margin-bottom: 20px; }

        aside.sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 24px 16px;
            z-index: 100;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 40px;
            text-decoration: none;
            color: white;
            padding-left: 8px;
        }
        .logo-orb { 
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,0.02);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border: 1px solid var(--border);
        }
        .logo-orb img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 4px;
        }
        .logo-area span { font-family: 'Outfit'; font-weight: 800; font-size: 1.4rem; letter-spacing: -0.5px; }

        .nav-group { margin-bottom: 32px; }
        .nav-label { font-size: 0.7rem; text-transform: uppercase; color: var(--text-muted); padding-left: 12px; display: block; margin-bottom: 12px; }
        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 600;
            transition: 0.2s;
        }
        .nav-link:hover { background: rgba(99, 102, 241, 0.1); color: var(--primary); transform: translateX(5px); }
        .nav-link.active { background: rgba(99, 102, 241, 0.15); color: var(--primary); border-left: 3px solid var(--primary); }
        .nav-link svg { width: 20px; height: 20px; opacity: 0.8; }

        main.content-wrapper { flex: 1; height: 100vh; overflow-y: auto; background: radial-gradient(circle at 100% 0%, rgba(99, 102, 241, 0.05) 0%, transparent 50%); }
        header.top-bar { height: 80px; padding: 0 40px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); }
        .search-box { background: rgba(255,255,255,0.05); border: 1px solid var(--border); padding: 10px 16px; border-radius: 12px; width: 350px; color: white; border: 1px solid var(--border); }
        .user-meta { display: flex; align-items: center; gap: 24px; }
        .biz-tag { font-size: 0.7rem; background: var(--primary); color: white; padding: 2px 8px; border-radius: 4px; font-weight: 800; text-transform: uppercase; }
        .avatar { width: 36px; height: 36px; background: var(--accent); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; color: white; }

        .page-content { padding: 40px; }
        .glass-card { background: var(--bg-card); backdrop-filter: blur(10px); border: 1px solid var(--border); border-radius: 20px; padding: 24px; }
    </style>
</head>
<body>
    <div id="access-denied">
        <h1>🔒 Access Denied</h1>
        <p>Your business environment (TEST) does not have access to the Baker OS Portal.</p>
        <p style="margin-top: 20px; color: #888;">Only Trial and Live accounts can access this module.</p>
        <a href="/portal/dashboard" style="margin-top: 40px; color: var(--primary); font-weight: 700;">Return to Main Dashboard</a>
    </div>

    <aside id="baker-sidebar">
        <div style="padding: 32px; flex-shrink: 0; display: flex; align-items: center; gap: 12px;">
            <div id="baker-logo-container" style="width: 44px; height: 44px; background: linear-gradient(135deg, #6366f1, #a855f7); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 22px; font-style: italic; box-shadow: 0 10px 25px rgba(99, 102, 241, 0.2); overflow: hidden;">
                <span id="baker-logo-fallback">B</span>
            </div>
            <span id="baker-brand-name" style="font-size: 18px; font-weight: 900; letter-spacing: -0.05em; text-transform: uppercase; font-style: italic; color: white;">Baker <span style="color: #6366f1;">OS</span></span>
        </div>

        <nav class="no-scrollbar" style="flex: 1; padding: 16px; display: flex; flex-direction: column; gap: 8px; overflow-y: auto;">
            <p style="padding: 0 16px; font-size: 10px; font-weight: 900; text-transform: uppercase; color: rgba(255,255,255,0.2); letter-spacing: 0.3em; margin: 16px 0; font-style: italic;">Operational Hubs</p>
            
            <a href="/bakers-os#dashboard" class="nav-link" data-section="dashboard">
                <i class="lucide-layout-grid"></i>
                <span>Intelligence</span>
            </a>
            <a href="/bakers-os#orders" class="nav-link" data-section="orders">
                <i class="lucide-shopping-bag"></i>
                <span>Order Hub</span>
            </a>
            <a href="/bakers-os#costing" class="nav-link" data-section="costing">
                <i class="lucide-calculator"></i>
                <span>Bake Lab</span>
            </a>
            <a href="/bakers-os#products" class="nav-link" data-section="products">
                <i class="lucide-pizza"></i>
                <span>Catalog</span>
            </a>
            <a href="/bakers-os#delivery" class="nav-link" data-section="delivery">
                <i class="lucide-calendar"></i>
                <span>Logistics</span>
            </a>

            <div style="height: 1px; background: rgba(255,255,255,0.05); margin: 24px 16px;"></div>
            
            <p style="padding: 0 16px; font-size: 10px; font-weight: 900; text-transform: uppercase; color: rgba(255,255,255,0.2); letter-spacing: 0.3em; margin: 16px 0; font-style: italic;">Strategy Hubs</p>
            
            <a href="/bakers-os#analytics" class="nav-link" data-section="analytics">
                <i class="lucide-bar-chart-3"></i>
                <span>Sales Matrix</span>
            </a>
            <a href="/bakers-os#crm" class="nav-link" data-section="crm">
                <i class="lucide-users"></i>
                <span>Client CRM</span>
            </a>
            <a href="/bakers-os#website" class="nav-link" data-section="website">
                <i class="lucide-globe"></i>
                <span>Portal Edit</span>
            </a>
        </nav>

        <div style="padding: 24px; border-top: 1px solid rgba(255,255,255,0.05);">
            <a href="/bakers-os#settings" class="nav-link" data-section="settings">
                <i class="lucide-settings"></i>
                <span>Master Config</span>
            </a>
        </div>
    </aside>

    <main id="baker-main" class="no-scrollbar">
        <slot />
    </main>

    <script is:inline>
        // --- IDENTITY SYNC (Logo & Name) ---
        function syncBakerIdentity() {
            const saved = localStorage.getItem('ro_identity');
            if (saved) {
                try {
                    const config = JSON.parse(saved);
                    const lo = document.getElementById('baker-logo-container');
                    const bn = document.getElementById('baker-brand-name');
                    
                    if (config.logo && lo) {
                        lo.innerHTML = `<img src="${config.logo}" style="width:100%; height:100%; object-fit:cover;" />`;
                    }
                    if (config.name && bn) {
                        bn.innerHTML = `${config.name.split(' ')[0]} <span style="color: #6366f1;">OS</span>`;
                    }
                } catch (e) { console.warn("Identity Fail:", e); }
            }
        }

        function switchToSection(target) {
            if (!target) return;
            document.querySelectorAll('.section').forEach(sec => sec.classList.add('hidden'));
            const targetSec = document.getElementById(target + 'Section');
            if (targetSec) targetSec.classList.remove('hidden');

            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href').includes(target)) link.classList.add('active');
            });
        }

        window.addEventListener('hashchange', () => switchToSection(window.location.hash.substring(1) || 'dashboard'));
        window.addEventListener('DOMContentLoaded', () => {
            syncBakerIdentity();
            switchToSection(window.location.hash.substring(1) || 'dashboard');
        });
        setInterval(syncBakerIdentity, 2000);
    </script>
</body>
</html>
    <main class="content-wrapper">
        <header class="top-bar">
            <input type="text" class="search-box" placeholder="Search orders, ingredients, or clients..." />
            <div class="user-meta">
                <a href="/bakers-os/website" target="_blank" style="text-decoration: none; font-size: 0.8rem; font-weight: 700; color: var(--primary); background: rgba(99, 102, 241, 0.1); padding: 8px 16px; border-radius: 8px; border: 1px solid var(--primary); transition: 0.2s;">View Live Site ↗</a>
                <span class="biz-tag" id="envTag">Live</span>
                <span style="font-size: 0.9rem; font-weight: 600;" id="topBizName">Sarah's Patisserie</span>
                <div class="avatar" id="bizInitial">SJ</div>
            </div>
        </header>

        <div class="page-content">
            <slot />
        </div>
    </main>

    <script is:inline>
        // --- ABSOLUTE AUTHENTICATION GUARD ---
        if (localStorage.getItem('baker_os_auth') !== 'true' && !window.location.pathname.includes('login')) {
            window.location.href = '/bakers-login';
        }

        document.addEventListener('DOMContentLoaded', () => {
            try {
                // Find current account
                const accounts = JSON.parse(localStorage.getItem('bobo_accounts') || '[]');
                const client = accounts[accounts.length - 1] || { 
                    businessName: "Bakers OS", 
                    type: "Trial", 
                    ownerName: "Admin" 
                };

                // Security Check
                const ad = document.getElementById('access-denied');
                // Force access denied if no auth is found (double check)
                if (!localStorage.getItem('baker_os_auth')) {
                    if (ad) ad.style.display = 'flex';
                    window.location.href = '/bakers-login';
                    return;
                }

                // Branding Injection
                const profileData = JSON.parse(localStorage.getItem('bobo_baker_profile') || '{}');
                const websiteData = JSON.parse(localStorage.getItem('bobo_website_data') || '{}');
                
                // Force reset if it's the old default
                if (websiteData.bizName === "Bakers OS" || websiteData.bizName === "Home Bakers OS" || websiteData.bizName === "Trivia") {
                    websiteData.bizName = "Baker OS";
                }
                const finalName = profileData.business || websiteData.bizName || "Baker OS";
                const finalLogo = profileData.logo || websiteData.bizLogo || "/bakers-logo.png";

                const bn = document.getElementById('bizName');
                if (bn) bn.innerText = finalName;
                
                const tbn = document.getElementById('topBizName');
                if (tbn) tbn.innerText = finalName;
                
                const et = document.getElementById('envTag');
                if (et) et.innerText = client.type || "Live";
                
                const bi = document.getElementById('bizInitial');
                if (bi) {
                    if (finalLogo && (finalLogo.startsWith('http') || finalLogo.startsWith('/'))) {
                        bi.innerHTML = `<img src="${finalLogo}" style="width:100%; height:100%; border-radius:50%; object-fit:cover;">`;
                    } else {
                        bi.innerText = finalName.charAt(0).toUpperCase();
                    }
                }

                // Sidebar Logo Orb
                const lo = document.getElementById('bizLogo');
                if (lo && websiteData.bizLogo) {
                    lo.innerHTML = `<img src="${websiteData.bizLogo}" alt="Logo">`;
                }

                // Navigation State
                const currentPath = window.location.pathname;
                document.querySelectorAll('.nav-link').forEach(link => {
                    const navPath = link.getAttribute('data-nav');
                    if (navPath && (currentPath === navPath || currentPath === navPath + '/')) {
                        link.classList.add('active');
                    }
                });
            } catch(e) {
                console.warn("Layout error:", e);
            }
        });
    </script>
</body>
</html>
