---
interface Props {
  title: string;
}

const { title = "Restaurant OS" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style is:global>
      * { box-sizing: border-box !important; }
      
      html, body {
        width: 100% !important;
        height: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
        background: #0b0f1a !important;
        color: white !important;
        font-family: 'Plus Jakarta Sans', sans-serif !important;
        overflow-x: hidden !important;
        overflow-y: visible !important;
      }

      /* HIDE CUSTOM SCROLLBARS FOR CLEAN OS LOOK */
      .no-scrollbar::-webkit-scrollbar { display: none !important; }
      .no-scrollbar { -ms-overflow-style: none !important; scrollbar-width: none !important; }
      
      #restaurant-root-sidebar {
        width: 256px !important;
        min-width: 256px !important;
        background: #0f172a !important;
        z-index: 99999 !important;
        border-right: 2px solid rgba(249, 115, 22, 0.4) !important; /* Bright orange border hint for confirmation */
        display: flex !important;
        flex-direction: column !important;
      }

      .nav-link {
        display: flex;
        align-items: center;
        padding: 10px 16px !important;
        color: rgba(255,255,255,0.6) !important;
        text-decoration: none !important;
        font-weight: 500 !important;
        font-size: 13px !important;
        border-radius: 12px !important;
        transition: all 0.2s ease-in-out !important;
      }
      
      /* NORMAL ACTIVE STATE (Non-POS) */
      .nav-link.active {
        background: rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        font-weight: 700 !important;
        box-shadow: none !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
      }

      /* POS TERMINAL TOUCH SCREEN OVERRIDE MODE */
      body.pos-active-mode .nav-link {
        text-transform: uppercase !important;
        font-style: italic !important;
        font-weight: 800 !important;
        letter-spacing: 0.05em !important;
        padding: 18px 20px !important; /* Touch targets */
      }
      body.pos-active-mode #restaurant-root-sidebar nav {
        gap: 8px !important;
      }
      body.pos-active-mode .nav-link.active {
        background: rgba(249, 115, 22, 0.15) !important;
        color: #f97316 !important;
        box-shadow: inset 0 0 20px rgba(249, 115, 22, 0.1) !important;
        border: 1px solid rgba(249, 115, 22, 0.2) !important;
      }
      .nav-link:hover {
        background: rgba(255,255,255,0.08) !important;
        color: white !important;
      }


      /* Removed CSS-based lockdown: relying on dynamic terminal module loading from backend schema below */

      /* Hide Break/Logout for Privilege Roles (Only show for chef/waiter) */
      body:not([data-role="waiter"]):not([data-role="chef"]) #staffControlPanel { 
        display: none !important; 
      }
    </style>

    <script is:inline>
      (function syncRole() {
         const role = localStorage.getItem('ro_role') || 'owner';
         const permission = localStorage.getItem('ro_permission') || 'entire';
         const rawModules = localStorage.getItem('ro_modules') || '[]';
         
         let modules = [];
         try { modules = JSON.parse(rawModules); } catch(e){}

         document.documentElement.setAttribute('data-role', role);
         
         const enforcePermissions = () => {
             document.body.setAttribute('data-role', role);
             // Role-based structural limits
             if (role === 'chef') {
                 const allLinks = document.querySelectorAll('[data-section]');
                 allLinks.forEach(link => {
                     const sectionId = link.getAttribute('data-section');
                     if (sectionId !== 'kitchen' && sectionId !== 'waiter' && sectionId !== 'tables') {
                         link.style.setProperty('display', 'none', 'important');
                     } else {
                         if (link.classList.contains('nav-link')) {
                             link.style.setProperty('display', 'flex', 'important');
                         } else {
                             link.style.display = '';
                         }
                     }
                 });
             } else if (role === 'waiter') {
                 const allLinks = document.querySelectorAll('[data-section]');
                 allLinks.forEach(link => {
                     const sectionId = link.getAttribute('data-section');
                     if (sectionId !== 'pos' && sectionId !== 'waiter' && sectionId !== 'tables') {
                         link.style.setProperty('display', 'none', 'important');
                     } else {
                         if (link.classList.contains('nav-link')) {
                             link.style.setProperty('display', 'flex', 'important');
                         } else {
                             link.style.display = '';
                         }
                     }
                 });
             } else if (permission === 'limited' && role !== 'owner') {
                 const allLinks = document.querySelectorAll('[data-section]');
                 allLinks.forEach(link => {
                     const sectionId = link.getAttribute('data-section');
                     
                     let mappedModule = sectionId;
                     if (sectionId === 'menu-upload') mappedModule = 'upload';
                     if (sectionId === 'crm') mappedModule = 'customers';
                     if (sectionId === 'reports') mappedModule = 'analytics';
                     if (sectionId === 'settings') mappedModule = 'staff';
                     
                     if (mappedModule !== 'dashboard' && mappedModule !== 'pos' && mappedModule !== 'waiter' && mappedModule !== 'kitchen' && mappedModule !== 'tables' && mappedModule !== 'menu' && mappedModule !== 'upload' && mappedModule !== 'customers' && mappedModule !== 'analytics' && mappedModule !== 'staff' && mappedModule !== 'billing') {
                         return;
                     }
                     
                     if (!modules.includes(mappedModule)) {
                         link.style.setProperty('display', 'none', 'important');
                     }
                 });
             }
         };

         const syncBody = () => {
            if (document.body && document.querySelectorAll('[data-section]').length > 0) {
               enforcePermissions();
            } else {
               requestAnimationFrame(syncBody);
            }
         };
         syncBody();
         
         document.addEventListener('DOMContentLoaded', enforcePermissions);
         syncBody();
      })();
    </script>
</head>
<body class="bg-[#0b0f1a] text-white" data-role="owner">

  <!-- SIDEBAR (GLOBAL ROOT LEVEL CHILD OF BODY) -->
  <aside id="restaurant-root-sidebar" class="fixed left-0 top-0 h-screen bg-[#0c0c0d] border-r border-white/5 z-[99999]" style="display: flex; flex-direction: column; width: 256px;">
    
    <div style="padding: 32px; flex-shrink: 0; display: flex; align-items: center; gap: 12px;">
      <div id="sidebar-logo-container" style="width: 40px; height: 40px; background: linear-gradient(135deg, #f97316, #e11d48); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 20px; font-style: italic; box-shadow: 0 10px 20px rgba(249, 115, 22, 0.2); overflow: hidden;">
        <span id="sidebar-logo-fallback">B</span>
      </div>
      <span id="sidebar-brand-name" style="font-size: 18px; font-weight: 900; letter-spacing: -0.05em; text-transform: uppercase; font-style: italic; color: white;">Bobo <span style="color: #f97316;">OS</span></span>
    </div>

    <nav class="no-scrollbar" style="flex: 1; padding: 16px; display: flex; flex-direction: column; gap: 2px; overflow-y: auto; min-height: 0;">
      <p style="padding: 0 16px; font-size: 9px; font-weight: 900; text-transform: uppercase; color: rgba(255,255,255,0.2); letter-spacing: 0.3em; margin: 8px 0 16px 0; font-style: italic;">SYSTEM TERMINAL Hub</p>
      
      <a href="/restaurant-dashboard#dashboard" class="nav-link" data-section="dashboard">
        <span>Dashboard</span>
      </a>

      <div style="height: 1px; background: rgba(255,255,255,0.05); margin: 12px 16px;"></div>

      <a href="/restaurant-dashboard#pos" class="nav-link" data-section="pos">
        <span>POS Terminal</span>
      </a>
      <a href="/restaurant-dashboard#tables" class="nav-link" data-section="tables">
        <span>Tables</span>
      </a>
      <a href="/restaurant-dashboard#kitchen" class="nav-link" data-section="kitchen">
        <span>Kitchen Hub</span>
      </a>
      <a href="/restaurant-dashboard#waiter" class="nav-link" data-section="waiter">
        <span>Waiter Queue</span>
      </a>
      <a href="/restaurant-dashboard#menu" class="nav-link" data-section="menu">
        <span>Menu Hub</span>
      </a>
      <a href="/restaurant-dashboard#upload" class="nav-link" data-section="menu-upload">
        <span>Smart Upload</span>
      </a>

      <div style="height: 1px; background: rgba(255,255,255,0.05); margin: 12px 16px;"></div>

      <a href="/restaurant-dashboard#crm" class="nav-link" data-section="crm">
        <span>Guest CRM</span>
      </a>
      <a href="/restaurant-dashboard#reports" class="nav-link" data-section="reports">
        <span>Daily Report</span>
      </a>
      <button onclick="recordStaffEvent('logout')" class="w-[calc(100%-32px)] mx-4 flex items-center justify-center px-4 py-3 rounded-xl bg-rose-500/10 border border-rose-500/20 text-rose-500 font-black italic text-[12px] uppercase tracking-widest hover:bg-rose-500/20 transition-all transition-transform active:scale-95 mb-4 mt-2">
         <span>Exit Terminal</span>
      </button>
    </nav>

       <!-- Audit & Break Control -->
       <div id="staffControlPanel" class="mt-8 pt-8 border-t border-white/5 space-y-4">
          <button onclick="recordStaffEvent('break_start')" class="w-full flex items-center gap-4 px-6 py-4 rounded-2xl bg-amber-500/10 border border-amber-500/20 text-amber-500 font-black italic text-[10px] uppercase tracking-widest hover:bg-amber-500/20 transition-all transition-transform active:scale-95">
             <i class="lucide-coffee"></i> <span>Request Break</span>
          </button>
       </div>

       <!-- INSTALL APP PORTAL (PERMANENTLY VISIBLE) -->
       <div id="install-container" style="padding: 12px; margin-top: 20px; background: rgba(249, 115, 22, 0.1); border-radius: 16px; border: 1px dashed #f97316; display: block;">
          <span style="font-size: 0.65rem; color: #f97316; font-weight: 800; text-transform: uppercase; display: block; margin-bottom: 8px; text-align: center;">📲 Bobo Apps & APK Center</span>
          <button id="btnInstall" style="background: linear-gradient(135deg, #f97316, #e11d48); color: white; border: none; width: 100%; padding: 12px; border-radius: 12px; font-weight: 900; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 10px; text-transform: uppercase; font-style: italic; box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3);">
              <i class="lucide-download" style="font-size: 14px;"></i>
              <span>Download App</span>
          </button>
       </div>
    </div>
  </aside>

  <script is:inline>
     async function recordStaffEvent(type) {
        const user = localStorage.getItem('ro_username') || 'system_root';
        try {
           await fetch('/api/v2/restaurant/staff/logs', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ username: user, event_type: type })
           });

           if (type === 'logout') {
              localStorage.removeItem('restaurant_auth');
              window.location.href = '/restaurant-login';
           } else {
              alert(`Shift Event [${type.toUpperCase()}] Recorded.`);
           }
        } catch (err) { console.error("Log Fail:", err); }
     }

     let deferredPrompt;
     const btnInstall = document.getElementById('btnInstall');

     window.addEventListener('beforeinstallprompt', (e) => {
         e.preventDefault();
         deferredPrompt = e;
         console.log('✅ Software Install Ready');
     });

     if (btnInstall) {
         btnInstall.addEventListener('click', async () => {
             if (deferredPrompt) {
                 deferredPrompt.prompt();
                 const { outcome } = await deferredPrompt.userChoice;
                 deferredPrompt = null;
             } else {
                 alert("App Installation Info:\n\n1. Mobile: Tap 'Install App' or 'Add to Home Screen' in browser menu.\n2. PC: Click the 'Install' icon ⊕ in URL bar.\n3. Already installed? Open it from your home screen!");
             }
         });
     }

     window.addEventListener('appinstalled', () => console.log('✅ Software Installed.'));
  </script>

  <!-- MAIN CONTENT (OFFSET BY SIDEBAR) -->
  <main id="restaurant-main-view" style="margin-left: 256px !important; padding: 24px; min-height: 100vh; position: relative; z-index: 10; background: #0b0f1a;">
     <slot />
  </main>

  <!-- OVERLAY FOR EXPIRED SUBSCRIPTIONS -->
  <div id="global-expired-overlay" style="display:none; margin-left:256px;" class="fixed inset-0 bg-[#05081a]/95 backdrop-blur-3xl z-[99998] flex items-center justify-center p-6">
    <div class="text-center max-w-md bg-[#0f172a] p-10 rounded-3xl border border-rose-500/20 shadow-2xl shadow-rose-500/10">
      <div class="text-6xl mb-6 flex justify-center"><i class="lucide-lock text-rose-500"></i></div>
      <h2 class="text-3xl font-black italic uppercase tracking-tighter mb-4 text-white">Subscription <span class="text-rose-500">Expired</span></h2>
      <p class="text-white/40 mb-8 font-semibold text-sm">Your restaurant OS access has been locked due to subscription expiry. Renew your plan to resume full operations immediately.</p>
      <a href="/restaurant-pricing" class="block w-full py-4 bg-gradient-to-r from-orange-600 to-rose-500 rounded-2xl font-black uppercase text-xs tracking-widest italic text-center text-white hover:from-orange-500 transition-all shadow-xl">
        Renew Subscription →
      </a>
      <a href="/restaurant-os/billing" class="block mt-4 text-[10px] font-black uppercase tracking-widest text-white/30 hover:text-white/60 transition-colors">
        View Billing History
      </a>
    </div>
  </div>

  <script is:inline>
     // --- ENTERPRISE ROLE SYNC (Instant) ---
     (function syncRole() {
        const role = localStorage.getItem('ro_role') || 'owner';
        document.body.setAttribute('data-role', role);
     })();

     // --- AUTH GUARD ---
     function checkAuth() {
       try {
         if (localStorage.getItem('restaurant_auth') !== 'true') {
            window.location.replace("/restaurant-login");
            return;
         }
         
         if (window.location.pathname !== '/restaurant-pricing' && window.location.pathname !== '/restaurant-os/billing') {
            const status = localStorage.getItem('subscription_status');
            const expiryStr = localStorage.getItem('subscription_expiry');
            const expiry = expiryStr ? parseInt(expiryStr) : 0;
            const now = Date.now();
            
            if (status === 'cancelled' && expiry < now) {
                localStorage.setItem('subscription_status', 'expired');
            }

            if ((localStorage.getItem('subscription_status') === 'expired') || (expiry > 0 && expiry < now)) {
                document.getElementById('restaurant-main-view').style.display = 'none';
                const overlay = document.getElementById('global-expired-overlay');
                if(overlay) overlay.style.display = 'flex';
                localStorage.setItem('subscription_status', 'expired');
            }
         }
       } catch (e) { console.warn("Auth check failed:", e); }
     }
     // --- IDENTITY SYNC (Logo & Name) ---
     function syncIdentity() {
        const saved = localStorage.getItem('ro_identity');
        if (saved) {
           try {
              const config = JSON.parse(saved);
              const logoContainers = [
                 document.getElementById('sidebar-logo-container'),
                 document.getElementById('header-logo-container')
              ];
              const brandNames = [
                 document.getElementById('sidebar-brand-name'),
                 document.getElementById('header-brand-name'),
                 document.getElementById('activeBranch')
              ];

              if (config.logo) {
                 logoContainers.forEach(container => {
                    if (container) {
                       container.innerHTML = `<img src="${config.logo}" style="width:100%; height:100%; object-fit:cover;" />`;
                    }
                 });
              }

              if (config.name) {
                 // Update specific brand name elements if they exist
                 const sidebarBrand = document.getElementById('sidebar-brand-name');
                 if (sidebarBrand) {
                    sidebarBrand.innerHTML = `${config.name.split(' ')[0]} <span style="color: #f97316;">OS</span>`;
                 }
              }
           } catch (e) { console.warn("Identity Sync Fail:", e); }
        }
     }
     
     syncIdentity();
     window.addEventListener('storage', (e) => {
        if (e.key === 'ro_identity') syncIdentity();
     });
     // Also sync on frequent intervals for in-memory changes
     setInterval(syncIdentity, 2000);
  </script>
</body>
</html>
