---
const { title = "Bobo Retail OS" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --sidebar-width: 260px;
            --bg-dark: #05081a;
            --bg-glass: rgba(255, 255, 255, 0.03);
            --primary: #6366f1;
            --secondary: #a855f7;
            --text-main: #ffffff;
            --text-muted: rgba(255, 255, 255, 0.6);
            --border: rgba(255, 255, 255, 0.1);
            --success: #10b981;
            --warning: #f59e0b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-dark);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow: hidden;
        }

        /* Sidebar Styles */
        aside.sidebar {
            width: var(--sidebar-width);
            background: rgba(11, 17, 45, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 24px;
            z-index: 100;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 40px;
            text-decoration: none;
            color: white;
        }

        .logo-area img {
            width: 32px;
            height: 32px;
        }

        .logo-area span {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 1.25rem;
            background: linear-gradient(135deg, white 0%, #a5b4fc 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-bottom: 24px;
        }

        .nav-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            margin-bottom: 8px;
            padding-left: 12px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 500;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        .nav-link:hover {
            color: white;
            background: rgba(255, 255, 255, 0.05);
        }

        .nav-link.active {
            background: var(--primary);
            color: white;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        }

        .branch-selector {
            margin-top: auto;
            background: var(--bg-glass);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px;
        }

        .branch-info {
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        .branch-name {
            font-weight: 600;
            color: white;
            display: block;
        }

        /* Main Content */
        main.content {
            flex: 1;
            height: 100vh;
            overflow-y: auto;
            position: relative;
            background: radial-gradient(circle at 50% 0%, rgba(99, 102, 241, 0.05) 0%, transparent 70%);
        }

        .top-nav {
            height: 72px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            background: rgba(5, 8, 26, 0.5);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 90;
        }

        .search-box {
            background: var(--bg-glass);
            border: 1px solid var(--border);
            padding: 10px 16px;
            border-radius: 20px;
            width: 300px;
            color: white;
            font-size: 0.9rem;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
        }

        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            aside.sidebar {
                width: 80px;
                padding: 16px;
            }
            .logo-area span, .nav-label, .nav-link span, .branch-info {
                display: none;
            }
            .nav-link {
                justify-content: center;
                padding: 12px;
            }
        }
    </style>
</head>
<body>
    <aside class="sidebar">
        <a href="/" class="logo-area">
            <img src="/logo.png" alt="Bobo" />
            <span>Bobo Retail OS</span>
        </a>

        <div class="nav-group">
            <span class="nav-label">Core Business</span>
            <a href="/retail-os" class="nav-link" data-nav="/retail-os">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                <span>Dashboard</span>
            </a>
            <a href="/pos-clothing" class="nav-link" data-nav="/pos-clothing">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span>Retail POS</span>
            </a>
        </div>

        <div class="nav-group">
            <span class="nav-label">Management</span>
            <a href="/retail-os/inventory" class="nav-link" data-nav="/retail-os/inventory">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="15" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="15" y2="18"/><path d="M21 12V6l-3 4-3-4v12l3-4 3 4v-6"/></svg>
                <span>Inventory</span>
            </a>
            <a href="/retail-os/customers" class="nav-link" data-nav="/retail-os/customers">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span>CRM / Customers</span>
            </a>
            <a href="/retail-os/staff" class="nav-link" data-nav="/retail-os/staff">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span>Staff Control</span>
            </a>
        </div>

        <div class="nav-group">
            <span class="nav-label">Reports</span>
            <a href="/retail-os/analytics" class="nav-link" data-nav="/retail-os/analytics">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
                <span>Analytics</span>
            </a>
            <a href="/retail-os/returns" class="nav-link" data-nav="/retail-os/returns">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 12 8 9l3-3"/><path d="m16 18 3-3-3-3"/><path d="M8 9h8c1 0 2 1 2 2v1"/><path d="M16 15H8c-1 0-2-1-2-2v-1"/></svg>
                <span>Returns Hub</span>
            </a>
        </div>

        <script is:inline>
            // --- AUTH GUARD ---
            if (!localStorage.getItem('retail_os_auth')) {
                window.location.href = '/retail-os-login';
            }

            // Highlight active navigation link
            const currentPath = window.location.pathname;
            const navLinks = document.querySelectorAll('.nav-link');
            navLinks.forEach(link => {
                const linkPath = link.getAttribute('data-nav');
                if (currentPath === linkPath || (currentPath === '/retail-os/' && linkPath === '/retail-os')) {
                    link.classList.add('active');
                } else {
                    link.classList.remove('active');
                }
            });

            // Handle Logout
            document.getElementById('logout-btn')?.addEventListener('click', () => {
                localStorage.removeItem('retail_os_auth');
                localStorage.removeItem('retail_os_user');
                window.location.href = '/retail-os-login';
            });
        </script>

        <div class="branch-selector">
            <div class="branch-info">
                <span>Active Store</span>
                <span class="branch-name">South City Mall</span>
            </div>
            <button id="logout-btn" style="width: 100%; margin-top: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444; padding: 8px; border-radius: 8px; font-size: 0.8rem; font-weight: 700; cursor: pointer;">Sign Out</button>
        </div>
    </aside>

    <main class="content">
        <nav class="top-nav">
            <input type="text" class="search-box" placeholder="Search orders, SKU, customers..." />
            <div class="top-nav-right" style="display: flex; align-items: center; gap: 24px;">
                <div class="notification-bell" style="cursor: pointer; color: var(--text-muted);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                </div>
                <div class="user-profile">
                    <div class="avatar">JD</div>
                    <div class="user-meta" style="display: flex; flex-direction: column;">
                        <span style="font-size: 0.85rem; font-weight: 600;">Jane Doe</span>
                        <span style="font-size: 0.75rem; color: var(--text-muted);">Store Manager</span>
                    </div>
                </div>
            </div>
        </nav>
        <section style="padding: 32px;">
            <slot />
        </section>
    </main>
</body>
</html>
