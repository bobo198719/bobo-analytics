---
const { title = "Bobo Retail OS" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">
    <style is:global>
        :root {
            --bg-dark: #05081a;
            --indigo-600: #4f46e5;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #05081a;
            color: white;
            min-height: 100vh;
        }

        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.01); }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.05); border-radius: 10px; }
    </style>
</head>
<body>
  <div class="flex h-screen bg-[#05081a] overflow-hidden font-['Plus_Jakarta_Sans'] text-white">
    
    <!-- Sidebar -->
    <aside class="w-20 md:w-24 border-r border-white/10 bg-[#05081a]/50 backdrop-blur-2xl flex flex-col justify-between py-10 items-center">
      <div class="flex flex-col gap-8">
        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center font-black text-white text-xl shadow-lg shadow-indigo-600/20 italic">B</div>
        <nav class="flex flex-col gap-6" id="main-nav">
           <a href="/retail-os" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all" data-nav="/retail-os">
              <i class="lucide-layout-grid text-xl"></i>
           </a>
           <a href="/retail-os/inventory" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all" data-nav="/retail-os/inventory">
              <i class="lucide-box text-xl"></i>
           </a>
           <a href="/pos-clothing" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all font-bold" data-nav="/pos-clothing">
              <i class="lucide-receipt text-xl"></i>
           </a>
           <a href="/retail-os/customers" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all" data-nav="/retail-os/customers">
              <i class="lucide-users-2 text-xl"></i>
           </a>
           <a href="/retail-os/staff" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all" data-nav="/retail-os/staff">
              <i class="lucide-award text-xl"></i>
           </a>
           <a href="/retail-os/returns" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all" data-nav="/retail-os/returns">
              <i class="lucide-undo-2 text-xl"></i>
           </a>
           <a href="/retail-os/analytics" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all" data-nav="/retail-os/analytics">
              <i class="lucide-bar-chart-3 text-xl"></i>
           </a>
        </nav>
      </div>

      <div class="flex flex-col gap-6">
         <button id="logout-btn" class="p-4 text-white/20 hover:text-rose-400 hover:bg-rose-400/10 rounded-2xl transition-all"><i class="lucide-log-out text-xl"></i></button>
      </div>
    </aside>

    <main class="flex-1 overflow-y-auto custom-scrollbar p-6 md:p-12 relative">
        <slot />
    </main>
  </div>

  <script is:inline>
     // --- AUTH GUARD ---
     if (!localStorage.getItem('retail_os_auth')) {
         window.location.href = '/retail-os-login';
     }

     // Highlight active navigation link
     const currentPath = window.location.pathname;
     const navLinks = document.querySelectorAll('[data-nav]');
     navLinks.forEach(link => {
         const linkPath = link.getAttribute('data-nav');
         if (currentPath === linkPath || (currentPath === '/retail-os/' && linkPath === '/retail-os')) {
             link.classList.add('text-indigo-400', 'bg-indigo-500/10', 'shadow-lg', 'shadow-indigo-500/5');
             link.classList.remove('text-white/20');
         }
     });

     // Handle Logout
     document.getElementById('logout-btn')?.addEventListener('click', () => {
         localStorage.removeItem('retail_os_auth');
         localStorage.removeItem('retail_os_user');
         window.location.href = '/retail-os-login';
     });
  </script>
</body>
</html>
