---
const { title = "Bobo Grocery OS" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --sidebar-width: 280px;
            --bg-dark: #020617;
            --bg-card: rgba(30, 41, 59, 0.5);
            --primary: #10b981;
            --secondary: #3b82f6;
            --accent: #f59e0b;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border: rgba(255, 255, 255, 0.08);
            --success: #10b981;
            --error: #ef4444;
            --warning: #f59e0b;
            --sidebar-bg: rgba(15, 23, 42, 0.95);
        }

        /* 10 Instant Themes */
        [data-theme="midnight"] {
            --bg-dark: #020617;
            --bg-card: rgba(15, 23, 42, 0.8);
            --primary: #6366f1;
            --sidebar-bg: #0f172a;
            --accent: #8b5cf6;
        }

        [data-theme="pure"] {
            --bg-dark: #f8fafc;
            --bg-card: #ffffff;
            --primary: #0f172a;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --sidebar-bg: #ffffff;
        }

        [data-theme="emerald"] {
            --bg-dark: #022c22;
            --primary: #10b981;
            --bg-card: rgba(6, 78, 59, 0.4);
            --sidebar-bg: #064e3b;
        }

        [data-theme="ocean"] {
            --bg-dark: #082f49;
            --primary: #0ea5e9;
            --bg-card: rgba(12, 74, 110, 0.5);
            --sidebar-bg: #0c4a6e;
        }

        [data-theme="sunrise"] {
            --bg-dark: #451a03;
            --primary: #f97316;
            --bg-card: rgba(124, 45, 18, 0.5);
            --sidebar-bg: #7c2d12;
            --text-main: #fff7ed;
        }

        [data-theme="neon"] {
            --bg-dark: #050510;
            --primary: #ff00ff;
            --accent: #00ffff;
            --bg-card: rgba(20, 20, 45, 0.6);
            --sidebar-bg: #0a0a20;
            --text-main: #f0f0ff;
        }

        [data-theme="minimal"] {
            --bg-dark: #f0f2f5;
            --bg-card: #ffffff;
            --primary: #1a1a1a;
            --text-main: #1a1a1a;
            --text-muted: #666;
            --border: #ddd;
            --sidebar-bg: #f8f9fa;
        }

        [data-theme="modern"] {
            --bg-dark: #000000;
            --primary: #ffffff;
            --bg-card: rgba(255, 255, 255, 0.05);
            --sidebar-bg: #111111;
            --accent: #3d3d3d;
        }

        [data-theme="luxury"] {
            --bg-dark: #1c1917;
            --primary: #d4af37;
            --bg-card: rgba(41, 37, 36, 0.8);
            --sidebar-bg: #292524;
            --accent: #ffffff;
            --font-main: 'Outfit', serif;
        }

        [data-theme="classic"] {
            --bg-dark: #2d3436;
            --primary: #0984e3;
            --bg-card: #dfe6e9;
            --text-main: #2d3436;
            --sidebar-bg: #636e72;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
        }

        body {
            font-family: var(--font-main, 'Inter'), sans-serif;
            background: var(--bg-dark);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow: hidden;
        }

        /* Sidebar Navigation */
        aside.sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            backdrop-filter: blur(20px);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 24px 16px;
            z-index: 100;
            overflow-y: auto;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 32px;
            text-decoration: none;
            color: var(--text-main);
            padding: 0 12px;
        }

        .logo-orb {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
        }

        .logo-area span {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: -0.01em;
        }

        .nav-group {
            margin-bottom: 24px;
        }

        .nav-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--text-muted);
            margin-bottom: 12px;
            padding-left: 12px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 500;
            font-size: 0.95rem;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav-link:hover {
            color: white;
            background: rgba(255, 255, 255, 0.05);
            transition: 0.2s;
        }

        .nav-link.active {
            background: rgba(16, 185, 129, 0.1);
            color: var(--primary);
            border-right: 3px solid var(--primary);
        }

        .sidebar-divider {
            height: 1px;
            background: var(--border);
            margin: 16px 20px;
            opacity: 0.5;
        }

        .bakers-accent {
            background: rgba(236, 72, 153, 0.05) !important;
            color: #ec4899 !important;
            border-radius: 12px;
            margin: 0 16px;
        }

        .bakers-accent:hover {
            background: rgba(236, 72, 153, 0.1) !important;
            box-shadow: 0 0 15px rgba(236, 72, 153, 0.2);
        }

        .new-badge {
            margin-left: auto;
            background: #ec4899;
            color: white;
            font-size: 0.6rem;
            font-weight: 900;
            padding: 2px 6px;
            border-radius: 4px;
            letter-spacing: 0.05em;
        }

        .nav-link svg {
            width: 20px;
            height: 20px;
        }

        /* Main Content Wrapper */
        main.content-wrapper {
            flex: 1;
            height: 100vh;
            overflow-y: auto;
            background: radial-gradient(circle at 100% 0%, rgba(16, 185, 129, 0.05) 0%, transparent 50%);
        }

        header.top-bar {
            height: 80px;
            padding: 0 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(2, 6, 23, 0.5);
            backdrop-filter: blur(8px);
            position: sticky;
            top: 0;
            z-index: 90;
            border-bottom: 1px solid var(--border);
        }

        .search-container {
            position: relative;
            width: 400px;
        }

        .search-container input {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            padding: 12px 16px 12px 48px;
            border-radius: 14px;
            color: white;
            font-size: 0.9rem;
        }

        .search-container svg {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }

        .user-actions {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .notification-btn {
            position: relative;
            color: var(--text-muted);
            cursor: pointer;
        }

        .notif-dot {
            position: absolute;
            top: -2px;
            right: -2px;
            width: 8px;
            height: 8px;
            background: var(--error);
            border-radius: 50%;
            border: 2px solid var(--bg-dark);
        }

        .profile-btn {
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--bg-card);
            padding: 6px 16px 6px 6px;
            border-radius: 30px;
            border: 1px solid var(--border);
            cursor: pointer;
        }

        .avatar-box {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.8rem;
        }

        .page-content {
            padding: 40px;
            max-width: 1600px;
            margin: 0 auto;
        }

        /* Utility Classes */
        .glass-card {
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 24px;
        }

        @media (max-width: 1024px) {
            aside.sidebar {
                width: 80px;
                padding: 24px 12px;
            }
            .logo-area span, .nav-label, .nav-link span, .profile-name {
                display: none;
            }
            .nav-link {
                justify-content: center;
            }
            .search-container {
                width: 200px;
            }
        }
    </style>
</head>
<body>
    <aside class="sidebar">
        <a href="/grocery-os" class="logo-area">
            <div class="logo-orb">🍎</div>
            <span>Grocery OS</span>
        </a>

        <div class="nav-group">
            <span class="nav-label">Core Business</span>
            <a href="/grocery-os" class="nav-link" data-nav="/grocery-os">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                <span>Dashboard</span>
            </a>
            <a href="/grocery-os/pos" class="nav-link" data-nav="/grocery-os/pos">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span>POS Billing</span>
            </a>
            <a href="/grocery-os/orders" class="nav-link" data-nav="/grocery-os/orders">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V4a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v16l4-4h12a2 2 0 0 0 2-2z"/></svg>
                <span>Orders</span>
            </a>
        </div>

        <div class="nav-group">
            <span class="nav-label">Management</span>
            <a href="/grocery-os/products" class="nav-link" data-nav="/grocery-os/products">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <span>Products</span>
            </a>
            <a href="/grocery-os/inventory" class="nav-link" data-nav="/grocery-os/inventory">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                <span>Inventory</span>
            </a>
            <a href="/grocery-os/suppliers" class="nav-link" data-nav="/grocery-os/suppliers">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span>Suppliers</span>
            </a>
            <a href="/grocery-os/delivery" class="nav-link" data-nav="/grocery-os/delivery">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polyline points="16 8 20 8 23 11 23 16 16 16"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>Delivery</span>
            </a>
        </div>

        <div class="nav-group">
            <span class="nav-label">Growth & AI</span>
            <a href="/grocery-os/customers" class="nav-link" data-nav="/grocery-os/customers">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                <span>Customers</span>
            </a>
            <a href="/grocery-os/marketing" class="nav-link" data-nav="/grocery-os/marketing">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                <span>Marketing</span>
            </a>
            <a href="/grocery-os/online-store" class="nav-link" data-nav="/grocery-os/online-store">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                <span>Online Store Builder</span>
            </a>
            <a href="/grocery-os/whatsapp-bot" class="nav-link" data-nav="/grocery-os/whatsapp-bot">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-11.7 8.38 8.38 0 0 1 3.8.9L21 3z"/></svg>
                <span>WhatsApp Bot</span>
            </a>
            <a href="/grocery-os/ai-insights" class="nav-link" data-nav="/grocery-os/ai-insights">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10h-10V2z"/></svg>
                <span>AI Insights</span>
            </a>
        </div>

        <div class="nav-group">
            <span class="nav-label">Admin Control</span>
            <a href="/grocery-os/reports" class="nav-link" data-nav="/grocery-os/reports">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>
                <span>Advanced Reports</span>
            </a>
            <a href="/grocery-os/staff" class="nav-link" data-nav="/grocery-os/staff">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span>Staff & Access</span>
            </a>
            <a href="/grocery-os/integrations" class="nav-link" data-nav="/grocery-os/integrations">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                <span>Integrations</span>
            </a>
            <a href="/grocery-os/infrastructure" class="nav-link" data-nav="/grocery-os/infrastructure">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
                <span>SaaS Schema</span>
            </a>
            <a href="/grocery-os/settings" class="nav-link" data-nav="/grocery-os/settings">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1-2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                <span>Settings</span>
            </a>
            
            <div class="sidebar-divider"></div>
            
            <a href="/bakers-os" class="nav-link bakers-accent" data-nav="/bakers-os">
                <span class="icon">🧁</span>
                <span>Home Bakers OS</span>
                <span class="new-badge">NEW</span>
            </a>

            <!-- INSTALL APP PORTAL (PERMANENTLY VISIBLE) -->
            <div id="install-container" style="padding: 12px; margin-top: 20px; background: rgba(16, 185, 129, 0.1); border-radius: 16px; border: 1px dashed var(--primary); display: block;">
                <span style="font-size: 0.65rem; color: var(--primary); font-weight: 800; text-transform: uppercase; display: block; margin-bottom: 8px; text-align: center;">📲 Bobo Apps & APK Center</span>
                <button id="btnInstall" class="nav-link" style="background: var(--primary); color: white; border: none; width: 100%; cursor: pointer; justify-content: center; gap: 8px; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    <span>Download App</span>
                </button>
            </div>
        </div>

        <script is:inline>
            let deferredPrompt;
            const btnInstall = document.getElementById('btnInstall');

            window.addEventListener('beforeinstallprompt', (e) => {
                e.preventDefault();
                deferredPrompt = e;
                console.log('✅ Software Install Ready');
            });

            if (btnInstall) {
                btnInstall.addEventListener('click', async () => {
                    if (deferredPrompt) {
                        deferredPrompt.prompt();
                        const { outcome } = await deferredPrompt.userChoice;
                        deferredPrompt = null;
                    } else {
                        alert("App Installation Info:\n\n1. Mobile: Tap 'Install App' or 'Add to Home Screen' in browser menu.\n2. PC: Click the 'Install' icon ⊕ in URL bar.\n3. Already installed? Open it from your home screen!");
                    }
                });
            }

            window.addEventListener('appinstalled', () => console.log('✅ Software Installed.'));
        </script>

        <!-- AI Autopilot Widget -->
        <div class="autopilot-teaser">
            <div class="ai-header">
                <span class="pulse"></span>
                <span>AI Autopilot</span>
            </div>
            <p>Predicting 15% stock surge for weekend.</p>
            <button class="teaser-btn">Manage Shop</button>
        </div>

        <style>
            .autopilot-teaser {
                margin-top: auto;
                background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(59, 130, 246, 0.1));
                border: 1px solid var(--border);
                border-radius: 16px;
                padding: 16px;
                display: flex;
                flex-direction: column;
                gap: 8px;
            }
            .ai-header { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 0.8rem; color: var(--primary); }
            .pulse { width: 8px; height: 8px; background: var(--primary); border-radius: 50%; animation: pulse 2s infinite; }
            @keyframes pulse { 0% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.2); } 100% { opacity: 1; transform: scale(1); } }
            .autopilot-teaser p { font-size: 0.75rem; color: var(--text-muted); line-height: 1.4; }
            .teaser-btn { background: var(--primary); color: white; border: none; padding: 6px; border-radius: 8px; font-size: 0.75rem; font-weight: 700; cursor: pointer; }
        </style>

        <script is:inline>
            // Theme Initialization
            const savedTheme = localStorage.getItem('bobo_grocery_theme') || 'emerald';
            document.documentElement.setAttribute('data-theme', savedTheme);

            // Auth Check
            if (!localStorage.getItem('grocery_os_auth') && !window.location.pathname.includes('login')) {
                 window.location.href = '/grocery-login';
            }

            // Highlighting active nav link
            const currentPath = window.location.pathname;
            document.querySelectorAll('.nav-link').forEach(link => {
                const navPath = link.getAttribute('data-nav');
                if (currentPath === navPath || (currentPath === navPath + '/') || (currentPath === '/grocery-os/' && navPath === '/grocery-os')) {
                    link.classList.add('active');
                } else {
                    link.classList.remove('active');
