---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const { title = "Bobo Analytics" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <style>
        :root {
            --bg-color: #05081a;
            --text-color: #ffffff;
            --accent-color: #6366f1;
        }
        * {
            box-sizing: border-box;
        }
        body {
            margin: 0;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg-color);
            color: var(--text-color);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }
        main {
            flex: 1;
        }
    </style>
</head>
<body>
    <div style="background: #059669; color: white; text-align: center; padding: 8px; font-weight: 800; z-index: 9999; position: relative; font-size: 0.75rem; letter-spacing: 0.5px; border-bottom: 2px solid rgba(0,0,0,0.1);">
        🟢 PRODUCTION SYSTEM ACTIVE - ENTERPRISE DATA ENGINE LIVE (V11.2)
    </div>
    <Navbar />
    <main>
        <slot />
    </main>
    <Footer />
</body>
</html>