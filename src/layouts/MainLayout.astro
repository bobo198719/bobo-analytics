---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const { title = "Bobo Analytics", hideNav = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="7eTIrcExWh6vKQURAn-WzHy0NSdBdRgBfJnL-JTwzsY" />
    <title>Bobo Analytics | SaaS Platform for Bakery, Pharmacy & Retail Businesses</title>
    <meta name="description" content="Bobo Analytics helps bakery, pharmacy, grocery and retail businesses manage orders, CRM, billing and analytics in one powerful platform." />
    <meta name="keywords" content="bakery software, pharmacy POS, grocery POS, SaaS business tools India" />
    
    <!-- Favicons & Icons -->
    <link rel="icon" href="/favicon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png">
    <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-192x192.png">
    <link rel="apple-touch-icon" sizes="167x167" href="/icons/icon-192x192.png">
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json">
    
    <!-- Theme Colors -->
    <meta name="theme-color" content="#6366f1" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#05081a" media="(prefers-color-scheme: dark)">
    
    <!-- iOS PWA Meta Tags -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Bobo Analytics">
    
    <!-- Windows PWA Meta Tags -->
    <meta name="msapplication-TileColor" content="#6366f1">
    <meta name="msapplication-TileImage" content="/icons/icon-144x144.png">
    <meta name="msapplication-config" content="/browserconfig.xml">
    
    <!-- Mobile Optimization -->
    <meta name="format-detection" content="telephone=no">
    <meta name="mobile-web-app-capable" content="yes">

    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').then(reg => {
            console.log('✅ App Controller Active (Mobile & Desktop Software Bridge)');
          }).catch(err => {
            console.warn('❌ App Deployment Failed:', err);
          });
        });
      }
    </script>

    <script type="application/ld+json">
    {
     "@context": "https://schema.org",
     "@type": "Organization",
     "name": "Bobo Analytics",
     "url": "https://boboanalytics.com",
     "logo": "https://boboanalytics.com/favicon.png",
     "description": "Bobo Analytics provides scalable SaaS software solutions for bakery, pharmacy, grocery and retail businesses."
    }
    </script>

    <script type="application/ld+json">
    {
     "@context": "https://schema.org",
     "@type": "WebSite",
     "url": "https://boboanalytics.com",
     "name": "Bobo Analytics",
     "potentialAction": {
     "@type": "SearchAction",
     "target": "https://boboanalytics.com/?q={search_term_string}",
     "query-input": "required name=search_term_string"
     }
    }
    </script>
    <style>
        :root {
            --bg-color: #05081a;
            --text-color: #ffffff;
            --accent-color: #6366f1;
        }
        * {
            box-sizing: border-box;
        }
        body {
            margin: 0;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg-color);
            color: var(--text-color);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }
        main {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
    </style>
</head>
<body>
    {!hideNav && (
        <>
            <div style="background: #059669; color: white; text-align: center; padding: 8px; font-weight: 800; z-index: 9999; position: relative; font-size: 0.75rem; letter-spacing: 0.5px; border-bottom: 2px solid rgba(0,0,0,0.1);">
                🟢 PRODUCTION SYSTEM ACTIVE - ENTERPRISE DATA ENGINE LIVE (V11.2)
            </div>
            <Navbar />
        </>
    )}
    <main>
        <slot />
    </main>
    {!hideNav && <Footer />}
</body>
</html>
