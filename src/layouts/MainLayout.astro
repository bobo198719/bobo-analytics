---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const { title = "Bobo Analytics", hideNav = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="7eTIrcExWh6vKQURAn-WzHy0NSdBdRgBfJnL-JTwzsY" />
    <title>Bobo Analytics | Scalable SaaS for Bakery, Pharmacy & Retail Businesses</title>
    <meta name="description" content="Bobo Analytics is a scalable SaaS platform helping bakeries, pharmacies, groceries and retailers manage orders, inventory, customers and analytics in one powerful dashboard." />
    <meta name="keywords" content="bakery software, pharmacy POS, grocery POS, SaaS business tools India" />
    
    <!-- Open Graph Social Previews -->
    <meta property="og:title" content="Bobo Analytics SaaS Platform" />
    <meta property="og:description" content="Manage bakery, pharmacy, grocery and retail businesses with one powerful SaaS platform." />
    <meta property="og:url" content="https://boboanalytics.com" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://boboanalytics.com/favicon.png" />
    
    <link rel="icon" href="/favicon.png" type="image/png">

    <!-- JSON-LD Structured Data for Google -->
    <script type="application/ld+json">
    {
     "@context":"https://schema.org",
     "@type":"Organization",
     "name":"Bobo Analytics",
     "url":"https://boboanalytics.com",
     "logo":"https://boboanalytics.com/favicon.png",
     "description":"Bobo Analytics provides scalable SaaS software solutions for bakery, pharmacy, grocery and retail businesses.",
     "sameAs":[
     "https://boboanalytics.com"
     ]
    }
    </script>
    
    <script type="application/ld+json">
    {
     "@context":"https://schema.org",
     "@type":"WebSite",
     "url":"https://boboanalytics.com",
     "name":"Bobo Analytics",
     "potentialAction":{
     "@type":"SearchAction",
     "target":"https://boboanalytics.com/?q={search_term_string}",
     "query-input":"required name=search_term_string"
     }
    }
    </script>
    
    <script type="application/ld+json">
    {
     "@context":"https://schema.org",
     "@type":"SoftwareApplication",
     "name":"Bobo Analytics",
     "operatingSystem":"Web",
     "applicationCategory":"BusinessApplication",
     "offers":{
     "@type":"Offer",
     "price":"0",
     "priceCurrency":"INR"
     }
    }
    </script>
    <style>
        :root {
            --bg-color: #05081a;
            --text-color: #ffffff;
            --accent-color: #6366f1;
        }
        * {
            box-sizing: border-box;
        }
        body {
            margin: 0;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg-color);
            color: var(--text-color);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }
        main {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
    </style>
</head>
<body>
    {!hideNav && (
        <div style="background: #059669; color: white; text-align: center; padding: 8px; font-weight: 800; z-index: 9999; position: relative; font-size: 0.75rem; letter-spacing: 0.5px; border-bottom: 2px solid rgba(0,0,0,0.1);">
            🟢 PRODUCTION SYSTEM ACTIVE - ENTERPRISE DATA ENGINE LIVE (V11.2)
        </div>
        <Navbar />
    )}
    <main>
        <slot />
    </main>
    {!hideNav && <Footer />}
</body>
</html>