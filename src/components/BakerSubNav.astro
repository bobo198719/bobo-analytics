---
const { active = "dashboard" } = Astro.props;

const links = [
  { id: "dashboard", label: "Dashboard", href: "/grocery-os/home-bakers" },
  { id: "orders", label: "Orders", href: "/grocery-os/home-bakers/orders" },
  { id: "products", label: "Bake Catalog", href: "/grocery-os/home-bakers/products" },
  { id: "profile", label: "Profile", href: "/grocery-os/home-bakers/profile" },
  { id: "gallery", label: "Portfolio", href: "/grocery-os/home-bakers/gallery" },
  { id: "customers", label: "Customers", href: "/grocery-os/home-bakers/customers" }
];
---

<nav class="baker-subnav">
    {links.map(l => (
        <a href={l.href} class={`sub-link ${active === l.id ? 'active' : ''}`}>
            {l.label}
        </a>
    ))}
</nav>

<style>
    .baker-subnav {
        display: flex;
        gap: 32px;
        margin-bottom: 40px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border);
    }
    .sub-link {
        text-decoration: none;
        color: var(--text-muted);
        font-weight: 700;
        font-size: 0.9rem;
        position: relative;
        padding: 4px 0;
        transition: 0.2s;
    }
    .sub-link:hover {
        color: white;
    }
    .sub-link.active {
        color: #f472b6;
    }
    .sub-link.active::after {
        content: '';
        position: absolute;
        bottom: -13px;
        left: 0;
        width: 100%;
        height: 3px;
        background: #f472b6;
        border-radius: 10px;
    }
</style>
