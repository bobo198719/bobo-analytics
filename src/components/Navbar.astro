---

<nav class="navbar">
  <div class="container">
    <a href="/" class="logo">
      <img src="/logo.png" alt="Bobo Analytics" />
      <span>Bobo Analytics</span>
    </a>

    <div class="nav-links">
      <a href="/pricing" class="nav-link">Pricing</a>
      <div class="dropdown">
        <button class="dropbtn">
          Login 
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="dropdown-content">
          <a href="/pharmacy-login">
            <span class="icon">💊</span> Pharmacy Login
          </a>
          <hr />
          <a href="/solutions/healthcare#login">
            <span class="icon">🏥</span> Healthcare Login
          </a>
          <a href="/grocery-login">
            <span class="icon">🍎</span> Grocery OS Login
          </a>
          <a href="/retail-os-login">
            <span class="icon">👗</span> Bobo Retail OS
          </a>
          <hr />
          <a href="/login">
            <span class="icon">🔑</span> All Logins
          </a>
        </div>
      </div>
      <a href="/signup" class="btn-signup">Start Free Trial</a>
    </div>
  </div>
</nav>

<style>
.navbar {
  position: sticky;
  top: 0;
  z-index: 1000;
  background: rgba(5, 8, 26, 0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  color: white;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 12px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  color: white;
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: -0.025em;
}

.logo img {
  height: 36px;
  width: auto;
  border-radius: 4px;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 20px;
}

.nav-link {
  color: rgba(255, 255, 255, 0.8);
  text-decoration: none;
  font-weight: 500;
  transition: color 0.2s ease;
}

.nav-link:hover {
  color: white;
}

.dropdown {
  position: relative;
}

.dropbtn {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.2);
  padding: 8px 16px;
  border-radius: 8px;
  color: white;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: all 0.2s ease;
}

.dropbtn:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.4);
}

.dropdown-content {
  display: none;
  position: absolute;
  right: 0;
  top: calc(100% + 8px);
  background: #0b112d;
  min-width: 220px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 8px 0;
}

.dropdown-content a {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  color: rgba(255, 255, 255, 0.8);
  text-decoration: none;
  font-size: 0.95rem;
  transition: all 0.2s ease;
}

.dropdown-content a:hover {
  background: rgba(255, 255, 255, 0.05);
  color: white;
}

.dropdown-content hr {
  margin: 8px 0;
  border: 0;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.dropdown:hover .dropdown-content {
  display: block;
}

.btn-signup {
  background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
  padding: 8px 20px;
  border-radius: 8px;
  color: white;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.95rem;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.btn-signup:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4);
}

.icon {
  font-size: 1.1rem;
}

@media (max-width: 640px) {
  .logo span {
    display: none;
  }
}
</style>