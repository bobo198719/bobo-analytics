---
const { title } = Astro.props;
---

<div class="card">
  <div class="card-inner">

    <div class="card-front">
      <h3>{title}</h3>
    </div>

    <div class="card-back">
      <p>
        Smart analytics and AI-powered insights designed for {title} businesses.
      </p>
    </div>

  </div>
</div>

<style>
.card {
  width: 220px;
  height: 120px;
  perspective: 1000px;
}

.card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s;
}

.card:hover .card-inner {
  transform: rotateY(180deg);
}

.card-front,
.card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 10px;
  display:flex;
  align-items:center;
  justify-content:center;
  backface-visibility:hidden;
  background:#1e293b;
  color:white;
}

.card-front{
  font-weight:600;
}

.card-back{
  transform:rotateY(180deg);
  font-size:14px;
  padding:10px;
}
</style>
