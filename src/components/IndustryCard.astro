---
const { title, description, link } = Astro.props;
---

<a href={link} class="card">

<div class="card-inner">

<div class="card-front">
<h3>{title}</h3>
</div>

<div class="card-back">
<p>{description}</p>
</div>

</div>

</a>

<style>

.card{
perspective:1000px;
text-decoration:none;
}

.card-inner{
position:relative;
width:100%;
height:130px;
transform-style:preserve-3d;
transition:transform 0.6s;
}

.card:hover .card-inner{
transform:rotateY(180deg);
}

.card-front,
.card-back{
position:absolute;
width:100%;
height:100%;
display:flex;
align-items:center;
justify-content:center;
border-radius:12px;
backface-visibility:hidden;
font-weight:600;
}

.card-front{
background:#151515;
color:white;
box-shadow:
0 0 10px rgba(0,255,150,0.4),
0 0 20px rgba(0,255,150,0.3),
0 0 40px rgba(0,255,150,0.2);
}

.card-back{
background:#1c1c1c;
color:#9fffcb;
transform:rotateY(180deg);

box-shadow:
0 0 10px rgba(0,255,150,0.6),
0 0 30px rgba(0,255,150,0.5),
0 0 60px rgba(0,255,150,0.3);
}

.card:hover .card-front{
box-shadow:
0 0 20px rgba(0,255,150,0.7),
0 0 40px rgba(0,255,150,0.6),
0 0 80px rgba(0,255,150,0.4);
}

</style>
