---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/restaurant.css";
---

<MainLayout title="Restaurant Intelligence Engine | Bobo Analytics" hideNav={true}>
  <div class="restaurant-page bg-[#05081a] min-h-screen font-['Plus_Jakarta_Sans'] text-white relative overflow-hidden">
    
    <!-- Hero Background Animation -->
    <div class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-30">
       <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-orange-500/10 rounded-full blur-[120px] -mr-64 -mt-64 animate-pulse"></div>
       <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-rose-500/10 rounded-full blur-[120px] -ml-64 -mb-64"></div>
    </div>

    <!-- Navigation Overlay -->
    <nav class="relative z-50 flex justify-between items-center p-8 max-w-7xl mx-auto">
       <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-orange-600 rounded-xl flex items-center justify-center font-black text-white shadow-lg shadow-orange-600/20 italic">B</div>
          <span class="text-xl font-black italic uppercase tracking-tighter">Bobo <span class="text-orange-500">Restaurant</span></span>
       </div>
       <div class="flex items-center gap-8">
          <a href="/" class="text-xs font-black uppercase tracking-widest text-white/40 hover:text-white transition-colors">Main Hub</a>
          <a href="/crm-login" class="px-8 py-3 bg-white/5 border border-white/10 rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-white/10 transition-all">Portal Login</a>
       </div>
    </nav>

    <!-- Main Content -->
    <main class="relative z-10 max-w-7xl mx-auto px-8 py-20 md:py-32 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
       
       <div class="space-y-12">
          <div class="space-y-6">
             <span class="px-4 py-2 bg-orange-500/10 border border-orange-500/20 rounded-full text-[10px] font-black uppercase tracking-widest text-orange-400 italic">Hospitality Tech v4.2</span>
             <h1 class="text-6xl md:text-8xl font-black italic tracking-tighter leading-none uppercase">
                Culinary <br />
                <span class="bg-gradient-to-r from-orange-500 to-rose-400 bg-clip-text text-transparent">Intelligence</span>
             </h1>
             <p class="text-white/40 text-lg md:text-xl font-medium leading-relaxed max-w-xl italic">
                Master your culinary operations with AI-powered kitchen systems, automated table yields, and high-performance POS intelligence.
             </p>
          </div>

          <div class="grid grid-cols-2 gap-6 pb-8">
             <div class="p-6 bg-white/5 border border-white/10 rounded-3xl group hover:border-orange-500/50 transition-all">
                <div class="text-3xl mb-4 group-hover:scale-110 transition-transform">🍳</div>
                <h3 class="font-black italic uppercase text-sm mb-2">Kitchen OS</h3>
                <p class="text-xs text-white/30 font-bold italic uppercase tracking-tight">Smart KDS Order Handlers</p>
             </div>
             <div class="p-6 bg-white/5 border border-white/10 rounded-3xl group hover:border-rose-500/50 transition-all">
                <div class="text-3xl mb-4 group-hover:scale-110 transition-transform">🍷</div>
                <h3 class="font-black italic uppercase text-sm mb-2">Yield Labs</h3>
                <p class="text-xs text-white/30 font-bold italic uppercase tracking-tight">AI-Optimized Table Turns</p>
             </div>
          </div>

          <div class="flex items-center gap-6">
             <a href="/restaurant-login" class="px-12 py-6 bg-gradient-to-r from-orange-600 to-orange-500 rounded-3xl text-sm font-black italic uppercase tracking-[0.2em] shadow-2xl shadow-orange-600/20 hover:scale-[1.05] active:scale-95 transition-all">
                Launch Terminal
             </a>
             <button class="text-xs font-black italic uppercase tracking-[0.3em] text-white/20 hover:text-white transition-colors">Field Performance</button>
          </div>
       </div>

       <!-- Visual element: Digital Kitchen Mock -->
       <div class="relative group">
          <div class="absolute inset-0 bg-orange-600/20 blur-[100px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative bg-white/5 border border-white/10 rounded-[64px] p-8 backdrop-blur-3xl shadow-2xl overflow-hidden aspect-square flex flex-col items-center justify-center border-b-white/20">
             
             <!-- Dashboard Pulse Mockup -->
             <div class="w-full h-full flex flex-col gap-6 opacity-40">
                <div class="w-full h-12 bg-white/10 rounded-2xl flex items-center px-4 gap-4">
                   <div class="w-3 h-3 rounded-full bg-rose-500"></div>
                   <div class="w-3 h-3 rounded-full bg-amber-500"></div>
                   <div class="w-3 h-3 rounded-full bg-emerald-500"></div>
                </div>
                <div class="grid grid-cols-3 gap-6">
                   <div class="h-24 bg-white/10 rounded-3xl animate-pulse"></div>
                   <div class="h-24 bg-white/10 rounded-3xl animate-pulse" style="animation-delay: 0.1s"></div>
                   <div class="h-24 bg-white/10 rounded-3xl animate-pulse" style="animation-delay: 0.2s"></div>
                </div>
                <div class="flex-1 bg-white/10 rounded-3xl border border-white/10 p-6 flex flex-col gap-4">
                   <div class="w-full h-4 bg-white/20 rounded-full"></div>
                   <div class="w-3/4 h-4 bg-white/20 rounded-full"></div>
                   <div class="w-1/2 h-4 bg-white/20 rounded-full"></div>
                </div>
             </div>
             
             <!-- Floating Badge -->
             <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 bg-orange-600/20 rounded-full flex items-center justify-center backdrop-blur-xl border border-white/20 shadow-2xl scale-125 transition-transform group-hover:scale-150 duration-500">
                <div class="text-6xl animate-bounce">🍕</div>
             </div>
          </div>
       </div>

    </main>

    <footer class="mt-20 p-20 text-center opacity-20 text-[10px] font-black uppercase tracking-[0.5em] italic border-t border-white/5">
       Bobo Analytics Cloud Engine | Hospitality Framework
    </footer>
  </div>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #05081a; }
  </style>
</MainLayout>
