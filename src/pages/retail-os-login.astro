---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/restaurant.css";
---

<MainLayout title="Retail Intelligence Login | Bobo Analytics" hideNav={true}>
  <div class="auth-page bg-[#05081a] min-h-screen flex items-center justify-center p-6 relative font-['Plus_Jakarta_Sans'] overflow-hidden">
    
    <!-- Ambient Background Effects -->
    <div class="absolute inset-0 pointer-events-none opacity-30">
       <div class="absolute top-0 left-0 w-[800px] h-[800px] bg-indigo-500/10 blur-[150px] -ml-96 -mt-96 animate-pulse"></div>
       <div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-cyan-500/10 blur-[120px] -mr-64 -mb-64"></div>
    </div>

    <div class="login-card max-w-lg w-full bg-white/5 border border-white/10 p-12 md:p-16 rounded-[64px] shadow-2xl backdrop-blur-3xl relative z-10 group transition-all hover:bg-white/[0.07] border-b-white/20">
       <div class="text-center mb-12">
          <div class="w-20 h-20 bg-gradient-to-br from-indigo-500 to-cyan-600 rounded-3xl flex items-center justify-center text-4xl mx-auto mb-8 shadow-2xl shadow-indigo-500/20 group-hover:scale-110 group-hover:rotate-3 transition-transform">🛍️</div>
          <p class="text-indigo-400 text-[10px] font-black uppercase tracking-[0.4em] mb-4 italic">Enterprise Sales Engine</p>
          <h1 class="text-4xl font-black italic text-white uppercase tracking-tighter leading-none">Retail OS <br/><span class="text-white/40">Terminal</span></h1>
       </div>

       <form id="retailLoginForm" class="space-y-8">
          <div class="space-y-3">
             <label class="text-[10px] font-black uppercase text-white/30 tracking-[0.2em] ml-2 italic">Store Identifier</label>
             <input type="text" id="storeId" placeholder="e.g. SOUTH-CITY-POS" required class="w-full bg-[#05081a]/80 border border-white/10 p-5 rounded-2xl outline-none focus:border-indigo-500 transition-all font-black text-white" />
          </div>
          <div class="space-y-3">
             <label class="text-[10px] font-black uppercase text-white/30 tracking-[0.2em] ml-2 italic">Access Key</label>
             <input type="password" id="password" placeholder="••••••••" required class="w-full bg-[#05081a]/80 border border-white/10 p-5 rounded-2xl outline-none focus:border-indigo-500 transition-all font-black text-white" />
          </div>

          <div id="errorBox" class="text-rose-500 text-[10px] font-black uppercase tracking-widest text-center min-h-[1rem]"></div>

          <button type="submit" class="group relative w-full py-6 bg-gradient-to-r from-indigo-600 to-indigo-500 rounded-3xl text-white font-black italic uppercase tracking-[0.2em] text-sm shadow-2xl shadow-indigo-600/20 hover:scale-[1.02] active:scale-95 transition-all overflow-hidden">
             <span class="relative z-10">Initialize Workspace</span>
             <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform"></div>
          </button>
       </form>

       <footer class="mt-12 text-center flex flex-col gap-6">
          <a href="/crm-login" class="text-white/20 hover:text-white font-bold text-[10px] transition-colors italic uppercase tracking-[0.3em]">Abort & Redirect to Master Portal</a>
          <div class="p-4 bg-white/5 rounded-2xl border border-white/5 flex items-center justify-between">
             <span class="text-[8px] font-black uppercase tracking-widest text-white/20">Secure Instance: 2.4.0-R</span>
             <div class="flex gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-500/40"></div>
             </div>
          </div>
       </footer>
    </div>
  </div>

  <script is:inline>
    const form = document.getElementById("retailLoginForm");
    const errorBox = document.getElementById("errorBox");

    form.onsubmit = async (e) => {
       e.preventDefault();
       const storeId = document.getElementById('storeId').value.trim();
       const pass = document.getElementById('password').value.trim();

       // Demo credentials
       if ((storeId === 'bobo' || storeId === 'SOUTH-CITY-POS') && (pass === 'retailos' || pass === 'bobo123')) {
          errorBox.innerText = "Provisioning Intelligence Shell...";
          errorBox.style.color = "#10b981";
          
          localStorage.setItem('retail_os_auth', 'true');
          localStorage.setItem('retail_os_user', JSON.stringify({
            storeId: storeId,
            name: 'Jane Doe',
            role: 'Store Manager'
          }));
          
          setTimeout(() => {
             window.location.href = "/retail-os";
          }, 800);
       } else {
          errorBox.innerText = "Authentication Failed: Invalid Key";
          errorBox.style.color = "#f43f5e";
          
          form.style.animation = "shake 0.4s ease";
          setTimeout(() => form.style.animation = "", 400);
       }
    };
  </script>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #05081a; }

    @keyframes shake {
       0%, 100% { transform: translateX(0); }
       25% { transform: translateX(-8px); }
       75% { transform: translateX(8px); }
    }
  </style>
</MainLayout>
