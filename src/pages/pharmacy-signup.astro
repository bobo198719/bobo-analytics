---
import MainLayout from "../layouts/MainLayout.astro";
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Sign Up - Pharmacy Portal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --primary: #4f46e5;
      --primary-light: #818cf8;
      --bg-outside: #e0e7ff;
      --text-main: #1e293b;
      --text-muted: #94a3b8;
      --border: #e2e8f0;
    }
    body {
      margin: 0;
      padding: 0;
      background: var(--bg-outside);
      font-family: 'Inter', sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      box-sizing: border-box;
      padding: 40px 20px;
    }
    
    * {
      box-sizing: inherit;
    }

    .wrapper {
      background: #ffffff;
      width: 100%;
      max-width: 1300px;
      height: 900px;
      max-height: 95vh;
      border-radius: 40px;
      display: flex;
      overflow: hidden;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    /* --- LEFT SIDE --- */
    .form-side {
      flex: 1.1;
      padding: 60px 80px;
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      background: #fff;
    }

    .form-side::-webkit-scrollbar { width: 0; }

    .back-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: var(--text-muted);
      margin-bottom: 30px;
      transition: 0.2s;
    }
    .back-btn:hover {
      background: #f1f5f9;
      color: var(--text-main);
    }

    h1 {
      font-size: 2.2rem;
      font-weight: 800;
      margin: 0 0 10px;
      color: var(--text-main);
    }
    .subtitle {
      color: var(--text-muted);
      font-size: 0.95rem;
      margin-bottom: 30px;
    }

    .user-type-toggle {
      display: flex;
      background: #f1f5f9;
      border-radius: 30px;
      padding: 4px;
      width: max-content;
      margin-bottom: 40px;
    }
    .toggle-btn {
      padding: 10px 24px;
      border-radius: 24px;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
      border: none;
      background: transparent;
      color: var(--text-muted);
      transition: 0.3s;
    }
    .toggle-btn.active {
      background: var(--primary);
      color: #fff;
      box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3);
    }

    .input-group {
      display: flex;
      align-items: center;
      border-bottom: 1px solid var(--border);
      padding: 12px 0;
      margin-bottom: 24px;
    }
    .input-group svg {
      color: var(--text-muted);
      margin-right: 16px;
      width: 20px;
      height: 20px;
    }
    .input-group input {
      border: none;
      outline: none;
      font-size: 1rem;
      width: 100%;
      color: var(--text-main);
      font-family: inherit;
    }
    .input-group input::placeholder {
      color: #cbd5e1;
    }

    .phone-prefix {
      color: var(--text-muted);
      font-weight: 600;
      margin-right: 12px;
      font-size: 0.95rem;
    }

    .password-hints {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: -16px;
      margin-bottom: 24px;
      padding-left: 36px;
      line-height: 1.6;
    }
    .password-hints ul {
      margin: 0;
      padding-left: 16px;
    }

    .form-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-top: 10px;
    }

    .btn-submit {
      background: var(--primary);
      color: white;
      border: none;
      padding: 14px 28px;
      border-radius: 30px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: 0.3s;
      box-shadow: 0 8px 15px rgba(79, 70, 229, 0.25);
    }
    .btn-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 20px rgba(79, 70, 229, 0.35);
    }
    .btn-submit .arrow-circle {
      background: rgba(255,255,255,0.2);
      border-radius: 50%;
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .social-btns {
      display: flex;
      gap: 12px;
      margin-left: auto;
    }
    .social-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      background: #fff;
      cursor: pointer;
      transition: 0.2s;
    }
    .social-btn:hover {
      background: #f8fafc;
    }
    .social-btn img {
      width: 20px;
      height: 20px;
    }

    .footer-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 40px;
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    .footer-row a {
      color: var(--primary);
      font-weight: 700;
      text-decoration: none;
    }
    .lang-selector {
      display: flex;
      align-items: center;
      gap: 6px;
      font-weight: 600;
      cursor: pointer;
    }

    /* --- RIGHT SIDE --- */
    .visual-side {
      flex: 0.9;
      background: linear-gradient(145deg, #4f46e5, #3b82f6);
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Abstract shapes */
    .shape-1 {
      position: absolute;
      top: -10%;
      right: -10%;
      width: 80%;
      height: 80%;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
    }
    .shape-2 {
      position: absolute;
      bottom: -20%;
      left: -20%;
      width: 120%;
      height: 60%;
      background: rgba(37, 99, 235, 0.5);
      transform: rotate(-15deg);
      border-radius: 50% 50% 0 0;
    }
    .shape-3 {
      position: absolute;
      top: -5%;
      left: 10%;
      width: 300px;
      height: 100px;
      background: #1e3a8a;
      border-radius: 50px;
      transform: rotate(15deg);
    }

    /* Floating Cards */
    .floating-elements {
      position: relative;
      width: 100%;
      height: 100%;
      z-index: 10;
    }

    .card-sm, .card-lg {
      position: absolute;
      background: #fff;
      border-radius: 20px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.15);
      padding: 24px;
    }

    .card-sm {
      top: 25%;
      left: 20%;
      width: 180px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }
    .card-sm h4 {
      margin: 0;
      font-size: 0.85rem;
      font-weight: 800;
      color: #1e293b;
      line-height: 1.3;
    }
    .card-sm .metric {
      width: 45px;
      height: 45px;
      background: #0f172a;
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 1.1rem;
    }
    
    .card-lg {
      bottom: 25%;
      right: 15%;
      width: 320px;
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 30px;
    }
    .card-lg .content {
      flex: 1;
    }
    .card-lg h3 {
      margin: 0 0 10px;
      font-size: 1rem;
      color: #1e293b;
      border-bottom: 2px solid #fbbf24;
      padding-bottom: 4px;
      display: inline-block;
    }
    .card-lg p {
      margin: 0;
      font-size: 0.75rem;
      color: #64748b;
      line-height: 1.6;
    }
    .red-cross {
      font-size: 4rem;
      color: #fb7185;
      line-height: 1;
      font-family: Arial, sans-serif;
      font-weight: 800;
    }

    .float-icon {
      position: absolute;
      width: 45px;
      height: 45px;
      background: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }
    .float-icon.fb { top: 32%; right: 28%; color: #1877f2; font-size: 1.5rem; }
    .float-icon.ig { top: 45%; right: 18%; background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%); color: #fff; font-size: 1.3rem; }

    @media (max-width: 900px) {
      .visual-side { display: none; }
      .form-side { padding: 40px; }
      .wrapper { height: auto; margin: 20px; border-radius: 20px; }
    }
  </style>
</head>
<body>

  <div class="wrapper">
    <!-- LEFT PANEL: Form -->
    <div class="form-side">
      <a href="/pharmacy-login" class="back-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>

      <h1>Sign Up</h1>
      <div class="subtitle">Secure Your Communication with Patients</div>

      <div class="user-type-toggle">
        <button class="toggle-btn" onclick="window.location.href='/signup'">Consumer</button>
        <button class="toggle-btn active">Pharmacy</button>
      </div>

      <form action="/pharmacy-dashboard" method="GET">
        <div class="input-group">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <input type="text" placeholder="Pharmacy Name" required />
        </div>

        <div class="input-group">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <input type="text" placeholder="Registration License (eg. SLMC-1234)" required />
        </div>

        <div class="input-group">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <input type="text" placeholder="Address" required />
        </div>

        <div class="input-group">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <input type="text" placeholder="Postal Code" />
        </div>

        <div class="input-group">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span class="phone-prefix">+94</span>
          <input type="tel" placeholder="Pharmacy Number" required />
        </div>

        <div class="input-group">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          <input type="email" placeholder="Email Address" required />
        </div>

        <div class="input-group">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <input type="password" placeholder="Password" required />
        </div>
        
        <div class="password-hints">
          <ul>
            <li>Must be Minimum of 8 characters</li>
            <li>Contains a mixture of letters, numbers & symbols</li>
          </ul>
        </div>

        <div class="input-group" style="margin-bottom: 30px;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <input type="password" placeholder="Re-Type Password" required />
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-submit">
            Sign Up 
            <span class="arrow-circle">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </button>
          
          <div class="social-btns">
            <div class="social-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#1877f2" stroke="none"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </div>
            <div class="social-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" stroke="none"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" stroke="none"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" stroke="none"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" stroke="none"/></svg>
            </div>
          </div>
        </div>
      </form>

      <div class="footer-row">
        <div>Already member? <a href="/pharmacy-login">Sign in ➔</a></div>
        <div class="lang-selector">
          <img src="https://flagcdn.com/w20/gb.png" alt="English" width="20" style="border-radius:2px;"/>
          ENG
        </div>
      </div>
    </div>

    <!-- RIGHT PANEL: Visual Abstract Art -->
    <div class="visual-side">
      <div class="shape-1"></div>
      <div class="shape-2"></div>
      <div class="shape-3"></div>

      <div class="floating-elements">
        <!-- Floating Small Card -->
        <div class="card-sm">
          <h4>Pharmacy<br/>Solutions Lanka</h4>
          <div class="metric">45</div>
          <svg viewBox="0 0 100 30" width="100%" height="30" preserveAspectRatio="none" style="stroke:#fbbf24; stroke-width:3; fill:none; stroke-linecap:round;">
            <path d="M0,25 C10,0 20,-10 30,20 C40,50 50,-10 60,30 C70,70 80,-20 90,15 L100,10" />
            <path d="M30,20 C40,50 50,-10 60,30" style="stroke:#60a5fa;" />
          </svg>
        </div>

        <!-- Floating Icon Facebook Add-on -->
        <div class="float-icon fb">f</div>
        <!-- Floating Icon Instagram Add-on -->
        <div class="float-icon ig">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </div>

        <!-- Floating Large Card -->
        <div class="card-lg">
          <div class="content">
            <h3>Medicine</h3>
            <p>Medicine is the science and practice of caring for a patient, managing the diagnosis, prognosis, prevention, treatment, palliation of their injury or disease, and promoting their health.</p>
          </div>
          <div class="red-cross">+</div>
        </div>
      </div>
    </div>
  </div>

</body>
</html>
