---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/restaurant.css";

// Mock data for products
const products = [
  {
    id: 1,
    name: "Premium Black Shirt",
    sku: "SH-BL-001",
    barcode: "8901234567890",
    price: 999,
    category: "Shirts",
    image: "https://images.unsplash.com/photo-1583743814966-8936f5b7be1a?auto=format&fit=crop&q=80&w=200",
    variants: {
      sizes: ["S", "M", "L", "XL"],
      colors: ["Black", "Midnight Blue"]
    }
  },
  {
    id: 2,
    name: "Classic Blue Jeans",
    sku: "JN-BL-002",
    barcode: "8901234567891",
    price: 1999,
    category: "Jeans",
    image: "https://images.unsplash.com/photo-1542272604-787c3835535d?auto=format&fit=crop&q=80&w=200",
    variants: {
      sizes: ["30", "32", "34", "36"],
      colors: ["Blue", "Dark Denim"]
    }
  },
  {
    id: 3,
    name: "Designer Red Kurti",
    sku: "KR-RD-003",
    barcode: "8901234567892",
    price: 1499,
    category: "Ethnic",
    image: "https://images.unsplash.com/photo-1583391733956-6c78276477e2?auto=format&fit=crop&q=80&w=200",
    variants: {
      sizes: ["M", "L", "XL"],
      colors: ["Red", "Maroon"]
    }
  },
  {
    id: 4,
    name: "Classic White T-Shirt",
    sku: "TS-WH-004",
    barcode: "8901234567893",
    price: 599,
    category: "T-Shirts",
    image: "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&q=80&w=200",
    variants: {
      sizes: ["S", "M", "L", "XL"],
      colors: ["White", "Black"]
    }
  }
];
---

<MainLayout title="Omnichannel POS Terminal | Bobo OS" hideNav={true}>
  <div class="flex h-screen bg-[#05081a] overflow-hidden font-['Plus_Jakarta_Sans'] text-white">
    
    <!-- Sidebar -->
    <aside class="w-20 md:w-24 border-r border-white/10 bg-[#05081a]/50 backdrop-blur-2xl flex flex-col justify-between py-10 items-center">
      <div class="flex flex-col gap-8">
        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center font-black text-white text-xl shadow-lg shadow-indigo-600/20 italic">B</div>
        <nav class="flex flex-col gap-6">
           <a href="/retail-os" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-layout-grid text-xl"></i>
           </a>
           <a href="/retail-os/inventory" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-box text-xl"></i>
           </a>
           <a href="/pos-clothing" class="p-4 text-indigo-400 bg-indigo-500/10 rounded-2xl transition-all shadow-lg shadow-indigo-500/5 font-bold">
              <i class="lucide-receipt text-xl"></i>
           </a>
           <a href="/retail-os/customers" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-users-2 text-xl"></i>
           </a>
           <a href="/retail-os/analytics" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-bar-chart-3 text-xl"></i>
           </a>
        </nav>
      </div>

      <div class="flex flex-col gap-6">
         <a href="/crm-login" class="p-4 text-white/20 hover:text-rose-400 hover:bg-rose-400/10 rounded-2xl transition-all"><i class="lucide-log-out text-xl"></i></a>
      </div>
    </aside>

    <!-- Content Workspace -->
    <main class="flex-1 overflow-hidden flex flex-col p-6 md:p-8 relative">
       
       <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8">
          <div class="flex-1 max-w-2xl relative group">
             <i class="lucide-search absolute left-5 top-1/2 -translate-y-1/2 text-white/20 group-focus-within:text-indigo-500 transition-colors"></i>
             <input type="text" id="barcode-search" placeholder="SCAN BARCODE OR QUERY SKU..." class="w-full bg-white/5 border border-white/10 p-5 pl-14 rounded-2xl outline-none focus:border-indigo-500 transition-all font-black text-[10px] uppercase tracking-widest" />
             <div class="absolute right-6 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)] animate-pulse"></div>
          </div>
          <div class="flex items-center gap-4">
             <div class="px-6 py-4 bg-white/5 border border-white/10 rounded-2xl text-center">
                <div class="text-[8px] font-black uppercase text-white/30 tracking-widest italic">Shift Total</div>
                <div class="text-xl font-black italic tracking-tighter">₹14,250</div>
             </div>
          </div>
       </header>

       <div class="flex-1 flex gap-8 min-h-0">
          
          <!-- Catalog Section -->
          <section class="flex-[1.5] flex flex-col gap-6 min-w-0">
             <div class="flex items-center justify-between">
                <div class="flex gap-2">
                   {['All', 'Shirts', 'Jeans', 'Ethnic'].map((cat, idx) => (
                      <button class={`px-4 py-2 rounded-xl text-[8px] font-black uppercase tracking-widest border transition-all ${idx === 0 ? 'bg-indigo-600 border-indigo-400' : 'bg-white/5 border-white/10 hover:border-white/20'}`}>{cat}</button>
                   ))}
                </div>
             </div>

             <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 overflow-y-auto custom-scrollbar pr-4 pb-8">
                {products.map(product => (
                   <div class="bg-white/5 border border-white/10 rounded-[32px] overflow-hidden group hover:bg-white/[0.08] transition-all cursor-pointer product-card" data-id={product.id}>
                      <div class="h-40 bg-black/20 relative overflow-hidden">
                         <img src={product.image} alt={product.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500 opacity-60" />
                         <div class="absolute top-4 right-4 bg-black/60 backdrop-blur-md border border-white/10 rounded-xl px-2 py-1 text-[8px] font-black italic text-indigo-400">{product.sku}</div>
                      </div>
                      <div class="p-5">
                         <h3 class="text-xs font-black italic uppercase tracking-tight mb-4 line-clamp-1">{product.name}</h3>
                         <div class="flex justify-between items-center">
                            <span class="text-lg font-black italic text-white/90">₹{product.price}</span>
                            <div class="w-8 h-8 rounded-xl bg-indigo-600 flex items-center justify-center text-white shadow-lg shadow-indigo-600/20"><i class="lucide-plus text-xs"></i></div>
                         </div>
                      </div>
                   </div>
                ))}
             </div>
          </section>

          <!-- Billing Section -->
          <aside class="flex-1 flex flex-col gap-6 min-w-[380px]">
             
             <!-- VIP Hub -->
             <div class="bg-white/5 border border-white/10 rounded-[32px] p-5 relative overflow-hidden group">
                <div class="flex items-center gap-4">
                   <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-cyan-500 rounded-2xl flex items-center justify-center font-black italic text-xs">V</div>
                   <div class="flex-1">
                      <div class="text-[8px] font-black uppercase tracking-widest text-indigo-400 italic">VIP IDENTIFIED</div>
                      <div class="text-xs font-black italic">RAHUL SHARMA</div>
                   </div>
                   <div class="text-right">
                      <div class="text-[8px] font-black uppercase tracking-widest text-white/20 italic">Loyalty PTs</div>
                      <div class="text-xs font-black italic text-emerald-400">1,240</div>
                   </div>
                </div>
                <div class="absolute top-0 right-0 w-24 h-24 bg-indigo-600/5 blur-[50px] -z-10"></div>
             </div>

             <!-- Cart List -->
             <div class="flex-1 bg-white/5 border border-white/10 rounded-[32px] flex flex-col min-h-0">
                <div class="p-6 border-b border-white/5 flex justify-between items-center">
                   <h3 class="text-sm font-black italic uppercase tracking-widest">Active Basket</h3>
                   <button class="text-[8px] font-black uppercase text-rose-500/50 hover:text-rose-500 transition-all font-mono" id="clear-cart">PURGE :: [C]</button>
                </div>
                
                <div class="flex-1 overflow-y-auto custom-scrollbar p-6 space-y-4" id="cart-items">
                   <!-- Empty State -->
                   <div class="h-full flex flex-col items-center justify-center text-center opacity-20">
                      <i class="lucide-qr-code text-5xl mb-4"></i>
                      <div class="text-[10px] font-black uppercase tracking-[0.2em] italic">Awaiting Scan Instance</div>
                   </div>
                </div>

                <div class="p-8 bg-black/20 space-y-4 rounded-b-[32px]">
                   <div class="space-y-2">
                      <div class="flex justify-between text-[10px] font-black uppercase text-white/30 italic">
                         <span>Subtotal</span>
                         <span id="subtotal">₹0.00</span>
                      </div>
                      <div class="flex justify-between text-[10px] font-black uppercase text-indigo-400 italic">
                         <span>TAX (GST 18%)</span>
                         <span id="gst-amount">₹0.00</span>
                      </div>
                   </div>
                   <div class="flex justify-between items-end border-t border-white/5 pt-4">
                      <div>
                         <div class="text-[8px] font-black uppercase text-white/20 tracking-widest">Grand Total</div>
                         <div class="text-3xl font-black italic tracking-tighter text-indigo-400" id="grand-total">₹0.00</div>
                      </div>
                      <button class="bg-indigo-600 px-8 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-indigo-600/30 hover:scale-[1.05] transition-all italic">GENERATE INVOICE</button>
                   </div>
                </div>
             </div>

             <div class="grid grid-cols-3 gap-4">
                {['CASH', 'UPI', 'CARD'].map(method => (
                   <button class="py-4 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:border-indigo-500 transition-all italic opacity-60 hover:opacity-100">{method}</button>
                ))}
             </div>

          </aside>
       </div>

    </main>
  </div>

  <!-- Variant Modal -->
  <div id="variant-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-6 backdrop-blur-3xl bg-black/80 font-['Plus_Jakarta_Sans']">
     <div class="bg-[#05081a] border border-white/10 w-full max-w-lg rounded-[48px] overflow-hidden shadow-2xl shadow-indigo-600/10">
        <div class="p-10">
           <div class="flex items-center gap-6 mb-10">
              <div class="w-24 h-24 rounded-3xl overflow-hidden bg-white/5 border border-white/10">
                 <img id="modal-product-image" src="" alt="" class="w-full h-full object-cover opacity-60" />
              </div>
              <div>
                 <h2 id="modal-product-name" class="text-xl font-black italic uppercase tracking-tight"></h2>
                 <div id="modal-product-price" class="text-2xl font-black italic text-indigo-400 mt-2"></div>
              </div>
           </div>

           <div class="space-y-8">
              <div>
                 <label class="text-[10px] font-black uppercase tracking-widest text-white/30 italic mb-4 block">Select Size Variant</label>
                 <div id="size-chips" class="flex flex-wrap gap-3"></div>
              </div>
              <div>
                 <label class="text-[10px] font-black uppercase tracking-widest text-white/30 italic mb-4 block">Select Colorway</label>
                 <div id="color-chips" class="flex flex-wrap gap-3"></div>
              </div>
           </div>

           <div class="mt-12 flex gap-4">
              <button class="flex-1 py-5 bg-white/5 border border-white/10 rounded-3xl text-[10px] font-black uppercase tracking-widest hover:bg-rose-500/10 hover:text-rose-500 hover:border-rose-500/20 transition-all italic" onclick="document.getElementById('variant-modal').classList.add('hidden')">Cancel Instance</button>
              <button class="flex-1 py-5 bg-indigo-600 rounded-3xl text-[10px] font-black uppercase tracking-widest shadow-xl shadow-indigo-600/30 hover:scale-[1.02] transition-all italic confirm-add-btn">Append to Basket</button>
           </div>
        </div>
     </div>
  </div>

  <script is:inline>
     // Mock Data Sync
     const products = [
       { id: 1, name: "Premium Black Shirt", sku: "SH-BL-001", price: 999, image: "https://images.unsplash.com/photo-1583743814966-8936f5b7be1a?auto=format&fit=crop&q=80&w=200", variants: { sizes: ["S", "M", "L", "XL"], colors: ["Black", "Midnight Blue"] } },
       { id: 2, name: "Classic Blue Jeans", sku: "JN-BL-002", price: 1999, image: "https://images.unsplash.com/photo-1542272604-787c3835535d?auto=format&fit=crop&q=80&w=200", variants: { sizes: ["30", "32", "34", "36"], colors: ["Blue", "Dark Denim"] } },
       { id: 3, name: "Designer Red Kurti", sku: "KR-RD-003", price: 1499, image: "https://images.unsplash.com/photo-1583391733956-6c78276477e2?auto=format&fit=crop&q=80&w=200", variants: { sizes: ["M", "L", "XL"], colors: ["Red", "Maroon"] } },
       { id: 4, name: "Classic White T-Shirt", sku: "TS-WH-004", price: 599, image: "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&q=80&w=200", variants: { sizes: ["S", "M", "L", "XL"], colors: ["White", "Black"] } }
     ];

     let cart = [];
     let currentEditingProduct = null;
     let selectedSize = null;
     let selectedColor = null;

     const modal = document.getElementById('variant-modal');

     function updateCartUI() {
       const basket = document.getElementById('cart-items');
       if (cart.length === 0) {
         basket.innerHTML = `
           <div class="h-full flex flex-col items-center justify-center text-center opacity-20">
              <i class="lucide-qr-code text-5xl mb-4"></i>
              <div class="text-[10px] font-black uppercase tracking-[0.2em] italic">Awaiting Scan Instance</div>
           </div>`;
       } else {
         basket.innerHTML = cart.map((item, idx) => `
           <div class="bg-white/5 border border-white/5 p-4 rounded-2xl flex items-center gap-4 animate-in slide-in-from-right duration-300">
              <div class="w-12 h-12 rounded-xl overflow-hidden grayscale">
                 <img src="${item.image}" class="w-full h-full object-cover opacity-50" />
              </div>
              <div class="flex-1">
                 <div class="text-[10px] font-black italic uppercase tracking-tight">${item.name}</div>
                 <div class="text-[8px] font-black uppercase text-white/30 italic">${item.size} / ${item.color}</div>
              </div>
              <div class="text-right">
                 <div class="text-xs font-black italic">₹${item.price * item.qty}</div>
                 <div class="flex items-center gap-2 mt-1">
                    <button class="w-5 h-5 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-[10px] hover:bg-rose-500/20" onclick="updateQty(${idx}, -1)">-</button>
                    <span class="text-[8px] font-black">${item.qty}</span>
                    <button class="w-5 h-5 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-[10px] hover:bg-emerald-500/20" onclick="updateQty(${idx}, 1)">+</button>
                 </div>
              </div>
           </div>
         `).join('');
       }
       calculateTotals();
     }

     function calculateTotals() {
       const subtotal = cart.reduce((s, i) => s + (i.price * i.qty), 0);
       const gst = subtotal * 0.18;
       const total = subtotal + gst;

       document.getElementById('subtotal').innerText = '₹' + subtotal.toFixed(2);
       document.getElementById('gst-amount').innerText = '₹' + gst.toFixed(2);
       document.getElementById('grand-total').innerText = '₹' + total.toFixed(2);
     }

     window.updateQty = (idx, delta) => {
       cart[idx].qty += delta;
       if(cart[idx].qty <= 0) cart.splice(idx, 1);
       updateCartUI();
     }

     function showModal(product) {
       currentEditingProduct = product;
       document.getElementById('modal-product-image').src = product.image;
       document.getElementById('modal-product-name').innerText = product.name;
       document.getElementById('modal-product-price').innerText = '₹' + product.price;

       const sList = document.getElementById('size-chips');
       sList.innerHTML = product.variants.sizes.map(s => `
         <button class="chip px-6 py-3 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:border-indigo-500 transition-all italic" onclick="selectV('size', '${s}', this)">${s}</button>
       `).join('');

       const cList = document.getElementById('color-chips');
       cList.innerHTML = product.variants.colors.map(c => `
         <button class="chip px-6 py-3 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:border-indigo-500 transition-all italic" onclick="selectV('color', '${c}', this)">${c}</button>
       `).join('');

       selectedSize = null; selectedColor = null;
       modal.classList.remove('hidden');
     }

     window.selectV = (type, val, el) => {
       el.parentElement.querySelectorAll('button').forEach(b => b.classList.remove('bg-indigo-600', 'border-indigo-400'));
       el.classList.add('bg-indigo-600', 'border-indigo-400');
       if(type==='size') selectedSize = val;
       if(type==='color') selectedColor = val;
     }

     document.querySelectorAll('.product-card').forEach(card => {
       card.addEventListener('click', () => {
         const id = parseInt(card.dataset.id);
         const p = products.find(p => p.id === id);
         showModal(p);
       });
     });

     document.querySelector('.confirm-add-btn').addEventListener('click', () => {
       if(!selectedSize || !selectedColor) return;
       const exists = cart.find(i => i.id === currentEditingProduct.id && i.size === selectedSize && i.color === selectedColor);
       if(exists) exists.qty++;
       else cart.push({...currentEditingProduct, size: selectedSize, color: selectedColor, qty: 1});
       modal.classList.add('hidden');
       updateCartUI();
     });

     document.getElementById('clear-cart').addEventListener('click', () => {
       if(confirm('PURGE CURRENT BASKET?')) { cart = []; updateCartUI(); }
     });

  </script>

  <script is:inline>
     // Auth Guard
     if (localStorage.getItem('retail_os_auth') !== 'true') {
        window.location.href = "/retail-os-login";
     }
  </script>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #05081a; }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.01); }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.05); border-radius: 10px; }
  </style>

  <!-- Lucide Icon Support -->
  <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">
</MainLayout>
