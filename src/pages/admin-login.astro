---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Admin Secure Login | Bobo Analytics">
  <section class="admin-login-wrapper">
    <div class="login-container">
      <div class="login-header">
        <div class="icon-circle">🛡️</div>
        <h1>System Admin Portal</h1>
        <p>Restricted access. Authorized personnel only.</p>
        <div style="font-size:0.75rem; color:#ef4444; margin-bottom:10px; font-weight:bold;">PRODUCTION ENGINE v15.2</div>
      </div>

      <form id="adminLoginForm" class="login-form">
        <div class="form-group">
          <label for="adminId">Admin ID (Email)</label>
          <input type="text" id="adminId" placeholder="admin@bobo.com" required autocomplete="off" />
        </div>

        <div class="form-group">
          <label for="password">Security Key</label>
          <input type="password" id="password" placeholder="••••••••••" required />
        </div>

        <button type="submit" class="btn-login">Authenticate Master Console</button>
        <p id="error" class="error-msg"></p>
      </form>
      
      <div class="back-link">
        <a href="/crm-login">← Back to Portal Selection</a>
      </div>
    </div>
  </section>

  <style>
    .admin-login-wrapper { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 60px 24px; background: radial-gradient(circle at center, rgba(239, 68, 68, 0.05) 0%, transparent 70%); }
    .login-container { width: 100%; max-width: 440px; background: rgba(5, 8, 16, 0.03); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 24px; padding: 40px; backdrop-filter: blur(10px); box-shadow: 0 20px 40px rgba(0,0,0,0.5); text-align: center; }
    .icon-circle { width: 64px; height: 64px; background: rgba(239, 68, 68, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 20px; border: 1px solid rgba(239, 68, 68, 0.3); }
    .login-header h1 { font-size: 2rem; margin-bottom: 8px; }
    .login-form { display: flex; flex-direction: column; gap: 20px; text-align: left; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-group label { font-size: 0.9rem; font-weight: 500; opacity: 0.8; }
    .form-group input { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); padding: 12px 16px; border-radius: 10px; color: white; transition: 0.3s; }
    .form-group input:focus { border-color: #ef4444; }
    .btn-login { background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%); color: white; padding: 14px; border: none; border-radius: 10px; font-size: 1rem; font-weight: 700; cursor: pointer; margin-top: 10px; }
    .error-msg { color: #ef4444; font-size: 0.9rem; margin-top: 15px; min-height: 20px; }
    .back-link { margin-top: 25px; opacity: 0.5; font-size: 0.9rem; }
    .back-link a { color: white; text-decoration: none; }
  </style>

  <script is:inline>
    const form = document.getElementById("adminLoginForm");
    const errorEl = document.getElementById("error");
    const API = "/api";

    form.onsubmit = async (e) => {
      e.preventDefault();
      const email = document.getElementById("adminId").value.trim();
      const password = document.getElementById("password").value.trim();
      
      errorEl.style.color = "#3b82f6";
      errorEl.innerText = "Connecting to Production Master Node...";

      try {
        const res = await fetch(API + "/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, password, industry: "admin" })
        });
        const data = await res.json();
        
        if (data.token) {
          localStorage.setItem("token", data.token);
          errorEl.style.color = "#10b981";
          errorEl.innerText = "✅ VAULT UNLOCKED. Redirecting...";
          setTimeout(() => window.location.replace("/admin/saas"), 800);
        } else {
          errorEl.style.color = "#ef4444";
          errorEl.innerText = "⚠️ REJECTED: " + (data.error || "Invalid Credentials");
        }
      } catch (err) {
        errorEl.style.color = "#f59e0b";
        errorEl.innerText = "❌ Master API Offline. Ensure 'npm run backend' is active.";
      }
    };
  </script>
</MainLayout>
