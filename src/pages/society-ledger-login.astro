---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/restaurant.css";
---

<MainLayout title="Society Ledger Login | Bobo Analytics" hideNav={true}>
  <div class="auth-page min-h-screen flex items-center justify-center p-6 relative font-['Plus_Jakarta_Sans'] text-white" style="background: url('/images/society-ledger-bg.png') no-repeat center center; background-size: cover;">
    
    <!-- Dark Theme Overlay -->
    <div class="absolute inset-0 bg-[#020617]/85 backdrop-blur-[3px] pointer-events-none z-[0]"></div>
    
    <!-- Ambient Background Lighting (Gold & Deep Cyan) -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden z-[1]">
       <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-amber-500/10 rounded-full blur-[140px] -mr-64 -mt-64"></div>
       <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-cyan-500/10 rounded-full blur-[140px] -ml-64 -mb-64"></div>
    </div>

    <!-- Login Card -->
    <div class="login-card max-w-lg w-full bg-white/5 border border-white/10 p-12 md:p-16 rounded-[64px] shadow-2xl backdrop-blur-3xl relative z-10 group transition-all hover:bg-white/[0.08] hover:border-amber-500/30 overflow-hidden">
       <!-- Gold Glow Element -->
       <div class="absolute top-0 right-0 w-32 h-32 bg-amber-500/10 blur-[60px] -z-10 group-hover:bg-amber-500/20 transition-all"></div>
       
       <div class="text-center mb-12">
          <div class="w-24 h-24 bg-gradient-to-br from-amber-400 to-orange-600 rounded-3xl flex items-center justify-center text-5xl mx-auto mb-8 shadow-2xl shadow-amber-500/30 group-hover:scale-110 group-hover:rotate-3 transition-transform italic border border-white/10">S</div>
          <h1 class="text-3xl md:text-4xl font-black italic text-white uppercase tracking-tighter leading-none">Society <br /><span class="bg-gradient-to-r from-amber-400 to-yellow-500 bg-clip-text text-transparent">Ledger OS</span></h1>
          <p class="text-white/40 text-[10px] font-black uppercase tracking-[0.4em] mt-4 italic">Maintenance Billing & Resident Node</p>
       </div>

       <form id="loginForm" class="space-y-8">
          <div class="space-y-3">
             <label class="text-[10px] font-black uppercase text-white/30 tracking-[0.2em] ml-4 italic">Society ID / Admin ID</label>
             <div class="relative">
                <i class="lucide-building absolute left-5 top-1/2 -translate-y-1/2 text-white/20 text-xs"></i>
                <input type="text" id="societyId" placeholder="PREMIUM-SOCIETY-01" required autocomplete="off" class="w-full bg-white/5 border border-white/10 p-5 pl-12 rounded-2xl outline-none focus:border-amber-400 transition-all font-black text-xs uppercase" />
                <button type="button" onclick="document.getElementById('societyId').value=''" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/20 hover:text-white transition-colors"><i class="lucide-x-circle text-xs"></i></button>
             </div>
          </div>
          <div class="space-y-3">
             <label class="text-[10px] font-black uppercase text-white/30 tracking-[0.2em] ml-4 italic">Master Access Key</label>
             <div class="relative">
                <i class="lucide-shield-check absolute left-5 top-1/2 -translate-y-1/2 text-white/20 text-xs"></i>
                <input type="password" id="password" placeholder="••••••••" required autocomplete="off" class="w-full bg-white/5 border border-white/10 p-5 pl-12 rounded-2xl outline-none focus:border-amber-400 transition-all font-black text-xs" />
                <button type="button" onclick="document.getElementById('password').value=''" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/20 hover:text-white transition-colors"><i class="lucide-x-circle text-xs"></i></button>
             </div>
          </div>

          <div id="auth-status" class="text-rose-500 text-[10px] font-black uppercase tracking-widest text-center min-h-[1rem] italic"></div>

          <button type="submit" class="w-full py-6 bg-gradient-to-r from-amber-500 to-orange-600 rounded-3xl text-white font-black italic uppercase tracking-[0.3em] text-xs shadow-2xl shadow-amber-600/30 hover:scale-[1.03] active:scale-95 transition-all">
             Launch Ledger Node
          </button>
       </form>

       <footer class="mt-12 text-center">
          <a href="/crm-login" class="text-white/10 hover:text-white font-black text-[8px] transition-colors italic uppercase tracking-[0.4em]">Abort Secure Handshake</a>
       </footer>
    </div>
  </div>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #020617; margin: 0; }
    .shake { animation: shake 0.4s ease; }
    @keyframes shake {
       0%, 100% { transform: translateX(0); }
       25% { transform: translateX(-8px); }
       75% { transform: translateX(8px); }
    }
  </style>

  <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">

  <script is:inline>
    const loginForm = document.getElementById('loginForm');
    const authStatus = document.getElementById('auth-status');

    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const sId = document.getElementById('societyId').value;
      const pass = document.getElementById('password').value;
      
      authStatus.style.color = "#fbbf24"; // amber
      authStatus.innerHTML = 'Establishing Secure Link...';

      // --- MASTER OVERRIDE ---
      if (sId.toLowerCase() === 'society' && pass === 'society') {
          localStorage.setItem('user', JSON.stringify({ username: 'Society Admin', role: 'admin' }));
          localStorage.setItem('ledger_os_auth', 'true');
          window.location.href = '/society-ledger';
          return;
      }

      setTimeout(() => {
        authStatus.style.color = "#f43f5e";
        authStatus.innerHTML = 'SYNC ERROR: Society Node ID Not Recognized.';
        loginForm.classList.add('shake');
        setTimeout(() => loginForm.classList.remove('shake'), 400);
      }, 1000);
    });
  </script>
</MainLayout>
