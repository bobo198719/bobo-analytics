---
export const prerender = false;
import "../../styles/restaurant.css";
const { table } = Astro.params;

// ⚡ SERVER-SIDE PRE-FETCH: Embed menu data directly in HTML for instant load
let ssrMenuData = [];
let ssrTablesData = [];

try {
    const origin = Astro.url.origin;
    const [menuRes, tablesRes] = await Promise.all([
        fetch(`${origin}/api/v2/restaurant/menu`, { signal: AbortSignal.timeout(2000) }),
        fetch(`${origin}/api/v2/restaurant/tables`, { signal: AbortSignal.timeout(2000) })
    ]);
    const rawMenu = await menuRes.json();
    const rawTables = await tablesRes.json();
    ssrMenuData = Array.isArray(rawMenu) ? rawMenu : [];
    ssrTablesData = Array.isArray(rawTables) ? rawTables : [];
} catch (e) {
    // SSR timed out or failed — client-side backgroundSync will load data
    ssrMenuData = [];
    ssrTablesData = [];
}
---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Menu - Table {table}</title>
</head>
<body class="bg-[#111] text-white font-sans antialiased pb-24">
    
    <div id="app" class="max-w-md mx-auto relative min-h-screen flex flex-col">
        
        <!-- ========================================== -->
        <!-- 1. WELCOME VIEW (LANDING) -->
        <!-- ========================================== -->
        <div id="viewWelcome" class="flex-1 flex flex-col p-6 animate-in fade-in duration-700">
            <div class="relative w-full h-80 rounded-[40px] overflow-hidden shadow-2xl mb-8">
                <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&q=80&w=600" class="w-full h-full object-cover scale-110" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#111] via-[#111]/20 to-transparent"></div>
                <div class="absolute bottom-6 left-6">
                    <div class="w-16 h-16 bg-white text-black rounded-2xl flex items-center justify-center font-black italic text-3xl shadow-xl mb-3">B</div>
                    <h1 class="text-3xl font-black italic uppercase leading-tight tracking-tighter">Grand Cafe Bobo</h1>
                </div>
            </div>

            <div class="space-y-6 flex-1">
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center shrink-0">📍</div>
                    <div>
                        <p class="text-[10px] text-white/30 font-black uppercase tracking-widest mb-1">Location</p>
                        <p class="text-xs font-bold leading-relaxed">123 Culinary Boulevard, Tech Park Sector, Digital City - 560001</p>
                    </div>
                </div>

                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center shrink-0">📞</div>
                    <div>
                        <p class="text-[10px] text-white/30 font-black uppercase tracking-widest mb-1">Contact</p>
                        <p class="text-xs font-bold leading-relaxed">+91 95185 25420</p>
                    </div>
                </div>

                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center shrink-0">🕒</div>
                    <div>
                        <p class="text-[10px] text-white/30 font-black uppercase tracking-widest mb-1">Hours</p>
                        <p class="text-xs font-bold leading-relaxed">Open: 09:00 AM • Close: 11:30 PM</p>
                    </div>
                </div>
            </div>

            <div class="pt-8 mb-4">
                <button onclick="goToModeSelector()" class="w-full py-5 bg-white text-black rounded-3xl font-black uppercase tracking-[0.2em] italic shadow-xl shadow-white/5 active:scale-95 transition-all text-sm">
                    Order Food →
                </button>
            </div>
        </div>

        <!-- ========================================== -->
        <!-- 2. MODE SELECTOR VIEW -->
        <!-- ========================================== -->
        <div id="viewModeSelector" class="hidden flex-1 flex flex-col p-8 justify-center animate-in slide-in-from-bottom duration-500">
            <h2 class="text-3xl font-black italic uppercase mb-12 text-center leading-tight">How would you like<br/><span class="text-orange-500">to order?</span></h2>
            
            <div class="space-y-4">
                <button onclick="startOrdering('dine_in')" class="w-full group p-6 bg-[#222] border border-white/5 rounded-[32px] flex items-center gap-6 hover:border-orange-500 transition-all">
                    <div class="w-16 h-16 bg-orange-500/10 rounded-2xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform">🍽️</div>
                    <div class="text-left">
                        <h3 class="font-black uppercase text-sm italic">Dine-In</h3>
                        <p class="text-[10px] text-white/30 font-bold tracking-widest uppercase mt-1">Serve at Table {table}</p>
                    </div>
                </button>

                <button onclick="startOrdering('pickup')" class="w-full group p-6 bg-[#222] border border-white/5 rounded-[32px] flex items-center gap-6 hover:border-orange-500 transition-all">
                    <div class="w-16 h-16 bg-blue-500/10 rounded-2xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform">🛍️</div>
                    <div class="text-left">
                        <h3 class="font-black uppercase text-sm italic">Pick-Up</h3>
                        <p class="text-[10px] text-white/30 font-bold tracking-widest uppercase mt-1">Take away from Counter</p>
                    </div>
                </button>

                <button onclick="startOrdering('delivery')" class="w-full group p-6 bg-[#222] border border-white/5 rounded-[32px] flex items-center gap-6 hover:border-orange-500 transition-all">
                    <div class="w-16 h-16 bg-emerald-500/10 rounded-2xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform">🛵</div>
                    <div class="text-left">
                        <h3 class="font-black uppercase text-sm italic">Home Delivery</h3>
                        <p class="text-[10px] text-white/30 font-bold tracking-widest uppercase mt-1">Free delivery via Bobo</p>
                    </div>
                </button>
            </div>
        </div>

        <!-- ========================================== -->
        <!-- 3. MENU HUB VIEW (THE MAIN ENGINE) -->
        <!-- ========================================== -->
        <div id="viewMenuHub" class="hidden flex flex-col flex-1">
            <header class="bg-[#111] p-5 sticky top-0 z-50 border-b border-white/5 flex justify-between items-center backdrop-blur-xl">
               <div class="flex items-center gap-3">
                  <div onclick="window.location.reload()" class="w-10 h-10 bg-white text-black rounded-xl flex items-center justify-center font-black italic text-xl">B</div>
                  <div>
                      <h1 class="font-black italic uppercase leading-none text-xs">Menu Intelligence</h1>
                      <p id="activeModeLabel" class="text-[8px] text-orange-400 font-bold uppercase tracking-widest mt-1">DINE-IN • T-{table}</p>
                  </div>
               </div>
               <button onclick="toggleCart()" class="relative p-2.5 bg-white/5 rounded-2xl border border-white/5">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                  <span id="cartBadge" class="absolute -top-1 -right-1 bg-white text-black text-[10px] font-black w-5 h-5 rounded-full flex items-center justify-center hidden">0</span>
               </button>
            </header>

            <div class="sticky top-[81px] bg-[#111] z-40 p-4 pb-2 space-y-4">
                <div class="relative group">
                    <input 
                        type="text" id="searchInput" oninput="handleSearch(this.value)" placeholder="Search for dishes..." 
                        class="w-full bg-[#1a1a1a] border border-white/10 rounded-2xl py-4 px-12 text-sm font-bold focus:outline-none focus:border-white transition-all placeholder:text-white/20"
                    />
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-white/20 group-focus-within:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    </div>
                </div>
                <div id="categoryBar" class="flex gap-2 overflow-x-auto no-scrollbar pb-2 pt-1 border-t border-white/5"></div>
            </div>

            <div id="menuItemsGrid" class="p-4 space-y-4 pb-32"></div>
        </div>
        
        <!-- Live Status Tracking View -->
        <div id="viewTracker" class="hidden p-6">
            <h2 class="text-3xl font-black uppercase text-center mb-8 italic">Order Tracker</h2>
            <div id="trackerSteps" class="space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-white/20 before:to-transparent">
                <div class="flex flex-col items-center justify-center py-10 gap-4 opacity-50 relative z-10">
                    <div class="w-8 h-8 border-4 border-white/10 border-t-orange-500 rounded-full animate-spin"></div>
                    <p class="text-[10px] font-black uppercase tracking-widest text-white">Locating Order...</p>
                    <button onclick="localStorage.removeItem('active_qr_order_' + table); window.location.reload();" class="mt-4 px-4 py-2 border border-white/10 rounded-xl text-[8px] font-black uppercase">Refresh Menu</button>
                </div>
            </div>
            
            <div id="paymentBox" class="hidden mt-12 bg-[#222] p-6 border border-[#333] rounded-2xl shadow-xl shadow-orange-500/10">
               <h3 class="text-xl font-black uppercase text-center mb-4">Total: ₹<span id="liveTotal">0</span></h3>
               <button onclick="simulatePayment()" class="w-full py-4 bg-gradient-to-r from-emerald-500 to-emerald-600 rounded-xl font-black uppercase tracking-widest active:scale-95 transition-all text-sm">Pay Securely</button>
            </div>
            
            <div id="feedbackBox" class="hidden mt-8 text-center animate-in fade-in zoom-in duration-500">
               <div class="text-emerald-500 text-6xl mb-4">🍽️</div>
               <h3 class="text-xl font-black uppercase mb-4">How was your meal?</h3>
               <div class="flex justify-center gap-4 mb-6">
                  <button class="text-4xl hover:scale-125 transition-transform" onclick="submitFeedback()">😞</button>
                  <button class="text-4xl hover:scale-125 transition-transform" onclick="submitFeedback()">😐</button>
                  <button class="text-4xl hover:scale-125 transition-transform" onclick="submitFeedback()">😋</button>
                  <button class="text-4xl hover:scale-125 transition-transform" onclick="submitFeedback()">😍</button>
               </div>
               <p class="text-xs text-white/40 uppercase font-black">Thank you for dining with us</p>
            </div>
        </div>

        <!-- Floating Cart Mini -->
        <div id="floatingCart" class="fixed bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-[#000] via-[#111] to-transparent z-50 transform translate-y-full transition-transform duration-300">
            <div class="max-w-md mx-auto bg-[#222] border border-[#333] rounded-3xl p-6 shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
               <div class="flex justify-between items-center mb-4 border-b border-[#333] pb-4">
                  <h3 class="font-black italic uppercase text-lg">Your Order</h3>
                  <button onclick="toggleCart()" class="text-white/40">Close</button>
               </div>
               <div id="cartItems" class="max-h-40 overflow-y-auto mb-4 space-y-3"></div>
               <div class="flex justify-between items-center font-black text-xl mb-6">
                  <span>TOTAL</span>
                  <span class="text-orange-400">₹<span id="cartTotal">0</span></span>
               </div>
               <button onclick="placeOrder()" class="w-full py-4 bg-white text-black rounded-xl font-black uppercase tracking-widest shadow-lg active:scale-95 transition-all">Send to Waiter</button>
            </div>
        </div>
    </div>

    <script define:vars={{ table, ssrMenuData, ssrTablesData }}>
       // ⚡ INSTANT LOAD: Data pre-rendered server-side — zero client wait
       let menuData = Array.isArray(ssrMenuData) ? ssrMenuData : [];
       let tablesData = Array.isArray(ssrTablesData) ? ssrTablesData : [];
       let cart = [];
       let activeOrderId = localStorage.getItem('active_qr_order_' + table);
       let activeCategory = 'All';
       let searchQuery = '';
       let orderMode = '';
       let dataReady = menuData.length > 0;
       let pollAttempts = 0;

       const backgroundSync = async () => {
          try {
             const [menuRes, tablesRes] = await Promise.all([
                 fetch('/api/v2/restaurant/menu'),
                 fetch('/api/v2/restaurant/tables')
             ]);
             const rawMenu = await menuRes.json();
             const rawTables = await tablesRes.json();
             if (Array.isArray(rawMenu) && rawMenu.length > 0) menuData = rawMenu;
             if (Array.isArray(rawTables) && rawTables.length > 0) tablesData = rawTables;
             dataReady = true;
             if (!document.getElementById('viewMenuHub').classList.contains('hidden')) {
                renderCategories();
                renderMenu();
             }
          } catch (e) { }
       };

       window.goToModeSelector = () => {
          document.getElementById('viewWelcome').classList.add('hidden');
          document.getElementById('viewModeSelector').classList.remove('hidden');
       };

       window.startOrdering = (mode) => {
          orderMode = mode;
          document.getElementById('activeModeLabel').innerText = mode.replace('_',' ').toUpperCase() + ` • T-${table}`;
          document.getElementById('viewModeSelector').classList.add('hidden');
          document.getElementById('viewMenuHub').classList.remove('hidden');
          if (dataReady) { renderCategories(); renderMenu(); }
       };

       window.handleSearch = (val) => { searchQuery = val.toLowerCase(); renderMenu(); };
       window.setCategory = (cat) => { activeCategory = cat; renderCategories(); renderMenu(); };

       const renderCategories = () => {
          const bar = document.getElementById('categoryBar');
          if (!bar) return;
          const cats = ['All', ...new Set(menuData.map(i => i.category))];
          bar.innerHTML = cats.map(cat => `
             <button onclick="setCategory('${cat}')" 
                class="whitespace-nowrap px-6 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest transition-all border ${activeCategory === cat ? 'bg-white border-white text-black shadow-lg shadow-white/10' : 'bg-[#222] border-[#333] text-white/40'}"
             >
                ${cat}
             </button>
          `).join('');
       };

       const renderMenu = () => {
          const c = document.getElementById('menuItemsGrid'); if (!c) return;
          const filtered = menuData.filter(item => {
             const matchesCat = activeCategory === 'All' || item.category === activeCategory;
             return matchesCat && (item.name.toLowerCase().includes(searchQuery) || (item.description || '').toLowerCase().includes(searchQuery));
          });
          c.innerHTML = filtered.map(item => `
             <div class="bg-white/5 border border-white/5 rounded-3xl overflow-hidden flex shadow-2xl p-2 group">
                <div class="relative w-24 h-24 rounded-2xl overflow-hidden shrink-0">
                    <img src="${item.image_url || 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=300'}" class="w-full h-full object-cover" />
                </div>
                <div class="p-3 pl-4 flex-1 flex flex-col justify-between">
                   <div>
                      <h4 class="font-black italic uppercase leading-none text-xs mb-1 line-clamp-2">${item.name}</h4>
                      <p class="text-[9px] text-white/30 leading-tight line-clamp-2 mt-1">${item.description || item.name}</p>
                   </div>
                   <div class="flex justify-between items-end mt-2">
                       <span class="text-orange-500 font-black text-sm italic">₹${item.price}</span>
                       <button onclick="addToCart(${item.id})" class="bg-white text-black w-8 h-8 rounded-xl flex items-center justify-center font-black">+</button>
                   </div>
                </div>
             </div>
          `).join('');
       };

       window.addToCart = (id) => {
          const item = menuData.find(i => i.id === id); if (!item) return;
          const ext = cart.find(c => c.id === id); if(ext) ext.qty++; else cart.push({...item, qty:1});
          updateCartUI();
       };

       const updateCartUI = () => {
          const badge = document.getElementById('cartBadge');
          const totalQty = cart.reduce((acc, c)=>acc+c.qty, 0);
          if(totalQty > 0) { badge.classList.remove('hidden'); badge.innerText = totalQty; } else { badge.classList.add('hidden'); }
          const c = document.getElementById('cartItems');
          c.innerHTML = cart.map(i => `<div class="flex justify-between items-center text-sm font-bold border-b border-white/5 pb-2"><span>${i.name} (x${i.qty})</span><span>₹${i.price * i.qty}</span></div>`).join('');
          document.getElementById('cartTotal').innerText = cart.reduce((acc, c)=>acc + (c.price*c.qty), 0);
       };

       window.toggleCart = () => {
          const el = document.getElementById('floatingCart');
          if (cart.length === 0 && !el.classList.contains('translate-y-0')) return alert("Empty basket");
          el.classList.toggle('translate-y-full'); el.classList.toggle('translate-y-0');
       };

       window.placeOrder = async () => {
          const btn = document.querySelector('#floatingCart button');
          btn.innerText = "Sending..."; btn.disabled = true;
          try {
              const total = cart.reduce((acc, c) => acc + (c.price * c.qty), 0);
              const res = await fetch('/api/v2/restaurant/qr-orders', {
                  method: 'POST',
                  headers: {'Content-Type': 'application/json'},
                  body: JSON.stringify({ table, items: cart, total, status: 'placed' })
              });
              const data = await res.json();
              if (data.success || data.order_id) {
                  toggleCart();
                  document.getElementById('viewMenuHub').classList.add('hidden');
                  activeOrderId = data.order_id;
                  localStorage.setItem('active_qr_order_' + table, activeOrderId);
                  localStorage.setItem('last_order_state_' + table, JSON.stringify({ total, status: 'placed' }));
                  showTracker();
              } else throw new Error(data.error);
          } catch(err) { alert(err.message); btn.innerText = "Re-try"; btn.disabled = false; }
       };

       const showTracker = () => {
          document.getElementById('viewMenuHub').classList.add('hidden');
          document.getElementById('viewWelcome').classList.add('hidden');
          document.getElementById('viewTracker').classList.remove('hidden');
          const cached = localStorage.getItem('last_order_state_' + table);
          if (cached) { try { const state = JSON.parse(cached); renderTrackerSteps(state.status, state.total); } catch(e) {} }
          pollStatus();
       };

       let pollInterval;
       const pollStatus = async () => {
          const f = async () => {
              if(!activeOrderId) return;
              const ctrl = new AbortController();
              const tid = setTimeout(() => ctrl.abort(), 2500);
              try {
                  const res = await fetch(`/api/v2/restaurant/qr-orders?order_id=${activeOrderId}&v=${Date.now()}`, { signal: ctrl.signal });
                  const { order } = await res.json();
                  clearTimeout(tid);
                  if (order && !order.error) {
                      pollAttempts = 0;
                      renderTrackerSteps(order.status, order.total_amount);
                      localStorage.setItem('last_order_state_' + table, JSON.stringify({ total: order.total_amount, status: order.status }));
                  } else {
                      pollAttempts++;
                      // If order not found for more than 5 attempts, it's likely purged or invalid. Offer reset.
                      if (pollAttempts > 5) {
                          document.getElementById('trackerSteps').innerHTML = `
                             <div class="flex flex-col items-center justify-center py-20 text-center gap-4 animate-in fade-in zoom-in duration-500">
                                <p class="text-xs font-black uppercase text-white/40 tracking-widest leading-loose">The previous session has expired<br/>or been completed.</p>
                                <button onclick="localStorage.removeItem('active_qr_order_' + table); window.location.reload();" class="px-8 py-4 bg-white text-black rounded-3xl font-black uppercase italic text-xs shadow-xl active:scale-95 transition-all">New Order →</button>
                             </div>
                          `;
                          clearInterval(pollInterval);
                      }
                  }
              } catch(e) { }
          };
          f(); pollInterval = setInterval(f, 3500);
       };

       const renderTrackerSteps = (status, total) => {
          if (!status) return;
          const liveTotalEl = document.getElementById('liveTotal');
          if (liveTotalEl) liveTotalEl.innerText = total || 0;
          const states = [
             { key: 'placed', label: 'Order Placed', desc: 'Waiting for confirmation', icon: '📝' },
             { key: 'waiter_confirmed', label: 'Order Confirmed', desc: 'Sent to kitchen', icon: '👨‍🍳' },
             { key: 'kitchen_preparing', label: 'Preparing', desc: 'Chefs are cooking', icon: '🔥' },
             { key: 'kitchen_ready', label: 'Ready', desc: 'Food is coming', icon: '🛎️' },
             { key: 'served', label: 'Served', desc: 'Enjoy your meal!', icon: '✨' },
             { key: 'paid', label: 'Completed', desc: 'Thank you!', icon: '❤️' }
          ];
          const currentIndex = states.findIndex(s => s.key === status);
          const c = document.getElementById('trackerSteps');
          if (!c) return;
          c.innerHTML = states.map((s, idx) => {
              const color = idx < currentIndex ? 'bg-emerald-500' : (idx === currentIndex ? 'bg-orange-500 animate-pulse border-white/20' : 'bg-[#222] border-white/5');
              const textColor = idx > currentIndex ? 'text-white/20' : 'text-white';
              return `<div class="relative flex items-center justify-between group">
                 <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-[#111] ${color} shrink-0 z-10 text-lg transition-colors duration-500">${s.icon}</div>
                 <div class="w-[calc(100%-4rem)] bg-[#222] p-4 rounded-2xl border border-white/5 shadow-lg ${textColor} transition-all duration-500">
                    <h4 class="font-black uppercase text-[11px] tracking-widest italic">${s.label}</h4>
                    <p class="text-[9px] opacity-70 border-t border-white/5 pt-2 mt-2 font-bold">${s.desc}</p>
                 </div>
              </div>`
          }).join('');
          if (status === 'served') document.getElementById('paymentBox').classList.remove('hidden');
          if (status === 'paid') { clearInterval(pollInterval); document.getElementById('paymentBox').classList.add('hidden'); document.getElementById('feedbackBox').classList.remove('hidden'); }
       };

       window.simulatePayment = async () => {
          if(!activeOrderId) return;
          const btn = document.querySelector('#paymentBox button');
          btn.innerText = "Processing Scan..."; btn.disabled = true;
          await fetch(`/api/v2/restaurant/qr-orders`, { method: 'PATCH', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ order_id: activeOrderId, status: 'paid' }) });
          renderTrackerSteps('paid', document.getElementById('liveTotal').innerText);
       };

       window.submitFeedback = () => { localStorage.removeItem('active_qr_order_' + table); window.location.reload(); };

       if (activeOrderId) showTracker();
       backgroundSync();
    </script>
</body>
</html>
