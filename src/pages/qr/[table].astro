---
export const prerender = false;
import "../../styles/restaurant.css";
const { table } = Astro.params;
---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Menu - Table {table}</title>
</head>
<body class="bg-[#111] text-white font-sans antialiased pb-24">
    
    <div id="app" class="max-w-md mx-auto relative min-h-screen">
        <!-- Header -->
        <header class="bg-[#222] p-5 sticky top-0 z-50 border-b border-[#333] flex justify-between items-center shadow-lg">
           <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-orange-500 rounded-xl flex items-center justify-center font-black italic text-xl">B</div>
              <div>
                  <h1 class="font-black italic uppercase leading-none">Grand Cafe Bobo</h1>
                  <p class="text-xs text-orange-400 font-bold uppercase tracking-widest mt-1">Table {table}</p>
              </div>
           </div>
           <button onclick="toggleCart()" class="relative p-2 bg-[#333] rounded-full">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
              <span id="cartBadge" class="absolute -top-1 -right-1 bg-rose-500 text-white text-[10px] font-black w-5 h-5 rounded-full flex items-center justify-center hidden">0</span>
           </button>
        </header>

        <!-- Dynamic Content Engine -->
        <div id="viewMenu" class="p-4 space-y-6">
           <!-- Rendered via JS -->
        </div>
        
        <!-- Live Status Tracking View -->
        <div id="viewTracker" class="hidden p-6">
            <h2 class="text-2xl font-black uppercase text-center mb-8 italic">Order Tracker</h2>
            <div class="space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-white/20 before:to-transparent">
                <!-- Status steps rendered via JS -->
            </div>
            
            <div id="paymentBox" class="hidden mt-12 bg-[#222] p-6 border border-[#333] rounded-2xl shadow-xl shadow-orange-500/10">
               <h3 class="text-xl font-black uppercase text-center mb-4">Total: ₹<span id="liveTotal">0</span></h3>
               <button onclick="simulatePayment()" class="w-full py-4 bg-gradient-to-r from-emerald-500 to-emerald-600 rounded-xl font-black uppercase tracking-widest active:scale-95 transition-all text-sm">Pay Securely</button>
            </div>
            
            <div id="feedbackBox" class="hidden mt-8 text-center animate-in fade-in zoom-in duration-500">
               <div class="text-emerald-500 text-6xl mb-4">🍽️</div>
               <h3 class="text-xl font-black uppercase mb-4">How was your meal?</h3>
               <div class="flex justify-center gap-4 mb-6">
                  <button class="text-4xl hover:scale-125 transition-transform" onclick="submitFeedback()">😞</button>
                  <button class="text-4xl hover:scale-125 transition-transform" onclick="submitFeedback()">😐</button>
                  <button class="text-4xl hover:scale-125 transition-transform" onclick="submitFeedback()">😋</button>
                  <button class="text-4xl hover:scale-125 transition-transform" onclick="submitFeedback()">😍</button>
               </div>
               <p class="text-xs text-white/40 uppercase font-black">Thank you for dining with us</p>
            </div>
        </div>

        <!-- Floating Cart Mini -->
        <div id="floatingCart" class="fixed bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-[#000] via-[#111] to-transparent z-50 transform translate-y-full transition-transform duration-300">
            <div class="max-w-md mx-auto bg-[#222] border border-[#333] rounded-3xl p-6 shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
               <div class="flex justify-between items-center mb-4 border-b border-[#333] pb-4">
                  <h3 class="font-black italic uppercase text-lg">Your Order</h3>
                  <button onclick="toggleCart()" class="text-white/40">Close</button>
               </div>
               <div id="cartItems" class="max-h-40 overflow-y-auto mb-4 space-y-3"></div>
               <div class="flex justify-between items-center font-black text-xl mb-6">
                  <span>TOTAL</span>
                  <span class="text-orange-400">₹<span id="cartTotal">0</span></span>
               </div>
               <button onclick="placeOrder()" class="w-full py-4 bg-orange-500 rounded-xl font-black uppercase tracking-widest shadow-lg shadow-orange-500/20 active:scale-95 transition-all">Send to Waiter</button>
            </div>
        </div>
    </div>

    <!-- Client Logic -->
    <script define:vars={{ table }}>
       let menuData = [];

       const fetchMenu = async () => {
          try {
             const res = await fetch('/api/v2/restaurant/menu');
             menuData = await res.json();
             if (activeOrderId) {
                showTracker();
             } else {
                renderMenu();
             }
          } catch (e) {
             console.error("Menu fetch failed:", e);
          }
       };

       let cart = [];
       let activeOrderId = localStorage.getItem('active_qr_order_' + table);

       const init = () => {
          if (activeOrderId) {
             showTracker();
          } else {
       const renderMenu = () => {
          const c = document.getElementById('viewMenu');
           c.innerHTML = menuData.map(item => `
              <div class="bg-[#222] border border-[#333] rounded-2xl overflow-hidden flex shadow-lg">
                 <img src="${item.image_url || 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=300'}" class="w-28 object-cover" />
                 <div class="p-4 flex-1 flex flex-col justify-between">
                    <div>
                       <h4 class="font-black uppercase leading-tight text-sm mb-1">${item.name}</h4>
                       <p class="text-[10px] text-white/50 leading-tight">${item.description || item.name}</p>
                    </div>
                    <div class="flex justify-between items-center mt-3">
                       <span class="text-orange-400 font-black">₹${item.price}</span>
                       <button onclick="addToCart(${item.id})" class="bg-[#333] hover:bg-orange-500 w-8 h-8 rounded-lg flex items-center justify-center font-black transition-colors">+</button>
                    </div>
                 </div>
              </div>
           `).join('');
       };

       const addToCart = (id) => {
          const item = menuData.find(i => i.id === id);
          const ext = cart.find(c => c.id === id);
          if(ext) ext.qty++;
          else cart.push({...item, qty:1});
          updateCartUI();
       };

       const updateCartUI = () => {
          const badge = document.getElementById('cartBadge');
          const totalQty = cart.reduce((acc, c)=>acc+c.qty, 0);
          if(totalQty > 0) {
             badge.classList.remove('hidden');
             badge.innerText = totalQty;
          } else {
             badge.classList.add('hidden');
          }

          const c = document.getElementById('cartItems');
          c.innerHTML = cart.map(i => `
             <div class="flex justify-between items-center text-sm font-bold border-b border-[#333] pb-2">
                <span>${i.name} (x${i.qty})</span>
                <span>₹${i.price * i.qty}</span>
             </div>
          `).join('');

          const total = cart.reduce((acc, c)=>acc + (c.price*c.qty), 0);
          document.getElementById('cartTotal').innerText = total;
       };

       const toggleCart = () => {
          if (cart.length === 0 && !document.getElementById('floatingCart').classList.contains('translate-y-0')) {
             return alert("Your basket is empty.");
          }
          const el = document.getElementById('floatingCart');
          el.classList.toggle('translate-y-full');
          el.classList.toggle('translate-y-0');
       };

       const placeOrder = async () => {
          toggleCart();
          const total = cart.reduce((acc, c)=>acc + (c.price*c.qty), 0);
          
          document.getElementById('viewMenu').classList.add('hidden');
          
          try {
              const res = await fetch('/api/v2/restaurant/qr-orders', {
                  method: 'POST',
                  headers: {'Content-Type': 'application/json'},
                  body: JSON.stringify({ table, items: cart, total })
              });
              const data = await res.json();
              if(data.success) {
                  activeOrderId = data.order_id;
                  localStorage.setItem('active_qr_order_' + table, activeOrderId);
                  showTracker();
              }
          } catch(err) {
              alert("Network error.");
              window.location.reload();
          }
       };

       // TRACKER SYSTEM
       const showTracker = () => {
          document.getElementById('viewMenu').classList.add('hidden');
          document.getElementById('viewTracker').classList.remove('hidden');
          pollStatus();
       };

       let pollInterval;
       const pollStatus = async () => {
          const fetchState = async () => {
              if(!activeOrderId) return;
              try {
                  const res = await fetch(`/api/v2/restaurant/qr-orders?order_id=${activeOrderId}`);
                  const { order } = await res.json();
                  if(order) renderTrackerSteps(order.status, order.total_amount);
              } catch(e) {}
          };
          fetchState();
          pollInterval = setInterval(fetchState, 3000); // Polling every 3s for native reactivity
       };

       const renderTrackerSteps = (status, total) => {
          document.getElementById('liveTotal').innerText = total || 0;
          
          const states = [
             { key: 'placed', label: 'Order Placed', desc: 'Waiting for waiter confirmation', icon: '📝' },
             { key: 'waiter_confirmed', label: 'Order Confirmed', desc: 'Waiter sent order to kitchen', icon: '👨‍🍳' },
             { key: 'kitchen_preparing', label: 'Preparing', desc: 'Chefs are cooking your meal', icon: '🔥' },
             { key: 'kitchen_ready', label: 'Ready to Serve', desc: 'Food is coming to your table', icon: '🛎️' },
             { key: 'served', label: 'Served', desc: 'Enjoy your meal!', icon: '✨' },
             { key: 'paid', label: 'Completed', desc: 'Thank you for dining.', icon: '❤️' }
          ];

          const currentIndex = states.findIndex(s => s.key === status);
          
          const c = document.querySelector('#viewTracker > .space-y-6');
          c.innerHTML = states.map((s, idx) => {
              const isPast = idx < currentIndex;
              const isCurrent = idx === currentIndex;
              const isFuture = idx > currentIndex;
              
              let color = isPast ? 'bg-emerald-500' : (isCurrent ? 'bg-orange-500 animate-pulse' : 'bg-[#333]');
              let textColor = isFuture ? 'text-white/30' : 'text-white';
              
              return `
              <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
                  <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-[#111] ${color} shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-xl z-10 text-lg">
                      ${s.icon}
                  </div>
                  <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-[#222] p-4 rounded-2xl border border-[#333] shadow-lg ${textColor}">
                      <h4 class="font-black uppercase text-sm">${s.label}</h4>
                      <p class="text-[10px] opacity-70 border-t border-white/5 pt-2 mt-2 font-bold">${s.desc}</p>
                  </div>
              </div>`
          }).join('');

          if (status === 'served') {
              document.getElementById('paymentBox').classList.remove('hidden');
          }
          
          if (status === 'paid') {
              clearInterval(pollInterval);
              document.getElementById('paymentBox').classList.add('hidden');
              document.getElementById('feedbackBox').classList.remove('hidden');
          }
       };

       const simulatePayment = async () => {
          if(!activeOrderId) return;
          const btn = document.querySelector('#paymentBox button');
          btn.innerText = "Processing...";
          
          await fetch('/api/v2/restaurant/qr-orders', {
             method: 'PATCH',
             headers: {'Content-Type':'application/json'},
             body: JSON.stringify({ order_id: activeOrderId, status: 'paid' })
          });
          
          // Next poll handles the UI shift
       };

       const submitFeedback = () => {
          alert("Thank you for your feedback! The QR session is now closed.");
          localStorage.removeItem('active_qr_order_' + table);
          window.location.reload();
       };

       fetchMenu();
    </script>
</body>
</html>
