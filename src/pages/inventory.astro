---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Inventory | Bobo Analytics">

<h1>Medicine Inventory</h1>

<table class="inventory">

<thead>
<tr>
<th>Medicine</th>
<th>Stock</th>
<th>Expiry</th>
</tr>
</thead>

<tbody>
<tr>
<td>Paracetamol</td>
<td>120</td>
<td>2027</td>
</tr>

<tr>
<td>Amoxicillin</td>
<td>80</td>
<td>2026</td>
</tr>

<tr>
<td>Ibuprofen</td>
<td>65</td>
<td>2025</td>
</tr>
</tbody>

</table>

<style>

.inventory{
width:100%;
margin-top:25px;
border-collapse:collapse;
}

.inventory th,
.inventory td{
padding:12px;
border-bottom:1px solid #333;
}

</style>

</MainLayout>