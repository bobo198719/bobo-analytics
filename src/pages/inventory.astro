---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Pharmacy Inventory">

<section class="inventory-container">

<h1>Pharmacy Inventory Management</h1>

<div class="inventory-form">

<input id="medicine" placeholder="Medicine Name" />

<input id="stock" type="number" placeholder="Stock Quantity" />

<input id="expiry" type="date" />

<button onclick="addMedicine()">Add Medicine</button>

</div>

<table class="inventory-table">

<thead>
<tr>
<th>Medicine</th>
<th>Stock</th>
<th>Expiry</th>
</tr>
</thead>

<tbody id="inventoryTable"></tbody>

</table>

</section>

<style>

.inventory-container{
padding:40px;
max-width:1000px;
margin:auto;
color:white;
}

.inventory-form{
display:flex;
gap:10px;
margin-bottom:30px;
flex-wrap:wrap;
}

.inventory-form input{
padding:10px;
border-radius:6px;
border:none;
min-width:180px;
}

.inventory-form button{
background:#00ff88;
border:none;
padding:10px 20px;
border-radius:6px;
cursor:pointer;
font-weight:bold;
}

.inventory-table{
width:100%;
border-collapse:collapse;
background:#111;
}

.inventory-table th,
.inventory-table td{
padding:12px;
border-bottom:1px solid #333;
text-align:left;
}

.inventory-table th{
color:#00ff88;
}

</style>

<script>

const API_URL="http://localhost:5000/api/inventory";

async function loadInventory(){

try{

const res=await fetch(API_URL+"?pharmacyId=abc001");

const data=await res.json();

const table=document.getElementById("inventoryTable");

table.innerHTML="";

data.forEach(item=>{

table.innerHTML+=`

<tr>

<td>${item.medicine}</td>

<td>${item.stock}</td>

<td>${item.expiry}</td>

</tr>

`;

});

}catch(err){

console.error("Inventory error",err);

}

}

async function addMedicine(){

const medicine=document.getElementById("medicine").value;

const stock=document.getElementById("stock").value;

const expiry=document.getElementById("expiry").value;

if(!medicine || !stock || !expiry){

alert("Please fill all fields");

return;

}

await fetch(API_URL,{

method:"POST",

headers:{

"Content-Type":"application/json"

},

body:JSON.stringify({

pharmacyId:"abc001",

medicine,

stock,

expiry

})

});

loadInventory();

document.getElementById("medicine").value="";
document.getElementById("stock").value="";
document.getElementById("expiry").value="";

}

loadInventory();

</script>

</MainLayout>
