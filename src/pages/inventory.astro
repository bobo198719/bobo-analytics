---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Inventory">

<div class="inventory-page">

<h1>Pharmacy Inventory</h1>

<p>Manage medicines, stock levels and expiry dates.</p>

<table>

<thead>
<tr>
<th>Medicine</th>
<th>Stock</th>
<th>Expiry</th>
</tr>
</thead>

<tbody id="inventoryTable">

<tr>
<td>Paracetamol</td>
<td>200</td>
<td>2026-08-10</td>
</tr>

<tr>
<td>Omeprazole</td>
<td>120</td>
<td>2026-05-02</td>
</tr>

<tr>
<td>Metformin</td>
<td>90</td>
<td>2026-04-18</td>
</tr>

</tbody>

</table>

</div>

<style>

.inventory-page{
padding:40px;
background:#0a0a0a;
color:white;
min-height:100vh;
}

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
background:#111;
}

th,td{
padding:12px;
border-bottom:1px solid #333;
}

th{
background:#1a1a1a;
}

</style>

</MainLayout>
