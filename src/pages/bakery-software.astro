---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Bakery Management Software | Bobo Analytics">
    <div style="padding: 100px 20px; max-width: 800px; margin: auto;">
        <h1 style="font-size: 3rem; margin-bottom: 20px; color: var(--accent-color);">Bakery Management Software</h1>
        <p style="font-size: 1.25rem; margin-bottom: 40px; color: #a0aec0;">Run your bakery business with ease. Track orders, manage custom cakes, and handle deliveries in one place.</p>
        
        <div style="background: rgba(255,255,255,0.05); padding: 40px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1);">
            <h2 style="margin-bottom: 20px;">Key Features</h2>
            <ul style="list-style: none; padding: 0;">
                <li style="margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                    <span style="color: #10b981;">✔</span> Order Management
                </li>
                <li style="margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                    <span style="color: #10b981;">✔</span> Custom Cake Builder
                </li>
                <li style="margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                    <span style="color: #10b981;">✔</span> Delivery Scheduling
                </li>
                <li style="margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                    <span style="color: #10b981;">✔</span> WhatsApp Integration
                </li>
            </ul>
            
            <a href="/login" style="display: inline-block; margin-top: 30px; background: var(--accent-color); color: white; padding: 15px 40px; border-radius: 12px; font-weight: 800; text-decoration: none;">Start Free Trial</a>
        </div>
    </div>
</MainLayout>
