---

import MainLayout from "../layouts/MainLayout.astro";

<MainLayout title="Retailer Bill Scanner"><div class="scanner"><h1>Retailer Bill Scanner</h1><p>Upload retailer bill photo or PDF</p><input type="file" id="billUpload" accept="image/*,.pdf"><button onclick="scanBill()">Scan Bill</button>

<div id="result"></div><a href="/pharmacy-dashboard">
<button>Back to Dashboard</button>
</a></div><style>

.scanner{
text-align:center;
padding:40px;
background:#0a0a0a;
min-height:100vh;
color:white;
}

input{
margin-top:20px;
}

button{
margin-top:20px;
padding:12px 20px;
background:#00ff88;
border:none;
border-radius:6px;
cursor:pointer;
}

#result{
margin-top:30px;
background:#111;
padding:20px;
border-radius:8px;
}

</style><script>

function scanBill(){

const file=document.getElementById("billUpload").files[0]

if(!file){
alert("Upload a bill first")
return
}

const reader=new FileReader()

reader.onload=function(){

const text="Paracetamol 50\nOmeprazole 30\nMetformin 40"

showResult(text)

}

reader.readAsDataURL(file)

}

function showResult(text){

const lines=text.split("\n")

let html="<h2>Detected Medicines</h2><ul>"

lines.forEach(l=>{
html+="<li>"+l+"</li>"
})

html+="</ul>"

document.getElementById("result").innerHTML=html

}

</script></MainLayout>