---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Offline - Bobo Analytics" hideNav={true}>
  <div class="offline-container">
    <div class="offline-content">
      <div class="offline-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 19.07 1.41-1.41"></path>
          <path d="m17.66 6.34 1.41-1.41"></path>
          <circle cx="12" cy="12" r="4"></circle>
          <line x1="2" y1="2" x2="22" y2="22" stroke="#ef4444" stroke-width="2"></line>
        </svg>
      </div>
      
      <h1>You're Offline</h1>
      <p>It looks like you've lost your internet connection. Don't worry, some features are still available offline.</p>
      
      <div class="offline-actions">
        <button onclick="window.location.reload()" class="btn-primary">
          Try Again
        </button>
        <a href="/" class="btn-secondary">
          Go to Home
        </a>
      </div>
      
      <div class="offline-tips">
        <h3>While you're offline, you can:</h3>
        <ul>
          <li>View cached pages you've visited before</li>
          <li>Access your saved data</li>
          <li>Continue working - your changes will sync when you're back online</li>
        </ul>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .offline-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: radial-gradient(circle at center, rgba(99, 102, 241, 0.1) 0%, transparent 60%);
  }

  .offline-content {
    max-width: 500px;
    text-align: center;
  }

  .offline-icon {
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 32px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.05); }
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 16px;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .offline-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-bottom: 48px;
  }

  .btn-primary {
    background: linear-gradient(135deg, #6366f1, #a855f7);
    color: white;
    padding: 14px 28px;
    border-radius: 10px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: white;
    padding: 14px 28px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.2s ease;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .offline-tips {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 24px;
    border-radius: 16px;
    text-align: left;
  }

  .offline-tips h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 16px;
    color: rgba(255, 255, 255, 0.9);
  }

  .offline-tips ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .offline-tips li {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.95rem;
    padding: 8px 0;
    padding-left: 24px;
    position: relative;
  }

  .offline-tips li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #10b981;
  }

  @media (max-width: 480px) {
    .offline-actions {
      flex-direction: column;
    }
  }
</style>
