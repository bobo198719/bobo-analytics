<script>
  const PLANS = {
    starter: { name: 'Starter', monthly: 999, annual: 799 },
    growth:  { name: 'Growth',  monthly: 1999, annual: 1599 },
    pro:     { name: 'Pro',     monthly: 2999, annual: 2399 },
  };

  // Razorpay Key — Replace with your live key when going live
  const RAZORPAY_KEY = 'rzp_test_YOUR_KEY_HERE';

  let currentBilling = 'monthly';
  let selectedPlan = null;

  // ── BILLING TOGGLE ──────────────────────────────
  function setBilling(type) {
    currentBilling = type;
    const mb = document.getElementById('monthly-btn');
    const ab = document.getElementById('annual-btn');
    const active = 'background:linear-gradient(135deg,#f97316,#e11d48);color:white;';
    const inactive = 'background:transparent;color:rgba(255,255,255,0.4);';
    mb.style.cssText += type==='monthly' ? active : inactive;
    ab.style.cssText += type==='annual' ? active : inactive;
    updatePrices();
  }

  function updatePrices() {
    Object.entries(PLANS).forEach(([key, plan]) => {
      const price = currentBilling === 'annual' ? plan.annual : plan.monthly;
      const el = document.getElementById(key + '-price');
      if (el) el.textContent = price;
    });
    document.querySelectorAll('.starter-price-tag').forEach(e => e.textContent = currentBilling==='annual' ? PLANS.starter.annual : PLANS.starter.monthly);
    document.querySelectorAll('.growth-price-tag').forEach(e => e.textContent = currentBilling==='annual' ? PLANS.growth.annual : PLANS.growth.monthly);
    document.querySelectorAll('.pro-price-tag').forEach(e => e.textContent = currentBilling==='annual' ? PLANS.pro.annual : PLANS.pro.monthly);
  }

  // ── TRIAL START ──────────────────────────────────
  function startTrial(planKey) {
    // Check if already logged in
    const auth = localStorage.getItem('restaurant_auth');
    if (auth === 'true') {
      activateTrial(planKey);
    } else {
      // Show signup/payment modal
      selectedPlan = planKey;
      openPaymentModal(planKey, true);
    }
  }

  function activateTrial(planKey) {
    const trialExpiry = Date.now() + (7 * 24 * 60 * 60 * 1000); // 7 days
    localStorage.setItem('restaurant_auth', 'true');
    localStorage.setItem('restaurant_plan', planKey);
    localStorage.setItem('subscription_status', 'trial');
    localStorage.setItem('trial_expiry', trialExpiry.toString());
    localStorage.setItem('subscription_expiry', trialExpiry.toString());
    showToast('✅ 7-day trial activated for ' + PLANS[planKey].name + ' plan!');
    setTimeout(() => window.location.href = '/restaurant-dashboard', 1500);
  }

  // ── PAYMENT MODAL ────────────────────────────────
  let isTrialFlow = false;

  function openPaymentModal(planKey, isTrial = false) {
    selectedPlan = planKey;
    isTrialFlow = isTrial;
    const plan = PLANS[planKey];
    const price = currentBilling === 'annual' ? plan.annual : plan.monthly;
    document.getElementById('payment-modal').style.display = 'flex';
    document.getElementById('modal-plan-label').textContent = plan.name + ' · ' + (currentBilling === 'annual' ? 'Annual' : 'Monthly');
    document.getElementById('modal-plan-name').textContent = plan.name;
    document.getElementById('modal-billing-cycle').textContent = currentBilling === 'annual' ? 'Annual (billed yearly)' : 'Monthly';
    document.getElementById('modal-amount').textContent = '₹' + price + (currentBilling === 'annual' ? '/mo (₹' + (price*12) + '/yr)' : '/month');

    if (isTrial) {
      document.getElementById('pay-now-btn').textContent = 'Start Free Trial →';
      document.getElementById('pay-now-btn').onclick = () => {
        const name = document.getElementById('pay-restaurant-name').value.trim();
        const email = document.getElementById('pay-email').value.trim();
        if (!name || !email) { showToast('❌ Please fill restaurant name and email'); return; }
        localStorage.setItem('restaurant_name', name);
        localStorage.setItem('restaurant_email', email);
        localStorage.setItem('restaurant_phone', document.getElementById('pay-phone').value.trim());
        closePaymentModal();
        activateTrial(planKey);
      };
    } else {
      document.getElementById('pay-now-btn').textContent = 'Pay Now →';
      document.getElementById('pay-now-btn').onclick = proceedToPayment;
    }
  }

  function closePaymentModal() {
    document.getElementById('payment-modal').style.display = 'none';
  }

  // ── RAZORPAY PAYMENT ─────────────────────────────
  async function proceedToPayment() {
    const name = document.getElementById('pay-restaurant-name').value.trim();
    const email = document.getElementById('pay-email').value.trim();
    const phone = document.getElementById('pay-phone').value.trim();
    if (!name || !email) { showToast('❌ Please fill restaurant name and email'); return; }

    const plan = PLANS[selectedPlan];
    const amount = currentBilling === 'annual' ? plan.annual * 12 : plan.monthly;

    const btn = document.getElementById('pay-now-btn');
    btn.textContent = 'Creating Order...';
    btn.disabled = true;

    try {
      // Create Razorpay order via our API
      const res = await fetch('/api/create-payment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plan: selectedPlan, amount, billing: currentBilling, email, name, phone })
      });
      const order = await res.json();

      const options = {
        key: RAZORPAY_KEY,
        amount: amount * 100, // paise
        currency: 'INR',
        name: 'Bobo Restaurant OS',
        description: plan.name + ' Plan — ' + currentBilling,
        image: 'https://bobo-analytics.vercel.app/favicon.ico',
        order_id: order.razorpay_order_id || undefined,
        prefill: { name, email, contact: phone },
        theme: { color: '#f97316' },
        handler: async (response) => {
          // Verify payment
          await fetch('/api/verify-payment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ...response, plan: selectedPlan, billing: currentBilling, email, name, phone })
          });
          // Activate subscription locally
          activateSubscription(selectedPlan, response.razorpay_payment_id);
        },
        modal: {
          ondismiss: () => {
            btn.textContent = 'Pay Now →';
            btn.disabled = false;
          }
        }
      };

      const rzp = new Razorpay(options);
      rzp.open();
      closePaymentModal();
    } catch(e) {
      console.error(e);
      // Demo mode — activate without payment when Razorpay key not set
      if (RAZORPAY_KEY.includes('YOUR_KEY') || RAZORPAY_KEY === '') {
        showToast('⚡ Demo Mode: Activating subscription (add Razorpay key for live payments)');
        activateSubscription(selectedPlan, 'DEMO_' + Date.now());
        closePaymentModal();
      } else {
        showToast('❌ Payment failed. Please try again.');
      }
    }
    btn.textContent = 'Pay Now →';
    btn.disabled = false;
  }

  function activateSubscription(planKey, paymentId) {
    const expiry = Date.now() + (30 * 24 * 60 * 60 * 1000); // 30 days
    localStorage.setItem('restaurant_auth', 'true');
    localStorage.setItem('restaurant_plan', planKey);
    localStorage.setItem('subscription_status', 'active');
    localStorage.setItem('subscription_expiry', expiry.toString());
    localStorage.setItem('last_payment_id', paymentId);
    // Save payment history
    const history = JSON.parse(localStorage.getItem('payment_history') || '[]');
    history.push({ id: paymentId, plan: planKey, amount: PLANS[planKey][currentBilling], date: new Date().toISOString(), status: 'paid' });
    localStorage.setItem('payment_history', JSON.stringify(history));
    showToast('🎉 Subscription activated! Redirecting...');
    setTimeout(() => window.location.href = '/restaurant-dashboard', 1800);
  }

  // ── TOAST ────────────────────────────────────────
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3500);
  }

  // ── COMPARISON TABLE ─────────────────────────────
  const compareRows = [
    ['POS Terminal', true, true, true],
    ['Dashboard & Analytics', true, true, true],
    ['Menu Hub', true, true, true],
    ['Max Tables', '5', '15', 'Unlimited'],
    ['Kitchen Display (KDS)', false, true, true],
    ['QR Ordering', false, true, true],
    ['Smart Menu Upload (AI)', false, true, true],
    ['Customer CRM', false, true, true],
    ['Multi-location', false, false, true],
    ['Custom Branding', false, false, true],
    ['API Access', false, false, true],
    ['Priority Support', false, false, true],
    ['White-label Reports', false, false, true],
  ];

  const tbody = document.getElementById('compare-body');
  compareRows.forEach(([feat, s, g, p]) => {
    const cell = (v, clr) => {
      if (v === true) return `<td style="text-align:center;padding:14px;"><span style="color:#10b981;font-size:18px;">✓</span></td>`;
      if (v === false) return `<td style="text-align:center;padding:14px;color:rgba(255,255,255,0.15);font-size:18px;">—</td>`;
      return `<td style="text-align:center;padding:14px;font-weight:800;color:${clr};">${v}</td>`;
    };
    tbody.innerHTML += `<tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
      <td style="padding:14px;font-size:13px;font-weight:600;color:rgba(255,255,255,0.6);">${feat}</td>
      ${cell(s,'rgba(255,255,255,0.6)')}${cell(g,'#f97316')}${cell(p,'#a855f7')}
    </tr>`;
  });

  // ── FAQ ──────────────────────────────────────────
  const faqs = [
    ['Do I need a credit card to start the trial?', 'No! Your 7-day free trial starts instantly with just your restaurant name and email. No payment info required.'],
    ['Can I switch plans later?', 'Yes, you can upgrade or downgrade your plan at any time from the Billing section in your dashboard.'],
    ['What payment methods do you accept?', 'We accept all major credit/debit cards, UPI (Google Pay, PhonePe, Paytm), net banking, and wallets via Razorpay.'],
    ['Is my data secure?', 'Absolutely. All data is encrypted in transit (SSL) and at rest. Razorpay handles all payment processing — we never store card details.'],
    ['What happens when my subscription expires?', 'Your account is locked (read-only). You can still view your data but POS and Kitchen operations are paused until you renew.'],
    ['Can multiple staff use the same account?', 'Yes! All plans support unlimited staff logins under a single restaurant account.'],
    ['Do you offer refunds?', 'We offer a full refund within 7 days of payment if you\'re not satisfied. Contact support@bobo.com.'],
  ];

  const faqList = document.getElementById('faq-list');
  faqs.forEach(([q, a]) => {
    faqList.innerHTML += `<div class="faq-item" onclick="this.classList.toggle('open')">
      <div class="faq-q">${q}<span class="faq-arrow" style="font-size:18px;color:rgba(255,255,255,0.3);">▾</span></div>
      <div class="faq-a">${a}</div>
    </div>`;
  });

  // Check if already has active subscription
  const status = localStorage.getItem('subscription_status');
  if (status === 'active') {
    showToast('You already have an active subscription!');
  }

  // Pulse animation
  const style = document.createElement('style');
  style.textContent = '@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}';
  document.head.appendChild(style);
</script>

</body>
</html>
