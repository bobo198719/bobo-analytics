<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Restaurant OS Pricing | Bobo SaaS</title>
  <meta name="description" content="Choose the perfect plan for your restaurant. Start with a 7-day free trial."/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700;1,800;1,900&display=swap" rel="stylesheet"/>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    html,body{background:#05081a;color:white;font-family:'Plus Jakarta Sans',sans-serif;min-height:100vh;}
    ::-webkit-scrollbar{width:4px} ::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:4px}
    .plan-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:32px;padding:40px;transition:all 0.3s;position:relative;overflow:hidden;}
    .plan-card.popular{background:rgba(249,115,22,0.06);border-color:rgba(249,115,22,0.3);transform:scale(1.03);}
    .plan-card:hover{border-color:rgba(249,115,22,0.4);background:rgba(249,115,22,0.05);}
    .feature-item{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:13px;color:rgba(255,255,255,0.7);font-weight:600;}
    .feature-item:last-child{border-bottom:none;}
    .check{width:20px;height:20px;border-radius:50%;background:linear-gradient(135deg,#10b981,#059669);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;}
    .cross{width:20px;height:20px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;opacity:0.4;}
    .btn-primary{width:100%;padding:16px;border:none;border-radius:20px;font-size:14px;font-weight:900;font-style:italic;text-transform:uppercase;letter-spacing:0.05em;cursor:pointer;transition:all 0.2s;}
    .btn-orange{background:linear-gradient(135deg,#f97316,#e11d48);color:white;box-shadow:0 8px 32px rgba(249,115,22,0.35);}
    .btn-orange:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(249,115,22,0.5);}
    .btn-outline{background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.7);border:1px solid rgba(255,255,255,0.15);}
    .btn-outline:hover{background:rgba(255,255,255,0.1);color:white;}
    .badge{display:inline-block;padding:4px 12px;border-radius:50px;font-size:10px;font-weight:900;text-transform:uppercase;letter-spacing:0.1em;}
    .toast{position:fixed;top:24px;right:24px;z-index:9999;background:#0f172a;border:1px solid rgba(249,115,22,0.4);border-radius:16px;padding:16px 24px;font-size:13px;font-weight:700;color:white;transform:translateY(-80px);transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1);max-width:320px;}
    .toast.show{transform:translateY(0);}
    .faq-item{border-bottom:1px solid rgba(255,255,255,0.07);padding:20px 0;}
    .faq-q{font-size:15px;font-weight:800;cursor:pointer;display:flex;justify-content:space-between;align-items:center;}
    .faq-a{font-size:13px;color:rgba(255,255,255,0.5);margin-top:12px;line-height:1.7;display:none;}
    .faq-item.open .faq-a{display:block;}
    .faq-item.open .faq-arrow{transform:rotate(180deg);}
    .faq-arrow{transition:transform 0.2s;}
  </style>
</head>
<body>

<!-- Toast -->
<div id="toast" class="toast"></div>

