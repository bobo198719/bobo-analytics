---
// Restaurant Pricing Page — Module 8 (Matrix V3.5)
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Bobo OS Enterprise Planning | Free Forever Matrix</title>
  <meta name="description" content="Scale your restaurant with the world's most powerful OS. All plans are currently free for early adopters."/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700;1,800;1,900&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0; -webkit-tap-highlight-color: transparent;}
    html,body{background:#05081a;color:white;font-family:'Plus Jakarta Sans',sans-serif;min-height:100vh; overflow-x: hidden;}
    ::-webkit-scrollbar{width:4px} ::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:4px}
    
    .plan-card{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:32px;padding:40px;transition:all 0.4s cubic-bezier(0.4, 0, 0.2, 1);position:relative;overflow:hidden; display: flex; flex-direction: column;}
    .plan-card.popular{background:rgba(249,115,22,0.04);border-color:rgba(249,115,22,0.25);transform:scale(1.05); z-index: 10;}
    .plan-card:hover{border-color:rgba(249,115,22,0.4);background:rgba(255,255,255,0.05); transform: translateY(-8px);}
    .plan-card.popular:hover { transform: scale(1.06) translateY(-8px); }

    .feature-item{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:12px;color:rgba(255,255,255,0.5);font-weight:700; text-transform: uppercase; letter-spacing: 0.05em;}
    .feature-item:last-child{border-bottom:none;}
    .check{width:22px;height:22px;border-radius:50%;background:linear-gradient(135deg,#10b981,#059669);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px; box-shadow: 0 4px 10px rgba(16,185,129,0.2);}
    .cross{width:22px;height:22px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;opacity:0.3;}
    
    .btn-primary{width:100%;padding:20px;border:none;border-radius:24px;font-size:13px;font-weight:900;font-style:italic;text-transform:uppercase;letter-spacing:0.1em;cursor:pointer;transition:all 0.3s cubic-bezier(0.4, 0, 0.2, 1); margin-top: auto;}
    .btn-orange{background:linear-gradient(135deg,#f97316,#fb923c);color:white;box-shadow:0 12px 30px rgba(249,115,22,0.2); position: relative; overflow: hidden;}
    .btn-orange:hover{transform:scale(1.02); box-shadow: 0 15px 40px rgba(249,115,22,0.4);}
    .btn-outline{background:rgba(255,255,255,0.03);color:rgba(255,255,255,0.4);border:1px solid rgba(255,255,255,0.1); font-weight: 800;}
    .btn-outline:hover{background:rgba(255,255,255,0.08); color:white; border-color: white/20;}
    
    .badge{display:inline-block;padding:6px 14px;border-radius:50px;font-size:9px;font-weight:900;text-transform:uppercase;letter-spacing:0.2em; font-style: italic;}
    .price-tag { font-size:48px; font-weight:900; font-style:italic; letter-spacing:-0.04em; background: linear-gradient(180deg, #fff 0%, rgba(255,255,255,0.6) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    
    .toast{position:fixed;bottom:24px;right:24px;z-index:9999;background:rgba(15,23,42,0.95);backdrop-filter:blur(20px);border:1px solid rgba(249,115,22,0.3);border-radius:20px;padding:18px 28px;font-size:13px;font-weight:700;color:white;transform:translateY(120px);transition:transform 0.5s cubic-bezier(0.34,1.56,0.64,1);box-shadow: 0 20px 40px rgba(0,0,0,0.4);}
    .toast.show{transform:translateY(0);}

    @keyframes pulse-glow { 0%,100% { opacity: 0.3; } 50% { opacity: 0.6; } }
    .glow-overlay { position: absolute; inset: 0; background: radial-gradient(circle at center, #f97316 0%, transparent 70%); opacity: 0.1; pointer-events: none; animation: pulse-glow 3s infinite; }
  </style>
</head>
<body>

<div id="toast" class="toast"></div>

<!-- MATRIX HERO -->
<section style="text-align:center;padding:100px 24px 80px;position:relative;">
  <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:1000px;height:400px;background:radial-gradient(ellipse,rgba(249,115,22,0.12) 0%,transparent 70%);pointer-events:none; filter: blur(40px);"></div>
  
  <div style="display:inline-flex;align-items:center;gap:12px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:50px;padding:8px 24px;margin-bottom:32px;">
    <span style="width:10px;height:10px;border-radius:50%;background:#10b981;box-shadow: 0 0 15px #10b981; display:inline-block;"></span>
    <span style="font-size:11px;font-weight:900;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:0.3em; font-style: italic;">Public Enterprise Beta Active</span>
  </div>

  <h1 style="font-size:clamp(40px,8vw,80px);font-weight:900;font-style:italic;text-transform:uppercase;letter-spacing:-0.05em;line-height:0.9;margin-bottom:24px;">
    Enterprise Scale.<br/><span style="background:linear-gradient(135deg,#f97316,#e11d48);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Zero Friction.</span>
  </h1>
  <p style="font-size:18px;color:rgba(255,255,255,0.4);font-weight:600;max-width:550px;margin:0 auto 48px; line-height: 1.6;">
    The world's most powerful Restaurant OS is currently open for everyone. Select your protocol and begin the digital transformation today.
  </p>

  <div style="display:inline-flex; gap:12px; margin-bottom: 60px;">
    <div style="padding:10px 20px; background:rgba(249,115,22,0.1); border:1px solid rgba(249,115,22,0.2); border-radius:16px;">
        <p style="font-size:10px; font-weight:900; text-transform:uppercase; color:#f97316; letter-spacing:0.1em;">Current Global Price</p>
        <p style="font-size:18px; font-weight:900; font-style:italic;">₹0 / Lifetime Free</p>
    </div>
  </div>
</section>

<!-- PLAN GRID -->
<section style="max-width:1200px;margin:0 auto;padding:0 24px 100px;display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:32px;align-items:stretch;">

  <!-- STARTER NODE -->
  <div class="plan-card">
    <div style="margin-bottom:32px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 24px;">
      <span class="badge" style="background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.4);margin-bottom:16px;">Starter Node</span>
      <div class="price-tag">₹0</div>
      <p style="font-size:13px;color:rgba(255,255,255,0.3);font-weight:700; margin-top: 8px;">For small diners looking for digital speed.</p>
    </div>
    
    <div style="margin-bottom:40px;">
      <div class="feature-item"><div class="check">✓</div>1 Restaurant Location</div>
      <div class="feature-item"><div class="check">✓</div>Basic POS Terminal</div>
      <div class="feature-item"><div class="check">✓</div>Table Management (10 Tables)</div>
      <div class="feature-item"><div class="check">✓</div>Manual Menu Synchronization</div>
      <div class="feature-item"><div class="check">✓</div>Digital GST Billing</div>
      <div class="feature-item"><div class="check">✓</div>Standard Yield Reports</div>
      <div class="feature-item"><div class="cross">✕</div><span style="opacity:0.3;">Kitchen Display (KDS)</span></div>
      <div class="feature-item"><div class="cross">✕</div><span style="opacity:0.3;">QR Table Ordering</span></div>
      <div class="feature-item"><div class="cross">✕</div><span style="opacity:0.3;">Smart AI Menu Upload</span></div>
    </div>
    
    <button class="btn-primary btn-outline" onclick="activateMatrix('starter')">Deploy Starter Node →</button>
  </div>

  <!-- GROWTH PROTOCOL -->
  <div class="plan-card popular">
    <div class="glow-overlay"></div>
    <div style="position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,#f97316,#e11d48);"></div>
    <div style="position:absolute;top:20px;right:24px;">
      <span class="badge" style="background:rgba(249,115,22,0.15);color:#f97316;border:1px solid rgba(249,115,22,0.3);">🔥 Recommended</span>
    </div>

    <div style="margin-bottom:32px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 24px;">
      <span class="badge" style="background:linear-gradient(135deg,#f97316,#e11d48);color:white;margin-bottom:16px;">Growth Protocol</span>
      <div class="price-tag" style="background:linear-gradient(180deg,#fff 0%,#f97316 100%); -webkit-background-clip:text;">₹0</div>
      <p style="font-size:13px;color:rgba(255,255,255,0.4);font-weight:700; margin-top: 8px;">The standard for modern restaurant chains.</p>
    </div>

    <div style="margin-bottom:40px;">
      <div class="feature-item"><div class="check">✓</div>Up to 5 Restaurant Locations</div>
      <div class="feature-item"><div class="check">✓</div>**Kitchen Display Hub (KDS)**</div>
      <div class="feature-item"><div class="check">✓</div>**UHD QR Table Ordering**</div>
      <div class="feature-item"><div class="check">✓</div>Smart AI Menu Uploads</div>
      <div class="feature-item"><div class="check">✓</div>Advanced Revenue Dashboards</div>
      <div class="feature-item"><div class="check">✓</div>GST Taxation Intelligence</div>
      <div class="feature-item"><div class="check">✓</div>30 Table Matrix Support</div>
      <div class="feature-item"><div class="check">✓</div>Customer Order Tracking</div>
      <div class="feature-item"><div class="cross">✕</div><span style="opacity:0.3;">Unlimited Everything</span></div>
    </div>

    <button class="btn-primary btn-orange" onclick="activateMatrix('growth')">Deploy Growth Protocol →</button>
  </div>

  <!-- MATRIX ENTERPRISE -->
  <div class="plan-card">
    <div style="margin-bottom:32px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 24px;">
      <span class="badge" style="background:rgba(168,85,247,0.1);color:#a855f7;border:1px solid rgba(168,85,247,0.3);margin-bottom:16px;">Matrix Enterprise</span>
      <div class="price-tag" style="background:linear-gradient(180deg,#fff 0%,#a855f7 100%); -webkit-background-clip:text;">₹0</div>
      <p style="font-size:13px;color:rgba(255,255,255,0.3);font-weight:700; margin-top: 8px;">Infinite scale for global food empires.</p>
    </div>

    <div style="margin-bottom:40px;">
      <div class="feature-item"><div class="check" style="background:linear-gradient(135deg,#a855f7,#6366f1);">✓</div>**Unlimited Restaurant Branches**</div>
      <div class="feature-item"><div class="check" style="background:linear-gradient(135deg,#a855f7,#6366f1);">✓</div>Unlimited Tables & Staff Logins</div>
      <div class="feature-item"><div class="check" style="background:linear-gradient(135deg,#a855f7,#6366f1);">✓</div>**Global Staff Governance Matrix**</div>
      <div class="feature-item"><div class="check" style="background:linear-gradient(135deg,#a855f7,#6366f1);">✓</div>Advanced Yield & Profit Projections</div>
      <div class="feature-item"><div class="check" style="background:linear-gradient(135deg,#a855f7,#6366f1);">✓</div>Custom Branding (Logo & Identity)</div>
      <div class="feature-item"><div class="check" style="background:linear-gradient(135deg,#a855f7,#6366f1);">✓</div>Full API Infrastructure Access</div>
      <div class="feature-item"><div class="check" style="background:linear-gradient(135deg,#a855f7,#6366f1);">✓</div>Priority 24/7 Matrix Shield Support</div>
      <div class="feature-item"><div class="check" style="background:linear-gradient(135deg,#a855f7,#6366f1);">✓</div>White-label Operational Reports</div>
    </div>

    <button class="btn-primary" style="background:linear-gradient(135deg,#a855f7,#6366f1);color:white;box-shadow:0 12px 30px rgba(168,85,247,0.25);" onclick="activateMatrix('enterprise')">Deploy Matrix Enterprise →</button>
  </div>

</section>

<!-- COMPARISON MATRIX -->
<section style="max-width:1000px;margin:0 auto 100px;padding:0 24px;">
  <h2 style="text-align:center;font-size:36px;font-weight:900;font-style:italic;text-transform:uppercase;margin-bottom:48px; letter-spacing: -0.02em;">Technical <span style="color:#f97316;">Matrix</span> Specs</h2>
  <div style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.06); border-radius:32px; overflow:hidden;">
    <table style="width:100%;border-collapse:collapse;font-size:12px;">
      <thead>
        <tr style="background:rgba(255,255,255,0.03); border-bottom:1px solid rgba(255,255,255,0.08);">
          <th style="text-align:left;padding:24px;color:rgba(255,255,255,0.4);text-transform:uppercase;font-weight:900;letter-spacing:0.1em;">Specification</th>
          <th style="text-align:center;padding:24px;font-weight:900;">Starter</th>
          <th style="text-align:center;padding:24px;font-weight:900; color:#f97316;">Growth</th>
          <th style="text-align:center;padding:24px;font-weight:900; color:#a855f7;">Enterprise</th>
        </tr>
      </thead>
      <tbody id="compare-matrix-body"></tbody>
    </table>
  </div>
</section>

<!-- TESTIMONIALS -->
<section style="max-width:900px;margin:0 auto 120px;padding:0 24px; text-align:center;">
    <p style="font-size:14px; font-weight:800; color:#f97316; text-transform:uppercase; letter-spacing:0.2em; margin-bottom:16px;">Modern Power</p>
    <h2 style="font-size:32px; font-weight:900; margin-bottom:48px; font-style:italic;">Trusted by 500+ <span style="color:rgba(255,255,255,0.4);">Scale-Driven</span> Restaurants</h2>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:40px;">
        <div>
            <p style="font-size:32px; font-weight:900; color:white;">99.9%</p>
            <p style="font-size:10px; font-weight:800; color:rgba(255,255,255,0.3); text-transform:uppercase; margin-top:4px;">Uptime Shield</p>
        </div>
        <div>
            <p style="font-size:32px; font-weight:900; color:white;">2min</p>
            <p style="font-size:10px; font-weight:800; color:rgba(255,255,255,0.3); text-transform:uppercase; margin-top:4px;">Instant Setup</p>
        </div>
        <div>
            <p style="font-size:32px; font-weight:900; color:white;">2x</p>
            <p style="font-size:10px; font-weight:800; color:rgba(255,255,255,0.3); text-transform:uppercase; margin-top:4px;">Yield Optimization</p>
        </div>
    </div>
</section>

<script is:inline>
  const compareData = [
    ['POS Matrix Terminal', true, true, true],
    ['Kitchen Display Hub (KDS)', false, true, true],
    ['UHD QR Ordering', false, true, true],
    ['Smart AI Menu Sync', false, true, true],
    ['Max Tables Support', '10', '30', 'Unlimited'],
    ['Branch Multi-Sync', '1 Node', '5 Nodes', 'Infinite'],
    ['GST Intelligence', true, true, true],
    ['Advanced Staff Lockdown', false, true, true],
    ['Global Governance Matrix', false, false, true],
    ['Yield Projections', false, true, true],
    ['API Infrastructure', false, false, true],
    ['Matrix Shield Support', 'Standard', 'Priority', '24/7 Dedicated'],
  ];

  const tbody = document.getElementById('compare-matrix-body');
  compareData.forEach(([feat, s, g, p]) => {
    const renderCell = (v, clr) => {
      if (v === true) return `<td style="text-align:center;padding:20px;"><span style="color:#10b981;font-size:16px;">✓</span></td>`;
      if (v === false) return `<td style="text-align:center;padding:20px;color:rgba(255,255,255,0.1);font-size:16px;">—</td>`;
      return `<td style="text-align:center;padding:20px;font-weight:900;color:${clr};">${v}</td>`;
    };
    tbody.innerHTML += `
      <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
        <td style="padding:20px;font-size:12px;font-weight:700;color:rgba(255,255,255,0.5);">${feat}</td>
        ${renderCell(s, 'rgba(255,255,255,0.4)')}
        ${renderCell(g, '#f97316')}
        ${renderCell(p, '#a855f7')}
      </tr>
    `;
  });

  function activateMatrix(planKey) {
    const plans = { 
        'starter': 'Starter Node', 
        'growth': 'Growth Protocol', 
        'enterprise': 'Matrix Enterprise' 
    };
    
    // Save to local persistence
    localStorage.setItem('restaurant_auth', 'true');
    localStorage.setItem('restaurant_plan', planKey);
    localStorage.setItem('subscription_status', 'active');
    localStorage.setItem('subscription_expiry', (Date.now() + (365 * 24 * 60 * 60 * 1000)).toString()); // 1 year free
    
    showToast(`⚡ ${plans[planKey]} DEPLOYED SUCCESSFULLY! Redirecting...`);
    
    setTimeout(() => {
        window.location.href = '/restaurant-dashboard';
    }, 1500);
  }

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 4000);
  }
</script>

</body>
</html>
