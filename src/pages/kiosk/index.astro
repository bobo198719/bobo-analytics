---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Kiosk | Self Ordering">
    <div class="min-h-screen bg-black text-white flex flex-col relative overflow-hidden font-sans">
        <!-- Abstract Background styling for premium look -->
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-900/40 via-black to-fuchsia-900/30 z-0 pointer-events-none"></div>
        <div class="absolute -top-32 -left-32 w-96 h-96 bg-indigo-500/20 rounded-full blur-3xl z-0 pointer-events-none"></div>
        
        <!-- Header -->
        <header class="p-8 z-10 flex justify-between items-center backdrop-blur-md border-b border-white/10">
            <div>
                <h1 class="text-4xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-fuchsia-400">Order Here</h1>
                <p class="text-gray-400 text-lg mt-1">Tap what you're craving to get started.</p>
            </div>
            <button class="bg-white/10 hover:bg-white/20 border border-white/20 rounded-2xl px-6 py-3 font-semibold transition backdrop-blur-md">
                Start Over
            </button>
        </header>

        <main class="flex-1 z-10 p-8 flex gap-8">
            <!-- Main Content Area -->
            <div class="flex-1">
                <nav class="flex gap-4 mb-8 overflow-x-auto pb-4 hide-scrollbar">
                    <button class="bg-white text-black px-6 py-3 rounded-full font-bold text-lg shadow-lg shadow-white/10">Popular</button>
                    <button class="bg-white/10 text-white border border-white/20 px-6 py-3 rounded-full font-bold text-lg">Burgers</button>
                    <button class="bg-white/10 text-white border border-white/20 px-6 py-3 rounded-full font-bold text-lg">Drinks</button>
                </nav>
                
                <div class="grid grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- Card 1 -->
                    <div class="bg-white/5 border border-white/10 rounded-3xl p-4 backdrop-blur hover:bg-white/10 transition cursor-pointer group">
                        <div class="aspect-square bg-gray-800 rounded-2xl mb-4 overflow-hidden relative">
                            <!-- Placeholder for food image -->
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                        </div>
                        <h3 class="text-xl font-bold mb-1">Classic Burger</h3>
                        <p class="text-indigo-300 font-semibold text-lg">$14.00</p>
                        <button class="w-full mt-4 bg-white/10 hover:bg-white/20 text-white py-3 rounded-xl font-semibold border border-white/10 transition group-hover:bg-indigo-600 group-hover:border-indigo-500">Add to Order</button>
                    </div>
                </div>
            </div>

            <!-- Vertical Cart Sidebar -->
            <aside class="w-96 bg-white/5 border border-white/10 rounded-3xl backdrop-blur-xl flex flex-col overflow-hidden shadow-2xl">
                <div class="p-6 border-b border-white/10 bg-black/40">
                    <h2 class="text-2xl font-bold">Your Order</h2>
                </div>
                
                <div class="flex-1 p-6 overflow-y-auto">
                    <!-- Empty State -->
                    <div class="text-center text-gray-500 mt-20">
                        <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        <p class="font-medium text-lg">Your cart is empty.</p>
                    </div>
                </div>

                <div class="p-6 border-t border-white/10 bg-black/60">
                    <div class="flex justify-between items-center mb-6">
                        <span class="text-gray-400 font-medium">Total</span>
                        <span class="text-3xl font-bold whitespace-nowrap text-white">$0.00</span>
                    </div>
                    <button class="w-full bg-gradient-to-r from-indigo-500 to-fuchsia-500 text-white py-4 rounded-2xl font-bold text-xl shadow-lg hover:scale-[1.02] transition-transform">
                        Checkout
                    </button>
                </div>
            </aside>
        </main>
    </div>
</MainLayout>
