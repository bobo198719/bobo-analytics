---

import MainLayout from "../../layouts/MainLayout.astro";

<MainLayout title="Fashion Analytics Pro"><section class="hero">
<h1>Fashion Analytics Pro</h1>
<p>Trend analysis and size-wise stock management.</p><div class="stats">
<div><h2>150+</h2><span>Brands</span></div>
<div><h2>Trend</h2><span>Analytics</span></div>
<div><h2>Size</h2><span>Tracking</span></div>
<div><h2>20%</h2><span>Stock Efficiency</span></div>
</div></section><section class="features"><div class="card">
<h3>Trend Prediction</h3>
<p>Stay ahead of fashion cycles.</p>
</div><div class="card">
<h3>Size Optimization</h3>
<p>Keep the right sizes in stock.</p>
</div><div class="card">
<h3>Visual Merchandising</h3>
<p>Optimize store layouts for sales.</p>
</div></section><section class="login"><h2>Clothing CRM Login</h2><form>
<input placeholder="Username">
<input type="password" placeholder="Password">
<button>Login</button>
</form></section><style>

.hero{
background:linear-gradient(135deg,#2b001f,#4d0036);
color:white;
text-align:center;
padding:80px 20px;
}

.stats h2{
color:#ff4fd8;
}

.card:hover{
border-color:#ff4fd8;
}

.login button{
background:#ff4fd8;
}

</style></MainLayout>