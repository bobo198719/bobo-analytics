---

import MainLayout from "../../layouts/MainLayout.astro";

<MainLayout title="Financial Analytics Suite"><section class="hero">
<h1>Financial Analytics Suite</h1>
<p>Real-time financial insights and risk management.</p><div class="stats">
<div><h2>100+</h2><span>Banks</span></div>
<div><h2>Gold</h2><span>Security Standard</span></div>
<div><h2>Real-Time</h2><span>Processing</span></div>
<div><h2>99.9%</h2><span>Uptime</span></div>
</div></section><section class="features"><div class="card">
<h3>Risk Assessment</h3>
<p>Evaluate credit and market risks.</p>
</div><div class="card">
<h3>Profitability Analysis</h3>
<p>Analyze revenue streams.</p>
</div><div class="card">
<h3>Fraud Detection</h3>
<p>AI-powered security alerts.</p>
</div></section><section class="login"><h2>Finance CRM Login</h2><form>
<input placeholder="Username">
<input type="password" placeholder="Password">
<button>Login</button>
</form></section><style>

.hero{
background:linear-gradient(135deg,#2b2500,#4d4300);
color:white;
text-align:center;
padding:80px 20px;
}

.stats{
display:flex;
justify-content:center;
gap:40px;
margin-top:40px;
flex-wrap:wrap;
}

.stats h2{
color:#ffd700;
}

.features{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:60px 20px;
max-width:1100px;
margin:auto;
}

.card{
background:#111;
padding:30px;
border-radius:10px;
border:1px solid #333;
}

.card:hover{
border-color:#ffd700;
}

.login{
text-align:center;
padding:60px;
}

.login input{
display:block;
margin:10px auto;
padding:10px;
width:250px;
}

.login button{
padding:10px 20px;
background:#ffd700;
border:none;
}

</style></MainLayout>