          { value: "0%", label: "Data Loss" }
        ],
        features: [
          { title: "Patient Analytics", desc: "Track patient history and health trends." },
          { title: "Reporting", desc: "Generate medical reports instantly." },
          { title: "Smart Billing", desc: "Automated insurance and billing." }
        ],
        loginTitle: "Healthcare CRM Login",
        theme: {
          gradientFrom: "#001f2b",
          gradientTo: "#004e6b",
          accent: "#00c3ff"
        }
      }
    },
    {
      industry: "retail",
      data: {
        title: "Retail Intelligence Platform",
        subtitle: "Boost sales with AI-driven inventory analytics.",
        stats: [
          { value: "1000+", label: "Retailers" },
          { value: "85%", label: "Sales Growth" },
          { value: "AI", label: "Forecasting" },
          { value: "10%", label: "Cost Reduction" }
        ],
        features: [
          { title: "Demand Forecasting", desc: "Predict what sells next." },
          { title: "Inventory Optimization", desc: "Reduce overstock and stockouts." },
          { title: "Customer Insights", desc: "Understand buying patterns." }
        ],
        loginTitle: "Retail CRM Login",
        theme: {
          gradientFrom: "#2b1600",
          gradientTo: "#4d2a00",
          accent: "#ff9f43"
        }
      }
    },
    {
      industry: "finance",
      data: {
        title: "Financial Analytics Suite",
        subtitle: "Real-time financial insights and risk management.",
        stats: [
          { value: "100+", label: "Banks" },
          { value: "Gold", label: "Security Standard" },
          { value: "Real-Time", label: "Processing" },
          { value: "99.9%", label: "Uptime" }
        ],
        features: [
          { title: "Risk Assessment", desc: "Evaluate credit and market risks." },
          { title: "Profitability Analysis", desc: "Analyze revenue streams." },
          { title: "Fraud Detection", desc: "AI-powered security alerts." }
        ],
        loginTitle: "Finance CRM Login",
        theme: {
          gradientFrom: "#2b2500",
          gradientTo: "#4d4300",
          accent: "#ffd700"
        }
      }
    },
    {
      industry: "groceries",
      data: {
        title: "Grocery Smart Hub",
        subtitle: "Efficient fresh stock tracking and customer retention.",
        stats: [
          { value: "300+", label: "Stores" },
          { value: "Fresh", label: "Stock Guarantee" },
          { value: "24/7", label: "Support" },
          { value: "15%", label: "Margin Boost" }
        ],
        features: [
          { title: "Freshness Tracking", desc: "Monitor perishables effectively." },
          { title: "Loyalty Programs", desc: "Engage customers with rewards." },
          { title: "Quick Billing", desc: "Reduce checkout wait times." }
        ],
        loginTitle: "Grocery CRM Login",
        theme: {
          gradientFrom: "#1b2b00",
          gradientTo: "#304d00",
          accent: "#6aff00"
        }
      }
    },
    {
      industry: "clothing-store",
      data: {
        title: "Fashion Analytics Pro",
        subtitle: "Trend analysis and size-wise stock management.",
        stats: [
          { value: "150+", label: "Brands" },
          { value: "Trend", label: "Analytics" },
          { value: "Size", label: "Tracking" },
          { value: "20%", label: "Stock Efficiency" }
        ],
        features: [
          { title: "Trend Prediction", desc: "Stay ahead of fashion cycles." },
          { title: "Size Optimization", desc: "Keep the right sizes in stock." },
          { title: "Visual Merchandising", desc: "Optimize store layouts for sales." }
        ],
        loginTitle: "Clothing CRM Login",
