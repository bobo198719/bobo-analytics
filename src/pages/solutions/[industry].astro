const { industry } = Astro.params;
const { title, subtitle, stats, cards, color, gradient } = Astro.props;
---

<MainLayout title={title}>

<section class="hero">

<h1>{title}</h1>
<p>{subtitle}</p>

<div class="stats">

{stats.map(s => (
<div class="stat">
<span class="num">{s.val}</span>
<span class="label">{s.label}</span>
</div>
))}

</div>

</section>

<section class="cards">

{cards.map(c => (
<div class="card">
<h3>{c.title}</h3>
<p>{c.desc}</p>
</div>
))}

</section>


<style>

.hero{
background:{gradient};
padding:80px 20px;
text-align:center;
color:white;
}

.hero h1{
font-size:42px;
margin-bottom:10px;
}

.hero p{
color:#ccc;
}

.stats{
display:flex;
justify-content:center;
gap:40px;
margin-top:40px;
flex-wrap:wrap;
}

.num{
font-size:32px;
font-weight:bold;
color:{color};
}

.label{
color:#aaa;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:20px;
max-width:1200px;
margin:60px auto;
padding:20px;
}

.card{
background:#111;
padding:30px;
border-radius:12px;
border:1px solid #333;
transition:0.3s;
}

.card:hover{
border-color:{color};
box-shadow:0 0 20px {color};
transform:translateY(-6px);
}

.card h3{
color:white;
}

.card p{
color:#aaa;
}

</style>

</MainLayout>