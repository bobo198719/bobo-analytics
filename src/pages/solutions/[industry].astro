          gradientTo: "#4d0036",
          accent: "#ff4fd8"
        }
      }
    },
    {
      industry: "stock-trading",
      data: {
        title: "TradeGuard Analytics",
        subtitle: "Portfolio analytics and real-time risk assessment.",
        stats: [
          { value: "5k+", label: "Traders" },
          { value: "Low", label: "Latency" },
          { value: "AI", label: "Risk Model" },
