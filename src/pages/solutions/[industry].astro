}

const { data } = Astro.props;
---

<MainLayout title={`${data.title} | Bobo Analytics`}>
  <section class="hero" style={`--gradient-from: ${data.theme.gradientFrom}; --gradient-to: ${data.theme.gradientTo};`}>
    <h1>{data.title}</h1>
    <p>{data.subtitle}</p>
    
    <div class="stats">
      {data.stats.map(stat => (
        <div class="stat-item">
          <h2 style={`color: ${data.theme.accent};`}>{stat.value}</h2>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="features">
    <div class="features-header">
      <h2>Key Capabilities</h2>
      <p>Transform your operations with our industry-specific tools.</p>
    </div>
    
    <div class="feature-grid">
      {data.features.map(feature => (
        <div class="feature-card" style={`--accent-color: ${data.theme.accent};`}>
          <h3>{feature.title}</h3>
          <p>{feature.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="login" class="login-section">
    <div class="login-container">
      <h2>{data.loginTitle}</h2>
      <p>Access your secure dashboard.</p>
      
      <form id="industryLoginForm" class="crm-form">
        <!-- Hidden input to pass industry type to client JS -->
        <input type="hidden" id="currentIndustry" value={data.industry || Astro.params.industry} />
        
        <input type="text" id="crmUsername" placeholder="Instance ID / Username" required />
        <input type="password" id="crmPassword" placeholder="Password" required />
        
        <button type="submit" style={`background: ${data.theme.accent}; box-shadow: 0 4px 15px ${data.theme.accent}40;`}>
          Sign In
        </button>
        <p id="crmLoginError" style="color: #ef4444; margin-top: 10px; min-height: 20px; font-size: 0.9rem;"></p>
      </form>
    </div>
  </section>
</MainLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const loginForm = document.getElementById("industryLoginForm");
    const errorMsg = document.getElementById("crmLoginError");

    if (loginForm) {
      loginForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorMsg.innerText = "";
        
        const username = document.getElementById("crmUsername").value.trim();
        const pwd = document.getElementById("crmPassword").value;
        const currentInd = document.getElementById("currentIndustry").value;

        try {
          // Simulate latency
          const btn = loginForm.querySelector("button");
          const originalBtnText = btn.innerText;
          btn.innerText = "Authenticating...";
          await new Promise(r => setTimeout(r, 600));
          btn.innerText = originalBtnText;

          let tenants = JSON.parse(localStorage.getItem("bobo_tenants") || "[]");
          
          let validTenant = tenants.find(t => 
             t.pharmacyId === username && 
             t.password === pwd && 
             t.industry === currentInd
          );

          if (validTenant) {
            // Set Unified Context
            localStorage.setItem("activeTenantContext", JSON.stringify({
               id: validTenant.pharmacyId,
               name: validTenant.pharmacy,
               industry: validTenant.industry,
               plan: validTenant.plan
            }));
            window.location.href = "/dashboard";
          } else {
             // Fallback: check if they exist but wrong industry
             let existAnywhere = tenants.find(t => t.pharmacyId === username && t.password === pwd);
             if (existAnywhere) {
                errorMsg.innerText = `Invalid portal. This account belongs to the ${existAnywhere.industry} vertical.`;
             } else {
                errorMsg.innerText = "Invalid credentials. Contact Super Admin to provision an instance.";
             }
          }
        } catch(err) {
           errorMsg.innerText = "System error during authentication.";
        }
      });
    }
  });
</script>

<style>
  .hero {
    background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));
    color: white;
    text-align: center;
    padding: 100px 24px;
    border-radius: 24px;
    margin: 20px 24px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  .hero h1 {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .hero p {
    font-size: 1.25rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  .stats {
    display: flex;
    justify-content: center;
    gap: 60px;
    margin-top: 60px;
    flex-wrap: wrap;
    background: rgba(0,0,0,0.2);
    padding: 30px;
    border-radius: 20px;
    display: inline-flex;
    backdrop-filter: blur(10px);
  }

  .stat-item h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .stat-item span {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0.8;
  }

  .features {
    padding: 100px 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .features-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .features-header h2 {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .features-header p {
    color: rgba(255,255,255,0.6);
    font-size: 1.1rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }

  .feature-card {
    background: rgba(255,255,255,0.03);
    padding: 40px;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.05);
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    background: rgba(255,255,255,0.05);
  }

  .feature-card h3 {
    font-size: 1.5rem;
    margin-bottom: 16px;
  }

  .feature-card p {
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
  }

  .login-section {
    padding: 60px 24px 100px;
    display: flex;
    justify-content: center;
  }

  .login-container {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 50px;
    border-radius: 24px;
    text-align: center;
    width: 100%;
    max-width: 450px;
  }

  .login-container h2 {
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .login-container p {
    color: rgba(255,255,255,0.5);
    margin-bottom: 30px;
  }

  .crm-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .crm-form input {
    padding: 14px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.05);
    color: white;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .crm-form input:focus {
    outline: none;
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.3);
  }

  .crm-form button {
    padding: 14px;
    border: none;
    border-radius: 12px;
    color: #111;
    font-weight: 700;
    font-size: 1.05rem;
    cursor: pointer;
    margin-top: 10px;
    transition: all 0.2s ease;
  }

  .crm-form button:hover {
    transform: translateY(-2px);
    filter: brightness(1.1);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 60px 20px;
      margin: 10px;
    }
    .hero h1 {
      font-size: 2.5rem;
    }
    .stats {
      gap: 30px;
      padding: 20px;
    }
  }
</style>
