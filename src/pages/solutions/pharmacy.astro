---

import MainLayout from "../../layouts/MainLayout.astro";

<MainLayout title="Pharmacy Management Software"><section class="hero">
<h1>Pharmacy Management Software</h1>
<p>AI powered analytics and automation for modern pharmacies.</p><div class="stats">
<div><h2>500+</h2><span>Pharmacies</span></div>
<div><h2>99%</h2><span>Inventory Accuracy</span></div>
<div><h2>24/7</h2><span>AI Monitoring</span></div>
<div><h2>0%</h2><span>Expiry Loss</span></div>
</div>
</section><section class="features"><div class="card">
<h3>Medicine Inventory</h3>
<p>Track stock levels and expiry dates.</p>
</div><div class="card">
<h3>Barcode Scanner</h3>
<p>Scan medicines instantly.</p>
</div><div class="card">
<h3>Smart Billing</h3>
<p>Generate GST invoices.</p>
</div><div class="card">
<h3>Supplier Management</h3>
<p>Manage suppliers and purchase orders.</p>
</div><div class="card">
<h3>Expiry Alerts</h3>
<p>Get notifications before expiry.</p>
</div></section><section class="login"><h2>Pharmacy CRM Login</h2><form>
<input placeholder="Username">
<input type="password" placeholder="Password">
<button>Login</button>
</form></section><style>

.hero{
background:linear-gradient(135deg,#002b1f,#004d36);
color:white;
text-align:center;
padding:80px 20px;
}

.stats{
display:flex;
justify-content:center;
gap:40px;
margin-top:40px;
flex-wrap:wrap;
}

.stats h2{
color:#00ff96;
}

.features{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:60px 20px;
max-width:1100px;
margin:auto;
}

.card{
background:#111;
padding:30px;
border-radius:10px;
border:1px solid #333;
}

.card:hover{
border-color:#00ff96;
}

.login{
text-align:center;
padding:60px;
}

.login input{
display:block;
margin:10px auto;
padding:10px;
width:250px;
}

.login button{
padding:10px 20px;
background:#00ff96;
border:none;
}

</style></MainLayout>