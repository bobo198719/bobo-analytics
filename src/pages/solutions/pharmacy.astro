---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Pharmacy Management Software"><section class="hero"><h1>Pharmacy Management Software</h1>
<p class="subtitle">
AI powered analytics and automation for modern pharmacies
</p><div class="stats"><div class="stat">
<h2>500+</h2>
<p>Pharmacies Using Our Platform</p>
</div><div class="stat">
<h2>99%</h2>
<p>Inventory Accuracy</p>
</div><div class="stat">
<h2>24/7</h2>
<p>AI Monitoring</p>
</div><div class="stat">
<h2>0%</h2>
<p>Medicine Expiry Loss</p>
</div></div></section><section class="features"><div class="feature">
<h3>Medicine Inventory</h3>
<p>Track stock levels, batch numbers and expiry dates.</p>
</div><div class="feature">
<h3>Barcode Scanner</h3>
<p>Scan medicines instantly using barcode technology.</p>
</div><div class="feature">
<h3>Smart Billing</h3>
<p>Generate GST invoices and manage customer records.</p>
</div><div class="feature">
<h3>Supplier Management</h3>
<p>Manage suppliers and purchase orders easily.</p>
</div><div class="feature">
<h3>Expiry Alerts</h3>
<p>Get notifications before medicines expire.</p>
</div></section><section class="login-box"><h2>Login to Pharmacy CRM</h2><form id="loginForm"><input
type="text"
id="username"
placeholder="Username"
required
/>

<input
type="password"
id="password"
placeholder="Password"
required
/>

<button type="submit">
Login
</button></form><p id="error"></p></section><style>

.hero{
text-align:center;
padding:80px 20px;
}

.subtitle{
color:#666;
margin-bottom:40px;
}

.stats{
display:flex;
justify-content:center;
gap:50px;
flex-wrap:wrap;
}

.stat h2{
color:#16a34a;
font-size:32px;
}

.features{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:60px;
max-width:1200px;
margin:auto;
}

.feature{
background:#f5f5f5;
padding:25px;
border-radius:10px;
}

.login-box{
text-align:center;
padding:80px 20px;
background:#111;
color:white;
}

.login-box input{
display:block;
margin:10px auto;
padding:12px;
width:260px;
border-radius:6px;
border:none;
}

.login-box button{
padding:12px 25px;
background:#22c55e;
border:none;
color:white;
border-radius:6px;
cursor:pointer;
}

</style><script>

const form=document.getElementById("loginForm")

form.addEventListener("submit",async(e)=>{

e.preventDefault()

const username=document.getElementById("username").value
const password=document.getElementById("password").value

const res=await fetch("/api/auth/login",{

method:"POST",

headers:{
"Content-Type":"application/json"
},

body:JSON.stringify({
username:username,
password:password
})

})

const data=await res.json()

if(res.ok){

localStorage.setItem("boboUser",username)

window.location.href="/pharmacy-dashboard"

}else{

document.getElementById("error").innerText="Invalid login"

}

})

</script></MainLayout>