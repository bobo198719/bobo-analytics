---

import MainLayout from "../../layouts/MainLayout.astro";

<MainLayout title="Retail Intelligence Platform"><section class="hero">
<h1>Retail Intelligence Platform</h1>
<p>Boost sales with AI-driven inventory analytics.</p><div class="stats">
<div><h2>1000+</h2><span>Retailers</span></div>
<div><h2>85%</h2><span>Sales Growth</span></div>
<div><h2>AI</h2><span>Forecasting</span></div>
<div><h2>10%</h2><span>Cost Reduction</span></div>
</div></section><section class="features"><div class="card">
<h3>Demand Forecasting</h3>
<p>Predict what sells next.</p>
</div><div class="card">
<h3>Inventory Optimization</h3>
<p>Reduce overstock and stockouts.</p>
</div><div class="card">
<h3>Customer Insights</h3>
<p>Understand buying patterns.</p>
</div></section><section class="login"><h2>Retail CRM Login</h2><form>
<input placeholder="Username">
<input type="password" placeholder="Password">
<button>Login</button>
</form></section><style>

.hero{
background:linear-gradient(135deg,#2b1600,#4d2a00);
color:white;
text-align:center;
padding:80px 20px;
}

.stats{
display:flex;
justify-content:center;
gap:40px;
margin-top:40px;
flex-wrap:wrap;
}

.stats h2{
color:#ff9f43;
}

.features{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:60px 20px;
max-width:1100px;
margin:auto;
}

.card{
background:#111;
padding:30px;
border-radius:10px;
border:1px solid #333;
}

.card:hover{
border-color:#ff9f43;
}

.login{
text-align:center;
padding:60px;
}

.login input{
display:block;
margin:10px auto;
padding:10px;
width:250px;
}

.login button{
padding:10px 20px;
background:#ff9f43;
border:none;
}

</style></MainLayout>