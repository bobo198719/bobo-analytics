---

import MainLayout from "../../layouts/MainLayout.astro";

<MainLayout title="Healthcare Management Software"><section class="hero">
<h1>Healthcare Management Software</h1>
<p>Patient analytics and hospital insights.</p><div class="stats">
<div><h2>200+</h2><span>Hospitals</span></div>
<div><h2>98%</h2><span>Accuracy</span></div>
<div><h2>24/7</h2><span>Monitoring</span></div>
<div><h2>0%</h2><span>Data Loss</span></div>
</div>
</section><section class="features"><div class="card">
<h3>Patient Analytics</h3>
<p>Track patient history and health trends.</p>
</div><div class="card">
<h3>Reporting</h3>
<p>Generate medical reports instantly.</p>
</div><div class="card">
<h3>Smart Billing</h3>
<p>Automated insurance and billing.</p>
</div></section><section class="login"><h2>Healthcare CRM Login</h2><form>
<input placeholder="Username">
<input type="password" placeholder="Password">
<button>Login</button>
</form></section><style>

.hero{
background:linear-gradient(135deg,#001f2b,#004e6b);
color:white;
text-align:center;
padding:80px 20px;
}

.stats{
display:flex;
justify-content:center;
gap:40px;
margin-top:40px;
flex-wrap:wrap;
}

.stats h2{
color:#00c3ff;
}

.features{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:60px 20px;
max-width:1100px;
margin:auto;
}

.card{
background:#111;
padding:30px;
border-radius:10px;
border:1px solid #333;
}

.card:hover{
border-color:#00c3ff;
}

.login{
text-align:center;
padding:60px;
}

.login input{
display:block;
margin:10px auto;
padding:10px;
width:250px;
}

.login button{
padding:10px 20px;
background:#00c3ff;
border:none;
}

</style></MainLayout>