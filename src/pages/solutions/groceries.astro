---

import MainLayout from "../../layouts/MainLayout.astro";

<MainLayout title="Grocery Smart Hub"><section class="hero">
<h1>Grocery Smart Hub</h1>
<p>Efficient fresh stock tracking and customer retention.</p><div class="stats">
<div><h2>300+</h2><span>Stores</span></div>
<div><h2>Fresh</h2><span>Stock Guarantee</span></div>
<div><h2>24/7</h2><span>Support</span></div>
<div><h2>15%</h2><span>Margin Boost</span></div>
</div></section><section class="features"><div class="card">
<h3>Freshness Tracking</h3>
<p>Monitor perishables effectively.</p>
</div><div class="card">
<h3>Loyalty Programs</h3>
<p>Engage customers with rewards.</p>
</div><div class="card">
<h3>Quick Billing</h3>
<p>Reduce checkout wait times.</p>
</div></section><section class="login"><h2>Grocery CRM Login</h2><form>
<input placeholder="Username">
<input type="password" placeholder="Password">
<button>Login</button>
</form></section><style>

.hero{
background:linear-gradient(135deg,#1b2b00,#304d00);
color:white;
text-align:center;
padding:80px 20px;
}

.stats{
display:flex;
justify-content:center;
gap:40px;
margin-top:40px;
flex-wrap:wrap;
}

.stats h2{
color:#6aff00;
}

.features{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:60px 20px;
max-width:1100px;
margin:auto;
}

.card{
background:#111;
padding:30px;
border-radius:10px;
border:1px solid #333;
}

.card:hover{
border-color:#6aff00;
}

.login button{
background:#6aff00;
}

</style></MainLayout>