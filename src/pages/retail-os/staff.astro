---
import MainLayout from "../../layouts/MainLayout.astro";
import "../../styles/restaurant.css";

// Mock data for staff members
const staff = [
  { id: 1, name: "Jane Doe", role: "Store Manager", email: "jane.d@boboretail.com", store: "South City Mall", joined: "Jan 2024", performance: "Exceeding" },
  { id: 2, name: "Arjun Mehta", role: "Sales Associate", email: "arjun.m@boboretail.com", store: "South City Mall", joined: "Mar 2024", performance: "Meeting" },
  { id: 3, name: "Priya Singh", role: "Inventory Lead", email: "priya.s@boboretail.com", store: "South City Mall", joined: "Feb 2024", performance: "Outstanding" },
  { id: 4, name: "Karan Johar", role: "Cashier", email: "karan.j@boboretail.com", store: "South City Mall", joined: "May 2024", performance: "Meeting" }
];
---

<MainLayout title="Workforce Control | Bobo OS" hideNav={true}>
  <div class="flex h-screen bg-[#05081a] overflow-hidden font-['Plus_Jakarta_Sans'] text-white">
    
    <!-- Sidebar -->
    <aside class="w-20 md:w-24 border-r border-white/10 bg-[#05081a]/50 backdrop-blur-2xl flex flex-col justify-between py-10 items-center">
      <div class="flex flex-col gap-8">
        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center font-black text-white text-xl shadow-lg shadow-indigo-600/20 italic">B</div>
        <nav class="flex flex-col gap-6">
           <a href="/retail-os" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-layout-grid text-xl"></i>
           </a>
           <a href="/retail-os/inventory" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-box text-xl"></i>
           </a>
           <a href="/pos-clothing" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all font-bold">
              <i class="lucide-receipt text-xl"></i>
           </a>
           <a href="/retail-os/customers" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-users-2 text-xl"></i>
           </a>
           <a href="/retail-os/analytics" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-bar-chart-3 text-xl"></i>
           </a>
        </nav>
      </div>

      <div class="flex flex-col gap-6">
         <a href="/crm-login" class="p-4 text-white/20 hover:text-rose-400 hover:bg-rose-400/10 rounded-2xl transition-all"><i class="lucide-log-out text-xl"></i></a>
      </div>
    </aside>

    <!-- Content Workspace -->
    <main class="flex-1 overflow-y-auto custom-scrollbar p-6 md:p-12 relative">
       
       <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
          <div>
             <h1 class="text-3xl font-black italic uppercase tracking-tighter">Human Resource Matrix</h1>
             <p class="text-white/40 text-xs font-bold uppercase tracking-[0.2em] mt-2 italic">Workforce Control: Central Terminal</p>
          </div>
          <div class="flex items-center gap-4">
             <button class="px-6 py-3 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all italic">Roster Planner</button>
             <button class="px-6 py-3 bg-indigo-600 rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-indigo-600/20 hover:scale-[1.05] transition-all italic">+ Onboard Staff</button>
          </div>
       </header>

       <!-- Staff Grid -->
       <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          {staff.map(person => (
             <div class="bg-white/5 border border-white/10 rounded-[48px] p-8 group hover:bg-white/[0.08] transition-all relative overflow-hidden">
                <div class="flex items-end justify-between mb-8">
                   <div class="relative">
                      <div class="w-16 h-16 bg-gradient-to-br from-indigo-500 to-cyan-500 rounded-3xl flex items-center justify-center text-xl font-black italic border border-white/10 shadow-lg shadow-indigo-600/20">
                         {person.name.split(' ').map(n=>n[0]).join('')}
                      </div>
                      <div class="absolute -bottom-1 -right-1 w-4 h-4 rounded-full bg-emerald-500 border-2 border-[#05081a] shadow-[0_0_10px_rgba(16,185,129,0.4)]"></div>
                   </div>
                   <div class="text-right">
                      <div class="text-[10px] font-black uppercase tracking-widest text-white/30 italic">ID: BR-00{person.id}</div>
                      <div class={`text-[8px] font-black uppercase tracking-widest px-2 py-1 rounded-lg mt-1 ${person.performance === 'Outstanding' ? 'text-emerald-400 bg-emerald-500/10' : 'text-indigo-400 bg-indigo-500/10'}`}>{person.performance}</div>
                   </div>
                </div>

                <div class="space-y-1 mb-8">
                   <h3 class="text-lg font-black italic uppercase tracking-tight">{person.name}</h3>
                   <span class="text-[10px] font-black uppercase tracking-widest text-indigo-400 italic">{person.role}</span>
                </div>

                <div class="space-y-4 border-t border-white/5 pt-8">
                   <div class="flex items-center gap-3 text-[8px] font-black uppercase tracking-widest text-white/40 italic">
                      <i class="lucide-map-pin text-xs"></i>
                      <span>Terminal: <span class="text-white/60">{person.store}</span></span>
                   </div>
                   <div class="flex items-center gap-3 text-[8px] font-black uppercase tracking-widest text-white/40 italic">
                      <i class="lucide-calendar text-xs"></i>
                      <span>Joined: <span class="text-white/60">{person.joined}</span></span>
                   </div>
                </div>

                <div class="mt-8">
                   <button class="w-full py-3 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:border-indigo-500 transition-all italic">Access Profile</button>
                </div>
                
                <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-600/5 blur-[60px] -z-10 group-hover:bg-indigo-600/10 transition-all"></div>
             </div>
          ))}
       </div>

    </main>
  </div>

  <script is:inline>
     // Auth Guard
     if (localStorage.getItem('retail_os_auth') !== 'true') {
        window.location.href = "/retail-os-login";
     }
  </script>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #05081a; }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.01); }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.05); border-radius: 10px; }
  </style>

  <!-- Lucide Icon Support -->
  <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">
</MainLayout>
