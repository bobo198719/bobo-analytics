---
import MainLayout from "../../layouts/MainLayout.astro";
import "../../styles/restaurant.css";

// Mock data for returns
const returns = [
  { id: "RET-1024", date: "Today, 10:20 AM", customer: "Rahul Sharma", product: "Black Linen Shirt (L)", reason: "Wrong Size", amount: "₹1,250", status: "Processed" },
  { id: "RET-1025", date: "Today, 11:45 AM", customer: "Ananya Iyer", product: "Red Kurti (M)", reason: "Defective Fabric", amount: "₹1,499", status: "Pending Inspection" },
  { id: "RET-1026", date: "Yesterday", customer: "Vikram Gupta", product: "Slim Fit Jeans (32)", reason: "Not satisfied", amount: "₹2,400", status: "Refunded" }
];
---

<MainLayout title="Returns Hub | Bobo OS" hideNav={true}>
  <div class="flex h-screen bg-[#05081a] overflow-hidden font-['Plus_Jakarta_Sans'] text-white">
    
    <!-- Sidebar -->
    <aside class="w-20 md:w-24 border-r border-white/10 bg-[#05081a]/50 backdrop-blur-2xl flex flex-col justify-between py-10 items-center">
      <div class="flex flex-col gap-8">
        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center font-black text-white text-xl shadow-lg shadow-indigo-600/20 italic">B</div>
        <nav class="flex flex-col gap-6">
           <a href="/retail-os" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-layout-grid text-xl"></i>
           </a>
           <a href="/retail-os/inventory" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-box text-xl"></i>
           </a>
           <a href="/pos-clothing" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all font-bold">
              <i class="lucide-receipt text-xl"></i>
           </a>
           <a href="/retail-os/customers" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-users-2 text-xl"></i>
           </a>
           <a href="/retail-os/analytics" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-bar-chart-3 text-xl"></i>
           </a>
        </nav>
      </div>

      <div class="flex flex-col gap-6">
         <a href="/crm-login" class="p-4 text-white/20 hover:text-rose-400 hover:bg-rose-400/10 rounded-2xl transition-all"><i class="lucide-log-out text-xl"></i></a>
      </div>
    </aside>

    <!-- Content Workspace -->
    <main class="flex-1 overflow-y-auto custom-scrollbar p-6 md:p-12 relative">
       
       <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
          <div>
             <h1 class="text-3xl font-black italic uppercase tracking-tighter">Returns & Exchanges</h1>
             <p class="text-white/40 text-xs font-bold uppercase tracking-[0.2em] mt-2 italic">Automated Reconciliation Hub</p>
          </div>
          <div class="flex items-center gap-4">
             <button class="px-6 py-3 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all italic">Policy Manager</button>
             <button class="px-6 py-3 bg-indigo-600 rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-indigo-600/20 hover:scale-[1.05] transition-all italic">Start Return</button>
          </div>
       </header>

       <!-- Pipeline Visualizer -->
       <div class="bg-white/5 border border-white/10 p-10 rounded-[48px] flex items-center gap-12 mb-12 relative overflow-hidden">
          {[
             { step: 1, title: "Intake", desc: "Scan Invoice", active: true },
             { step: 2, title: "Selection", desc: "Refund Mode", active: false },
             { step: 3, title: "Resolution", desc: "Credit Issue", active: false }
          ].map((item, idx) => (
             <>
                <div class={`flex items-center gap-6 ${item.active ? 'opacity-100' : 'opacity-20'}`}>
                   <div class={`w-14 h-14 rounded-2xl flex items-center justify-center font-black text-xl border-2 ${item.active ? 'bg-indigo-600 border-indigo-400 shadow-lg shadow-indigo-600/30' : 'bg-white/5 border-white/10'}`}>
                      {item.step}
                   </div>
                   <div>
                      <div class="text-[10px] font-black uppercase tracking-widest text-white">{item.title}</div>
                      <div class="text-[8px] font-black uppercase tracking-widest text-white/40 italic">{item.desc}</div>
                   </div>
                </div>
                {idx < 2 && <div class="flex-1 h-px bg-white/10 relative"><div class="absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-1.5 bg-white/10 rounded-full"></div></div>}
             </>
          ))}
          <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-600/5 blur-[100px] -z-10"></div>
       </div>

       <!-- Activity Table -->
       <section class="bg-white/5 border border-white/10 rounded-[48px] overflow-hidden">
          <div class="p-8 border-b border-white/10 flex justify-between items-center bg-white/5">
             <h3 class="text-sm font-black italic uppercase tracking-widest">Recent Activity Log</h3>
             <div class="flex bg-black/20 p-1 rounded-xl border border-white/5">
                {['All', 'Pending', 'Processed'].map(tab => (
                   <button class={`px-4 py-2 rounded-lg text-[8px] font-black uppercase tracking-widest transition-all ${tab === 'All' ? 'bg-white/10 text-white' : 'text-white/30 hover:text-white'}`}>{tab}</button>
                ))}
             </div>
          </div>
          <div class="p-8 overflow-x-auto">
             <table class="w-full text-left">
                <thead>
                   <tr class="text-[10px] font-black uppercase tracking-widest text-white/20 border-b border-white/5 italic">
                      <th class="pb-6 px-4">Identifier</th>
                      <th class="pb-6 px-4">Timestamp</th>
                      <th class="pb-6 px-4">Customer Entity</th>
                      <th class="pb-6 px-4">Product Component</th>
                      <th class="pb-6 px-4">Fault Reason</th>
                      <th class="pb-6 px-4">Credit Value</th>
                      <th class="pb-6 px-4">Workflow Status</th>
                      <th class="pb-6 px-4">Ops</th>
                   </tr>
                </thead>
                <tbody>
                   {returns.map(ret => (
                      <tr class="group/row hover:bg-white/[0.02] transition-all">
                         <td class="py-6 px-4 font-black text-indigo-400 italic text-sm">{ret.id}</td>
                         <td class="py-6 px-4 text-[10px] font-black uppercase text-white/30 italic">{ret.date}</td>
                         <td class="py-6 px-4 font-black italic text-sm text-white/80">{ret.customer}</td>
                         <td class="py-6 px-4 font-black italic text-sm text-white/60">{ret.product}</td>
                         <td class="py-6 px-4">
                            <span class="text-[8px] font-black uppercase tracking-widest bg-amber-500/10 text-amber-500 border border-amber-500/20 px-3 py-1 rounded-full">{ret.reason}</span>
                         </td>
                         <td class="py-6 px-4 font-black italic text-white/80">{ret.amount}</td>
                         <td class="py-6 px-4">
                            <span class={`text-[8px] font-black uppercase tracking-widest px-3 py-1 rounded-full border ${ret.status === 'Processed' ? 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20' : (ret.status === 'Refunded' ? 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20' : 'bg-amber-500/10 text-amber-500 border-amber-500/20')}`}>
                               {ret.status}
                            </span>
                         </td>
                         <td class="py-6 px-4">
                            <button class="p-2 bg-white/5 border border-white/10 rounded-xl hover:border-indigo-500 transition-all">
                               <i class="lucide-external-link text-xs italic text-white/40"></i>
                            </button>
                         </td>
                      </tr>
                   ))}
                </tbody>
             </table>
          </div>
       </section>

    </main>
  </div>

  <script is:inline>
     // Auth Guard
     if (localStorage.getItem('retail_os_auth') !== 'true') {
        window.location.href = "/retail-os-login";
     }
  </script>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #05081a; }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.01); }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.05); border-radius: 10px; }
  </style>

  <!-- Lucide Icon Support -->
  <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">
</MainLayout>
