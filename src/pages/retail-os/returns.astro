---
import RetailOSLayout from "../../layouts/RetailOSLayout.astro";

// Mock data for returns
const returns = [
  { id: "RET-1024", date: "Today, 10:20 AM", customer: "Rahul Sharma", product: "Black Linen Shirt (L)", reason: "Wrong Size", amount: "₹1,250", status: "Processed" },
  { id: "RET-1025", date: "Today, 11:45 AM", customer: "Ananya Iyer", product: "Red Kurti (M)", reason: "Defective Fabric", amount: "₹1,499", status: "Pending Inspection" },
  { id: "RET-1026", date: "Yesterday", customer: "Vikram Gupta", product: "Slim Fit Jeans (32)", reason: "Not satisfied", amount: "₹2,400", status: "Refunded" }
];
---

<RetailOSLayout title="Returns Hub | Bobo Retail OS">
  <div class="header-section">
      <div>
          <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 8px; font-family: 'Outfit'; letter-spacing: -0.02em;">Returns <span class="gradient-text">& Exchanges</span> Hub</h1>
          <p style="color: var(--text-muted); font-size: 1.1rem;">AI-assisted returns process with automated store credit and stock reconciliation.</p>
      </div>
      <div class="action-buttons">
          <button class="btn secondary">Return Policy</button>
          <button class="btn primary">Start New Return</button>
      </div>
  </div>

  <div class="return-pipeline">
      <div class="pipeline-step active">
          <div class="step-num">1</div>
          <div class="step-info">
              <span>Intake</span>
              <p>Scan Invoice / SKU</p>
          </div>
      </div>
      <div class="pipeline-divider"></div>
      <div class="pipeline-step">
          <div class="step-num">2</div>
          <div class="step-info">
              <span>Selection</span>
              <p>Refund / Exchange</p>
          </div>
      </div>
      <div class="pipeline-divider"></div>
      <div class="pipeline-step">
          <div class="step-num">3</div>
          <div class="step-info">
              <span>Resolution</span>
              <p>Credit / Cash</p>
          </div>
      </div>
  </div>

  <div class="panel">
      <div class="panel-header">
          <h3>Recent Return Activity</h3>
          <div class="filter-pills">
              <button class="pill active">All</button>
              <button class="pill">Pending</button>
              <button class="pill">Processed</button>
          </div>
      </div>
      <div class="return-table-wrapper">
          <table>
              <thead>
                  <tr>
                      <th>Return ID</th>
                      <th>Date</th>
                      <th>Customer</th>
                      <th>Product</th>
                      <th>Reason</th>
                      <th>Amount</th>
                      <th>Status</th>
                      <th>Actions</th>
                  </tr>
              </thead>
              <tbody>
                  {returns.map(ret => (
                      <tr class="return-row">
                          <td style="font-weight: 700; color: var(--primary);">{ret.id}</td>
                          <td style="font-size: 0.85rem; color: var(--text-muted);">{ret.date}</td>
                          <td>{ret.customer}</td>
                          <td>{ret.product}</td>
                          <td>
                              <span class="reason-badge">{ret.reason}</span>
                          </td>
                          <td style="font-weight: 700;">{ret.amount}</td>
                          <td>
                              <span class={`status-chip ${ret.status.toLowerCase().replace(' ', '-')}`}>{ret.status}</span>
                          </td>
                          <td>
                              <button class="action-icon">
                                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 11v 8a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V11"/><path d="M19 11H5"/><path d="M12 2L12 7"/></svg>
                              </button>
                          </td>
                      </tr>
                  ))}
              </tbody>
          </table>
      </div>
  </div>

  <style>
      .gradient-text { background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
      .header-section {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 48px;
      }

      .btn {
          padding: 14px 28px;
          border-radius: 12px;
          font-weight: 700;
          cursor: pointer;
          border: none;
          transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          font-family: 'Outfit';
      }

      .btn.primary { background: var(--primary); color: white; box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3); }
      .btn.primary:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(99, 102, 241, 0.4); }
      .btn.secondary { background: var(--bg-glass); color: white; border: 1px solid var(--border); }
      .btn.secondary:hover { background: rgba(255,255,255,0.08); border-color: white; }

      .return-pipeline {
          display: flex;
          align-items: center;
          gap: 24px;
          margin-bottom: 48px;
          background: rgba(11, 17, 45, 0.4);
          padding: 40px;
          border-radius: 24px;
          border: 1px solid var(--border);
          backdrop-filter: blur(20px);
          position: relative;
          overflow: hidden;
      }
      
      .return-pipeline::after {
          content: '';
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background: radial-gradient(circle at 0% 0%, var(--primary) 0%, transparent 40%);
          opacity: 0.05;
          pointer-events: none;
      }

      .pipeline-step {
          display: flex;
          align-items: center;
          gap: 20px;
          flex: 1;
          opacity: 0.4;
          transition: 0.3s;
      }

      .pipeline-step.active { opacity: 1; transform: scale(1.02); }

      .step-num {
          width: 48px;
          height: 48px;
          background: rgba(255, 255, 255, 0.05);
          border-radius: 14px;
          display: flex;
          align-items: center;
          justify-content: center;
          font-weight: 800;
          font-size: 1.2rem;
          border: 2px solid var(--border);
          font-family: 'Outfit';
      }

      .pipeline-step.active .step-num {
          background: var(--primary);
          border-color: var(--primary);
          box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
          color: white;
      }

      .step-info span {
          display: block;
          font-weight: 700;
          font-size: 1.1rem;
          color: white;
      }

      .step-info p {
          font-size: 0.85rem;
          color: var(--text-muted);
          margin-top: 2px;
      }

      .pipeline-divider {
          height: 2px;
          background: var(--border);
          flex: 0.3;
          position: relative;
      }
      
      .pipeline-divider::after {
          content: '→';
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          font-weight: 900;
          color: var(--border);
      }

      .panel {
          background: rgba(11, 17, 45, 0.4);
          border: 1px solid var(--border);
          border-radius: 24px;
          padding: 32px;
          backdrop-filter: blur(20px);
      }

      .panel-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 32px;
      }
      
      .panel-header h3 { font-family: 'Outfit'; font-size: 1.4rem; }

      .filter-pills {
          display: flex;
          gap: 8px;
          background: rgba(255, 255, 255, 0.03);
          padding: 6px;
          border-radius: 14px;
          border: 1px solid var(--border);
      }

      .pill {
          background: transparent;
          border: none;
          color: var(--text-muted);
          padding: 8px 20px;
          border-radius: 10px;
          font-size: 0.85rem;
          cursor: pointer;
          transition: 0.2s;
          font-weight: 600;
      }

      .pill.active {
          background: white;
          color: black;
          font-weight: 700;
      }

      .return-table-wrapper {
          overflow-x: auto;
      }

      table {
          width: 100%;
          border-collapse: collapse;
      }

      th {
          text-align: left;
          padding: 16px;
          font-size: 0.75rem;
          text-transform: uppercase;
          color: var(--text-muted);
          border-bottom: 1px solid var(--border);
          letter-spacing: 0.05em;
          font-weight: 700;
      }

      td {
          padding: 24px 16px;
          border-bottom: 1px solid rgba(255, 255, 255, 0.03);
          font-size: 0.95rem;
      }
      
      .return-row:hover { background: rgba(255,255,255,0.02); }

      .reason-badge {
          background: rgba(245, 158, 11, 0.1);
          color: #f59e0b;
          padding: 6px 12px;
          border-radius: 8px;
          font-size: 0.8rem;
          font-weight: 700;
          text-transform: uppercase;
      }

      .status-chip {
          padding: 6px 14px;
          border-radius: 30px;
          font-size: 0.75rem;
          font-weight: 800;
          text-transform: uppercase;
          letter-spacing: 0.02em;
      }

      .status-chip.processed { background: rgba(16, 185, 129, 0.1); color: #10b981; }
      .status-chip.pending-inspection { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }
      .status-chip.refunded { background: rgba(99, 102, 241, 0.1); color: var(--primary); }

      .action-icon {
          background: rgba(255,255,255,0.05);
          border: 1px solid var(--border);
          color: var(--text-muted);
          width: 36px;
          height: 36px;
          border-radius: 10px;
          display: flex;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          transition: 0.2s;
      }

      .action-icon:hover { color: white; border-color: white; background: rgba(255,255,255,0.1); }
  </style>
</RetailOSLayout>
