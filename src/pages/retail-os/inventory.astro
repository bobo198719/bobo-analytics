---
import RetailOSLayout from "../../layouts/RetailOSLayout.astro";

// Mock data for products with variants
const inventory = [
  {
    id: 1,
    name: "Men's Linen Shirt",
    category: "Shirts",
    brand: "Bobo Classic",
    base_price: 1200,
    total_stock: 145,
    variants: [
        { size: "S", color: "White", sku: "SH-LIN-WH-S", stock: 12, price: 1200 },
        { size: "M", color: "White", sku: "SH-LIN-WH-M", stock: 18, price: 1200 },
        { size: "L", color: "White", sku: "SH-LIN-WH-L", stock: 2, price: 1250, alert: true },
        { size: "XL", color: "White", sku: "SH-LIN-WH-XL", stock: 15, price: 1250 },
        { size: "L", color: "Midnight Black", sku: "SH-LIN-BL-L", stock: 24, price: 1300 }
    ]
  },
  {
    id: 2,
    name: "Slim Fit Stretch Jeans",
    category: "Jeans",
    brand: "Denim Co",
    base_price: 2400,
    total_stock: 88,
    variants: [
        { size: "32", color: "Indigo Blue", sku: "JN-SLM-IN-32", stock: 1, price: 2400, alert: true },
        { size: "34", color: "Indigo Blue", sku: "JN-SLM-IN-34", stock: 12, price: 2400 },
        { size: "36", color: "Indigo Blue", sku: "JN-SLM-IN-36", stock: 8, price: 2400 }
    ]
  }
];
---

<RetailOSLayout title="Retail Inventory Terminal | Bobo OS">
   <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
      <div>
         <h1 class="text-3xl font-black italic uppercase tracking-tighter">Inventory Control</h1>
         <p class="text-white/40 text-xs font-bold uppercase tracking-[0.2em] mt-2 italic">Active Terminal: Central Warehouse</p>
      </div>
      <div class="flex items-center gap-4">
         <button class="px-6 py-3 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all italic">Bulk Import</button>
         <button class="px-6 py-3 bg-indigo-600 rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-indigo-600/20 hover:scale-[1.05] transition-all italic">+ Add Sku</button>
      </div>
   </header>

   <!-- Filter Bar -->
   <div class="flex gap-4 mb-12 items-center">
      <div class="relative flex-1 group">
         <i class="lucide-search absolute left-5 top-1/2 -translate-y-1/2 text-white/20 group-focus-within:text-indigo-500 transition-colors"></i>
         <input type="text" placeholder="QUERY SKU, BARCODE OR NAME..." class="w-full bg-white/5 border border-white/10 p-4 pl-14 rounded-2xl outline-none focus:border-indigo-500 transition-all font-black text-[10px] uppercase tracking-widest" />
      </div>
      <select class="bg-white/5 border border-white/10 p-4 rounded-2xl outline-none text-[10px] font-black uppercase tracking-widest italic cursor-pointer">
         <option>All Categories</option>
         <option>Shirts</option>
         <option>Jeans</option>
      </select>
   </div>

   <div class="space-y-12">
      {inventory.map(product => (
         <section class="bg-white/5 border border-white/10 rounded-[48px] overflow-hidden group">
            <!-- Product Header -->
            <div class="p-8 bg-white/5 border-b border-white/10 flex items-center gap-8">
               <div class="w-20 h-20 bg-white/10 rounded-3xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform">👕</div>
               <div class="flex-1">
                  <div class="flex items-center gap-4 mb-2">
                     <h3 class="text-xl font-black italic uppercase tracking-tight">{product.name}</h3>
                     <span class="px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-[8px] font-black uppercase text-indigo-400 italic">{product.category}</span>
                  </div>
                  <div class="flex items-center gap-6 text-[10px] font-black uppercase tracking-widest text-white/20 italic">
                     <span>Brand: <span class="text-white/60">{product.brand}</span></span>
                     <span>Total Units: <span class="text-white/60">{product.total_stock}</span></span>
                  </div>
               </div>
               <div class="px-6 py-3 bg-indigo-500/10 border border-indigo-500/20 rounded-2xl flex items-center gap-3">
                  <i class="lucide-sparkles text-indigo-400 text-xs"></i>
                  <span class="text-[10px] font-black text-indigo-400 uppercase tracking-widest italic">Size L High Demand</span>
               </div>
            </div>

            <!-- Matrix Table -->
            <div class="p-8 overflow-x-auto">
               <table class="w-full text-left">
                  <thead>
                     <tr class="text-[10px] font-black uppercase tracking-widest text-white/20 border-b border-white/5 italic">
                        <th class="pb-6 px-4">Variant Component</th>
                        <th class="pb-6 px-4">Identifier (SKU)</th>
                        <th class="pb-6 px-4">Market Price</th>
                        <th class="pb-6 px-4">Terminal Stock</th>
                        <th class="pb-6 px-4">Status</th>
                        <th class="pb-6 px-4">Operations</th>
                     </tr>
                  </thead>
                  <tbody>
                     {product.variants.map(variant => (
                        <tr class={`group/row hover:bg-white/[0.02] transition-all ${variant.alert ? 'bg-rose-500/5' : ''}`}>
                           <td class="py-6 px-4">
                              <div class="flex items-center gap-4">
                                 <div class="w-3 h-3 rounded-full shadow-[0_0_10px_rgba(255,255,255,0.1)]" style={`background: ${variant.color.toLowerCase().includes('black') ? '#000' : (variant.color.toLowerCase().includes('white') ? '#fff' : '#6366f1')}`}></div>
                                 <span class="font-black italic text-sm">{variant.size} / {variant.color}</span>
                              </div>
                           </td>
                           <td class="py-6 px-4">
                              <code class="text-[10px] font-black text-white/30 bg-white/5 px-2 py-1 rounded-lg uppercase tracking-wider">{variant.sku}</code>
                           </td>
                           <td class="py-6 px-4 font-black italic">₹{variant.price}</td>
                           <td class="py-6 px-4">
                              <div class="flex items-center gap-4">
                                 <div class="w-24 h-2 bg-white/5 rounded-full overflow-hidden">
                                    <div class={`h-full rounded-full ${variant.stock < 5 ? 'bg-rose-500' : variant.stock < 15 ? 'bg-amber-500' : 'bg-emerald-500'}`} style={`width: ${Math.min(variant.stock, 50) * 2}%`}></div>
                                 </div>
                                 <span class="text-sm font-black italic">{variant.stock}</span>
                              </div>
                           </td>
                           <td class="py-6 px-4">
                              <span class={`text-[8px] font-black uppercase tracking-widest px-3 py-1 rounded-full ${variant.stock < 5 ? 'bg-rose-500/10 text-rose-500 border border-rose-500/20' : (variant.stock < 15 ? 'bg-amber-500/10 text-amber-500 border border-amber-500/20' : 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20')}`}>
                                 {variant.stock < 5 ? 'Critical' : (variant.stock < 15 ? 'Refill Needed' : 'Stable')}
                              </span>
                           </td>
                           <td class="py-6 px-4">
                              <div class="flex gap-2">
                                 <button class="p-2 text-white/20 hover:text-white hover:bg-white/10 rounded-xl transition-all"><i class="lucide-edit-3 text-sm"></i></button>
                                 <button class="p-2 text-white/20 hover:text-indigo-400 hover:bg-indigo-500/10 rounded-xl transition-all"><i class="lucide-refresh-cw text-sm"></i></button>
                              </div>
                           </td>
                        </tr>
                     ))}
                  </tbody>
               </table>
            </div>
         </section>
      ))}
   </div>
</RetailOSLayout>
