---
import RetailOSLayout from "../../layouts/RetailOSLayout.astro";

// Mock data for products with variants
const inventory = [
  {
    id: 1,
    name: "Men's Linen Shirt",
    category: "Shirts",
    brand: "Bobo Classic",
    base_price: 1200,
    total_stock: 145,
    variants: [
        { size: "S", color: "White", sku: "SH-LIN-WH-S", stock: 12, price: 1200 },
        { size: "M", color: "White", sku: "SH-LIN-WH-M", stock: 18, price: 1200 },
        { size: "L", color: "White", sku: "SH-LIN-WH-L", stock: 2, price: 1250, alert: true },
        { size: "XL", color: "White", sku: "SH-LIN-WH-XL", stock: 15, price: 1250 },
        { size: "L", color: "Midnight Black", sku: "SH-LIN-BL-L", stock: 24, price: 1300 }
    ]
  },
  {
    id: 2,
    name: "Slim Fit Stretch Jeans",
    category: "Jeans",
    brand: "Denim Co",
    base_price: 2400,
    total_stock: 88,
    variants: [
        { size: "32", color: "Indigo Blue", sku: "JN-SLM-IN-32", stock: 1, price: 2400, alert: true },
        { size: "34", color: "Indigo Blue", sku: "JN-SLM-IN-34", stock: 12, price: 2400 },
        { size: "36", color: "Indigo Blue", sku: "JN-SLM-IN-36", stock: 8, price: 2400 }
    ]
  }
];
---

<RetailOSLayout title="Inventory | Bobo Retail OS">
  <div class="header-section">
      <div>
          <h1 style="font-size: 2rem; margin-bottom: 8px;">Inventory Control</h1>
          <p style="color: var(--text-muted);">Manage your product catalog across multiple stores and channels.</p>
      </div>
      <div class="action-buttons">
          <button class="btn secondary">Bulk Import</button>
          <button class="btn primary">+ Add New Product</button>
      </div>
  </div>

  <div class="filter-bar">
      <div class="search-wrapper">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" placeholder="Search by name, SKU, or barcode..." class="search-input" />
      </div>
      <select class="filter-select">
          <option>All Categories</option>
          <option>Shirts</option>
          <option>Jeans</option>
          <option>Ethnic</option>
      </select>
      <select class="filter-select">
          <option>All Stores</option>
          <option>South City Mall</option>
          <option>High Street Outlet</option>
      </select>
  </div>

  <div class="inventory-container">
      {inventory.map(product => (
          <div class="inventory-card">
              <div class="product-summary">
                  <div class="product-thumb"></div>
                  <div style="flex: 1;">
                      <h3 class="product-name">{product.name}</h3>
                      <div class="product-meta">
                          <span class="badge category">{product.category}</span>
                          <span class="badge brand">{product.brand}</span>
                          <span class="total-stock-label">Total Stock: <strong>{product.total_stock}</strong></span>
                      </div>
                  </div>
                  <div class="predictive-badge">
                      <div class="spark">✨</div>
                      <span>AI: Size L High Demand</span>
                  </div>
              </div>

              <div class="variant-matrix">
                  <table>
                      <thead>
                          <tr>
                              <th>Variant (Size/Color)</th>
                              <th>SKU</th>
                              <th>Base Price</th>
                              <th>Stock Level</th>
                              <th>Status</th>
                              <th>Actions</th>
                          </tr>
                      </thead>
                      <tbody>
                          {product.variants.map(variant => (
                              <tr class={variant.alert ? 'row-alert' : ''}>
                                  <td>
                                      <div class="variant-info">
                                          <div class="color-dot" style={`background: ${variant.color.toLowerCase().includes('black') ? '#000' : (variant.color.toLowerCase().includes('white') ? '#fff' : '#6366f1')}; border: 1px solid rgba(255,255,255,0.2);`}></div>
                                          <span>{variant.size} / {variant.color}</span>
                                      </div>
                                  </td>
                                  <td><code class="sku-code">{variant.sku}</code></td>
                                  <td>₹{variant.price}</td>
                                  <td>
                                      <div class="stock-progress">
                                          <div class="progress-bg">
                                              <div class="progress-fill" style={`width: ${Math.min(variant.stock, 50) * 2}%; background: ${variant.stock < 5 ? '#ef4444' : (variant.stock < 15 ? '#f59e0b' : '#10b981')};`}></div>
                                          </div>
                                          <span class="stock-count">{variant.stock}</span>
                                      </div>
                                  </td>
                                  <td>
                                      <span class={`status-badge ${variant.stock < 5 ? 'critical' : (variant.stock < 15 ? 'warning' : 'healthy')}`}>
                                          {variant.stock < 5 ? 'Low Stock' : (variant.stock < 15 ? 'Reorder Soon' : 'Optimal')}
                                      </span>
                                  </td>
                                  <td>
                                      <div class="actions">
                                          <button class="mini-btn">Edit</button>
                                          <button class="mini-btn">Transfer</button>
                                      </div>
                                  </td>
                              </tr>
                          ))}
                      </tbody>
                  </table>
              </div>
          </div>
      ))}
  </div>

  <style>
      .header-section {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 32px;
      }

      .btn {
          padding: 12px 24px;
          border-radius: 12px;
          font-weight: 700;
          cursor: pointer;
          border: none;
          transition: 0.2s;
      }

      .btn.primary { background: var(--primary); color: white; }
      .btn.secondary { background: var(--bg-glass); color: white; border: 1px solid var(--border); }
      .btn:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.3); }

      .filter-bar {
          display: flex;
          gap: 16px;
          margin-bottom: 24px;
          align-items: center;
      }

      .search-wrapper {
          position: relative;
          flex: 1;
      }

      .search-icon {
          position: absolute;
          left: 16px;
          top: 50%;
          transform: translateY(-50%);
          color: var(--text-muted);
      }

      .search-input {
          width: 100%;
          background: var(--bg-glass);
          border: 1px solid var(--border);
          padding: 12px 16px 12px 48px;
          border-radius: 12px;
          color: white;
          font-size: 0.95rem;
      }

      .filter-select {
          background: var(--bg-glass);
          border: 1px solid var(--border);
          padding: 12px 16px;
          border-radius: 12px;
          color: white;
          cursor: pointer;
      }

      .inventory-container {
          display: flex;
          flex-direction: column;
          gap: 24px;
      }

      .inventory-card {
          background: var(--bg-glass);
          border: 1px solid var(--border);
          border-radius: 20px;
          overflow: hidden;
          backdrop-filter: blur(10px);
      }

      .product-summary {
          padding: 24px;
          display: flex;
          align-items: center;
          gap: 20px;
          border-bottom: 1px solid var(--border);
          background: rgba(255, 255, 255, 0.02);
      }

      .product-thumb {
          width: 64px;
          height: 64px;
          background: #1e293b;
          border-radius: 12px;
          border: 1px solid var(--border);
      }

      .product-name {
          font-size: 1.25rem;
          font-weight: 700;
          margin-bottom: 4px;
      }

      .product-meta {
          display: flex;
          align-items: center;
          gap: 12px;
          font-size: 0.85rem;
      }

      .badge {
          background: rgba(255, 255, 255, 0.05);
          padding: 4px 10px;
          border-radius: 6px;
          color: var(--text-muted);
      }

      .predictive-badge {
          background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(168, 85, 247, 0.1) 100%);
          border: 1px solid rgba(99, 102, 241, 0.2);
          padding: 8px 16px;
          border-radius: 20px;
          display: flex;
          align-items: center;
          gap: 8px;
          font-size: 0.85rem;
          font-weight: 600;
          color: #a5b4fc;
      }

      .variant-matrix {
          padding: 0 24px 24px;
      }

      table {
          width: 100%;
          border-collapse: collapse;
          margin-top: 12px;
      }

      th {
          text-align: left;
          padding: 12px;
          font-size: 0.8rem;
          text-transform: uppercase;
          color: var(--text-muted);
          letter-spacing: 0.05em;
          border-bottom: 1px solid var(--border);
      }

      td {
          padding: 16px 12px;
          border-bottom: 1px solid rgba(255, 255, 255, 0.03);
          font-size: 0.95rem;
      }

      .row-alert {
          background: rgba(239, 68, 68, 0.03);
      }

      .variant-info {
          display: flex;
          align-items: center;
          gap: 12px;
          font-weight: 600;
      }

      .color-dot {
          width: 16px;
          height: 16px;
          border-radius: 50%;
      }

      .sku-code {
          background: rgba(0,0,0,0.3);
          padding: 4px 8px;
          border-radius: 4px;
          color: #a5b4fc;
          font-family: monospace;
          font-size: 0.85rem;
      }

      .stock-progress {
          display: flex;
          align-items: center;
          gap: 12px;
      }

      .progress-bg {
          width: 100px;
          height: 6px;
          background: rgba(255, 255, 255, 0.05);
          border-radius: 3px;
          overflow: hidden;
      }

      .progress-fill {
          height: 100%;
          border-radius: 3px;
      }

      .stock-count {
          font-weight: 700;
          font-size: 0.9rem;
      }

      .status-badge {
          font-size: 0.75rem;
          font-weight: 700;
          text-transform: uppercase;
          padding: 4px 8px;
          border-radius: 4px;
      }

      .status-badge.healthy { color: #10b981; background: rgba(16, 185, 129, 0.1); }
      .status-badge.warning { color: #f59e0b; background: rgba(245, 158, 11, 0.1); }
      .status-badge.critical { color: #ef4444; background: rgba(239, 68, 68, 0.1); }

      .mini-btn {
          background: transparent;
          border: 1px solid var(--border);
          color: var(--text-muted);
          padding: 4px 10px;
          border-radius: 6px;
          cursor: pointer;
          font-size: 0.8rem;
          transition: 0.2s;
      }

      .mini-btn:hover {
          border-color: var(--primary);
          color: white;
      }
  </style>
</RetailOSLayout>
