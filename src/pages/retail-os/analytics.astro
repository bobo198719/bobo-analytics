---
import MainLayout from "../../layouts/MainLayout.astro";
import "../../styles/restaurant.css";

// Analytics Metrics
const metrics = [
  { label: "Conversion Rate", value: "3.2%", trend: "+0.4%", target: "3.5%", color: "#6366f1" },
  { label: "Avg Basket Value", value: "₹2,140", trend: "+₹120", target: "₹2,500", color: "#22d3ee" },
  { label: "Stock Turnover", value: "4.8x", trend: "+0.2x", target: "5.0x", color: "#10b981" },
  { label: "Footfall", value: "45k", trend: "+8.2%", target: "50k", color: "#f59e0b" }
];
---

<MainLayout title="Retail AI Analytics | Bobo OS" hideNav={true}>
  <div class="flex h-screen bg-[#05081a] overflow-hidden font-['Plus_Jakarta_Sans'] text-white">
    
    <!-- Sidebar -->
    <aside class="w-20 md:w-24 border-r border-white/10 bg-[#05081a]/50 backdrop-blur-2xl flex flex-col justify-between py-10 items-center">
      <div class="flex flex-col gap-8">
        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center font-black text-white text-xl shadow-lg shadow-indigo-600/20 italic">B</div>
        <nav class="flex flex-col gap-6">
           <a href="/retail-os" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-layout-grid text-xl"></i>
           </a>
           <a href="/retail-os/inventory" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-box text-xl"></i>
           </a>
           <a href="/pos-clothing" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all font-bold">
              <i class="lucide-receipt text-xl"></i>
           </a>
           <a href="/retail-os/customers" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-users-2 text-xl"></i>
           </a>
           <a href="/retail-os/analytics" class="p-4 text-indigo-400 bg-indigo-500/10 rounded-2xl transition-all shadow-lg shadow-indigo-500/5">
              <i class="lucide-bar-chart-3 text-xl"></i>
           </a>
        </nav>
      </div>

      <div class="flex flex-col gap-6">
         <a href="/crm-login" class="p-4 text-white/20 hover:text-rose-400 hover:bg-rose-400/10 rounded-2xl transition-all"><i class="lucide-log-out text-xl"></i></a>
      </div>
    </aside>

    <!-- Content Workspace -->
    <main class="flex-1 overflow-y-auto custom-scrollbar p-6 md:p-12 relative">
       
       <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
          <div>
             <h1 class="text-3xl font-black italic uppercase tracking-tighter">AI DATA ANALYTICS</h1>
             <p class="text-white/40 text-xs font-bold uppercase tracking-[0.2em] mt-2 italic">Data Stream: Retail Intelligence v4.0</p>
          </div>
          <div class="flex items-center gap-4">
             <button class="px-6 py-3 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all italic">Schedule Report</button>
             <button class="px-6 py-3 bg-indigo-600 rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-indigo-600/20 hover:scale-[1.05] transition-all italic">Download PDF</button>
          </div>
       </header>

       <!-- Metrics Grid -->
       <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
          {metrics.map(metric => (
             <div class="bg-white/5 border border-white/10 p-8 rounded-[40px] group hover:bg-white/[0.08] transition-all">
                <div class="flex justify-between items-start mb-6">
                   <span class="text-[10px] font-black uppercase tracking-widest text-white/30 italic">{metric.label}</span>
                   <span class={`text-[8px] font-black italic px-2 py-1 rounded-lg ${metric.trend.startsWith('+') ? 'text-emerald-400 bg-emerald-500/10' : 'text-rose-400 bg-rose-500/10'}`}>{metric.trend} Today</span>
                </div>
                <div class="text-3xl font-black italic tracking-tighter mb-6" style={`color: ${metric.color}`}>{metric.value}</div>
                
                <div class="space-y-2">
                   <div class="flex justify-between text-[8px] font-black uppercase text-white/20 italic">
                      <span>Target: {metric.target}</span>
                      <span>Progress: 85%</span>
                   </div>
                   <div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden">
                      <div class="h-full rounded-full transition-all duration-1000" style={`width: 85%; background: ${metric.color}`}></div>
                   </div>
                </div>
             </div>
          ))}
       </div>

       <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          
          <!-- Line Chart Panel -->
          <section class="bg-white/5 border border-white/10 rounded-[48px] p-10 relative overflow-hidden group">
             <div class="flex items-center justify-between mb-10">
                <h2 class="text-lg font-black italic uppercase tracking-tight">Sales Trend Analysis</h2>
                <div class="flex gap-4">
                   <div class="flex items-center gap-2 text-[8px] font-black uppercase text-white/30 italic"><div class="w-2 h-2 rounded-full bg-indigo-500"></div> Shirts</div>
                   <div class="flex items-center gap-2 text-[8px] font-black uppercase text-white/30 italic"><div class="w-2 h-2 rounded-full bg-cyan-500"></div> Jeans</div>
                </div>
             </div>
             
             <div class="h-64 relative">
                <svg width="100%" height="100%" viewBox="0 0 1000 200" preserveAspectRatio="none" class="drop-shadow-[0_0_15px_rgba(99,102,241,0.2)]">
                   <path d="M0,180 L200,140 L400,160 L600,80 L800,110 L1000,40" stroke="#6366f1" stroke-width="6" fill="none" class="animate-[dash_2s_ease-out_forwards]" style="stroke-dasharray: 2000; stroke-dashoffset: 2000;" />
                   <path d="M0,150 L200,170 L400,120 L600,130 L800,60 L1000,90" stroke="#22d3ee" stroke-width="6" fill="none" class="animate-[dash_2s_ease-out_forwards] delay-300" style="stroke-dasharray: 2000; stroke-dashoffset: 2000;" />
                </svg>
             </div>
             
             <div class="flex justify-between mt-8 px-4 text-[10px] font-black uppercase tracking-widest text-white/20">
                <span>MON</span><span>TUE</span><span>WED</span><span>THU</span><span>FRI</span><span>SAT</span><span>SUN</span>
             </div>
          </section>

          <!-- Distribution Panel -->
          <section class="bg-white/5 border border-white/10 rounded-[48px] p-10">
             <h2 class="text-lg font-black italic uppercase tracking-tight mb-10">Volume Distribution</h2>
             <div class="flex items-center gap-12">
                <div class="relative w-48 h-48 rounded-full border-[20px] border-white/5 flex items-center justify-center">
                   <div class="text-center">
                      <div class="text-3xl font-black italic tracking-tighter text-indigo-400">42%</div>
                      <div class="text-[8px] font-black uppercase tracking-widest text-white/30">Size M Dominance</div>
                   </div>
                   <!-- Simple CSS conic gradient representive of segments -->
                   <div class="absolute inset-[-20px] rounded-full border-[20px] border-transparent border-t-indigo-500 border-r-cyan-500 rotate-45 opacity-50"></div>
                </div>
                <div class="flex-1 space-y-4">
                   {[
                      { l: "Small (S)", v: "12%", vnum: 12, c: "bg-white/20" },
                      { l: "Medium (M)", v: "42%", vnum: 42, c: "bg-indigo-500" },
                      { l: "Large (L)", v: "35%", vnum: 35, c: "bg-cyan-500" },
                      { l: "XL+", v: "11%", vnum: 11, c: "bg-rose-500" }
                   ].map(item => (
                      <div class="p-4 bg-white/5 border border-white/5 rounded-2xl flex justify-between items-center group hover:border-indigo-500/30 transition-all cursor-crosshair">
                         <div class="flex items-center gap-3">
                            <div class={`w-2 h-2 rounded-full ${item.c}`}></div>
                            <span class="text-[10px] font-black uppercase tracking-widest text-white/60">{item.l}</span>
                         </div>
                         <span class="text-xs font-black italic text-white">{item.v}</span>
                      </div>
                   ))}
                </div>
             </div>
          </section>

       </div>

    </main>
  </div>

  <script is:inline>
     // Auth Guard
     if (localStorage.getItem('retail_os_auth') !== 'true') {
        window.location.href = "/retail-os-login";
     }
  </script>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #05081a; }

    @keyframes dash {
       to { stroke-dashoffset: 0; }
    }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.01); }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.05); border-radius: 10px; }
  </style>

  <!-- Lucide Icon Support -->
  <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">
</MainLayout>
