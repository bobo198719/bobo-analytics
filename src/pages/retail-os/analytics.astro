---
import RetailOSLayout from "../../layouts/RetailOSLayout.astro";

// Analytics Metrics
const metrics = [
  { label: "Conversion Rate", value: "3.2%", trend: "+0.4%", target: "3.5%", color: "var(--primary)" },
  { label: "Avg Basket Value", value: "₹2,140", trend: "+₹120", target: "₹2,500", color: "var(--secondary)" },
  { label: "Stock Turnover", value: "4.8x", trend: "+0.2x", target: "5.0x", color: "var(--success)" },
  { label: "Footfall", value: "45k", trend: "+8.2%", target: "50k", color: "#f59e0b" }
];
---

<RetailOSLayout title="Analytics | Bobo Retail OS">
  <div class="header-section">
      <div>
          <h1 style="font-size: 2rem; margin-bottom: 8px;">Retail Analytics</h1>
          <p style="color: var(--text-muted);">Deep dive into your store's performance with AI-driven datasets.</p>
      </div>
      <div class="action-buttons">
          <button class="btn secondary">Schedule Report</button>
          <button class="btn primary">Download PDF</button>
      </div>
  </div>

  <div class="metrics-grid">
      {metrics.map(metric => (
          <div class="metric-card">
              <div class="metric-info">
                  <span class="metric-label">{metric.label}</span>
                  <div class="metric-value-row">
                      <span class="metric-value" style={`color: ${metric.color}`}>{metric.value}</span>
                      <span class="metric-trend" style={metric.trend.startsWith('+') ? 'color: #10b981;' : 'color: #ef4444;'}>{metric.trend}</span>
                  </div>
              </div>
              <div class="metric-progress">
                  <div class="progress-header">
                      <span>Progress to Target ({metric.target})</span>
                      <span>{Math.round((parseFloat(metric.value.replace(/[^\d.]/g, '')) / parseFloat(metric.target.replace(/[^\d.]/g, ''))) * 100)}%</span>
                  </div>
                  <div class="progress-track">
                      <div class="progress-fill" style={`width: 85%; background: ${metric.color};`}></div>
                  </div>
              </div>
          </div>
      ))}
  </div>

  <div class="main-charts-grid">
      <div class="panel">
          <div class="panel-header">
              <h3>Sales Trend by Category</h3>
              <div class="chart-legend">
                  <div class="legend-item"><span class="dot primary"></span> Shirts</div>
                  <div class="legend-item"><span class="dot secondary"></span> Jeans</div>
                  <div class="legend-item"><span class="dot success"></span> Ethnic</div>
              </div>
          </div>
          <div class="line-chart-mock">
              <svg width="100%" height="200" viewBox="0 0 1000 200" preserveAspectRatio="none">
                  <path d="M0,180 L200,140 L400,160 L600,80 L800,110 L1000,40" stroke="var(--primary)" stroke-width="4" fill="none" />
                  <path d="M0,150 L200,170 L400,120 L600,130 L800,60 L1000,90" stroke="var(--secondary)" stroke-width="4" fill="none" />
                  <path d="M0,190 L200,160 L400,180 L600,140 L800,150 L1000,120" stroke="var(--success)" stroke-width="4" fill="none" />
              </svg>
              <div class="chart-labels">
                  <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
              </div>
          </div>
      </div>

      <div class="panel">
          <div class="panel-header">
              <h3>Top Selling Variants (BySize)</h3>
          </div>
          <div class="pie-chart-mock">
              <div class="segment s1" style="transform: rotate(0deg) skew(40deg); background: var(--primary);"></div>
              <div class="segment s2" style="transform: rotate(50deg) skew(60deg); background: var(--secondary);"></div>
              <div class="segment s3" style="transform: rotate(150deg) skew(20deg); background: var(--success);"></div>
              <div class="segment s4" style="transform: rotate(250deg) skew(30deg); background: #f59e0b;"></div>
              <div class="pie-center">
                  <span class="main-label">Size M</span>
                  <span class="sub-label">42% Volume</span>
              </div>
          </div>
          <div class="chart-list">
              <div class="list-item"><span>Small (S)</span> <strong style="color: var(--primary);">12%</strong></div>
              <div class="list-item"><span>Medium (M)</span> <strong style="color: var(--secondary);">42%</strong></div>
              <div class="list-item"><span>Large (L)</span> <strong style="color: var(--success);">35%</strong></div>
              <div class="list-item"><span>XL+</span> <strong style="color: #f59e0b;">11%</strong></div>
          </div>
      </div>
  </div>

  <style>
      .header-section {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 32px;
      }

      .btn {
          padding: 12px 24px;
          border-radius: 12px;
          font-weight: 700;
          cursor: pointer;
          border: none;
          transition: 0.2s;
      }

      .btn.primary { background: var(--primary); color: white; }
      .btn.secondary { background: var(--bg-glass); color: white; border: 1px solid var(--border); }

      .metrics-grid {
          display: grid;
          grid-template-columns: repeat(4, 1fr);
          gap: 20px;
          margin-bottom: 32px;
      }

      .metric-card {
          background: var(--bg-glass);
          border: 1px solid var(--border);
          border-radius: 20px;
          padding: 24px;
          backdrop-filter: blur(10px);
      }

      .metric-label {
          font-size: 0.85rem;
          color: var(--text-muted);
          font-weight: 500;
          display: block;
          margin-bottom: 8px;
      }

      .metric-value-row {
          display: flex;
          align-items: baseline;
          gap: 12px;
          margin-bottom: 20px;
      }

      .metric-value {
          font-size: 1.75rem;
          font-weight: 800;
          font-family: 'Outfit', sans-serif;
      }

      .metric-trend {
          font-size: 0.85rem;
          font-weight: 700;
      }

      .metric-progress {
          display: flex;
          flex-direction: column;
          gap: 8px;
      }

      .progress-header {
          display: flex;
          justify-content: space-between;
          font-size: 0.75rem;
          color: var(--text-muted);
      }

      .progress-track {
          height: 6px;
          background: rgba(255, 255, 255, 0.05);
          border-radius: 3px;
          overflow: hidden;
      }

      .progress-fill {
          height: 100%;
          border-radius: 3px;
          box-shadow: 0 0 10px rgba(99, 102, 241, 0.2);
      }

      .main-charts-grid {
          display: grid;
          grid-template-columns: 1fr 340px;
          gap: 20px;
      }

      .panel {
          background: var(--bg-glass);
          border: 1px solid var(--border);
          border-radius: 20px;
          padding: 24px;
          backdrop-filter: blur(10px);
      }

      .panel-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 24px;
      }

      .chart-legend {
          display: flex;
          gap: 16px;
      }

      .legend-item {
          display: flex;
          align-items: center;
          gap: 6px;
          font-size: 0.8rem;
          color: var(--text-muted);
      }

      .dot {
          width: 8px;
          height: 8px;
          border-radius: 50%;
      }

      .dot.primary { background: var(--primary); }
      .dot.secondary { background: var(--secondary); }
      .dot.success { background: var(--success); }

      .line-chart-mock {
          padding: 20px;
          background: rgba(0,0,0,0.2);
          border-radius: 12px;
      }

      .chart-labels {
          display: flex;
          justify-content: space-between;
          margin-top: 10px;
          font-size: 0.75rem;
          color: var(--text-muted);
      }

      .pie-chart-mock {
          width: 200px;
          height: 200px;
          margin: 0 auto 32px;
          position: relative;
          background: var(--bg-glass);
          border-radius: 50%;
          overflow: hidden;
          display: flex;
          align-items: center;
          justify-content: center;
      }

      .segment {
          position: absolute;
          width: 200px;
          height: 200px;
          top: -100px;
          left: -100px;
          transform-origin: 100% 100%;
      }

      .pie-center {
          width: 120px;
          height: 120px;
          background: #0b112d;
          border-radius: 50%;
          z-index: 10;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          border: 1px solid var(--border);
      }

      .chart-list {
          display: flex;
          flex-direction: column;
          gap: 12px;
      }

      .list-item {
          display: flex;
          justify-content: space-between;
          padding: 8px 12px;
          background: rgba(255, 255, 255, 0.03);
          border-radius: 8px;
          font-size: 0.9rem;
      }
  </style>
</RetailOSLayout>
