---
import MainLayout from "../../layouts/MainLayout.astro";
import "../../styles/restaurant.css";

// Mock data for customers
const customers = [
  {
    id: 1,
    name: "Rahul Sharma",
    phone: "+91 98765 43210",
    email: "rahul.s@example.com",
    tag: "VIP",
    spend: "₹18,250",
    visits: 12,
    wallet: "₹450",
    loyalty: 1250,
    status: "Active"
  },
  {
    id: 2,
    name: "Ananya Iyer",
    phone: "+91 98321 09876",
    email: "ananya.i@example.com",
    tag: "Repeat",
    spend: "₹8,400",
    visits: 5,
    wallet: "₹120",
    loyalty: 420,
    status: "Active"
  },
  {
    id: 3,
    name: "Vikram Gupta",
    phone: "+91 91234 56789",
    email: "vikram.g@example.com",
    tag: "High Value",
    spend: "₹45,000",
    visits: 28,
    wallet: "₹2,100",
    loyalty: 6800,
    status: "Dormant"
  }
];
---

<MainLayout title="Retail CRM Terminal | Bobo OS" hideNav={true}>
  <div class="flex h-screen bg-[#05081a] overflow-hidden font-['Plus_Jakarta_Sans'] text-white">
    
    <!-- Sidebar -->
    <aside class="w-20 md:w-24 border-r border-white/10 bg-[#05081a]/50 backdrop-blur-2xl flex flex-col justify-between py-10 items-center">
      <div class="flex flex-col gap-8">
        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center font-black text-white text-xl shadow-lg shadow-indigo-600/20 italic">B</div>
        <nav class="flex flex-col gap-6">
           <a href="/retail-os" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-layout-grid text-xl"></i>
           </a>
           <a href="/retail-os/inventory" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-box text-xl"></i>
           </a>
           <a href="/pos-clothing" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all font-bold">
              <i class="lucide-receipt text-xl"></i>
           </a>
           <a href="/retail-os/customers" class="p-4 text-indigo-400 bg-indigo-500/10 rounded-2xl transition-all shadow-lg shadow-indigo-500/5">
              <i class="lucide-users-2 text-xl"></i>
           </a>
           <a href="/retail-os/analytics" class="p-4 text-white/20 hover:text-white hover:bg-white/5 rounded-2xl transition-all">
              <i class="lucide-bar-chart-3 text-xl"></i>
           </a>
        </nav>
      </div>

      <div class="flex flex-col gap-6">
         <a href="/crm-login" class="p-4 text-white/20 hover:text-rose-400 hover:bg-rose-400/10 rounded-2xl transition-all"><i class="lucide-log-out text-xl"></i></a>
      </div>
    </aside>

    <!-- Content Workspace -->
    <main class="flex-1 overflow-y-auto custom-scrollbar p-6 md:p-12 relative">
       
       <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
          <div>
             <h1 class="text-3xl font-black italic uppercase tracking-tighter">Customer CRM</h1>
             <p class="text-white/40 text-xs font-bold uppercase tracking-[0.2em] mt-2 italic">Intelligence Lab: Relationship Manager</p>
          </div>
          <div class="flex items-center gap-4">
             <button class="px-6 py-3 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all italic">Export Data</button>
             <button class="px-6 py-3 bg-indigo-600 rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-indigo-600/20 hover:scale-[1.05] transition-all italic">+ New Lead</button>
          </div>
       </header>

       <!-- Summary Grid -->
       <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          {[
             { label: "VIP Segments", val: "24", icon: "💎", color: "from-indigo-500/20" },
             { label: "Dormant (30d+)", val: "12", icon: "⏰", color: "from-rose-500/20" },
             { label: "Loyalty Points", val: "142k", icon: "🎟️", color: "from-emerald-500/20" }
          ].map(card => (
             <div class={`bg-gradient-to-br ${card.color} to-transparent border border-white/10 p-8 rounded-[40px] flex items-center gap-6 group hover:scale-[1.02] transition-all`}>
                <div class="w-16 h-16 bg-white/10 rounded-3xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform">{card.icon}</div>
                <div>
                   <span class="text-[10px] font-black uppercase tracking-widest text-white/30 italic">{card.label}</span>
                   <div class="text-3xl font-black italic tracking-tighter">{card.val}</div>
                </div>
             </div>
          ))}
       </div>

       <!-- Filter Bar -->
       <div class="flex gap-4 mb-12 items-center">
          <div class="relative flex-1 group">
             <i class="lucide-search absolute left-5 top-1/2 -translate-y-1/2 text-white/20 group-focus-within:text-indigo-500 transition-colors"></i>
             <input type="text" placeholder="QUERY NAME, PHONE OR EMAIL..." class="w-full bg-white/5 border border-white/10 p-4 pl-14 rounded-2xl outline-none focus:border-indigo-500 transition-all font-black text-[10px] uppercase tracking-widest" />
          </div>
          <select class="bg-white/5 border border-white/10 p-4 rounded-2xl outline-none text-[10px] font-black uppercase tracking-widest italic cursor-pointer">
             <option>All Segments</option>
             <option>VIP Only</option>
             <option>Dormant Only</option>
          </select>
       </div>

       <!-- Customers Table -->
       <section class="bg-white/5 border border-white/10 rounded-[48px] overflow-hidden">
          <div class="p-8 overflow-x-auto">
             <table class="w-full text-left">
                <thead>
                   <tr class="text-[10px] font-black uppercase tracking-widest text-white/20 border-b border-white/5 italic">
                      <th class="pb-6 px-4">Profile Instance</th>
                      <th class="pb-6 px-4">Segment Tag</th>
                      <th class="pb-6 px-4">Direct Spend</th>
                      <th class="pb-6 px-4">Visits</th>
                      <th class="pb-6 px-4">Wallet Balance</th>
                      <th class="pb-6 px-4">Loyalty</th>
                      <th class="pb-6 px-4">Status</th>
                      <th class="pb-6 px-4">Operations</th>
                   </tr>
                </thead>
                <tbody>
                   {customers.map(customer => (
                      <tr class="group/row hover:bg-white/[0.02] transition-all">
                         <td class="py-6 px-4">
                            <div class="flex items-center gap-4">
                               <div class="w-10 h-10 bg-gradient-to-br from-indigo-500 to-cyan-500 rounded-full flex items-center justify-center text-[10px] font-black italic border border-white/10">
                                  {customer.name.split(' ').map(n=>n[0]).join('')}
                               </div>
                               <div>
                                  <div class="font-black italic text-sm">{customer.name}</div>
                                  <div class="text-[8px] font-black uppercase text-white/20 tracking-widest">{customer.phone}</div>
                               </div>
                            </div>
                         </td>
                         <td class="py-6 px-4">
                            <span class={`text-[8px] font-black uppercase tracking-widest px-3 py-1 rounded-full border ${customer.tag === 'VIP' ? 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20' : 'bg-white/5 text-white/40 border-white/10'}`}>
                               {customer.tag}
                            </span>
                         </td>
                         <td class="py-6 px-4 text-emerald-400 font-black italic">{customer.spend}</td>
                         <td class="py-6 px-4 font-black italic text-white/60">{customer.visits}</td>
                         <td class="py-6 px-4 text-amber-500 font-black italic text-sm">{customer.wallet}</td>
                         <td class="py-6 px-4 font-black italic text-indigo-400">{customer.loyalty}</td>
                         <td class="py-6 px-4">
                            <div class="flex items-center gap-2">
                               <div class={`w-1.5 h-1.5 rounded-full ${customer.status === 'Active' ? 'bg-emerald-500 animate-pulse' : 'bg-white/20'}`}></div>
                               <span class="text-[8px] font-black uppercase tracking-widest text-white/40 italic">{customer.status}</span>
                            </div>
                         </td>
                         <td class="py-6 px-4">
                            <button class="px-4 py-2 bg-white/5 border border-white/10 rounded-xl text-[8px] font-black uppercase tracking-widest hover:border-indigo-500 transition-all italic">Profile Hub</button>
                         </td>
                      </tr>
                   ))}
                </tbody>
             </table>
          </div>
       </section>

    </main>
  </div>

  <script is:inline>
     // Auth Guard
     if (localStorage.getItem('retail_os_auth') !== 'true') {
        window.location.href = "/retail-os-login";
     }
  </script>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #05081a; }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.01); }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.05); border-radius: 10px; }
  </style>

  <!-- Lucide Icon Support -->
  <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">
</MainLayout>
</RetailOSLayout>
