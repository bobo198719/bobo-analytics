---
import RetailOSLayout from "../../layouts/RetailOSLayout.astro";

// Mock data for customers
const customers = [
  {
    id: 1,
    name: "Rahul Sharma",
    phone: "+91 98765 43210",
    email: "rahul.s@example.com",
    tag: "VIP",
    spend: "₹18,250",
    visits: 12,
    wallet: "₹450",
    loyalty: 1250,
    status: "Active"
  },
  {
    id: 2,
    name: "Ananya Iyer",
    phone: "+91 98321 09876",
    email: "ananya.i@example.com",
    tag: "Repeat",
    spend: "₹8,400",
    visits: 5,
    wallet: "₹120",
    loyalty: 420,
    status: "Active"
  },
  {
    id: 3,
    name: "Vikram Gupta",
    phone: "+91 91234 56789",
    email: "vikram.g@example.com",
    tag: "High Value",
    spend: "₹45,000",
    visits: 28,
    wallet: "₹2,100",
    loyalty: 6800,
    status: "Dormant"
  }
];
---

<RetailOSLayout title="CRM | Bobo Retail OS">
  <div class="header-section">
      <div>
          <h1 style="font-size: 2rem; margin-bottom: 8px;">Customer CRM</h1>
          <p style="color: var(--text-muted);">Manage high-value relationships and AI-driven loyalty programs.</p>
      </div>
      <div class="action-buttons">
          <button class="btn secondary">Export Data</button>
          <button class="btn primary">+ New Customer</button>
      </div>
  </div>

  <div class="crm-summary-grid">
      <div class="summary-card vip">
          <div class="summary-icon">💎</div>
          <div class="summary-info">
              <span class="summary-label">VIP Customers</span>
              <span class="summary-value">24</span>
          </div>
      </div>
      <div class="summary-card dormant">
          <div class="summary-icon">⏰</div>
          <div class="summary-info">
              <span class="summary-label">Dormant (30d+)</span>
              <span class="summary-value">12</span>
          </div>
      </div>
      <div class="summary-card loyalty">
          <div class="summary-icon">🎟️</div>
          <div class="summary-info">
              <span class="summary-label">Loyalty Redeemed</span>
              <span class="summary-value">142k PTs</span>
          </div>
      </div>
  </div>

  <div class="filter-bar">
      <div class="search-wrapper">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" placeholder="Search customer by name, phone or email..." class="search-input" />
      </div>
      <select class="filter-select">
          <option>All Segments</option>
          <option>VIP</option>
          <option>Dormant</option>
          <option>New Customers</option>
      </select>
  </div>

  <div class="crm-content">
      <div class="customer-list-panel">
          <table>
              <thead>
                  <tr>
                      <th>Customer</th>
                      <th>Segment</th>
                      <th>Total Spend</th>
                      <th>Visits</th>
                      <th>Wallet</th>
                      <th>Loyalty PTs</th>
                      <th>Status</th>
                      <th></th>
                  </tr>
              </thead>
              <tbody>
                  {customers.map(customer => (
                      <tr class="customer-row">
                          <td>
                              <div class="customer-info-cell">
                                  <div class="avatar-small">{customer.name.split(' ').map(n=>n[0]).join('')}</div>
                                  <div>
                                      <div class="name">{customer.name}</div>
                                      <div class="phone">{customer.phone}</div>
                                  </div>
                              </div>
                          </td>
                          <td>
                              <span class={`tag ${customer.tag.toLowerCase().replace(' ', '-')}`}>{customer.tag}</span>
                          </td>
                          <td class="spend">{customer.spend}</td>
                          <td>{customer.visits}</td>
                          <td class="wallet">{customer.wallet}</td>
                          <td class="loyalty">{customer.loyalty}</td>
                          <td>
                              <span class={`status-dot ${customer.status.toLowerCase()}`}></span>
                              {customer.status}
                          </td>
                          <td>
                              <button class="view-btn">View Profile</button>
                          </td>
                      </tr>
                  ))}
              </tbody>
          </table>
      </div>
  </div>

  <style>
      .header-section {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 32px;
      }

      .btn {
          padding: 12px 24px;
          border-radius: 12px;
          font-weight: 700;
          cursor: pointer;
          border: none;
          transition: 0.2s;
      }

      .btn.primary { background: var(--primary); color: white; }
      .btn.secondary { background: var(--bg-glass); color: white; border: 1px solid var(--border); }

      .crm-summary-grid {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 20px;
          margin-bottom: 32px;
      }

      .summary-card {
          padding: 24px;
          background: var(--bg-glass);
          border: 1px solid var(--border);
          border-radius: 20px;
          display: flex;
          align-items: center;
          gap: 20px;
          backdrop-filter: blur(10px);
      }

      .summary-icon {
          width: 48px;
          height: 48px;
          background: rgba(255, 255, 255, 0.05);
          border-radius: 12px;
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 1.5rem;
      }

      .summary-label {
          display: block;
          font-size: 0.85rem;
          color: var(--text-muted);
          font-weight: 500;
          margin-bottom: 4px;
      }

      .summary-value {
          font-size: 1.5rem;
          font-weight: 800;
          font-family: 'Outfit', sans-serif;
      }

      .filter-bar {
          display: flex;
          gap: 16px;
          margin-bottom: 24px;
          align-items: center;
      }

      .search-wrapper {
          position: relative;
          flex: 1;
      }

      .search-icon {
          position: absolute;
          left: 16px;
          top: 50%;
          transform: translateY(-50%);
          color: var(--text-muted);
      }

      .search-input {
          width: 100%;
          background: var(--bg-glass);
          border: 1px solid var(--border);
          padding: 12px 16px 12px 48px;
          border-radius: 12px;
          color: white;
          font-size: 0.95rem;
      }

      .filter-select {
          background: var(--bg-glass);
          border: 1px solid var(--border);
          padding: 12px 16px;
          border-radius: 12px;
          color: white;
      }

      .customer-list-panel {
          background: var(--bg-glass);
          border: 1px solid var(--border);
          border-radius: 20px;
          overflow: hidden;
          backdrop-filter: blur(10px);
      }

      table {
          width: 100%;
          border-collapse: collapse;
      }

      th {
          text-align: left;
          padding: 16px 24px;
          font-size: 0.8rem;
          text-transform: uppercase;
          color: var(--text-muted);
          letter-spacing: 0.05em;
          border-bottom: 1px solid var(--border);
      }

      td {
          padding: 16px 24px;
          border-bottom: 1px solid rgba(255, 255, 255, 0.03);
          font-size: 0.95rem;
      }

      .customer-info-cell {
          display: flex;
          align-items: center;
          gap: 12px;
      }

      .avatar-small {
          width: 40px;
          height: 40px;
          border-radius: 50%;
          background: linear-gradient(135deg, #a5b4fc, #818cf8);
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 0.8rem;
          font-weight: 700;
          color: #1e1b4b;
      }

      .name { font-weight: 700; font-size: 1rem; }
      .phone { font-size: 0.8rem; color: var(--text-muted); }

      .tag {
          font-size: 0.75rem;
          font-weight: 700;
          padding: 4px 10px;
          border-radius: 20px;
          border: 1px solid transparent;
      }

      .tag.vip { background: rgba(99, 102, 241, 0.1); color: var(--primary); border-color: var(--primary); }
      .tag.repeat { background: rgba(16, 185, 129, 0.1); color: #10b981; border-color: #10b981; }
      .tag.high-value { background: rgba(168, 85, 247, 0.1); color: var(--secondary); border-color: var(--secondary); }

      .spend { font-weight: 700; color: #10b981; }
      .wallet { color: #f59e0b; font-weight: 600; }
      .loyalty { color: #818cf8; font-weight: 600; }

      .status-dot {
          display: inline-block;
          width: 8px;
          height: 8px;
          border-radius: 50%;
          margin-right: 6px;
      }

      .status-dot.active { background: #10b981; box-shadow: 0 0 8px #10b981; }
      .status-dot.dormant { background: #64748b; }

      .view-btn {
          background: transparent;
          border: 1px solid var(--border);
          color: var(--text-muted);
          padding: 6px 14px;
          border-radius: 8px;
          cursor: pointer;
          font-size: 0.85rem;
          transition: 0.2s;
      }

      .view-btn:hover {
          background: var(--primary);
          border-color: var(--primary);
          color: white;
      }
  </style>
</RetailOSLayout>
