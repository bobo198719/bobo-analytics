---
import RetailOSLayout from "../../layouts/RetailOSLayout.astro";

// Mock data for AI Insights
const aiInsights = [
  { message: "Black Linen Shirts (L) are selling 24% faster than average this week.", type: "velocity" },
  { message: "Stock for Red Kurti (M) will deplete in 4 days. Suggest ordering 50 units.", type: "forecast" },
  { message: "Detected high return rate for Blue Slim Fit Jeans. Check sizing consistency.", type: "quality" }
];

const stats = [
  { label: "Today's Revenue", value: "₹84,250", trend: "+12.5%", color: "#6366f1", icon: "lucide-trending-up" },
  { label: "Active Orders", value: "42", trend: "Steady", color: "#22d3ee", icon: "lucide-shopping-bag" },
  { label: "Live Visits", value: "318", trend: "+8.2%", color: "#10b981", icon: "lucide-users" },
  { label: "Predictive LTV", value: "₹4.2k", trend: "+5.1%", color: "#f472b6", icon: "lucide-sparkles" }
];
---

<RetailOSLayout title="Retail Intelligence Dashboard | Bobo Analytics">
   <!-- Ambient Glow -->
   <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-indigo-600/5 rounded-full blur-[120px] -mr-64 -mt-64 pointer-events-none"></div>

   <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
      <div>
         <h1 class="text-3xl font-black italic uppercase tracking-tighter">Retail Intelligence</h1>
         <p class="text-white/40 text-xs font-bold uppercase tracking-[0.2em] mt-2 italic">Workspace: South City Mall Terminal</p>
      </div>
      <div class="flex items-center gap-4">
         <div class="px-6 py-3 bg-white/5 border border-white/10 rounded-2xl flex items-center gap-4">
            <div class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></div>
            <span class="text-[10px] font-black uppercase tracking-widest text-white/60">Live Engine Active</span>
         </div>
         <button class="w-12 h-12 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center hover:bg-white/10 transition-all text-white/40 hover:text-white">
            <i class="lucide-bell text-lg"></i>
         </button>
      </div>
   </header>

   <!-- Stats Grid -->
   <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {stats.map(stat => (
         <div class="bg-white/5 border border-white/10 p-8 rounded-[40px] group hover:bg-white/[0.08] transition-all relative overflow-hidden">
            <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity">
               <i class={`${stat.icon} text-6xl`}></i>
            </div>
            <div class="relative z-10">
               <div class="flex items-center justify-between mb-4">
                  <span class="text-[10px] font-black uppercase tracking-widest text-white/30 italic">{stat.label}</span>
                  <span class="text-[10px] font-black text-emerald-400 italic bg-emerald-500/10 px-2 py-1 rounded-lg">{stat.trend}</span>
               </div>
               <div class="text-4xl font-black italic tracking-tighter" style={`color: ${stat.color}`}>{stat.value}</div>
            </div>
         </div>
      ))}
   </div>

   <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- AI Insights Section -->
      <div class="lg:col-span-2 space-y-8">
         <section class="bg-white/5 border border-white/10 rounded-[48px] p-10 relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 to-transparent"></div>
            <div class="flex items-center justify-between mb-8 relative z-10">
               <h2 class="text-lg font-black italic uppercase tracking-tight flex items-center gap-3">
                  <span class="p-2 bg-indigo-500/20 rounded-xl text-indigo-400"><i class="lucide-sparkles"></i></span>
                  Retail AI Intelligence
               </h2>
               <button class="text-[10px] font-black uppercase tracking-widest text-white/40 hover:text-white transition-colors italic">Refresh Analysis</button>
            </div>

            <div class="space-y-4 relative z-10">
               {aiInsights.map(insight => (
                  <div class="p-6 bg-white/5 border border-white/5 rounded-3xl flex items-center gap-6 group/item hover:border-indigo-500/30 transition-all">
                     <div class={`w-2 h-2 rounded-full ${insight.type === 'velocity' ? 'bg-indigo-500' : insight.type === 'forecast' ? 'bg-cyan-500' : 'bg-rose-500'} shadow-[0_0_15px_rgba(255,255,255,0.2)]`}></div>
                     <p class="text-sm font-bold text-white/80 italic leading-relaxed">{insight.message}</p>
                  </div>
               ))}
            </div>
         </section>

         <section class="bg-white/5 border border-white/10 rounded-[48px] p-10">
            <h2 class="text-lg font-black italic uppercase tracking-tight mb-8">Hourly Distribution</h2>
            <div class="h-48 flex items-end gap-3 px-4">
               {[40, 60, 30, 90, 70, 50, 85, 45, 65, 80, 55, 75].map((h, i) => (
                  <div class="flex-1 group relative">
                     <div class={`w-full bg-indigo-500/20 rounded-t-xl group-hover:bg-indigo-500 transition-all cursor-pointer ${h === 90 ? 'bg-indigo-500 shadow-lg shadow-indigo-500/20' : ''}`} style={`height: ${h}%`}></div>
                     <div class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 scale-0 group-hover:scale-100 transition-transform px-2 py-1 bg-white text-black text-[10px] font-black rounded-lg">₹{(h * 1.5).toFixed(1)}k</div>
                  </div>
               ))}
            </div>
            <div class="flex justify-between mt-6 px-4 text-[10px] font-black uppercase tracking-widest text-white/20">
               <span>09:00</span>
               <span>12:00</span>
               <span>15:00</span>
               <span>18:00</span>
               <span>21:00</span>
            </div>
         </section>
      </div>

      <!-- Fast Action Panel -->
      <div class="space-y-8">
         <section class="bg-white/5 border border-white/10 rounded-[48px] p-10">
            <h2 class="text-lg font-black italic uppercase tracking-tight mb-8">Channel Pulse</h2>
            <div class="space-y-8">
               {[
                  { name: 'Direct POS', val: 65, color: 'bg-indigo-500' },
                  { name: 'Online Hub', val: 25, color: 'bg-cyan-500' },
                  { name: 'WhatsApp', val: 10, color: 'bg-emerald-500' }
               ].map(ch => (
                  <div class="space-y-3">
                     <div class="flex justify-between text-[10px] font-black uppercase tracking-widest italic">
                        <span>{ch.name}</span>
                        <span class="text-white/40">{ch.val}%</span>
                     </div>
                     <div class="h-3 w-full bg-white/5 rounded-full overflow-hidden">
                        <div class={`h-full ${ch.color} rounded-full transition-all duration-1000`} style={`width: ${ch.val}%`}></div>
                     </div>
                  </div>
               ))}
            </div>
         </section>

         <section class="bg-white/5 border border-white/10 rounded-[48px] p-10">
            <div class="flex items-center justify-between mb-8">
               <h2 class="text-lg font-black italic uppercase tracking-tight">Stock Alerts</h2>
               <a href="#" class="text-[10px] font-black uppercase tracking-widest text-indigo-400 hover:text-white transition-colors italic">Inventory Hub</a>
            </div>
            <div class="space-y-4">
               {[
                  { name: "Linen Shirt (White)", stock: 2, price: 1200 },
                  { name: "Slim Fit Jeans", stock: 1, price: 2400 }
               ].map(item => (
                  <div class="p-5 bg-white/5 border border-white/5 rounded-3xl flex items-center gap-4 group hover:border-rose-500/30 transition-all">
                     <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-xl">📦</div>
                     <div class="flex-1">
                        <h4 class="text-sm font-black italic text-white/80">{item.name}</h4>
                        <p class="text-[10px] font-black text-rose-500 uppercase tracking-widest mt-1">{item.stock} Units Left</p>
                     </div>
                     <button class="p-3 text-white/20 hover:text-indigo-400 hover:bg-indigo-500/10 rounded-xl transition-all"><i class="lucide-refresh-cw text-lg"></i></button>
                  </div>
               ))}
            </div>
         </section>
      </div>

   </div>
</RetailOSLayout>
