---
import RetailOSLayout from "../../layouts/RetailOSLayout.astro";

// Mock data for AI Insights
const aiInsights = [
  { message: "Black Linen Shirts (L) are selling 24% faster than average this week.", type: "velocity" },
  { message: "Stock for Red Kurti (M) will deplete in 4 days. Suggest ordering 50 units.", type: "forecast" },
  { message: "Detected high return rate for Blue Slim Fit Jeans. Check sizing consistency.", type: "quality" }
];

const stats = [
  { label: "Today's Revenue", value: "₹84,250", trend: "+12.5%", color: "var(--primary)" },
  { label: "Active Orders", value: "42", trend: "Normal", color: "#fbbf24" },
  { label: "Total Visits", value: "318", trend: "+8.2%", color: "#10b981" },
  { label: "New Customers", value: "14", trend: "+5.1%", color: "#ec4899" }
];
---

<RetailOSLayout title="Dashboard | Bobo Retail OS">
  <div class="dashboard-header-flex">
    <div>
        <h1 style="font-size: 2rem; margin-bottom: 8px;">Store Overview</h1>
        <p style="color: var(--text-muted);">Welcome back, Jane. Here's what's happening today at <span style="color: white; font-weight: bold;">South City Mall</span>.</p>
    </div>
    <div class="date-range">
        <button class="date-btn active">Today</button>
        <button class="date-btn">Weekly</button>
        <button class="date-btn">Monthly</button>
    </div>
  </div>

  <div class="stats-grid">
    {stats.map(stat => (
      <div class="stat-card">
        <div class="stat-label-row">
            <span class="stat-label">{stat.label}</span>
            <span class="trend" style={stat.trend.startsWith('+') ? 'color: var(--success);' : 'color: var(--text-muted);'}>{stat.trend}</span>
        </div>
        <div class="stat-value" style={`color: ${stat.color}`}>{stat.value}</div>
        <div class="stat-chart-sparkline"></div>
      </div>
    ))}
  </div>

  <div class="main-grid">
    <!-- AI Insights Section -->
    <div class="grid-col-1">
        <div class="panel ai-panel">
            <div class="panel-header">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <div class="ai-icon">✨</div>
                    <span style="font-weight: 700;">AI Retail Intelligence</span>
                </div>
                <button class="refresh-btn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                </button>
            </div>
            <div class="insights-list">
                {aiInsights.map(insight => (
                    <div class="insight-item">
                        <div class={`insight-dot ${insight.type}`}></div>
                        <p>{insight.message}</p>
                    </div>
                ))}
            </div>
        </div>

        <div class="panel sales-chart-panel">
            <div class="panel-header">
                <span style="font-weight: 700;">Hourly Sales Distribution</span>
            </div>
            <div class="chart-container-mock">
                <!-- Bars of different heights -->
                <div class="bar" style="height: 40%"></div>
                <div class="bar" style="height: 60%"></div>
                <div class="bar" style="height: 30%"></div>
                <div class="bar active" style="height: 90%"></div>
                <div class="bar" style="height: 70%"></div>
                <div class="bar" style="height: 50%"></div>
                <div class="bar" style="height: 85%"></div>
                <div class="bar" style="height: 45%"></div>
            </div>
        </div>
    </div>

    <!-- Right Side: Low Stock & Best Sellers -->
    <div class="grid-col-2">
        <div class="panel">
            <div class="panel-header">
                <span style="font-weight: 700;">Omnichannel Breakdown</span>
            </div>
            <div class="channel-distribution">
                <div class="channel-row">
                    <span style="width: 80px;">POS</span>
                    <div class="progress-bar"><div class="fill" style="width: 65%; background: var(--primary);"></div></div>
                    <span style="width: 40px; text-align: right;">65%</span>
                </div>
                <div class="channel-row">
                    <span style="width: 80px;">Online</span>
                    <div class="progress-bar"><div class="fill" style="width: 25%; background: var(--secondary);"></div></div>
                    <span style="width: 40px; text-align: right;">25%</span>
                </div>
                <div class="channel-row">
                    <span style="width: 80px;">WhatsApp</span>
                    <div class="progress-bar"><div class="fill" style="width: 10%; background: var(--success);"></div></div>
                    <span style="width: 40px; text-align: right;">10%</span>
                </div>
            </div>
        </div>

        <div class="panel inventory-alert">
            <div class="panel-header">
                <span style="font-weight: 700;">Critical Low Stock Items</span>
                <a href="/retail-os/inventory" style="font-size: 0.75rem; color: var(--primary);">View All</a>
            </div>
            <div class="stock-list">
                <div class="stock-item">
                    <div class="item-img-small" style="background: #1e293b;"></div>
                    <div style="flex: 1;">
                        <span class="item-name">Men's Linen Shirt (White/L)</span>
                        <span class="item-stock">2 Units left</span>
                    </div>
                    <button class="reorder-btn">PO</button>
                </div>
                <div class="stock-item">
                    <div class="item-img-small" style="background: #1e293b;"></div>
                    <div style="flex: 1;">
                        <span class="item-name">Slim Fit Jeans (32/Blue)</span>
                        <span class="item-stock">1 Unit left</span>
                    </div>
                    <button class="reorder-btn">PO</button>
                </div>
            </div>
        </div>
    </div>
  </div>

  <style>
    .dashboard-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 32px;
    }

    .date-range {
        display: flex;
        background: var(--bg-glass);
        padding: 4px;
        border-radius: 10px;
        border: 1px solid var(--border);
    }

    .date-btn {
        background: transparent;
        border: none;
        color: var(--text-muted);
        padding: 6px 16px;
        border-radius: 8px;
        font-size: 0.85rem;
        cursor: pointer;
        transition: 0.2s;
    }

    .date-btn.active {
        background: var(--primary);
        color: white;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: var(--bg-glass);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 20px;
        backdrop-filter: blur(10px);
    }

    .stat-label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .stat-label {
        font-size: 0.85rem;
        color: var(--text-muted);
        font-weight: 500;
    }

    .stat-value {
        font-size: 1.75rem;
        font-weight: 800;
        font-family: 'Outfit', sans-serif;
    }

    .trend {
        font-size: 0.8rem;
        font-weight: 600;
    }

    .main-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 20px;
    }

    .panel {
        background: var(--bg-glass);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 24px;
        margin-bottom: 20px;
    }

    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .ai-panel {
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(168, 85, 247, 0.1) 100%);
        border: 1px solid rgba(99, 102, 241, 0.2);
    }

    .ai-icon {
        width: 32px;
        height: 32px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .insights-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .insight-item {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(255, 255, 255, 0.05);
        padding: 12px 16px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .insight-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .insight-dot.velocity { background: var(--primary); box-shadow: 0 0 8px var(--primary); }
    .insight-dot.forecast { background: var(--warning); box-shadow: 0 0 8px var(--warning); }
    .insight-dot.quality { background: #ef4444; box-shadow: 0 0 8px #ef4444; }

    .insight-item p {
        font-size: 0.9rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.8);
    }

    .refresh-btn {
        background: transparent;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
    }

    .chart-container-mock {
        height: 200px;
        display: flex;
        align-items: flex-end;
        gap: 20px;
        padding-top: 20px;
    }

    .bar {
        flex: 1;
        background: rgba(99, 102, 241, 0.2);
        border-radius: 6px 6px 0 0;
        min-width: 30px;
        transition: 0.3s;
    }

    .bar:hover, .bar.active {
        background: var(--primary);
        box-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
    }

    .channel-distribution {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .channel-row {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.85rem;
    }

    .progress-bar {
        flex: 1;
        height: 8px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 4px;
        overflow: hidden;
    }

    .fill {
        height: 100%;
        border-radius: 4px;
    }

    .stock-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .stock-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
    }

    .item-img-small {
        width: 40px;
        height: 40px;
        border-radius: 8px;
    }

    .item-name {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .item-stock {
        font-size: 0.75rem;
        color: #ef4444;
    }

    .reorder-btn {
        background: rgba(99, 102, 241, 0.2);
        color: var(--primary);
        border: 1px solid var(--primary);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        cursor: pointer;
    }
  </style>
</RetailOSLayout>
