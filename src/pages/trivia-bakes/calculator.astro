---
import TriviaLayout from "../../layouts/TriviaLayout.astro";
---

<TriviaLayout title="Cost Calculator | Trivia Bakes CRM">
    <div class="header">
        <div class="page-title">
            <h1>Recipe Costing & Profit</h1>
            <p>Calculate ingredient costs and set the perfect selling price.</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-outline" onclick="clearCalculator()">Reset Desk</button>
            <button class="btn btn-primary" onclick="saveCalculation()">Save to Database</button>
        </div>
    </div>

    <div class="calculator-grid">
        <!-- Main Form -->
        <div class="card calc-form">
            <div class="form-group">
                <label>Recipe / Product Name</label>
                <input type="text" id="recipe-name" placeholder="e.g. Belgian Chocolate Truffle (1kg)" />
            </div>

            <div class="ingredient-header">
                <div class="h-name">Ingredient</div>
                <div class="h-qty">Qty (g/ml)</div>
                <div class="h-cost">Cost (per g/ml)</div>
                <div class="h-total">Total</div>
            </div>

            <div id="ingredient-list" class="ingredient-list">
                <!-- Rows added here -->
                <div class="ing-row">
                    <input type="text" placeholder="Flour" class="ing-name" oninput="calculateTotal()" />
                    <input type="number" placeholder="500" class="ing-qty" oninput="calculateTotal()" />
                    <input type="number" placeholder="0.06" class="ing-unit-cost" oninput="calculateTotal()" />
                    <div class="ing-row-total">₹0</div>
                </div>
            </div>

            <button class="btn btn-outline full-width mt-20" onclick="addRow()">+ Add Ingredient</button>

            <div class="overhead-section mt-30">
                <h3>Additional Costs</h3>
                <div class="form-grid-2">
                    <div class="form-group">
                        <label>Packaging (Box, Ribbon)</label>
                        <input type="number" id="cost-packaging" value="45" oninput="calculateTotal()" />
                    </div>
                    <div class="form-group">
                        <label>Utilities / Labor (Fixed)</label>
                        <input type="number" id="cost-labor" value="150" oninput="calculateTotal()" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Margin Results -->
        <div class="margin-sticky">
            <div class="card result-card">
                <h3>Financial Summary</h3>
                <div class="res-item">
                    <span>Total Production Cost</span>
                    <strong id="final-production-cost">₹0</strong>
                </div>
                <div class="res-item">
                    <span>Suggested Mark-up (70%)</span>
                    <span id="suggested-markup">₹0</span>
                </div>
                <div class="res-item border-top mt-20">
                    <label>Actual Selling Price</label>
                    <input type="number" id="actual-price" value="1200" oninput="calculateTotal()" />
                </div>
                
                <div class="profit-box mt-20">
                    <div class="p-label">Net Profit per Unit</div>
                    <div class="p-value" id="net-profit">₹0</div>
                </div>

                <div class="margin-meter mt-30">
                    <div class="m-head">
                        <span>Profit Margin</span>
                        <strong id="margin-pct">0%</strong>
                    </div>
                    <div class="m-bar"><div class="m-fill" id="margin-fill"></div></div>
                    <p class="m-status" id="margin-status">Setting up...</p>
                </div>
            </div>

            <div class="card mt-24">
                <h4>Pricing Tip</h4>
                <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; margin-top: 10px;">
                    For premium home bakes, a margin of <strong>60-75%</strong> is industry standard to cover artisanal labor and marketing costs.
                </p>
            </div>
        </div>
    </div>

    <style>
        .calculator-grid { display: grid; grid-template-columns: 1fr 340px; gap: 32px; align-items: flex-start; }
        .full-width { width: 100%; justify-content: center; }
        .mt-20 { margin-top: 20px; }
        .mt-30 { margin-top: 30px; }
        .mt-24 { margin-top: 24px; }

        .ingredient-header { 
            display: grid; 
            grid-template-columns: 2fr 1fr 1fr 80px; 
            gap: 16px; 
            padding: 12px 0; 
            border-bottom: 2px solid var(--secondary);
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        .ing-row { 
            display: grid; 
            grid-template-columns: 2fr 1fr 1fr 80px; 
            gap: 16px; 
            padding: 12px 0; 
            border-bottom: 1px solid rgba(141, 93, 70, 0.05);
        }

        .ing-row input { 
            background: rgba(141, 93, 70, 0.03); 
            border: 1px solid var(--border); 
            padding: 8px 12px; 
            border-radius: 8px; 
            font-family: inherit;
        }

        .ing-row-total { display: flex; align-items: center; font-weight: 700; color: var(--primary); }

        .overhead-section h3 { font-size: 1rem; margin-bottom: 16px; }

        .result-card h3 { font-size: 1rem; margin-bottom: 24px; border-bottom: 1px solid var(--border); padding-bottom: 12px; }
        .res-item { display: flex; justify-content: space-between; font-size: 0.9rem; margin-bottom: 12px; color: var(--text-muted); }
        .res-item strong { color: var(--text-main); font-weight: 800; }
        .border-top { border-top: 1px solid var(--border); padding-top: 16px; }

        .profit-box { 
            background: var(--primary); 
            color: white; 
            padding: 20px; 
            border-radius: 16px; 
            text-align: center;
            box-shadow: 0 10px 20px rgba(141, 93, 70, 0.2);
        }
        .p-label { font-size: 0.75rem; text-transform: uppercase; opacity: 0.8; font-weight: 700; }
        .p-value { font-size: 1.8rem; font-weight: 900; }

        .margin-meter { background: var(--secondary); padding: 16px; border-radius: 12px; }
        .m-head { display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 8px; font-weight: 700; color: var(--primary); }
        .m-bar { height: 8px; background: rgba(0,0,0,0.05); border-radius: 4px; overflow: hidden; margin-bottom: 8px; }
        .m-fill { height: 100%; background: var(--primary); width: 0%; transition: 0.5s; }
        .m-status { font-size: 0.75rem; color: var(--primary); opacity: 0.7; }

        .margin-sticky { position: sticky; top: 40px; }
    </style>

    <script is:inline>
        function addRow() {
            const list = document.getElementById('ingredient-list');
            const row = document.createElement('div');
            row.className = 'ing-row';
            row.innerHTML = `
                <input type="text" placeholder="Ingredient" class="ing-name" oninput="calculateTotal()" />
                <input type="number" placeholder="0" class="ing-qty" oninput="calculateTotal()" />
                <input type="number" placeholder="0" class="ing-unit-cost" oninput="calculateTotal()" />
                <div class="ing-row-total">₹0</div>
            `;
            list.appendChild(row);
        }

        function calculateTotal() {
            let totalIngredients = 0;
            const rows = document.querySelectorAll('.ing-row');
            
            rows.forEach(row => {
                const qty = parseFloat(row.querySelector('.ing-qty').value) || 0;
                const unit = parseFloat(row.querySelector('.ing-unit-cost').value) || 0;
                const rowTotal = qty * unit;
                totalIngredients += rowTotal;
                row.querySelector('.ing-row-total').innerText = '₹' + Math.round(rowTotal);
            });

            const packaging = parseFloat(document.getElementById('cost-packaging').value) || 0;
            const labor = parseFloat(document.getElementById('cost-labor').value) || 0;
            
            const prodCost = totalIngredients + packaging + labor;
            const sellingPrice = parseFloat(document.getElementById('actual-price').value) || 0;
            
            const markup = prodCost * 0.7;
            const profit = sellingPrice - prodCost;
            const marginPct = (profit / sellingPrice) * 100;

            document.getElementById('final-production-cost').innerText = '₹' + Math.round(prodCost);
            document.getElementById('suggested-markup').innerText = '₹' + Math.round(markup);
            document.getElementById('net-profit').innerText = '₹' + Math.round(profit);
            document.getElementById('margin-pct').innerText = Math.round(marginPct) + '%';
            document.getElementById('margin-fill').style.width = Math.min(100, Math.max(0, marginPct)) + '%';
            
            let status = 'Low Margin';
            if(marginPct > 60) status = 'Healthy Premium Margin';
            else if(marginPct > 40) status = 'Average Business Margin';
            document.getElementById('margin-status').innerText = status;
        }

        function saveCalculation() {
            alert('Recipe Saved to Bakery Database!');
        }

        function clearCalculator() {
            window.location.reload();
        }

        // Init
        document.addEventListener('DOMContentLoaded', calculateTotal);
    </script>
</TriviaLayout>
