---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Order Online | Trivia Bakes" hideNav={true}>
    <div class="customer-portal">
        <div class="portal-card">
            <header class="card-header">
                <img src="/trivia-bakes-logo.png" alt="Trivia Bakes" class="logo" onerror="this.src='https://api.dicebear.com/7.x/initials/svg?seed=TB&backgroundColor=fce4ec&fontFamily=Playfair%20Display'"/>
                <div class="brand-text">
                    <h1>Trivia Bakes</h1>
                    <p>Artisanal Home Bakery • Pune</p>
                </div>
            </header>

            <div class="stepper">
                <div class="step active" data-step="1">1. Customization</div>
                <div class="step" data-step="2">2. Delivery</div>
                <div class="step" data-step="3">3. Payment</div>
            </div>

            <form id="order-form">
                <!-- Step 1: Selection -->
                <div class="form-section active" id="section-1">
                    <div class="form-group">
                        <label>Customer Name</label>
                        <input type="text" id="c-name" placeholder="Enter your full name" required />
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="tel" id="c-phone" placeholder="+91" required />
                    </div>
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label>Product Type</label>
                            <select id="p-type">
                                <option>Signature Cakes</option>
                                <option>Custom Design Cake</option>
                                <option>Cupcakes (Box of 6/12)</option>
                                <option>Tea Cakes</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Flavor</label>
                            <select id="p-flavor">
                                <option>Belgian Chocolate</option>
                                <option>Red Velvet</option>
                                <option>Blueberry Cheesecake</option>
                                <option>Vanilla Bean</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Cake Weight / Quantity</label>
                        <div class="radio-grid">
                            <label class="radio-p"><input type="radio" name="weight" value="0.5kg" checked /> <span>0.5 kg</span></label>
                            <label class="radio-p"><input type="radio" name="weight" value="1kg" /> <span>1 kg</span></label>
                            <label class="radio-p"><input type="radio" name="weight" value="1.5kg" /> <span>1.5 kg</span></label>
                            <label class="radio-p"><input type="radio" name="weight" value="2kg" /> <span>2 kg</span></label>
                        </div>
                    </div>
                    <button type="button" class="btn-next" onclick="goStep(2)">Next: Delivery Details</button>
                </div>

                <!-- Step 2: Delivery -->
                <div class="form-section" id="section-2">
                    <div class="form-group">
                        <label>Delivery Date</label>
                        <input type="date" id="d-date" required />
                    </div>
                    <div class="form-group">
                        <label>Full Delivery Address</label>
                        <textarea id="d-address" rows="3" placeholder="Apartment, Street, Landmark..."></textarea>
                    </div>
                    <div class="form-group">
                        <label>Message on Cake / Instructions</label>
                        <input type="text" id="d-note" placeholder="e.g. Happy Birthday Rahul!" />
                    </div>
                    <div class="btn-group">
                        <button type="button" class="btn-back" onclick="goStep(1)">Back</button>
                        <button type="button" class="btn-next" onclick="preparePayment()">Continue to Payment</button>
                    </div>
                </div>

                <!-- Step 3: Payment -->
                <div class="form-section" id="section-3">
                    <div class="summary-box">
                        <h3>Order Summary</h3>
                        <div id="summary-content"></div>
                        <div class="total-row">
                            <span>Convenience Fee</span>
                            <span>₹50</span>
                        </div>
                        <div class="total-row grand">
                            <span>Total Payable</span>
                            <span id="grand-total">₹1,250</span>
                        </div>
                    </div>
                    
                    <div class="payment-methods">
                        <label class="pay-option">
                            <input type="radio" name="pay" value="upi" checked />
                            <div class="pay-icon">📱</div>
                            <span>UPI / GPay / PhonePe</span>
                        </label>
                        <label class="pay-option">
                            <input type="radio" name="pay" value="card" />
                            <div class="pay-icon">💳</div>
                            <span>Debit / Credit Card</span>
                        </label>
                    </div>

                    <button type="submit" class="btn-pay">Pay & Place Order</button>
                </div>
            </form>

            <div id="success-screen" class="success-screen">
                <div class="success-icon">🎉</div>
                <h2>Order Confirmed!</h2>
                <p>Thank you for choosing Trivia Bakes. We've sent a confirmation message to your WhatsApp.</p>
                <div class="order-id-box">Order ID: #TB-48291</div>
                <button class="btn-back-home" onclick="window.location.reload()">Back to Boutique</button>
            </div>
        </div>
    </div>

    <style>
        :root {
            --primary: #8d5d46;
            --secondary: #fce4ec;
            --text: #2d1a12;
            --bg: #fff9f9;
        }

        body { background: var(--bg); font-family: 'Outfit', sans-serif; }
        
        .customer-portal {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .portal-card {
            background: white;
            width: 100%;
            max-width: 500px;
            border-radius: 32px;
            box-shadow: 0 30px 60px rgba(141, 93, 70, 0.15);
            padding: 40px;
            position: relative;
            overflow: hidden;
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 40px;
        }

        .logo { width: 64px; height: 64px; border-radius: 50%; border: 3px solid var(--secondary); }
        .brand-text h1 { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: var(--primary); margin: 0; }
        .brand-text p { font-size: 0.85rem; color: #8d5d46; opacity: 0.7; margin: 0;}

        .stepper {
            display: flex;
            justify-content: space-between;
            margin-bottom: 32px;
            background: var(--bg);
            padding: 12px;
            border-radius: 16px;
        }

        .step { font-size: 0.75rem; font-weight: 700; color: #aaa; }
        .step.active { color: var(--primary); }

        .form-section { display: none; animation: slideIn 0.3s ease-out; }
        .form-section.active { display: block; }
        @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

        .form-group { margin-bottom: 24px; }
        .form-group label { display: block; font-size: 0.85rem; font-weight: 700; color: var(--primary); margin-bottom: 8px; }
        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 14px 16px;
            border-radius: 12px;
            border: 2px solid #f0f0f0;
            font-family: inherit;
            outline: none;
            transition: 0.2s;
        }
        .form-group input:focus { border-color: var(--secondary); background: #fffcfd; }

        .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

        .radio-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
        .radio-p { border: 2px solid #f0f0f0; padding: 12px; border-radius: 12px; display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 0.9rem; }
        .radio-p:has(input:checked) { border-color: var(--primary); background: var(--secondary); font-weight: 700; }
        .radio-p input { accent-color: var(--primary); }

        .btn-next, .btn-pay {
            width: 100%;
            padding: 16px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 16px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
        }
        .btn-next:hover, .btn-pay:hover { box-shadow: 0 10px 20px rgba(141, 93, 70, 0.3); transform: translateY(-2px); }

        .btn-back { width: 100px; border: none; background: none; font-weight: 700; color: #8d5d46; cursor: pointer; }
        .btn-group { display: flex; align-items: center; gap: 16px; }

        .summary-box { background: var(--bg); padding: 24px; border-radius: 20px; border: 1px dashed var(--primary); margin-bottom: 24px; }
        .summary-box h3 { font-size: 0.9rem; margin-bottom: 16px; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 8px; }
        .total-row { display: flex; justify-content: space-between; font-size: 0.85rem; color: #666; margin-top: 8px; }
        .total-row.grand { margin-top: 16px; border-top: 1px solid #ddd; padding-top: 16px; color: var(--primary); font-weight: 900; font-size: 1.1rem; }

        .payment-methods { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
        .pay-option { 
            display: flex; 
            align-items: center; 
            gap: 16px; 
            padding: 16px; 
            border: 2px solid #f0f0f0; 
            border-radius: 16px; 
            cursor: pointer;
        }
        .pay-option:has(input:checked) { border-color: var(--primary); background: var(--secondary); }
        .pay-icon { font-size: 1.5rem; }

        .success-screen { display: none; text-align: center; }
        .success-icon { font-size: 4rem; margin-bottom: 20px; }
        .order-id-box { background: var(--secondary); color: var(--primary); padding: 12px; border-radius: 12px; font-weight: 800; display: inline-block; margin: 24px 0; }
        .btn-back-home { background: var(--primary); color: white; border: none; padding: 14px 28px; border-radius: 12px; font-weight: 700; cursor: pointer; }

    </style>

    <script is:inline>
        function goStep(n) {
            document.querySelectorAll('.form-section').forEach(s => s.classList.remove('active'));
            document.getElementById('section-' + n).classList.add('active');
            document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
            document.querySelector(`.step[data-step="${n}"]`).classList.add('active');
        }

        function preparePayment() {
            const name = document.getElementById('c-name').value;
            const flavor = document.getElementById('p-flavor').value;
            const weight = document.querySelector('input[name="weight"]:checked').value;
            
            document.getElementById('summary-content').innerHTML = `
                <div class="total-row"><span>Product:</span> <strong>${flavor} Cake (${weight})</strong></div>
                <div class="total-row"><span>Customer:</span> <strong>${name}</strong></div>
            `;
            
            // Calc mock total
            let base = weight === '0.5kg' ? 650 : weight === '1kg' ? 1200 : 1800;
            document.getElementById('grand-total').innerText = '₹' + (base + 50);
            
            goStep(3);
        }

        document.getElementById('order-form').addEventListener('submit', (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('.btn-pay');
            btn.innerText = 'Processing Gateway...';
            btn.disabled = true;

            setTimeout(() => {
                document.getElementById('order-form').style.display = 'none';
                document.querySelector('.stepper').style.display = 'none';
                document.getElementById('success-screen').style.display = 'block';
                console.log("CRM AUTOMATION: New Order notification sent to Trista via WhatsApp.");
            }, 2500);
        });
    </script>
</MainLayout>
