---
import TriviaLayout from "../../layouts/TriviaLayout.astro";
---

<TriviaLayout title="Order Management | Trivia Bakes CRM">
    <div class="header">
        <div class="page-title">
            <h1>Active Bake List</h1>
            <p>Track, manage, and dispatch artisanal orders.</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-outline" id="calendar-view">Delivery Calendar</button>
            <button class="btn btn-primary" onclick="window.location.href='/trivia-bakes/order-online'">+ Manual Order</button>
        </div>
    </div>

    <!-- Stats Mini -->
    <div class="order-stats-strip">
        <div class="os-item active" data-filter="all">Total Orders <span>24</span></div>
        <div class="os-item" data-filter="new">New <span>4</span></div>
        <div class="os-item" data-filter="preparing">Kitchen <span>8</span></div>
        <div class="os-item" data-filter="out-for-delivery">Out for Delivery <span>3</span></div>
        <div class="os-item" data-filter="delivered">Delivered <span>9</span></div>
    </div>

    <!-- Order List -->
    <div class="card order-hub">
        <div class="hub-filters">
            <div class="search-wrap">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text" placeholder="Search customer, cake, or phone..." id="hubSearch"/>
            </div>
            <div class="date-filter">
                <input type="date" value="2026-03-13" />
            </div>
        </div>

        <div class="hub-table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer / Contact</th>
                        <th>Product Details</th>
                        <th>Delivery Date</th>
                        <th>Location</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Automations</th>
                    </tr>
                </thead>
                <tbody id="hub-orders-body">
                    <!-- Loaded via JS -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- WhatsApp Preview Sidebar (Hidden by default) -->
    <div id="wa-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>WhatsApp Notification</h3>
                <button class="close-modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="phone-preview">
                    <div class="wa-bubble">
                        <p id="wa-text"></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline close-modal">Cancel</button>
                <button class="btn btn-primary" id="confirm-wa">Send Message</button>
            </div>
        </div>
    </div>

    <style>
        .order-stats-strip {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
            overflow-x: auto;
            padding-bottom: 8px;
        }

        .os-item {
            background: #ffffff;
            padding: 12px 20px;
            border-radius: 12px;
            border: 1px solid var(--border);
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.9rem;
            white-space: nowrap;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .os-item span {
            background: var(--secondary);
            color: var(--primary);
            padding: 2px 8px;
            border-radius: 6px;
            font-size: 0.75rem;
        }

        .os-item:hover, .os-item.active {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--secondary);
        }

        .hub-filters {
            display: flex;
            justify-content: space-between;
            margin-bottom: 24px;
            gap: 16px;
        }

        .search-wrap {
            flex: 1;
            position: relative;
        }

        .search-wrap svg { position: absolute; left: 16px; top: 14px; color: var(--text-muted); }
        .search-wrap input {
            width: 100%;
            padding: 12px 12px 12px 48px;
            border-radius: 12px;
            border: 1px solid var(--border);
            font-family: inherit;
            outline: none;
            transition: 0.2s;
        }

        .search-wrap input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(141, 93, 70, 0.05); }

        .date-filter input {
            padding: 11px 16px;
            border-radius: 12px;
            border: 1px solid var(--border);
            font-family: inherit;
        }

        .action-btns { display: flex; gap: 8px; }
        .wa-btn {
            background: #25d366;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .wa-btn:hover { background: #128c7e; }

        .btn-status {
            padding: 6px 10px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: white;
            font-size: 0.75rem;
            cursor: pointer;
        }

        /* Modal */
        .modal {
            position: fixed;
            inset: 0;
            background: rgba(45, 26, 18, 0.4);
            backdrop-filter: blur(4px);
            z-index: 1000;
            display: none;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: white;
            width: 400px;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .modal-header { padding: 24px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; }
        .modal-body { padding: 24px; background: #f0f2f5; }
        .phone-preview {
            background: white;
            border-radius: 16px;
            padding: 20px;
            min-height: 150px;
            border: 1px solid #ddd;
            position: relative;
        }
        .wa-bubble {
            background: #dcf8c6;
            padding: 12px;
            border-radius: 8px;
            font-size: 0.9rem;
            max-width: 80%;
            position: relative;
        }
        .wa-bubble::after {
            content: '';
            position: absolute;
            right: -10px;
            top: 0;
            border: 10px solid transparent;
            border-left-color: #dcf8c6;
            border-top-color: #dcf8c6;
        }
        .modal-footer { padding: 20px; display: flex; gap: 12px; justify-content: flex-end; }
        .close-modal { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted); }
    </style>

    <script is:inline>
        const orders = [
            { id: '101', customer: 'Anjali Sharma', phone: '+91 98234 56789', product: 'Chocolate Truffle', weight: '1kg', date: 'Mar 13, 2:00 PM', location: 'Viman Nagar', amount: '₹1,200', status: 'preparing' },
            { id: '102', customer: 'Rahul Verma', phone: '+91 77234 12345', product: 'Blueberry Cupcakes', weight: '6 pcs', date: 'Mar 13, 4:30 PM', location: 'Kalyani Nagar', amount: '₹450', status: 'pending' },
            { id: '103', customer: 'Sonali Das', phone: '+91 99345 67890', product: 'Red Velvet Cake', weight: '1.5kg', date: 'Mar 14, 11:00 AM', location: 'Magarpatta', amount: '₹1,850', status: 'new' },
            { id: '104', customer: 'Ishan Gupta', phone: '+91 88200 11223', product: 'Fondant Spiderman', weight: '2kg', date: 'Mar 14, 6:00 PM', location: 'Aundh', amount: '₹3,500', status: 'preparing' }
        ];

        function renderOrders() {
            const tbody = document.getElementById('hub-orders-body');
            tbody.innerHTML = orders.map(o => `
                <tr>
                    <td>#TB-${o.id}</td>
                    <td><strong>${o.customer}</strong><br><small>${o.phone}</small></td>
                    <td>${o.product} (${o.weight})</td>
                    <td>${o.date}</td>
                    <td>${o.location}</td>
                    <td><strong>${o.amount}</strong></td>
                    <td><span class="status-badge status-${o.status}">${o.status}</span></td>
                    <td>
                        <div class="action-btns">
                            <button class="wa-btn" onclick="openWhatsApp('${o.id}', '${o.status}')">
                                WhatsApp
                            </button>
                            <button class="btn-status" onclick="cycleStatus('${o.id}')">Update</button>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        window.openWhatsApp = (id, status) => {
            const o = orders.find(x => x.id === id);
            let msg = '';
            if(status === 'new') msg = `Hello ${o.customer}! Your cake order #TB-${o.id} from Trivia Bakes has been received. ❤️`;
            else if(status === 'preparing') msg = `Hi ${o.customer}! We've started baking your delicious ${o.product}. It's smelling great! 👩‍🍳`;
            else if(status === 'out-for-delivery') msg = `Yay! Your order #TB-${o.id} is out for delivery. Our driver will reach you soon. 🧁`;
            else msg = `Hope you enjoyed your ${o.product}! Thank you for choosing Trivia Bakes. Share your feedback! ✨`;

            document.getElementById('wa-text').innerText = msg;
            document.getElementById('wa-modal').style.display = 'flex';
        };

        window.cycleStatus = (id) => {
            const idx = orders.findIndex(x => x.id === id);
            const flow = ['new', 'pending', 'preparing', 'out-for-delivery', 'delivered'];
            const current = flow.indexOf(orders[idx].status);
            orders[idx].status = flow[(current + 1) % flow.length];
            renderOrders();
        };

        document.querySelectorAll('.close-modal').forEach(b => {
             b.onclick = () => document.getElementById('wa-modal').style.display = 'none';
        });

        document.getElementById('confirm-wa').onclick = () => {
            alert('WhatsApp Notification Sent Successfully!');
            document.getElementById('wa-modal').style.display = 'none';
        };

        document.addEventListener('DOMContentLoaded', renderOrders);
    </script>
</TriviaLayout>
