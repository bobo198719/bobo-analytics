---
import TriviaLayout from "../../layouts/TriviaLayout.astro";
---

<TriviaLayout title="Customer Database | Trivia Bakes CRM">
    <div class="header">
        <div class="page-title">
            <h1>Our Baking Family</h1>
            <p>Manage relationships, loyalists, and delivery preferences.</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-outline">Broadcase Menu (WA)</button>
            <button class="btn btn-primary">+ Add Customer</button>
        </div>
    </div>

    <div class="card">
        <div class="customer-filters">
            <div class="search-wrap">
                <input type="text" placeholder="Search by name, address or phone..." id="customerSearch" />
            </div>
            <div class="filter-pill active">All (148)</div>
            <div class="filter-pill">Loyalists (32)</div>
            <div class="filter-pill">New (12)</div>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Customer Name</th>
                    <th>Contact Info</th>
                    <th>Default Address</th>
                    <th>Total Orders</th>
                    <th>Last Order</th>
                    <th>Lifetime Value</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="customer-list">
                <!-- Mock Data -->
                <tr>
                    <td><strong>Anjali Sharma</strong> <span class="badge-loyal">Loyalist</span></td>
                    <td>+91 98234 56789<br><small>anjali@email.com</small></td>
                    <td>Viman Nagar, Pune</td>
                    <td>14</td>
                    <td>Mar 12, 2026</td>
                    <td><strong>₹18,400</strong></td>
                    <td><button class="btn-icon">👁️</button></td>
                </tr>
                <tr>
                    <td><strong>Rahul Verma</strong></td>
                    <td>+91 77234 12345<br><small>rahul.v@email.com</small></td>
                    <td>Kalyani Nagar, Pune</td>
                    <td>3</td>
                    <td>Mar 13, 2026</td>
                    <td><strong>₹3,200</strong></td>
                    <td><button class="btn-icon">👁️</button></td>
                </tr>
                <tr>
                    <td><strong>Priya Iyer</strong> <span class="badge-loyal">Loyalist</span></td>
                    <td>+91 99345 67890<br><small>p.iyer@email.com</small></td>
                    <td>Magarpatta, Pune</td>
                    <td>22</td>
                    <td>Mar 08, 2026</td>
                    <td><strong>₹28,500</strong></td>
                    <td><button class="btn-icon">👁️</button></td>
                </tr>
            </tbody>
        </table>
    </div>

    <style>
        .customer-filters { display: flex; gap: 16px; align-items: center; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
        .search-wrap { flex: 1; }
        .search-wrap input { width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid var(--border); font-family: inherit; }
        
        .filter-pill { padding: 8px 16px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; color: var(--text-muted); cursor: pointer; border: 1px solid var(--border); }
        .filter-pill.active { background: var(--secondary); color: var(--primary); border-color: var(--primary); }

        .badge-loyal { background: #e3f2fd; color: #1565c0; font-size: 0.65rem; padding: 2px 8px; border-radius: 4px; font-weight: 800; text-transform: uppercase; margin-left: 8px; vertical-align: middle; }
        
        .btn-icon { background: none; border: none; font-size: 1.2rem; cursor: pointer; transition: 0.2s; }
        .btn-icon:hover { transform: scale(1.2); }
    </style>
</TriviaLayout>
