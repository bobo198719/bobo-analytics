---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Login Options | Bobo Analytics">
  <section class="selection-wrapper">
    <div class="selection-header">
      <h1>Secure Login Portal</h1>
      <p>Please select the portal you wish to access.</p>
    </div>

    <div class="options-grid">
      <a href="/pharmacy-login" class="option-card">
        <div class="option-icon">💊</div>
        <h3>Pharmacy Portal</h3>
        <p>Manage inventory, billing, and pharmacy operations.</p>
        <div class="arrow">→</div>
      </a>

      <a href="/solutions/healthcare#login" class="option-card">
        <div class="option-icon">🏥</div>
        <h3>Healthcare CRM</h3>
        <p>Patient analytics and hospital insights.</p>
        <div class="arrow">→</div>
      </a>

      <a href="/solutions/retail#login" class="option-card">
        <div class="option-icon">🛒</div>
        <h3>Retail Intelligence</h3>
        <p>Boost sales with AI-driven inventory analytics.</p>
        <div class="arrow">→</div>
      </a>

      <a href="/solutions/finance#login" class="option-card">
        <div class="option-icon">📈</div>
        <h3>Finance Suite</h3>
        <p>Real-time financial insights and risk management.</p>
        <div class="arrow">→</div>
      </a>

      <a href="/solutions/grocery#login" class="option-card">
        <div class="option-icon">🍎</div>
        <h3>Grocery Hub</h3>
        <p>Efficient fresh stock tracking and management.</p>
        <div class="arrow">→</div>
      </a>

      <a href="/solutions/fashion#login" class="option-card">
        <div class="option-icon">👕</div>
        <h3>Fashion Analytics</h3>
        <p>Trend analysis and size-wise stock management.</p>
        <div class="arrow">→</div>
      </a>

      <a href="/bakers-login" class="option-card">
        <div class="option-icon">🧁</div>
        <h3>Home Bakers Portal</h3>
        <p>Manage orders, bakes, and client portfolios.</p>
        <div class="arrow">→</div>
      </a>

      <a href="/solutions/tradeguard#login" class="option-card">
        <div class="option-icon">📈</div>
        <h3>TradeGuard Analytics</h3>
        <p>Portfolio analytics and real-time risk assessment.</p>
        <div class="arrow">→</div>
      </a>

      <a href="/admin-login" class="option-card admin">
        <div class="option-icon">🛡️</div>
        <h3>Admin Portal</h3>
        <p>Restricted access. Authorized personnel only.</p>
        <div class="arrow">→</div>
      </a>
    </div>

    <div class="signup-cta">
      <p>New to Bobo Analytics? <a href="/signup">Join 30-Day Trial 🚀</a></p>
    </div>
  </section>

  <style>
    .selection-wrapper {
      padding: 100px 24px;
      max-width: 1000px;
      margin: 0 auto;
      text-align: center;
    }

    .selection-header {
      margin-bottom: 60px;
    }

    .selection-header h1 {
      font-size: 3rem;
      font-weight: 800;
      margin-bottom: 16px;
    }

    .selection-header p {
      color: rgba(255, 255, 255, 0.6);
      font-size: 1.25rem;
    }

    .options-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
    }

    .option-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 40px 32px;
      border-radius: 20px;
      text-decoration: none;
      color: white;
      text-align: left;
      transition: all 0.3s ease;
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .option-card:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: #6366f1;
      transform: translateY(-5px);
    }

    .option-icon {
      font-size: 2.5rem;
      margin-bottom: 10px;
    }

    .option-card h3 {
      font-size: 1.5rem;
      margin: 0;
    }

    .option-card p {
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .arrow {
      font-size: 1.5rem;
      color: #6366f1;
      opacity: 0;
      transition: all 0.3s ease;
      transform: translateX(-10px);
    }

    .option-card:hover .arrow {
      opacity: 1;
      transform: translateX(0);
    }

    .option-card.admin {
      border-color: rgba(239, 68, 68, 0.2);
    }

    .option-card.admin:hover {
      border-color: #ef4444;
    }

    .option-card.admin .arrow {
      color: #ef4444;
    }

    .signup-cta {
      margin-top: 60px;
      padding: 24px;
      background: rgba(99, 102, 241, 0.05);
      border-radius: 20px;
      border: 1px dashed rgba(99, 102, 241, 0.3);
    }

    .signup-cta p {
      font-size: 1.1rem;
      margin: 0;
    }

    .signup-cta a {
      color: #6366f1;
      font-weight: 700;
      text-decoration: none;
      margin-left: 8px;
    }

    .signup-cta a:hover {
      text-decoration: underline;
    }
  </style>
</MainLayout>
