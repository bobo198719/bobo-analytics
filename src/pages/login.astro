---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Login Options | Bobo Analytics">
  <section class="selection-wrapper">
    <div class="selection-header">
      <h1>Secure Login Portal</h1>
      <p>Please select the portal you wish to access.</p>
    </div>

    <div class="options-grid">
      <a href="/pharmacy-login" class="option-card">
        <div class="option-icon">💊</div>
        <h3>Pharmacy Portal</h3>
        <p>Manage inventory, billing, and pharmacy operations.</p>
        <div class="arrow">→</div>
      </a>

      <div class="option-card disabled">
        <div class="option-icon">🏥</div>
        <h3>Healthcare Provider</h3>
        <p>Coming soon: Dedicated portal for hospitals and clinics.</p>
      </div>

      <div class="option-card disabled">
        <div class="option-icon">🛒</div>
        <h3>Retail Manager</h3>
        <p>Coming soon: Integrated retail intelligence dashboard.</p>
      </div>
    </div>
  </section>

  <style>
    .selection-wrapper {
      padding: 100px 24px;
      max-width: 1000px;
      margin: 0 auto;
      text-align: center;
    }

    .selection-header {
      margin-bottom: 60px;
    }

    .selection-header h1 {
      font-size: 3rem;
      font-weight: 800;
      margin-bottom: 16px;
    }

    .selection-header p {
      color: rgba(255, 255, 255, 0.6);
      font-size: 1.25rem;
    }

    .options-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
    }

    .option-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 40px 32px;
      border-radius: 20px;
      text-decoration: none;
      color: white;
      text-align: left;
      transition: all 0.3s ease;
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .option-card:hover:not(.disabled) {
      background: rgba(255, 255, 255, 0.08);
      border-color: #6366f1;
      transform: translateY(-5px);
    }

    .option-icon {
      font-size: 2.5rem;
      margin-bottom: 10px;
    }

    .option-card h3 {
      font-size: 1.5rem;
      margin: 0;
    }

    .option-card p {
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .arrow {
      font-size: 1.5rem;
      color: #6366f1;
      opacity: 0;
      transition: all 0.3s ease;
      transform: translateX(-10px);
    }

    .option-card:hover .arrow {
      opacity: 1;
      transform: translateX(0);
    }

    .disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .disabled h3::after {
      content: " (Soon)";
      font-size: 0.8rem;
      color: #7f00ff;
    }
  </style>
</MainLayout>
