---

import MainLayout from "../layouts/MainLayout.astro";

<MainLayout title="Bobo Analytics"><section class="hero"><h1>AI Analytics Platform for Every Industry</h1><p>Select your industry and experience software built specially for you.</p><div class="hero-buttons"><a href="/login" class="btn-login">Login to CRM</a>

<a href="/signup" class="btn-trial">Start Free Trial</a>

</div></section><section class="stats"><div class="stat">
<h2>500</h2>
<p>Pharmacies Onboarded</p>
</div><div class="stat">
<h2>120000</h2>
<p>Invoices Processed</p>
</div><div class="stat">
<h2>98</h2>
<p>% Customer Satisfaction</p>
</div><div class="stat">
<h2>24</h2>
<p>AI Monitoring Hours</p>
</div></section><section class="industries"><h2>Industries We Serve</h2><div class="industry-grid"><a href="/solutions/healthcare" class="industry-card">
Healthcare
</a><a href="/solutions/pharmacy" class="industry-card">
Pharmacy
</a><a href="/solutions/retail" class="industry-card">
Retail
</a><a href="/solutions/finance" class="industry-card">
Finance
</a><a href="/solutions/groceries" class="industry-card">
Groceries
</a><a href="/solutions/clothing" class="industry-card">
Clothing Store
</a><a href="/solutions/stock" class="industry-card">
Stock Trading
</a></div></section><section class="dashboard"><h2>Your Pharmacy Dashboard</h2><img src="/dashboard.png" alt="Pharmacy Dashboard"></section><footer class="footer"><div class="footer-grid"><div>
<h3>Bobo Analytics</h3>
<p>Smart Analytics for Smarter Business</p>
</div><div>
<h4>Product</h4>
<p>Pharmacy Software</p>
<p>Pricing</p>
<p>Start Free Trial</p>
</div><div>
<h4>Company</h4>
<p>About Us</p>
<p>Contact</p>
</div><div>
<h4>Legal</h4>
<p>Privacy Policy</p>
<p>Terms & Conditions</p>
<p>Disclaimer</p>
</div></div><p class="copyright">
© 2026 Bobo Analytics — AI Analytics Platform
</p></footer><style>

.hero{
padding:80px 20px;
text-align:center;
background:linear-gradient(135deg,#ff9f43,#60c6ff);
color:white;
border-radius:12px;
margin:20px;
}

.hero h1{
font-size:40px;
margin-bottom:10px;
}

.hero-buttons{
margin-top:20px;
}

.btn-login{
background:white;
padding:10px 20px;
border-radius:6px;
margin-right:10px;
color:black;
text-decoration:none;
}

.btn-trial{
background:#22c55e;
padding:10px 20px;
border-radius:6px;
color:white;
text-decoration:none;
}

.stats{
display:flex;
justify-content:center;
gap:60px;
padding:50px 20px;
flex-wrap:wrap;
text-align:center;
}

.stat h2{
color:#22c55e;
font-size:32px;
}

.industries{
padding:60px 20px;
text-align:center;
}

.industry-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
margin-top:30px;
}

.industry-card{
background:#111;
padding:40px;
border-radius:12px;
color:white;
text-decoration:none;
font-weight:600;
border:1px solid #333;
transition:all .3s ease;
box-shadow:0 0 15px rgba(0,255,150,0.2);
}

.industry-card:hover{
transform:translateY(-5px);
box-shadow:0 0 25px rgba(0,255,150,0.6);
}

.dashboard{
padding:60px 20px;
text-align:center;
}

.dashboard img{
max-width:900px;
width:100%;
border-radius:10px;
}

.footer{
background:#0b0b0b;
padding:40px 20px;
color:white;
margin-top:60px;
}

.footer-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:30px;
max-width:1000px;
margin:auto;
}

.footer p{
color:#aaa;
}

.copyright{
text-align:center;
margin-top:30px;
color:#666;
}

</style>