---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
import IndustryCard from "../components/IndustryCard.astro";
import Stats from "../components/Stats.astro";
import DemoForm from "../components/DemoForm.astro";
---

<MainLayout title="Bobo Analytics">

<!-- HERO SECTION -->
<Hero />

<!-- STATS SECTION -->
<Stats />

<!-- INDUSTRIES SECTION -->
<section class="industries">
  <h2>Industries We Serve</h2>

  <div class="industry-grid">

    <a href="/solutions/healthcare">
      <IndustryCard title="Healthcare" />
    </a>

    <a href="/solutions/pharmacy">
      <IndustryCard title="Pharmacy" />
    </a>

    <a href="/solutions/retail">
      <IndustryCard title="Retail" />
    </a>

    <a href="/solutions/finance">
      <IndustryCard title="Finance" />
    </a>

  </div>
</section>

<!-- DASHBOARD PREVIEW -->
<section class="dashboard">
  <h2>Your Pharmacy Dashboard</h2>

  <img src="/dashboard.png" alt="Pharmacy Dashboard" />
</section>

<!-- DEMO FORM -->
<DemoForm />

<style>

.industries{
  padding:80px 20px;
  text-align:center;
}

.industries h2{
  font-size:28px;
  margin-bottom:40px;
}

.industry-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
  gap:20px;
  max-width:1000px;
  margin:auto;
}

.dashboard{
  padding:80px 20px;
  text-align:center;
}

.dashboard img{
  width:80%;
  max-width:900px;
  margin-top:30px;
  border-radius:10px;
}

</style>

</MainLayout>
