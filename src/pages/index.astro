---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Analytics">

<section class="hero">
<h1>AI Analytics Platform for Every Industry</h1>
<p>Select your industry and experience software built specially for you.</p>

<div class="buttons">
<a href="/login" class="btn white">Login to CRM</a>
<a href="/signup" class="btn green">Start Free Trial</a>
</div>
</section>


<section class="stats">

<div class="stat">
<h2>500</h2>
<p>Pharmacies Onboarded</p>
</div>

<div class="stat">
<h2>120000</h2>
<p>Invoices Processed</p>
</div>

<div class="stat">
<h2>98</h2>
<p>% Customer Satisfaction</p>
</div>

<div class="stat">
<h2>24</h2>
<p>AI Monitoring Hours</p>
</div>

</section>



<section class="industries">

<h2>Industries We Serve</h2>

<div class="grid">

<a class="card" href="/solutions/healthcare">
Healthcare
</a>

<a class="card" href="/solutions/pharmacy">
Pharmacy
</a>

<a class="card" href="/solutions/retail">
Retail
</a>

<a class="card" href="/solutions/finance">
Finance
</a>

<a class="card" href="/solutions/groceries">
Groceries
</a>

<a class="card" href="/solutions/clothing">
Clothing Store
</a>

<a class="card" href="/solutions/stock">
Stock Trading
</a>

</div>

</section>



<style>

.hero{
background:linear-gradient(90deg,#ff9f43,#48dbfb);
padding:80px 20px;
margin:40px;
border-radius:12px;
text-align:center;
}

.hero h1{
color:white;
font-size:36px;
}

.hero p{
color:white;
margin-top:10px;
}

.buttons{
margin-top:20px;
}

.btn{
padding:12px 22px;
border-radius:6px;
text-decoration:none;
margin:6px;
font-weight:600;
}

.white{
background:white;
color:black;
}

.green{
background:#00ff88;
color:black;
}


.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
padding:60px 20px;
text-align:center;
}

.stat h2{
color:#00ff88;
font-size:34px;
}

.stat p{
color:#999;
}



.industries{
padding:60px 20px;
text-align:center;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
margin-top:30px;
}

.card{
background:#111;
padding:40px;
border-radius:12px;
color:white;
text-decoration:none;
font-weight:600;
border:1px solid #333;
transition:0.3s;
box-shadow:0 0 15px rgba(0,255,150,0.25);
}

.card:hover{
transform:translateY(-5px);
box-shadow:0 0 25px rgba(0,255,150,0.6);
}

</style>

</MainLayout>