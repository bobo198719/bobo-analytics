---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Analytics">

<div class="page">

<h1>Pharmacy Analytics Dashboard</h1>

<p>Track sales and pharmacy performance.</p>

<div class="cards">

<div class="card">
<h3>Total Sales</h3>
<p>₹1,25,000</p>
</div>

<div class="card">
<h3>Total Orders</h3>
<p>2,458</p>
</div>

<div class="card">
<h3>Customers</h3>
<p>1,120</p>
</div>

</div>

<canvas id="salesChart"></canvas>

</div>

<style>

.page{
padding:40px;
background:#0a0a0a;
color:white;
min-height:100vh;
}

.cards{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:20px;
margin:30px 0;
}

.card{
background:#111;
padding:20px;
border-radius:8px;
}

canvas{
background:#111;
padding:20px;
border-radius:8px;
}

</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script is:inline>

const ctx=document.getElementById("salesChart");

if(ctx){
new Chart(ctx,{
type:"bar",
data:{
labels:["Jan","Feb","Mar","Apr","May","Jun"],
datasets:[{
label:"Sales",
data:[120,210,300,250,320,410]
}]
}
});
}

</script>

</MainLayout>