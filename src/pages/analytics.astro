---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Analytics">

<div class="analytics-page">

<h1>Business Analytics</h1>

<p>Track pharmacy sales and performance.</p>

<div class="charts">

<div class="card">
<h2>Monthly Sales</h2>
<canvas id="salesChart"></canvas>
</div>

<div class="card">
<h2>Top Medicines</h2>
<ul>
<li>Paracetamol</li>
<li>Metformin</li>
<li>Omeprazole</li>
<li>Atorvastatin</li>
<li>Amoxicillin</li>
</ul>
</div>

</div>

</div>

<style>

.analytics-page{
padding:40px;
background:#0a0a0a;
color:white;
min-height:100vh;
}

.charts{
display:grid;
grid-template-columns:2fr 1fr;
gap:20px;
margin-top:20px;
}

.card{
background:#111;
padding:20px;
border-radius:8px;
}

</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const ctx=document.getElementById("salesChart");

new Chart(ctx,{
type:"bar",
data:{
labels:["Jan","Feb","Mar","Apr","May","Jun","Jul"],
datasets:[{
label:"Sales",
data:[120,210,180,260,300,420,380]
}]
}
});

</script>

</MainLayout>