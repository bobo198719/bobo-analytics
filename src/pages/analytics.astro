---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Analytics | Bobo Analytics">

<h1>Business Analytics</h1>

<p>View sales, revenue and pharmacy insights.</p>

<div class="stats">

<div class="card">
<h3>Total Sales</h3>
<p>₹42,000</p>
</div>

<div class="card">
<h3>Orders</h3>
<p>312</p>
</div>

<div class="card">
<h3>Customers</h3>
<p>126</p>
</div>

</div>

<style>

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-top:30px;
}

.card{
background:#111;
padding:25px;
border-radius:8px;
border:1px solid #222;
}

</style>

</MainLayout>