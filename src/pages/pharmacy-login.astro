---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/restaurant.css";
---

<MainLayout title="Pharmacy CRM Login | Bobo OS" hideNav={true}>
  <div class="auth-page min-h-screen flex items-center justify-center p-6 relative font-['Plus_Jakarta_Sans'] text-white" style="background: url('/images/pharmacy-cinematic-bg.png') no-repeat center center; background-size: cover;">
    
    <!-- Dark Theme Overlay -->
    <div class="absolute inset-0 bg-[#05081a]/70 backdrop-blur-[2px] pointer-events-none z-[0]"></div>
    
    <!-- Ambient Background Lighting -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden z-[1]">
       <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-600/30 rounded-full blur-[120px] -mr-64 -mt-64"></div>
       <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-cyan-400/20 rounded-full blur-[120px] -ml-64 -mb-64"></div>
    </div>

    <!-- Login Card -->
    <div class="login-card max-w-lg w-full bg-white/5 border border-white/10 p-12 md:p-16 rounded-[64px] shadow-2xl backdrop-blur-3xl relative z-10 group transition-all hover:bg-white/[0.08] hover:border-blue-500/30 overflow-hidden">
       <!-- Glow Element -->
       <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 blur-[60px] -z-10 group-hover:bg-blue-500/20 transition-all"></div>
       
       <div class="text-center mb-12">
          <div class="w-24 h-24 bg-gradient-to-br from-cyan-400 to-blue-600 rounded-3xl flex items-center justify-center text-5xl mx-auto mb-8 shadow-2xl shadow-blue-500/30 group-hover:scale-110 group-hover:rotate-3 transition-transform italic border border-white/10">B</div>
          <h1 class="text-3xl md:text-4xl font-black italic text-white uppercase tracking-tighter leading-none">Pharmacy <br /><span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">Intelligence</span></h1>
          <p class="text-white/40 text-[10px] font-black uppercase tracking-[0.4em] mt-4 italic">Provisioned Node v8.4.1 | Secure Cloud</p>
       </div>

       <form id="pharmacyLoginForm" class="space-y-8">
          <div class="space-y-3">
             <label class="text-[10px] font-black uppercase text-white/30 tracking-[0.2em] ml-4 italic">Admin Identity</label>
             <div class="relative">
                <i class="lucide-user absolute left-5 top-1/2 -translate-y-1/2 text-white/20 text-xs"></i>
                <input type="text" id="pharmacyId" placeholder="PHARMATEST" required class="w-full bg-white/5 border border-white/10 p-5 pl-12 rounded-2xl outline-none focus:border-cyan-400 transition-all font-black text-xs uppercase" />
             </div>
          </div>
          <div class="space-y-3">
             <label class="text-[10px] font-black uppercase text-white/30 tracking-[0.2em] ml-4 italic">Security Token</label>
             <div class="relative">
                <i class="lucide-lock absolute left-5 top-1/2 -translate-y-1/2 text-white/20 text-xs"></i>
                <input type="password" id="password" placeholder="••••••••" required class="w-full bg-white/5 border border-white/10 p-5 pl-12 rounded-2xl outline-none focus:border-cyan-400 transition-all font-black text-xs" />
             </div>
          </div>

          <div id="error" class="text-rose-500 text-[10px] font-black uppercase tracking-widest text-center min-h-[1rem] italic"></div>

          <button type="submit" class="w-full py-6 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-3xl text-white font-black italic uppercase tracking-[0.3em] text-xs shadow-2xl shadow-blue-600/30 hover:scale-[1.03] active:scale-95 transition-all">
             Initialize Interface
          </button>
       </form>

       <footer class="mt-12 text-center">
          <a href="/crm-login" class="text-white/10 hover:text-white font-black text-[8px] transition-colors italic uppercase tracking-[0.4em]">Abort Secure Handshake</a>
       </footer>
    </div>
  </div>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #05081a; margin: 0; }

    .shake { animation: shake 0.4s ease; }
    @keyframes shake {
       0%, 100% { transform: translateX(0); }
       25% { transform: translateX(-8px); }
       75% { transform: translateX(8px); }
    }
  </style>

  <!-- Lucide Icon Support -->
  <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">

  <script is:inline>
    const form = document.getElementById("pharmacyLoginForm");
    const errorEl = document.getElementById("error");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl.innerText = "";
      errorEl.style.color = "#06b6d4"; // cyan
      errorEl.innerText = "Provisioning Dashboard Matrix...";

      const pharmacyIdInput = document.getElementById("pharmacyId").value.trim();
      const pharmacyId = pharmacyIdInput.toLowerCase();
      const password = document.getElementById("password").value;

      try {
        let tenants = [];
        let accounts = [];
        try {
          const storedTenants = localStorage.getItem("bobo_tenants");
          if (storedTenants) tenants = JSON.parse(storedTenants);
          
          const storedAccounts = localStorage.getItem("bobo_accounts");
          if (storedAccounts) accounts = JSON.parse(storedAccounts);
        } catch (e) {
          console.error("Local storage parse error", e);
        }

        let validTenant = tenants.find(t => 
          ((t.pharmacyId && t.pharmacyId.toLowerCase() === pharmacyId) || (t.username && t.username.toLowerCase() === pharmacyId)) && 
          t.password === password
        );
        
        if (!validTenant) {
          validTenant = accounts.find(a => 
            ((a.username && a.username.toLowerCase() === pharmacyId) || (a.id && a.id.toLowerCase() === pharmacyId)) && 
            a.password === password && 
            a.industry === "pharmacy"
          );
        }

        // Hardcode fallback for pharmatest
        if (!validTenant && pharmacyId === "pharmatest" && password === "pharmatest") {
            validTenant = { pharmacyId: "pharmatest", pharmacy: "Test Pharmacy", password: "pharmatest", industry: "pharmacy" };
        }
        
        // Also support pharma123 from earlier
        if (!validTenant && pharmacyId === "pharma123" && password === "pharma123") {
            validTenant = { pharmacyId: "pharma123", pharmacy: "ABC Pharmacy", password: "pharma123", industry: "pharmacy" };
        }

        // Simulate network delay
        await new Promise(r => setTimeout(r, 600));

        if (validTenant) {
          localStorage.setItem("pharmacy", validTenant.pharmacy || validTenant.businessName);
          localStorage.setItem("pharmacyId", validTenant.pharmacyId || validTenant.username);
          localStorage.setItem("activeTenantContext", JSON.stringify({
            id: validTenant.pharmacyId || validTenant.username,
            name: validTenant.pharmacy || validTenant.businessName,
            industry: "pharmacy"
          }));
          window.location.href = "/pharmacy-dashboard";
        } else {
          errorEl.style.color = "#f43f5e"; // rose 500
          errorEl.innerText = "Invalid Master Token Identified";
          form.classList.add('shake');
          setTimeout(() => form.classList.remove('shake'), 400);
        }
      } catch (err) {
        console.error(err);
        errorEl.style.color = "#f43f5e";
        errorEl.innerText = "Network Handshake Failed";
      }
    });
  </script>
</MainLayout>
