---
import MainLayout from "../layouts/MainLayout.astro";

export function getStaticPaths() {
  return [
    { params: { industry: 'healthcare' } },
    { params: { industry: 'retail' } },
    { params: { industry: 'finance' } },
    { params: { industry: 'groceries' } },
    { params: { industry: 'clothing-store' } },
    { params: { industry: 'stock-trading' } },
  ];
}

const { industry } = Astro.params;
const title = `${industry.charAt(0).toUpperCase() + industry.slice(1)} Dashboard`;
---

<MainLayout title={title}>
    <div class="dashboard">
        <div class="sidebar">
            <h2 class="brand">Bobo Analytics</h2>
            <div class="nav-links">
                <a href="#" class="active">Overview</a>
                <a href="#">Analytics</a>
                <a href="#">Team</a>
                <a href="#">Settings</a>
            </div>
            <div class="user-profile">
                <p id="userNameDisplay">...</p>
                <button id="logoutBtn">Logout</button>
            </div>
        </div>
        <div class="main-content">
            <header>
                <h1>{title}</h1>
                <p class="welcome">Welcome back to your {industry} intelligence hub.</p>
            </header>

            <div class="view-grid">
                <div class="card wide">
                    <h3>Performance Overview</h3>
                    <div class="chart-box">
                        <canvas id="industryChart"></canvas>
                    </div>
                </div>
                <div class="card mini">
                    <h3>Critical Alerts</h3>
                    <ul class="alert-list">
                        <li>System online and stable</li>
                        <li>No urgent risk detected</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <style>
        .dashboard { display: flex; min-height: 100vh; background: #000; color: white; font-family: 'Inter', sans-serif; }
        .sidebar { width: 260px; background: #0b0b0b; padding: 40px 20px; display: flex; flex-direction: column; border-right: 1px solid #222; }
        .brand { color: #00ff96; font-size: 1.5rem; margin-bottom: 50px; font-weight: 800; }
        .nav-links { flex: 1; display: flex; flex-direction: column; gap: 10px; }
        .nav-links a { 
            color: #888; 
            text-decoration: none; 
            padding: 12px 15px; 
            border-radius: 8px; 
            font-weight: 500;
            transition: all 0.3s;
        }
        .nav-links a.active, .nav-links a:hover { background: #151515; color: #00ff96; }
        
        .user-profile { padding-top: 20px; border-top: 1px solid #222; }
        .user-profile p { margin-bottom: 10px; font-size: 0.9rem; color: #aaa; }
        .user-profile button { 
            width: 100%; 
            padding: 10px; 
            background: transparent; 
            color: #ff4d4d; 
            border: 1px solid #ff4d4d; 
            border-radius: 6px; 
            cursor: pointer;
            font-weight: 600;
        }

        .main-content { flex: 1; padding: 60px; overflow-y: auto; }
        header { margin-bottom: 50px; }
        header h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 10px; }
        .welcome { color: #666; font-size: 1.1rem; }

        .view-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 30px; }
        .card { background: #0a0a0a; border: 1px solid #222; border-radius: 16px; padding: 30px; }
        .card h3 { margin-bottom: 25px; font-size: 1.2rem; font-weight: 600; }
        .chart-box { height: 300px; display: flex; align-items: center; justify-content: center; background: #111; border-radius: 10px; border: 1px dashed #333; }
        
        .alert-list { list-style: none; padding: 0; }
        .alert-list li { padding: 12px 0; border-bottom: 1px solid #1a1a1a; color: #aaa; font-size: 0.9rem; }
        .alert-list li:last-child { border-bottom: none; }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script define:vars={{ industry }}>
        document.getElementById('logoutBtn')?.addEventListener('click', () => {
            localStorage.clear();
            window.location.href = `/solutions/${industry}`;
        });

        // Initialize a dummy chart
        const ctx = document.getElementById('industryChart');
        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Activity',
                        data: [65, 59, 80, 81, 56, 55, 40],
                        borderColor: '#00ff96',
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { display: false }, x: { grid: { display: false } } }
                }
            });
        }
    </script>
</MainLayout>
