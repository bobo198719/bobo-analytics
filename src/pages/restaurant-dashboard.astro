---
import RestaurantOSLayout from "../layouts/RestaurantOSLayout.astro";
import Dashboard from "../components/restaurant/Dashboard.jsx";
import MatrixAnalytics from "../components/restaurant/MatrixAnalytics.jsx";
import POS from "../components/restaurant/POS.jsx";
import Tables from "../components/restaurant/Tables.jsx";
import KDS from "../components/restaurant/KDS.jsx";
import MenuManager from "../components/restaurant/MenuManager.jsx";
import StaffManager from "../components/restaurant/StaffManager.jsx";
import SettingsNode from "../components/restaurant/SettingsNode.jsx";
import "../styles/restaurant.css";
---

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js" is:inline></script>

<RestaurantOSLayout title="Restaurant Intelligence Terminal | Bobo OS">
   <!-- Enterprise Control Layer -->
   <nav class="flex flex-col md:flex-row justify-between items-center bg-black/40 backdrop-blur-3xl border-b border-white/5 px-10 py-4 gap-6 sticky top-0 z-[100]">
      <div class="flex items-center gap-8">
         <div class="flex items-center gap-3 group cursor-pointer" onclick="window.location.hash='#dashboard'">
            <div class="w-10 h-10 bg-orange-600 rounded-2xl flex items-center justify-center font-black italic text-xl shadow-lg shadow-orange-600/20 group-hover:scale-110 transition-all">B</div>
            <span class="text-xs font-black uppercase tracking-[0.4em] italic text-white/40 group-hover:text-white transition-colors">Enterprise Matrix</span>
         </div>
         <div class="h-6 w-px bg-white/10 hidden md:block"></div>
         <!-- Branch Switcher (Stable) -->
         <div class="relative">
            <button onclick="toggleBranchMenu()" class="flex items-center gap-4 px-6 py-3 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest text-white/60 hover:text-white hover:bg-white/10 transition-all italic shadow-2xl">
               <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
               <span id="activeBranch">Main Branch (HQ)</span>
               <svg class="w-3 h-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div id="branchMenu" class="absolute top-full left-0 mt-4 w-72 bg-[#0c0c0d] border border-white/10 rounded-[32px] shadow-[0_40px_100px_rgba(0,0,0,0.8)] opacity-0 -translate-y-4 pointer-events-none transition-all z-[200] overflow-hidden">
               <div onclick="selectBranch('Main Branch (HQ)')" class="p-8 hover:bg-white/5 cursor-pointer border-b border-white/5 group transition-all">
                  <p class="text-[10px] font-black uppercase text-white group-hover:text-orange-400 italic">Main Branch (HQ)</p>
                  <p class="text-[8px] text-white/20 uppercase mt-2 font-black italic">ID: HUB-001 | 12 Protocol Nodes</p>
               </div>
               <div onclick="selectBranch('Airport Node')" class="p-8 hover:bg-white/5 cursor-pointer border-b border-white/5 group transition-all">
                  <p class="text-[10px] font-black uppercase text-white/40 group-hover:text-white italic">Airport Node</p>
                  <p class="text-[8px] text-white/10 uppercase mt-2 font-black italic">ID: NODE-042 | 8 Nodes Online</p>
               </div>
               <div onclick="selectBranch('Coastal Hub')" class="p-8 hover:bg-white/5 cursor-pointer border-b border-white/5 group transition-all">
                  <p class="text-[10px] font-black uppercase text-white/40 group-hover:text-white italic">Coastal Hub</p>
                  <p class="text-[8px] text-white/10 uppercase mt-2 font-black italic">ID: NODE-088 | 5 Nodes Online</p>
               </div>
            </div>
         </div>
      </div>

      <div class="flex items-center gap-6">
         <!-- Role Select Matrix (Stable Click) -->
         <div class="relative group">
            <button onclick="toggleRoleMenu()" class="px-8 py-3 bg-orange-600 rounded-2xl text-[10px] font-black uppercase tracking-widest italic shadow-xl shadow-orange-600/20 flex items-center gap-4 transition-all hover:scale-105 active:scale-95">
               <span id="activeRoleDisplay">Owner Protocol</span>
               <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div id="roleMenu" class="absolute top-full right-0 mt-4 w-72 bg-[#0c0c0d] border border-white/10 rounded-[32px] shadow-[0_40px_100px_rgba(0,0,0,0.8)] opacity-0 -translate-y-4 pointer-events-none transition-all z-[200] overflow-hidden">
               <div onclick="setAccessMode('owner', 'Owner Protocol')" class="p-8 hover:bg-white/5 cursor-pointer border-b border-white/5 group transition-all">
                  <p class="text-[10px] font-black uppercase text-orange-400 italic">Owner Dashboard</p>
                  <p class="text-[8px] text-white/20 uppercase mt-2 font-black italic">Full Operation Control & Yield Access</p>
               </div>
               <div onclick="setAccessMode('chef', 'Kitchen Hub Access')" class="p-8 hover:bg-white/5 cursor-pointer border-b border-white/5 group transition-all">
                  <p class="text-[10px] font-black uppercase text-white/60 group-hover:text-white italic">Kitchen Hub (Chef)</p>
                  <p class="text-[8px] text-white/20 uppercase mt-2 font-black italic">Restricted to KDS & Preparing Matrix</p>
               </div>
               <div onclick="setAccessMode('waiter', 'Service Access')" class="p-8 hover:bg-white/5 cursor-pointer border-b border-white/5 group transition-all">
                  <p class="text-[10px] font-black uppercase text-white/60 group-hover:text-white italic">Service Stack (Waiter)</p>
                  <p class="text-[8px] text-white/20 uppercase mt-2 font-black italic">Restricted to POS & Table Management</p>
               </div>
            </div>
         </div>
         <div onclick="window.location.hash='#settings'" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/40 hover:text-white cursor-pointer transition-all hover:bg-white/10 active:scale-90">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /></svg>
         </div>
      </div>
   </nav>

   <!-- Dynamic Section Container -->
   <div id="dashboardSection" class="section active animate-in fade-in transition-all">
      <Dashboard client:load />
   </div>

   <div id="posSection" class="section hidden animate-in fade-in transition-all">
      <POS client:load />
   </div>

   <div id="tablesSection" class="section hidden animate-in fade-in transition-all">
      <Tables client:load />
   </div>

   <div id="kitchenSection" class="section hidden animate-in fade-in transition-all">
      <KDS client:load />
   </div>

   <div id="menuSection" class="section hidden animate-in fade-in transition-all">
      <MenuManager client:load />
   </div>

   <div id="analyticsSection" class="section hidden animate-in fade-in transition-all">
      <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 bg-white/5 border border-white/10 p-10 rounded-[48px] relative overflow-hidden group mb-12">
          <div class="relative z-10">
             <h1 class="text-4xl font-black italic uppercase tracking-tighter leading-none">Matrix <span class="bg-gradient-to-r from-orange-500 to-rose-400 bg-clip-text text-transparent">Analytics</span></h1>
             <p class="text-white/30 text-xs font-black uppercase tracking-[0.3em] mt-3 italic">Autonomous Yield Matrix | V2.0</p>
          </div>
          <div class="flex gap-4 relative z-10">
             <button onclick="window.location.reload()" class="px-6 py-3 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all italic flex items-center gap-2">
               <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span> Mirror Snapshot
             </button>
             <button class="px-8 py-4 bg-orange-600 rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-xl shadow-orange-600/30 hover:scale-[1.05] transition-all italic">Generate Alpha Report</button>
          </div>
          <div class="absolute top-0 right-0 w-64 h-64 bg-rose-500/5 blur-[100px] -z-10 group-hover:bg-rose-500/10 transition-all"></div>
      </header>

      <MatrixAnalytics client:only="react" />
   </div>

   <div id="staffSection" class="section hidden animate-in fade-in transition-all">
      <StaffManager client:load />
   </div>

   <div id="settingsSection" class="section hidden animate-in fade-in transition-all">
      <SettingsNode client:load />
   </div>

   <div id="customersSection" class="section hidden animate-in fade-in transition-all">
      <!-- (Customer Intelligence UI remains the same) -->
      <div class="p-20 opacity-20 text-center font-black italic uppercase italic tracking-widest">Customer Protocol Active</div>
   </div>

</RestaurantOSLayout>

<script is:inline>
   // Navigation Engine
   function switchToSection(target) {
      if (!target) return;
      document.querySelectorAll('.section').forEach(sec => {
         sec.classList.add('hidden');
         sec.classList.remove('active');
      });
      const targetSec = document.getElementById(target + 'Section');
      if (targetSec) {
         targetSec.classList.remove('hidden');
         targetSec.classList.add('active');
      }
   }

   // Stable Dropdowns
   function toggleBranchMenu() {
      const menu = document.getElementById('branchMenu');
      const isVisible = menu.classList.contains('opacity-100');
      document.getElementById('roleMenu').classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      menu.classList.toggle('opacity-100', !isVisible);
      menu.classList.toggle('translate-y-0', !isVisible);
      menu.classList.toggle('pointer-events-auto', !isVisible);
   }

   function toggleRoleMenu() {
      const menu = document.getElementById('roleMenu');
      const isVisible = menu.classList.contains('opacity-100');
      document.getElementById('branchMenu').classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      menu.classList.toggle('opacity-100', !isVisible);
      menu.classList.toggle('translate-y-0', !isVisible);
      menu.classList.toggle('pointer-events-auto', !isVisible);
   }

   // Role Setup
   window.RO_ACCESS_ROLE = localStorage.getItem('ro_role') || 'owner';
   window.RO_ACCESS_DISPLAY = localStorage.getItem('ro_role_display') || 'Owner Protocol';
   document.getElementById('activeRoleDisplay').innerText = window.RO_ACCESS_DISPLAY;

   // Identity Setup
   const identity = JSON.parse(localStorage.getItem('ro_identity') || '{"name":"Grand Cafe Bobo"}');
   document.getElementById('activeBranch').innerText = identity.name;

   function setAccessMode(role, display) {
      localStorage.setItem('ro_role', role);
      localStorage.setItem('ro_role_display', display);
      if (role === 'chef') window.location.hash = '#kitchen';
      else if (role === 'waiter') window.location.hash = '#pos';
      else window.location.hash = '#dashboard';
      window.location.reload();
   }

   function selectBranch(name) {
      document.getElementById('activeBranch').innerText = name;
      toggleBranchMenu();
   }

   // Role-Based UI Restriction
   (function applyRestrictions() {
      const role = window.RO_ACCESS_ROLE;
      const sideMenu = document.querySelector('aside .flex-col');
      if (!sideMenu) return;

      if (role === 'owner') {
         // Add Staff Governance link
         if (!document.getElementById('staffNavLink')) {
            const node = document.createElement('div');
            node.id = 'staffNavLink';
            node.onclick = () => window.location.hash = '#staff';
            node.className = "flex items-center gap-4 px-8 py-5 rounded-3xl cursor-pointer hover:bg-white/5 transition-all group mb-4";
            node.innerHTML = `<svg class="w-4 h-4 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg><span class="text-[10px] font-black uppercase text-white/40 tracking-[0.2em] italic">Staff Governance</span>`;
            sideMenu.appendChild(node);
         }
      } else {
         // Generic Staff filtering
         Array.from(sideMenu.children).forEach(link => {
            const text = link.innerText.toLowerCase();
            if (role === 'chef' && !text.includes('kitchen')) link.style.display = 'none';
            if (role === 'waiter' && !(text.includes('pos') || text.includes('table') || text.includes('waiter'))) link.style.display = 'none';
         });
      }
   })();

   // Hash handling
   window.addEventListener('hashchange', () => switchToSection(window.location.hash.substring(1) || 'dashboard'));
   switchToSection(window.location.hash.substring(1) || 'dashboard');
</script>

<style is:global>
  .section.hidden { display: none; }
</style>
