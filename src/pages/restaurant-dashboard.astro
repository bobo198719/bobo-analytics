---
import RestaurantOSLayout from "../layouts/RestaurantOSLayout.astro";
import Dashboard from "../components/restaurant/Dashboard.jsx";
import MatrixAnalytics from "../components/restaurant/MatrixAnalytics.jsx";
import TouchPOS from "../components/restaurant/TouchPOS.jsx";
import Tables from "../components/restaurant/Tables.jsx";
import KDS from "../components/restaurant/KDS.jsx";
import MenuManager from "../components/restaurant/MenuManager.jsx";
import WaiterDashboard from "../components/restaurant/WaiterDashboard.jsx";
import SettingsNode from "../components/restaurant/SettingsNode.jsx";
import CRMManager from "../components/restaurant/CRMManager.jsx";
import SmartUpload from "../components/restaurant/SmartUpload.jsx";
import DailyReport from "../components/restaurant/DailyReport.jsx";
import "../styles/restaurant.css";
---

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js" is:inline></script>
<script src="https://cdn.jsdelivr.net/npm/exceljs/dist/exceljs.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" is:inline></script>

<RestaurantOSLayout title="Restaurant Intelligence Terminal | Bobo OS">
   <!-- Enterprise Control Layer -->
    <nav class="hidden">
       <!-- Legacy Nav Halted to prevent Z-Index Conflicts -->
    </nav>

   <div id="dashboardSection" data-section-node class="section active animate-in fade-in transition-all">
      <Dashboard client:load />
   </div>

   <div id="posSection" data-section-node class="section hidden animate-in fade-in transition-all">
      <TouchPOS client:load />
   </div>

   <div id="tablesSection" data-section-node class="section hidden animate-in fade-in transition-all">
      <Tables client:load />
   </div>

   <div id="kitchenSection" data-section-node class="section hidden animate-in fade-in transition-all">
      <KDS client:load />
   </div>

   <div id="menuSection" data-section-node class="section hidden animate-in fade-in transition-all">
      <MenuManager client:load />
   </div>

   <div id="analyticsSection" data-section-node class="section hidden animate-in fade-in transition-all">
      <MatrixAnalytics client:only="react" />
   </div>

   <div id="waiterSection" data-section-node class="section hidden animate-in fade-in transition-all">
      <div class="max-w-6xl mx-auto p-10">
         <WaiterDashboard client:load />
      </div>
   </div>

   <div id="settingsSection" data-section-node class="section hidden animate-in fade-in transition-all">
      <SettingsNode client:load />
   </div>

   <div id="uploadSection" data-section-node class="section hidden animate-in fade-in transition-all">
      <div class="max-w-6xl mx-auto p-10">
         <SmartUpload client:load />
      </div>
   </div>

   <div id="crmSection" data-section-node class="section hidden animate-in fade-in transition-all">
      <div class="max-w-7xl mx-auto p-10">
         <CRMManager client:load />
      </div>
   </div>

   <div id="reportsSection" data-section-node class="section hidden animate-in fade-in transition-all">
      <div class="max-w-7xl mx-auto p-10">
         <DailyReport client:load />
      </div>
   </div>

</RestaurantOSLayout>

<script is:inline>
     // --- TERMINAL HUB NAVIGATION HEARTBEAT (100ms) ---
     (function initializeTerminalSync() {
        console.log("🔓 TERMINAL SYNC ACTIVE: Listening for Node Shifts");
        const initialRole = localStorage.getItem('ro_role') || 'owner';
        const dH = initialRole === 'waiter' ? 'pos' : initialRole === 'chef' ? 'kitchen' : 'dashboard';

        function syncTerminalViewState() {
            let h;
            try { 
                h = window.location.hash.substring(1) || dH;
            } catch(e) { h = 'dashboard'; }
            
            const targetId = h + 'Section';
            const allNodes = document.querySelectorAll('[data-section-node]');
            
            if (allNodes.length > 0) {
                allNodes.forEach(node => {
                    if (node.id === targetId) {
                        node.style.setProperty('display', 'block', 'important');
                        node.style.setProperty('opacity', '1', 'important');
                        node.style.setProperty('visibility', 'visible', 'important');
                        node.style.setProperty('pointer-events', 'auto', 'important');
                        node.classList.remove('hidden');
                    } else {
                        node.style.setProperty('display', 'none', 'important');
                        node.style.setProperty('opacity', '0', 'important');
                        node.style.setProperty('visibility', 'hidden', 'important');
                        node.style.setProperty('pointer-events', 'none', 'important');
                        node.classList.add('hidden');
                    }
                });
            }

             // Sync Sidebar Links
             document.querySelectorAll('.nav-link').forEach(link => {
                 const href = link.getAttribute('href');
                 const iA = href && (href.includes('#' + h) || (h === 'dashboard' && href.endsWith('dashboard')));
                 link.classList.toggle('active', !!iA);
                 
                 // FORCE RELOAD on first click to ensure sync if stuck
                 if (link.dataset.bound !== 'true') {
                     link.addEventListener('click', () => {
                         setTimeout(() => window.location.reload(), 50);
                     });
                     link.dataset.bound = 'true';
                 }
             });
            
            document.body.classList.toggle('pos-active-mode', h === 'pos');
        }

        setInterval(syncTerminalViewState, 100);
        window.addEventListener('hashchange', syncTerminalViewState);
        document.addEventListener('DOMContentLoaded', syncTerminalViewState);
        syncTerminalViewState();

        // Control Exports
        window.switchToSection = (t) => { window.location.hash = t; };
        window.toggleBranchMenu = () => { document.getElementById('branchMenu')?.classList.toggle('opacity-100'); };
        window.toggleRoleMenu = () => { document.getElementById('roleMenu')?.classList.toggle('opacity-100'); };
        window.setAccessMode = (r, d) => { localStorage.setItem('ro_role', r); localStorage.setItem('ro_role_display', d); window.location.reload(); };
     })();
</script>
