---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/restaurant.css";
---

<MainLayout title="Secure CRM Portal | Bobo Analytics Master Selection" hideNav={true}>
  <div class="portal-page bg-[#05081a] min-h-screen font-['Plus_Jakarta_Sans'] flex items-center justify-center p-6 relative overflow-hidden">
    <!-- Ambient Background Lighting -->
    <div class="absolute top-0 left-0 w-full h-full pointer-events-none">
       <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-indigo-600/10 rounded-full blur-[120px] -mr-64 -mt-64"></div>
       <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-orange-600/10 rounded-full blur-[120px] -ml-64 -mb-64"></div>
    </div>

    <div class="max-w-4xl w-full relative z-10 text-center">
       <header class="mb-16">
          <h1 class="text-4xl md:text-6xl font-black italic tracking-tighter text-white mb-4">Secure CRM Portal</h1>
          <p class="text-white/40 text-sm md:text-lg font-bold uppercase tracking-widest italic">Select your industry to access your dedicated business workspace.</p>
       </header>

       <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          
          <!-- Pharmacy Portal Card -->
          <a href="/pharmacy-login" class="portal-card group relative p-12 bg-white/5 border border-white/10 rounded-[48px] overflow-hidden transition-all hover:border-indigo-500 hover:scale-[1.03] active:scale-95 shadow-2xl">
             <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
             <div class="relative z-10 flex flex-col items-center">
                <div class="w-20 h-20 bg-indigo-500/20 rounded-3xl flex items-center justify-center text-4xl mb-8 group-hover:scale-110 group-hover:rotate-6 transition-transform shadow-lg shadow-indigo-500/10">💊</div>
                <h3 class="text-2xl font-black italic text-white mb-4 uppercase tracking-tight">Pharmacy Portal</h3>
                <p class="text-white/40 text-sm font-medium leading-relaxed italic">Access inventory, prescriptions, and retail health analytics.</p>
                <div class="mt-10 px-10 py-4 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-[0.3em] opacity-0 group-hover:opacity-100 transition-all">Access Workspace</div>
             </div>
          </a>

          <!-- Restaurant Portal Card -->
          <a href="/restaurant-login" class="portal-card group relative p-12 bg-white/5 border border-white/10 rounded-[48px] overflow-hidden transition-all hover:border-orange-500 hover:scale-[1.03] active:scale-95 shadow-2xl">
              <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div class="relative z-10 flex flex-col items-center">
                 <div class="w-20 h-20 bg-orange-500/20 rounded-3xl flex items-center justify-center text-4xl mb-8 group-hover:scale-110 group-hover:-rotate-6 transition-transform shadow-lg shadow-orange-500/10">🍽️</div>
                 <h3 class="text-2xl font-black italic text-white mb-4 uppercase tracking-tight">Restaurant CRM</h3>
                 <p class="text-white/40 text-sm font-medium leading-relaxed italic">Manage tables, menu, kitchen orders, POS billing and business analytics.</p>
                 <div class="mt-10 px-10 py-4 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-[0.3em] opacity-0 group-hover:opacity-100 transition-all">Access Workspace</div>
              </div>
           </a>
       </div>

       <footer class="mt-20 opacity-20 text-[10px] font-black uppercase tracking-[0.5em] italic">Bobo Analytics Enterprise Engine | Secure Directory</footer>
    </div>
  </div>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
  </style>
</MainLayout>
