---
// Premium CRM Portal | Vanilla CSS Version for Stability
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Secure CRM Portal | Bobo OS</title>
  <style>
    :root {
      --bg: #05081a;
      --card-bg: rgba(255, 255, 255, 0.03);
      --card-border: rgba(255, 255, 255, 0.08);
      --accent: #6366f1;
      --orange: #f97316;
      --green: #10b981;
      --rose: #f43f5e;
      --emerald: #10b981;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: white;
      font-family: 'Inter', -apple-system, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow-x: hidden;
      padding: 40px 20px;
    }

    .ambient-glow {
      position: absolute;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(99, 102, 241, 0.1), transparent 70%);
      filter: blur(80px);
      z-index: -1;
      top: -100px;
      right: -100px;
    }

    header {
      text-align: center;
      margin-bottom: 60px;
      max-width: 600px;
    }

    h1 {
      font-size: 3.5rem;
      font-weight: 900;
      margin: 0 0 10px 0;
      font-style: italic;
      letter-spacing: -2px;
      text-transform: uppercase;
    }

    p.subtitle {
      color: rgba(255, 255, 255, 0.3);
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 4px;
      margin: 0;
    }

    .matrix {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      width: 100%;
      max-width: 1200px;
    }

    .card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 40px;
      padding: 48px 30px;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
      backdrop-filter: blur(10px);
    }

    .card:hover {
      transform: translateY(-8px);
      background: rgba(255, 255, 255, 0.06);
      border-color: rgba(255, 255, 255, 0.2);
    }

    .icon {
      width: 80px;
      height: 80px;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      margin-bottom: 30px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: 0.3s;
    }

    .card:hover .icon { transform: scale(1.1); }

    .card.restaurant .icon { color: var(--orange); background: rgba(249, 115, 22, 0.1); }
    .card.pharmacy .icon { color: var(--green); background: rgba(16, 185, 129, 0.1); }
    .card.retail .icon { color: var(--accent); background: rgba(99, 102, 241, 0.1); }
    .card.baker .icon { color: var(--rose); background: rgba(244, 63, 94, 0.1); }
    .card.grocery .icon { color: var(--emerald); background: rgba(16, 185, 129, 0.1); }
    .card.admin .icon { color: #ef4444; background: rgba(239, 68, 68, 0.1); }

    h3 {
      font-size: 22px;
      font-weight: 900;
      margin: 0 0 10px 0;
      text-transform: uppercase;
      font-style: italic;
    }

    p.desc {
      font-size: 11px;
      color: rgba(255, 255, 255, 0.3);
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 1px;
      line-height: 1.6;
      margin: 0 0 32px 0;
      max-width: 200px;
    }

    .btn {
      padding: 14px 28px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      font-weight: 800;
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-style: italic;
      transition: 0.3s;
      opacity: 0.5;
    }

    .card:hover .btn {
      background: white;
      color: black;
      opacity: 1;
      transform: translateY(-2px);
    }

    @media (max-width: 600px) {
      h1 { font-size: 2.5rem; }
      .matrix { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="ambient-glow"></div>
  
  <header>
    <h1>Secure <span style="color:rgba(255,255,255,0.4)">Portal</span></h1>
    <p class="subtitle">Bobo OS Industry Matrix Gate</p>
  </header>

  <div class="matrix">
    <a href="/restaurant-login" class="card restaurant">
      <div class="icon">🍽️</div>
      <h3>Restaurant CRM</h3>
      <p class="desc">Manage tables, menu, kitchen, POS and analytics.</p>
      <div class="btn">Connect Node</div>
    </a>

    <a href="/pharmacy-login" class="card pharmacy">
      <div class="icon">💊</div>
      <h3>Pharmacy Portal</h3>
      <p class="desc">Inventory management and prescription control HUB.</p>
      <div class="btn">Connect Node</div>
    </a>

    <a href="/retail-crm" class="card retail">
      <div class="icon">🛒</div>
      <h3>Retail CRM</h3>
      <p class="desc">High-speed retail analytics and behavior tracking.</p>
      <div class="btn">Connect Node</div>
    </a>

    <a href="/bakers-login" class="card baker">
      <div class="icon">🍰</div>
      <h3>Baker OS</h3>
      <p class="desc">Artisanal production and custom order management.</p>
      <div class="btn">Connect Node</div>
    </a>

    <a href="/grocery-login" class="card grocery">
      <div class="icon">🍎</div>
      <h3>Grocery OS</h3>
      <p class="desc">Supply chain tracking and high-speed supermarket POS.</p>
      <div class="btn">Connect Node</div>
    </a>

    <a href="/admin-login" class="card admin">
      <div class="icon">🛡️</div>
      <h3>System Admin</h3>
      <p class="desc">Master Control Panel for Bobo Analytics operations.</p>
      <div class="btn">Access Master Core</div>
    </a>
  </div>
</body>
</html>
