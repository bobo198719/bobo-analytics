---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Signup | Bobo Analytics">

<section class="auth">

<h1>Create Your Account</h1>

<form class="auth-form">

<input type="text" placeholder="Full Name" required />

<input type="email" placeholder="Email Address" required />

<input type="password" placeholder="Password" required />

<button type="submit">Create Account</button>

</form>

<p class="login-link">
Already have an account?
<a href="/pharmacy-login">Login</a>
</p>

</section>

<style>
.auth{
max-width:420px;
margin:auto;
padding:40px;
}

.auth-form{
display:flex;
flex-direction:column;
gap:12px;
margin-top:20px;
}

.auth-form input{
padding:12px;
border-radius:6px;
border:1px solid #333;
background:#111;
color:white;
}

.auth-form button{
padding:12px;
border:none;
border-radius:6px;
background:#00ff88;
font-weight:bold;
cursor:pointer;
}

.login-link{
margin-top:15px;
}
</style>

</MainLayout>