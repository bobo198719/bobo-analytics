---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Signup">

<div class="signup-page">

<h1>Create Your Account</h1>

<p class="subtitle">
Start using Bobo Analytics for your pharmacy business.
</p>

<div class="signup-box">

<input type="text" placeholder="Full Name" />

<input type="email" placeholder="Email Address" />

<input type="password" placeholder="Password" />

<button>Create Account</button>

<p class="login-link">
Already have an account? <a href="/pharmacy-login">Login</a>
</p>

</div>

</div>

<style>

.signup-page{
padding:40px;
min-height:100vh;
background:#0a0a0a;
color:white;
font-family:Arial, sans-serif;
}

.subtitle{
color:#bbb;
margin-bottom:25px;
}

.signup-box{
display:flex;
flex-direction:column;
gap:12px;
max-width:350px;
background:#111;
padding:25px;
border-radius:8px;
border:1px solid #222;
}

.signup-box input{
padding:12px;
border-radius:6px;
border:1px solid #333;
background:#0a0a0a;
color:white;
}

.signup-box button{
padding:12px;
background:#00ff88;
border:none;
border-radius:6px;
font-weight:bold;
cursor:pointer;
}

.login-link{
margin-top:10px;
font-size:14px;
}

.login-link a{
color:#00ff88;
text-decoration:none;
}

</style>

</MainLayout>