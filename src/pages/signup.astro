---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Signup">

<div class="signup">

<h1>Create Pharmacy Account</h1>

<p>Register your pharmacy to start using Bobo Analytics.</p>

<form>

<input type="text" placeholder="Pharmacy Name" required>

<input type="text" placeholder="Owner Name" required>

<input type="email" placeholder="Email" required>

<input type="password" placeholder="Password" required>

<button type="submit">Create Account</button>

</form>

</div>

<style>

.signup{
padding:40px;
background:#0a0a0a;
color:white;
min-height:100vh;
}

form{
display:flex;
flex-direction:column;
max-width:400px;
gap:15px;
margin-top:20px;
}

input{
padding:12px;
border-radius:6px;
border:none;
}

button{
padding:12px;
background:#00ff88;
border:none;
border-radius:6px;
cursor:pointer;
font-weight:bold;
}

</style>

</MainLayout>