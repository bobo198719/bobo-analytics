---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Admin Hub | Bobo Analytics">
  <div class="admin-layout">
    <aside class="sidebar">
      <div class="sidebar-header">
        <img src="/logo.png" alt="Bobo Analytics Logo" class="admin-logo" />
        <h2>Admin Hub</h2>
      </div>
      <nav class="sidebar-nav">
        <a href="#dashboard" class="active">Overview</a>
        <a href="#tenants">Create Tenants</a>
        <a href="#users">Manage Users</a>
        <a href="#billing">Billing & Subscriptions</a>
        <a href="#settings">System Settings</a>
      </nav>
      <div class="sidebar-footer">
        <button id="logoutBtn" class="btn-logout">Logout</button>
      </div>
    </aside>

    <main class="main-content">
      <header class="top-bar">
        <h1 id="pageTitle">Dashboard</h1>
        <div class="user-profile">
          <span>System Admin</span>
          <div class="avatar">SA</div>
        </div>
      </header>

      <!-- Dashboard Section -->
      <div id="sec-dashboard" class="admin-section active">
        <section class="overview-cards">
          <div class="card revenue">
            <h3>Total MRR</h3>
            <p class="value">₹12,45,000</p>
            <span class="trend positive">↑ 14% vs last month</span>
          </div>
          <div class="card">
            <h3>Active Industries</h3>
            <p class="value">7</p>
            <span class="trend">Across our network</span>
          </div>
          <div class="card">
            <h3>Total Tenants</h3>
            <p class="value">2,154</p>
            <span class="trend positive">↑ 8% vs last month</span>
          </div>
          <div class="card">
            <h3>System Health</h3>
            <p class="value">99.99%</p>
            <span class="trend positive">All Systems Operational</span>
          </div>
        </section>
      </div>

      <!-- Tenants Section -->
      <div id="sec-tenants" class="admin-section">
        <section class="tenant-creation">
          <div class="section-header">
            <h2>Provision New Tenant</h2>
            <p>Create dedicated instances and custom IDs for new businesses joining the platform.</p>
          </div>

          <div class="creation-panel">
            <form class="tenant-form" id="createTenantForm">
              <div class="form-row">
                <div class="form-group">
                  <label>Industry Vertical</label>
                  <select id="industrySelect" required>
                    <option value="" disabled selected>Select Industry</option>
                    <option value="pharmacy">Pharmacy</option>
                    <option value="healthcare">Healthcare</option>
                    <option value="retail">Retail</option>
                    <option value="finance">Finance</option>
                    <option value="groceries">Groceries</option>
                    <option value="clothing-store">Clothing Store</option>
                    <option value="stock-trading">Stock Trading</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Custom Instance ID</label>
                  <input type="text" id="customId" placeholder="e.g., apollo-pharm-1" required />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label>Business Name</label>
                  <input type="text" id="businessName" placeholder="Registered Name" required />
                </div>
                <div class="form-group">
                  <label>Admin Email</label>
                  <input type="email" id="adminEmail" placeholder="admin@business.com" required />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label>Subscription Plan</label>
                  <select id="subscriptionPlan" required>
                    <option value="starter">Starter</option>
                    <option value="professional" selected>Professional</option>
                    <option value="enterprise">Enterprise</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Account Password</label>
                  <input type="password" id="accountPassword" placeholder="••••••••" required />
                </div>
              </div>

              <div class="form-actions">
                <button type="submit" class="btn-primary">Provision Tenant Space</button>
              </div>
            </form>
            <div id="successMsg" class="success-alert" style="display: none;">
              ✅ Tenant space successfully provisioned! Credentials ready.
            </div>
          </div>
        </section>

        <section class="recent-activity" style="margin-top: 48px;">
          <h2>Recent Tenant Provisions</h2>
          <table class="activity-table">
            <thead>
              <tr>
                <th>Instance ID</th>
                <th>Industry</th>
                <th>Plan</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="tenantTableBody">
              <tr>
                <td>medcare-01</td>
                <td>Pharmacy</td>
                <td>Professional</td>
                <td><span class="badge success">Active</span></td>
              </tr>
              <tr>
                <td>freshfoods-nyc</td>
                <td>Groceries</td>
                <td>Enterprise</td>
                <td><span class="badge success">Active</span></td>
              </tr>
              <tr>
                <td>trust-bank-eu</td>
                <td>Finance</td>
                <td>Enterprise</td>
                <td><span class="badge pending">Provisioning</span></td>
              </tr>
            </tbody>
          </table>
        </section>
      </div>

      <!-- Manage Users Section -->
      <div id="sec-users" class="admin-section">
        <div class="section-header">
          <h2>Manage Users</h2>
          <p>View and manage all active users across instances.</p>
        </div>
        <div class="card" style="text-align: center; padding: 40px;">
          <p style="color: rgba(255,255,255,0.6); font-size: 1.1rem;">No active users found for current filter.</p>
        </div>
      </div>

      <!-- Billing Section -->
      <div id="sec-billing" class="admin-section">
        <div class="section-header">
          <h2>Billing & Subscriptions</h2>
          <p>Track payments and recurring revenue.</p>
        </div>
        <div class="card" style="text-align: center; padding: 40px;">
          <p style="color: rgba(255,255,255,0.6); font-size: 1.1rem;">No pending invoices.</p>
        </div>
      </div>

      <!-- System Settings Section -->
      <div id="sec-settings" class="admin-section">
        <div class="section-header">
          <h2>System Settings</h2>
          <p>Configure global platform attributes.</p>
        </div>
        <div class="creation-panel">
          <div class="form-row">
            <div class="form-group">
              <label>Maintenance Mode</label>
              <select>
                <option value="off">Off</option>
                <option value="on">On</option>
              </select>
            </div>
            <div class="form-group">
              <label>Data Backup Frequency</label>
              <select>
                <option value="daily">Daily</option>
                <option value="weekly">Weekly</option>
              </select>
            </div>
          </div>
          <button class="btn-primary" style="margin-top: 16px;">Save Settings</button>
        </div>
      </div>

    </main>
  </div>

  <style>
    .admin-layout {
      position: absolute;
      top: 0; left: 0;
      width: 100vw;
      height: 100vh;
      background: #05081a;
      display: flex;
      font-family: 'Inter', sans-serif;
      z-index: 9999;
      color: white;
      overflow: hidden;
    }

    .admin-section {
      display: none;
      animation: fadeIn 0.3s ease;
    }

    .admin-section.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .sidebar {
      width: 260px;
      background: #0b112d;
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      display: flex;
      flex-direction: column;
    }

    .sidebar-header {
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .admin-logo {
      width: 32px;
      height: 32px;
      object-fit: contain;
    }

    .sidebar-header h2 {
      font-size: 1.2rem;
      font-weight: 700;
      margin: 0;
    }

    .sidebar-nav {
      padding: 24px 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      flex: 1;
    }

    .sidebar-nav a {
      color: rgba(255, 255, 255, 0.7);
      text-decoration: none;
      padding: 12px 16px;
      border-radius: 8px;
      font-weight: 500;
      transition: all 0.2s;
    }

    .sidebar-nav a:hover, .sidebar-nav a.active {
      background: rgba(99, 102, 241, 0.1);
      color: #6366f1;
    }

    .sidebar-footer {
      padding: 24px;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .btn-logout {
      width: 100%;
      background: transparent;
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #ef4444;
      padding: 10px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      transition: all 0.2s;
    }

    .btn-logout:hover {
      background: rgba(239, 68, 68, 0.1);
    }

    .main-content {
      flex: 1;
      overflow-y: auto;
      padding: 32px 48px;
      background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.05) 0%, transparent 50%);
    }

    .top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 40px;
    }

    .top-bar h1 {
      font-size: 2rem;
      font-weight: 800;
      margin: 0;
    }

    .user-profile {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #6366f1;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
    }

    .overview-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 24px;
      margin-bottom: 48px;
    }

    .card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      padding: 24px;
    }

    .card.revenue {
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.2) 0%, rgba(168, 85, 247, 0.2) 100%);
      border-color: rgba(99, 102, 241, 0.3);
    }

    .card h3 {
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.6);
      margin: 0 0 12px 0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .card .value {
      font-size: 2rem;
      font-weight: 800;
      margin: 0 0 8px 0;
    }

    .trend {
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.5);
    }

    .trend.positive {
      color: #10b981;
    }

    .section-header {
      margin-bottom: 24px;
    }

    .section-header h2 {
      font-size: 1.5rem;
      margin: 0 0 8px 0;
    }

    .section-header p {
      color: rgba(255, 255, 255, 0.6);
      margin: 0;
    }

    .creation-panel {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 32px;
    }

    .form-row {
      display: flex;
      gap: 24px;
      margin-bottom: 24px;
    }

    .form-group {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .form-group label {
      font-size: 0.9rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.8);
    }

    .form-group input, .form-group select {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 12px 16px;
      border-radius: 10px;
      color: white;
      font-size: 1rem;
      outline: none;
      transition: border-color 0.2s;
    }
    
    .form-group select option {
        background: #0b112d;
        color: white;
    }

    .form-group input:focus, .form-group select:focus {
      border-color: #6366f1;
    }

    .form-actions {
      margin-top: 32px;
      display: flex;
      justify-content: flex-end;
    }

    .btn-primary {
      background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
      color: white;
      padding: 12px 24px;
      border: none;
      border-radius: 10px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
    }

    .success-alert {
      margin-top: 24px;
      padding: 16px;
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      border-radius: 10px;
      color: #10b981;
    }

    .recent-activity h2 {
      font-size: 1.5rem;
      margin: 0 0 24px 0;
    }

    .activity-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .activity-table th {
      color: rgba(255, 255, 255, 0.5);
      font-weight: 500;
      padding: 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .activity-table td {
      padding: 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .badge {
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .badge.success {
      background: rgba(16, 185, 129, 0.1);
      color: #10b981;
    }

    .badge.pending {
      background: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
    }

    @media (max-width: 1024px) {
      .form-row { flex-direction: column; gap: 16px; margin-bottom: 16px; }
    }
  </style>

  <script>
    // Authentication Check
    document.addEventListener("DOMContentLoaded", () => {
      const isAuth = localStorage.getItem("adminAuth");
      if (!isAuth) {
        window.location.href = "/admin-login";
      }

      // Tab Switching Logic
      const navLinks = document.querySelectorAll('.sidebar-nav a');
      const sections = document.querySelectorAll('.admin-section');
      const pageTitle = document.getElementById('pageTitle');

      navLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          
          navLinks.forEach(l => l.classList.remove('active'));
          link.classList.add('active');
          
          const targetId = 'sec-' + link.getAttribute('href').substring(1);
          
          sections.forEach(sec => {
            sec.classList.remove('active');
            if (sec.id === targetId) sec.classList.add('active');
          });

          // Update header title based on selected nav
          pageTitle.innerText = link.innerText;
        });
      });
    });

    // Handle Form Submission
    const form = document.getElementById("createTenantForm");
    const successMsg = document.getElementById("successMsg");
    const tbody = document.getElementById("tenantTableBody");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const industry = document.getElementById("industrySelect").value;
      const customId = document.getElementById("customId").value;
      const businessName = document.getElementById("businessName").value;
      const password = document.getElementById("accountPassword").value;
      const selectedPlan = document.getElementById("subscriptionPlan").value;

      try {
        // Simulatiing a live backend connection for production demo
        let tenants = JSON.parse(localStorage.getItem("bobo_tenants") || "[]");
        
        // Check if tenant customId already exists
        if (tenants.find(t => t.pharmacyId === customId)) {
           alert("Connection error: Tenant ID already in use. Please choose another.");
           return;
        }

        const newTenant = {
          pharmacy: businessName,
          pharmacyId: customId,
          password: password,
          industry: industry,
          plan: selectedPlan
        };

        tenants.push(newTenant);
        localStorage.setItem("bobo_tenants", JSON.stringify(tenants));

        // Simulate network delay
        await new Promise(r => setTimeout(r, 600));

        successMsg.style.display = "block";
        successMsg.innerText = "✅ Tenant space successfully provisioned! Credentials are ready.";
        
        const newRow = document.createElement("tr");
        newRow.style.animation = "fadeIn 0.5s ease";
        
        const industryText = industry.charAt(0).toUpperCase() + industry.slice(1);
        const planText = selectedPlan.charAt(0).toUpperCase() + selectedPlan.slice(1);
        
        newRow.innerHTML = `
          <td>${customId}</td>
          <td>${industryText}</td>
          <td>${planText}</td>
          <td><span class="badge success">Active</span></td>
        `;
        
        tbody.insertBefore(newRow, tbody.firstChild);

        setTimeout(() => {
          successMsg.style.display = "none";
          form.reset();
        }, 4000);
      } catch (err) {
        alert("Connection error. Could not provision tenant.");
      }
    });

    // Handle Logout
    document.getElementById("logoutBtn").addEventListener("click", () => {
      localStorage.removeItem("adminAuth");
      window.location.href = "/admin-login";
    });
  </script>
</MainLayout>
