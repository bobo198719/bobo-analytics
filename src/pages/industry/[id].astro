---
import MainLayout from "../../layouts/MainLayout.astro";

export const prerender = false;
const { id } = Astro.params;

const industryData = {
  baker: {
    title: "Baker OS",
    tagline: "The #1 Software for Modern Artisan Bakers",
    description: "Complete bakery management platform designed for modern dessert businesses and artisan shops.",
    icon: "🍰",
    benefits: [
      "Recipe costing automation (Save 5h per week)",
      "Order & delivery tracking",
      "Real-time profit margin insights",
      "Customer repeat analytics & automated WhatsApp marketing"
    ],
    comparison: [
      ["Inventory", "Real-time smart tracking", "Manual stock cards"],
      ["Orders", "Automated POS workflow", "Manual notebook entry"],
      ["Production", "Waste reduction AI", "Guessing volumes"],
      ["Analytics", "Growth intelligence", "No data insights"]
    ]
  },
  pharmacy: {
    title: "Pharmacy Intelligence",
    tagline: "Compliant. Automated. Profitable.",
    description: "Smart pharmacy system with stock intelligence, automated billing, and compliance monitoring.",
    icon: "💊",
    benefits: [
      "Automated Expiry Alerts",
      "1-Click WhatsApp Billing",
      "AI Stock replenishment engine",
      "Prescription forensic tracking"
    ],
    comparison: [
      ["Billing", "3-second checkout", "Slow manual billing"],
      ["Compliance", "Auto-audit ready", "High risk manual logs"],
      ["Expiry", "90-day predictive alerts", "Checking boxes manually"],
      ["Efficiency", "Reduced operational overhead", "High wastage/loss"]
    ]
  },
  society: {
    title: "Society Ledger OS",
    tagline: "Prime Intelligence for Smart Societies",
    description: "Real-time asset, finance, and security management for modern residential and commercial complexes.",
    icon: "🏢",
    benefits: [
      "Real-time Collection Velocity Tracking",
      "Automated WhatsApp Bulk Reminders",
      "Visitor Gate Pass Engine",
      "Unified Dashboard for Complaints & Defaulters"
    ],
    comparison: [
      ["Billing", "Auto-recurring & WhatsApp PDFs", "Complex manual tracking"],
      ["Reminders", "1-Click Bulk WhatsApp", "Dialing individually"],
      ["Security", "Real-time Gate Logs", "Paper logbooks"],
      ["Compliance", "Zero due slip-ups", "Losing track of defaulters"]
    ]
  },
  healthcare: {
    title: "Healthcare CRM",
    tagline: "Patient Care Powered by AI Analytics",
    description: "Patient data and hospital analytics platform for clinics and medical centers.",
    icon: "🏥",
    benefits: [
      "Patient lifecycle tracking",
      "Intelligent Appointment System",
      "Clincial outcomes insights",
      "Operational staff efficiency analytics"
    ],
    comparison: [
      ["Patient Data", "Centralized & Accessible", "Scattered paper files"],
      ["Waiting Times", "Optimized by AI", "Unpredictable delays"],
      ["Billing", "Integrated medical billing", "Disconnected workflows"],
      ["Security", "Enterprise HIPAA-style logs", "Low-security records"]
    ]
  },
  retail: {
    title: "Retail Intelligence",
    tagline: "From Footfalls to Loyal Fans",
    description: "Consumer behavior and sales insights for modern retail networks and big brands.",
    icon: "🛒",
    benefits: [
      "Consumer heatmap analytics",
      "AI-driven product placement",
      "Loyalty program automation",
      "Real-time supply chain mapping"
    ],
    comparison: [
      ["Stock", "JIT Inventory Control", "Overstocking issues"],
      ["Marketing", "Personalized AI offers", "Generic mass promos"],
      ["Sales", "Footfall correlation", "Unknown performance metrics"],
      ["Returns", "Predictive return analysis", "Reactive policy"]
    ]
  },
  finance: {
     title: "Finance Suite",
     tagline: "Market Intelligence for Decision Makers",
     description: "Real-time market analysis and risk assessment tools for financial firms.",
     icon: "📈",
     benefits: [
        "Portfolio risk guardrails",
        "Real-time market signals",
        "Automated compliance reporting",
        "Historical trend forecasting"
     ],
     comparison: [
        ["Risk Management", "Automated stop-loss logic", "Slow human reaction"],
        ["Signals", "Millisecond data alerts", "Lagging market news"],
        ["Reporting", "Instant PDF exports", "Days of manual compilation"]
     ]
  },
  grocery: {
     title: "Grocery OS",
     tagline: "Fresh Stock, Optimized Profits",
     description: "Supply chain, stock optimization, and AI-driven POS for grocery chains.",
     icon: "🍎",
     benefits: [
        "Fresh-item expiry management",
        "Smart shelf replenishment",
        "Vendor performance tracking",
        "Real-time bulk billing"
     ],
     comparison: [
        ["Spoilage", "Reduced by 35% with AI", "High wastage costs"],
        ["Checkouts", "Multi-terminal sync", "Individual POS lag"],
        ["Sourcing", "Demand-based ordering", "Bulk buying blind"]
     ]
  },
  restaurant: {
    title: "Restaurant OS",
    tagline: "The Complete Intelligence Layer for Modern Restaurants",
    description: "Full-stack restaurant management platform — from table to kitchen to analytics. Built for ambitious restaurateurs who want real-time control of every operation.",
    icon: "🍽️",
    benefits: [
      "Live Touch POS with instant KOT generation & kitchen routing",
      "Smart Menu Catalog with image upload, bulk import & live edit",
      "Table management — real-time floor map with status tracking",
      "Kitchen Display System (KDS) with order prioritization",
      "Guest Intelligence CRM — loyalty, visit history & feedback",
      "Revenue analytics — daily, weekly & monthly profit insights",
      "Multi-role access — Owner, Chef & Waiter dashboards",
      "Bulk menu import via Excel, CSV or PDF — 1-click catalog sync"
    ],
    comparison: [
      ["Order Taking", "Touch POS with instant KOT", "Paper slips & manual calls"],
      ["Menu Updates", "Live edit + image upload", "Reprinting paper menus"],
      ["Kitchen Sync", "Real-time KDS display", "Shouting across the kitchen"],
      ["Table Status", "Live floor map view", "Walking around to check"],
      ["Analytics", "Revenue radar & profit trends", "End-of-day manual tally"],
      ["CRM", "Guest loyalty & visit history", "No customer data at all"]
    ]
  }
};

const data = industryData[id] || industryData.baker;
---

<MainLayout title={`${data.title} | Bobo Analytics Solutions`}>
  <div class="industry-detail-page">
    <header class="industry-hero">
      <div class="badge-icon">{data.icon}</div>
      <h1>{data.title}</h1>
      <p class="tagline">{data.tagline}</p>
      <p class="description">{data.description}</p>
      <div class="header-actions">
        <a href="/crm-login" class="btn-primary">Access {data.title} Portal</a>
        <a href="#benefits" class="btn-ghost">View Benefits</a>
      </div>
    </header>

    <section id="benefits" class="benefits-section">
      <div class="section-title">
        <h2>🔥 Key Business Benefits</h2>
        <p>Why industry leaders choose Bobo for their {data.title.toLowerCase()} operations.</p>
      </div>
      <div class="benefits-grid">
        {data.benefits.map(b => (
          <div class="benefit-card">
            <span class="check">✓</span>
            <p>{b}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="comparison-section">
      <div class="section-title">
        <h2>🚀 Bobo vs. Traditional Methods</h2>
        <p>Experience the quantum leap in efficiency and intelligence.</p>
      </div>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Feature</th>
              <th class="highlight">Bobo {data.title}</th>
              <th>Legacy Software</th>
            </tr>
          </thead>
          <tbody>
            {data.comparison.map(c => (
              <tr>
                <td><b>{c[0]}</b></td>
                <td class="high-val">{c[1]}</td>
                <td>{c[2]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Visual UI Showcase -->
    <section class="visual-showcase">
       <div class="visual-block">
        <div class="visual-text">
          <h2>Unified Dashboard</h2>
          <p>Get a bird's-eye view of your {data.title.toLowerCase()} from one terminal. Automated, real-time, and mobile-ready.</p>
        </div>
        <div class="visual-frame relative-frame" style="background:#0b0f19; padding:0;">
          {id === 'baker' || !id ? (
            <div class="video-storyboard">
               <!-- Scene 1: Customer Phone -->
               <div class="scene-phone">
                  <div class="phone-screen">
                     <div class="cake-img">🎂</div>
                     <div class="phone-title">Truffle Cake</div>
                     <div class="phone-btn">Buy Now ₹450</div>
                     <div class="phone-cursor">👆</div>
                     <div class="phone-success">✅ Ordered!</div>
                  </div>
               </div>

               <!-- Scene 2: CRM Dashboard -->
               <div class="scene-crm">
                  <div class="crm-topbar">
                     <span>Trivia OS Baker</span>
                     <span class="pulse-dot"></span>
                  </div>
                  <div class="crm-content-mock">
                     <div class="crm-graph">
                        <svg viewBox="0 0 100 40">
                           <path d="M0,35 L20,35 L40,30 L60,15 L80,5 L100,0" fill="none" class="crm-graph-line" />
                        </svg>
                     </div>
                     <div class="crm-toast-mock">
                        🔔 New KOT: Truffle Cake!
                     </div>
                  </div>
               </div>

               <!-- Scene 3: Happy Customer -->
               <div class="scene-review">
                  <div class="review-box">
                     <div class="stars">⭐⭐⭐⭐⭐</div>
                     <div class="review-text">"So delicious! The ordering process was seamless. Super happy with Trivia OS Baker!"</div>
                     <div class="customer-avatar">👧 Happy Customer</div>
                  </div>
               </div>

               <!-- Progress Bar -->
               <div class="video-progress"></div>
            </div>
          ) : id === 'society' ? (
            <div class="society-dashboard-simulation">
               <div class="sl-sidebar">
                  <div class="sl-logo"><span class="o-logo">S</span> SOCIETY LEDGER</div>
                  <div class="sl-nav">CORE BUSINESS</div>
                  <div class="sl-item active">Dashboard</div>
                  <div class="sl-item">Billing</div>
                  <div class="sl-item">Residents</div>
                  <div class="sl-nav">SECURITY & OPS</div>
                  <div class="sl-item">Visitor Gate</div>
                  <div class="sl-item">WhatsApp Reminders</div>
                  <div class="sl-item">Complaints</div>
               </div>
               <div class="sl-main">
                  <div class="sl-header">
                     <div class="sl-title-box">
                        <h2>PRIME LEDGER INTELLIGENCE</h2>
                        <p>REAL-TIME ASSET MANAGEMENT FOR PRIME TOWER A BRANCH.</p>
                     </div>
                     <div class="sl-admin"><span class="sa-icon">SA</span> <div style="display:inline-block; line-height: 1.1;"><strong>SOCIETY ADMIN</strong><br/><small>PRIME TOWER A</small></div></div>
                  </div>
                  <div class="sl-metrics-grid">
                     <div class="sl-metric-card"><div class="sl-card-top"><span class="sl-icon">🏢</span> <span class="sl-sub">100% OCC.</span></div><span class="sm-label">TOTAL FLATS</span><span class="sm-value">120</span></div>
                     <div class="sl-metric-card"><div class="sl-card-top"><span class="sl-icon">💰</span> <span class="sl-sub">GOAL ₹2.5L</span></div><span class="sm-label">MONTHLY REV.</span><span class="sm-value">₹2.4L</span></div>
                     <div class="sl-metric-card"><div class="sl-card-top"><span class="sl-icon">✅</span> <span class="sl-sub">22 PENDING</span></div><span class="sm-label">PAID BILLS</span><span class="sm-value">98</span></div>
                     <div class="sl-metric-card sl-alert"><div class="sl-card-top"><span class="sl-icon">⚠️</span> <span class="sl-sub warning">DUE NOW</span></div><span class="sm-label">DEFAULTERS</span><span class="sm-value">₹42,500</span></div>
                     <div class="sl-metric-card"><div class="sl-card-top"><span class="sl-icon">🔔</span> <span class="sl-sub warning">2 CRITICAL</span></div><span class="sm-label">ACTIVE COMPLAIN</span><span class="sm-value">4</span></div>
                  </div>
                  
                  <div class="sl-content-split">
                     <div class="sl-graph-box">
                        <div class="sl-box-title">COLLECTION VELOCITY</div>
                        <div class="sl-bars">
                           <div class="sl-bar" style="--h: 40%"></div>
                           <div class="sl-bar" style="--h: 60%"></div>
                           <div class="sl-bar" style="--h: 70%"></div>
                           <div class="sl-bar" style="--h: 50%"></div>
                           <div class="sl-bar" style="--h: 80%"></div>
                           <div class="sl-bar" style="--h: 30%"></div>
                           <div class="sl-bar" style="--h: 90%" id="live-bar"></div>
                        </div>
                     </div>
                     <div class="sl-dues-box">
                        <div class="sl-box-title">CRITICAL DUES <span style="float:right; cursor:pointer;">MANAGE ALL</span></div>
                        <div class="sl-due-item">
                           <div class="due-info"><strong>Rahul Sharma</strong><br/><small>Yesterday</small></div>
                           <div class="due-amt">₹2,500<br/><span class="badge overdue">OVERDUE</span></div>
                        </div>
                        <div class="sl-due-item">
                           <div class="due-info"><strong>Priya Patel</strong><br/><small>Today</small></div>
                           <div class="due-amt">₹3,200<br/><span class="badge pending">PENDING</span></div>
                        </div>
                        <button class="sl-btn-remind">BULK WHATSAPP REMINDERS</button>
                     </div>
                  </div>
               </div>
            </div>
          ) : id === 'restaurant' ? (
            <div class="restaurant-dashboard-sim">
              <div class="rd-topbar">
                <span class="rd-logo">🍽️ RESTAURANT OS</span>
                <div class="rd-tabs">
                  <span class="rd-tab active">Dashboard</span>
                  <span class="rd-tab">POS</span>
                  <span class="rd-tab">KDS</span>
                  <span class="rd-tab">Menu</span>
                </div>
                <span class="rd-live">● LIVE</span>
              </div>
              <div class="rd-body">
                <div class="rd-metrics">
                  <div class="rd-metric">
                    <span class="rd-m-icon">💰</span>
                    <span class="rd-m-val">₹18,450</span>
                    <span class="rd-m-label">Today's Revenue</span>
                  </div>
                  <div class="rd-metric">
                    <span class="rd-m-icon">🧾</span>
                    <span class="rd-m-val">47</span>
                    <span class="rd-m-label">Orders Today</span>
                  </div>
                  <div class="rd-metric rd-metric-alert">
                    <span class="rd-m-icon">🔥</span>
                    <span class="rd-m-val">6</span>
                    <span class="rd-m-label">Kitchen Queue</span>
                  </div>
                  <div class="rd-metric">
                    <span class="rd-m-icon">🪑</span>
                    <span class="rd-m-val">12/18</span>
                    <span class="rd-m-label">Tables Active</span>
                  </div>
                </div>
                <div class="rd-split">
                  <div class="rd-orders-box">
                    <div class="rd-box-title">🧾 LIVE ORDERS</div>
                    <div class="rd-order-row active-order">T-3 · Chicken Biryani × 2 <span class="rd-badge">COOKING</span></div>
                    <div class="rd-order-row">T-7 · Paneer Butter Masala × 1 <span class="rd-badge done">READY</span></div>
                    <div class="rd-order-row">T-1 · Veg Thali × 3 <span class="rd-badge pending">PENDING</span></div>
                    <div class="rd-order-row">T-5 · Cold Coffee × 2 <span class="rd-badge done">READY</span></div>
                  </div>
                  <div class="rd-chart-box">
                    <div class="rd-box-title">📈 REVENUE TREND</div>
                    <div class="rd-bars">
                      <div class="rd-bar" style="--rh:40%"></div>
                      <div class="rd-bar" style="--rh:65%"></div>
                      <div class="rd-bar" style="--rh:50%"></div>
                      <div class="rd-bar" style="--rh:80%"></div>
                      <div class="rd-bar" style="--rh:60%"></div>
                      <div class="rd-bar" style="--rh:90%"></div>
                      <div class="rd-bar rd-bar-live" style="--rh:75%"></div>
                    </div>
                    <div class="rd-bar-labels">
                      <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Today</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <img src={`https://images.unsplash.com/photo-1551288049-bbda38a5f452?auto=format&fit=crop&q=80&w=1000`} alt="Dashboard Preview" />
          )}
        </div>
      </div>

       <div class="visual-block reverse">
        <div class="visual-text">
          <h2>AI Growth Radar</h2>
          <p>Our proprietary algorithms scan your sales data to identify growth opportunities and stock leakages before they happen.</p>
        </div>
        <div class="visual-frame">
          <img src={`https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=1000`} alt="Analytics Preview" />
        </div>
      </div>
    </section>

    <footer class="bottom-cta">
       <h3>Ready to transform your {data.title.toLowerCase()}?</h3>
       <a href="/crm-login" class="btn-primary">Get Started Now</a>
    </footer>
  </div>
</MainLayout>

<style>
  .industry-detail-page { padding: 120px 24px; max-width: 1100px; margin: 0 auto; color: white; }
  
  .industry-hero { text-align: center; margin-bottom: 100px; }
  .badge-icon { font-size: 4rem; margin-bottom: 20px; }
  .industry-hero h1 { font-size: 4rem; font-weight: 900; background: linear-gradient(135deg, #fff 0%, #6366f1 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 15px; }
  .tagline { color: #6366f1; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; font-size: 1.1rem; margin-bottom: 25px; }
  .description { font-size: 1.4rem; color: rgba(255,255,255,0.7); max-width: 800px; margin: 0 auto 40px; line-height: 1.6; }
  
  .header-actions { display: flex; gap: 20px; justify-content: center; }
  .btn-primary { background: #6366f1; color: white; padding: 16px 32px; border-radius: 14px; font-weight: 700; text-decoration: none; transition: 0.3s; }
  .btn-ghost { border: 1px solid rgba(255,255,255,0.1); color: white; padding: 16px 32px; border-radius: 14px; font-weight: 700; text-decoration: none; transition: 0.3s; }
  .btn-primary:hover { background: #4f46e5; transform: translateY(-3px); box-shadow: 0 10px 20px rgba(99,102,241,0.2); }

  .section-title { text-align: center; margin-bottom: 60px; }
  .section-title h2 { font-size: 2.5rem; margin-bottom: 10px; }
  .section-title p { opacity: 0.5; font-size: 1.1rem; }

  .benefits-section { margin-bottom: 120px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 100px; }
  .benefits-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
  .benefit-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 30px; border-radius: 20px; display: flex; align-items: flex-start; gap: 15px; }
  .check { color: #22c55e; font-weight: 900; font-size: 1.2rem; }
  .benefit-card p { font-weight: 600; font-size: 1rem; line-height: 1.4; margin: 0; }

  .comparison-section { margin-bottom: 120px; }
  .table-container { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 20px; overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; text-align: left; }
  th { padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.1); text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em; opacity: 0.6; }
  td { padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .highlight { color: #6366f1; font-weight: 900; background: rgba(99,102,241,0.05); }
  .high-val { color: #6366f1; font-weight: 700; }

  .visual-block { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; margin-bottom: 100px; }
  .visual-block.reverse { direction: rtl; }
  .visual-block.reverse .visual-text { direction: ltr; }
  .visual-text h2 { font-size: 2rem; margin-bottom: 20px; }
  .visual-text p { font-size: 1.1rem; opacity: 0.6; line-height: 1.7; }
  .visual-frame { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 15px; border-radius: 24px; box-shadow: 0 40px 80px rgba(0,0,0,0.4); }
  .visual-frame img { width: 100%; border-radius: 12px; }

  .bottom-cta { text-align: center; background: rgba(99,102,241,0.05); border: 1px dashed rgba(99,102,241,0.3); padding: 60px; border-radius: 40px; margin-top: 100px; }
  .bottom-cta h3 { font-size: 2rem; margin-bottom: 30px; }

  /* --- BAKER OS VIDEO STORYBOARD (Native CSS Video) --- */
  .relative-frame { position: relative; overflow: hidden; min-height: 450px; }
  .video-storyboard {
     position: absolute; top: 0; left: 0; width: 100%; height: 100%;
     background: #0b0f19; border-radius: 12px; overflow: hidden;
  }

  /* Shared Scene Defaults */
  .scene-phone, .scene-crm, .scene-review {
     position: absolute; width: 100%; height: 100%;
     display: flex; align-items: center; justify-content: center;
     opacity: 0; pointer-events: none;
  }

  /* ------ SCENE 1: CUSTOMER PHONE ------ */
  .scene-phone { animation: scene1 12s infinite; }
  .phone-screen {
     width: 200px; height: 350px; background: white; border-radius: 20px;
     border: 6px solid #333; display: flex; flex-direction: column; align-items: center; justify-content: center;
     box-shadow: 0 20px 40px rgba(0,0,0,0.5); position: relative;
  }
  .cake-img { font-size: 3rem; margin-bottom: 10px; }
  .phone-title { color: #111; font-weight: 800; font-size: 1.2rem; margin-bottom: 20px; }
  .phone-btn { background: #6366f1; color: white; padding: 10px 20px; border-radius: 8px; font-weight: 700; }
  .phone-cursor {
     position: absolute; font-size: 1.5rem; bottom: -20px; right: 20px;
     animation: cursorClick 12s infinite; opacity: 0;
  }
  .phone-success {
     position: absolute; background: #10b981; color: white; padding: 8px 16px; border-radius: 20px; font-weight: bold;
     opacity: 0; animation: successPop 12s infinite;
  }

  /* ------ SCENE 2: CRM DASHBOARD ------ */
  .scene-crm { animation: scene2 12s infinite; }
  .crm-topbar { width: 100%; height: 40px; background: #1a1e2e; position: absolute; top:0; left:0; display:flex; align-items:center; padding: 0 15px; color: white; font-weight: bold; border-bottom: 1px solid rgba(255,255,255,0.1); justify-content: space-between; }
  .pulse-dot { width: 10px; height: 10px; background: #10b981; border-radius: 50%; box-shadow: 0 0 10px #10b981; }
  .crm-content-mock { margin-top: 50px; width: 80%; height: 200px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 20px; position: relative; }
  .crm-graph { width: 100%; height: 100%; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .crm-graph-line { stroke: #10b981; stroke-width: 4; stroke-linecap: round; stroke-dasharray: 200; stroke-dashoffset: 200; animation: drawGraph 12s infinite; }
  .crm-toast-mock { 
     position: absolute; bottom: -20px; right: -20px; background: #05081a;
     border: 1px solid #6366f1; color: white; padding: 12px 20px; border-radius: 8px;
     box-shadow: 0 10px 30px rgba(0,0,0,0.5); opacity: 0; animation: toastPop 12s infinite;
  }

  /* ------ SCENE 3: HAPPY CUSTOMER ------ */
  .scene-review { animation: scene3 12s infinite; }
  .review-box {
     background: linear-gradient(135deg, #10b981 0%, #059669 100%);
