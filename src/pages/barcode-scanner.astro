---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Barcode Scanner">

<div class="page">

<h1>Barcode Scanner</h1>

<p>Scan or enter a medicine barcode to fetch product information.</p>

<input type="text" placeholder="Enter barcode">

<button>Search</button>

<div class="result">
<p>No barcode scanned yet.</p>
</div>

</div>

<style>

.page{
padding:40px;
background:#0a0a0a;
color:white;
min-height:100vh;
}

input{
padding:10px;
margin-right:10px;
margin-top:10px;
}

button{
padding:10px 16px;
background:#00ff88;
border:none;
border-radius:6px;
cursor:pointer;
}

.result{
margin-top:20px;
background:#111;
padding:20px;
border-radius:8px;
}

</style>

</MainLayout>