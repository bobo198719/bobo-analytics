---
import MainLayout from "../../layouts/MainLayout.astro";
const { tableId } = Astro.params;
import "../../styles/restaurant.css";
---

<MainLayout title={`Ordering at Table ${tableId} | Bobo QR`} hideNav={true}>
  <div class="min-h-screen bg-[#05081a] pb-32 font-['Plus_Jakarta_Sans']">
    <!-- Fluid Header -->
    <header class="p-6 pb-20 bg-gradient-to-b from-bobo-accent/20 via-bobo-accent/5 to-transparent flex flex-col items-center text-center">
       <div class="w-16 h-16 bg-white/10 rounded-full flex items-center justify-center text-3xl mb-6 backdrop-blur-xl border border-white/10">🍕</div>
       <h1 class="text-3xl font-black italic uppercase tracking-tighter">Table {tableId} Terminal</h1>
       <p class="text-white/40 text-xs font-bold uppercase tracking-[0.2em] mt-2">Digital Gastronomy Experience</p>
    </header>

    <main class="px-6 -mt-12 space-y-12 max-w-lg mx-auto">
       <!-- Menu Group -->
       <section class="space-y-6">
          <h2 class="text-xs font-black uppercase tracking-[0.3em] text-white/30 border-b border-white/5 pb-4">Most Loved Today</h2>
          
          <div class="grid gap-6">
             {[
                { name: 'Kashmiri Dum Aloo', price: 320, type: 'veg', icon: '🍲' },
                { name: 'Smoked Butter Chicken', price: 480, type: 'non-veg', icon: '🍗' },
                { name: 'Blue Lagoon Soda', price: 140, type: 'veg', icon: '🍹' }
             ].map((item) => (
                <div class="bg-white/5 border border-white/10 p-5 rounded-3xl flex items-center gap-6 group hover:border-white/20 transition-all">
                   <div class="w-20 h-20 bg-white/5 rounded-2xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform">{item.icon}</div>
                   <div class="flex-1">
                      <div class="flex items-center gap-2 mb-1">
                         <h3 class="font-black italic tracking-tight">{item.name}</h3>
                         <div class={`w-2 h-2 rounded-full ${item.type === 'veg' ? 'bg-emerald-500' : 'bg-rose-500'} shadow-lg`}></div>
                      </div>
                      <p class="text-sm font-black text-bobo-accent">₹{item.price}</p>
                   </div>
                   <button class="w-12 h-12 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center hover:bg-bobo-accent hover:border-bobo-accent transition-all">
                      <i class="lucide-plus"></i>
                   </button>
                </div>
             ))}
          </div>
       </section>
    </main>

    <!-- Floating Checkout Bar -->
    <div class="fixed bottom-0 inset-x-0 p-6 z-50">
       <div class="max-w-lg mx-auto bg-white/10 border border-white/20 backdrop-blur-3xl rounded-[40px] p-6 flex items-center justify-between shadow-2xl animate-in slide-in-from-bottom-10 duration-500">
          <div>
             <p class="text-[10px] font-black uppercase text-white/40 tracking-widest">Selected Intelligence</p>
             <h4 class="text-xl font-black italic">2 Items</h4>
          </div>
          <button class="bg-white text-black p-5 px-10 rounded-3xl font-black italic uppercase tracking-widest text-sm shadow-2xl hover:scale-[1.05] active:scale-95 transition-all">
             Send to KDS
          </button>
       </div>
    </div>
  </div>

  <!-- Lucide Icon Support -->
  <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
</MainLayout>
