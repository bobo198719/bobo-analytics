---
export const prerender = false;
const { tableId } = Astro.params;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Table {tableId} | Bobo Order Console</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700;1,800;1,900&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
    html, body { 
        height: 100%; 
        font-family: 'Plus Jakarta Sans', sans-serif; 
        background: #05081a; 
        color: white; 
        overflow-x: hidden;
    }
    
    /* CRYSTAL CLEAR TYPOGRAPHY */
    h1, h2, h3, h4 { font-style: italic; text-transform: uppercase; letter-spacing: -0.02em; }
    
    ::-webkit-scrollbar { width: 0; display: none; } 

    .cat-tab { 
        flex-shrink: 0; 
        padding: 12px 24px; 
        border-radius: 20px; 
        font-size: 13px; 
        font-weight: 900; 
        text-transform: uppercase; 
        border: 1px solid rgba(255,255,255,0.05); 
        cursor: pointer; 
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
        white-space: nowrap; 
        background: rgba(255,255,255,0.03); 
        color: rgba(255,255,255,0.4); 
    }
    .cat-tab.active { 
        background: linear-gradient(135deg,#f97316,#e11d48); 
        color: white; 
        border-color: transparent; 
        box-shadow: 0 10px 25px rgba(249,115,22,0.3); 
        transform: scale(1.05);
    }

    /* UHD DISH CARD */
    .dish-card { 
        background: rgba(255,255,255,0.03); 
        border: 1px solid rgba(255,255,255,0.06); 
        border-radius: 32px; 
        overflow: hidden; 
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); 
        display: flex;
        flex-direction: column;
        position: relative;
    }
    .dish-card:active { transform: scale(0.97); background: rgba(255,255,255,0.06); }
    
    .dish-image-container {
        width: 100%;
        aspect-ratio: 4/3;
        overflow: hidden;
        position: relative;
        background: #000;
    }
    .dish-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }
    
    .add-btn { 
        width: 48px; 
        height: 48px; 
        border-radius: 18px; 
        background: linear-gradient(135deg,#f97316,#fb923c); 
        border: none; 
        color: white; 
        cursor: pointer; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        transition: all 0.2s; 
        box-shadow: 0 8px 16px rgba(249,115,22,0.25);
    }
    .add-btn:active { transform: scale(0.85); filter: brightness(1.2); }

    .qty-ctrl { 
        display: flex; 
        align-items: center; 
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 18px;
        padding: 4px;
        gap: 12px; 
    }
    .qty-btn { 
        width: 36px; 
        height: 36px; 
        border-radius: 14px; 
        background: rgba(255,255,255,0.05); 
        border: none; 
        color: white; 
        font-size: 20px; 
        font-weight: 300;
        cursor: pointer; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
    }

    .cart-bar { 
        position: fixed; 
        bottom: 24px; 
        left: 16px; 
        right: 16px; 
        z-index: 100; 
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); 
    }
    .cart-bar.hidden { transform: translateY(200%); opacity: 0; }

    #checkout-modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.9);
        backdrop-filter: blur(20px);
        z-index: 500;
        align-items: flex-end;
    }
    .checkout-sheet {
        background: #0a0e1f;
        border-top: 1px solid rgba(255,255,255,0.1);
        width: 100%;
        border-radius: 40px 40px 0 0;
        padding: 32px 24px;
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        animation: sheetUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    @keyframes sheetUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

    .loading-spinner { width: 40px; height: 40px; border: 4px solid rgba(249,115,22,0.15); border-top-color: #f97316; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    
    .slide-up { animation: slideUp 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; opacity: 0; }
    @keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  </style>
</head>
<body>

  <!-- SUCCESS OVERLAY (TRACKING ACTIVE) -->
  <div id="order-success" style="display:none; position:fixed; inset:0; background:#05081a; z-index:999; flex-direction:column; align-items:center; justify-content:center; padding:24px;">
     <div id="status-icon" style="font-size:64px; margin-bottom:24px; filter: drop-shadow(0 0 20px rgba(249,115,22,0.3));">⏳</div>
     <h1 id="status-title" style="font-size:28px; font-weight:900; text-align:center; margin-bottom:12px;">Request Active</h1>
     <p id="status-desc" style="color:rgba(255,255,255,0.4); font-size:14px; text-align:center; font-weight:700; margin-bottom:32px;">Your order payload is in the sync queue.</p>
     
     <div style="width:100%; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:32px; padding:24px; margin-bottom:32px;">
        <div id="success-items" style="max-height:200px; overflow-y:auto; margin-bottom:20px;"></div>
        <div style="border-top:1px solid rgba(255,255,255,0.08); padding-top:20px; display:flex; justify-content:space-between; align-items:center;">
            <div>
                <p style="font-size:10px; font-weight:900; color:rgba(255,255,255,0.3); text-transform:uppercase;">Aggregate Dues</p>
                <div id="status-badge" style="display:inline-block; margin-top:8px; padding:6px 12px; border-radius:12px; background:rgba(249,115,22,0.1); border:1px solid rgba(249,115,22,0.2); color:#f97316; font-size:9px; font-weight:900; text-transform:uppercase; font-style:italic;">🟡 Pending Waiter</div>
            </div>
            <p id="success-total" style="font-size:24px; font-weight:900; color:#f97316; font-style:italic;"></p>
        </div>
     </div>
     
     <button onclick="resetOrder()" style="width:100%; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:white; border-radius:24px; padding:20px; font-size:14px; font-weight:900; text-transform:uppercase; font-style:italic;">Order More Items</button>
  </div>

  <!-- CHECKOUT SHEET -->
  <div id="checkout-modal">
    <div class="checkout-sheet">
        <div style="width:40px; height:4px; background:rgba(255,255,255,0.1); border-radius:2px; margin:0 auto 24px;"></div>
        <h2 style="font-size:24px; font-weight:900; margin-bottom:24px;">Final <span style="color:#f97316">Review</span></h2>
        
        <div id="checkout-items" style="flex:1; overflow-y:auto; margin-bottom:24px;"></div>
        
        <div style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:28px; padding:24px; margin-bottom:24px; space-y:12px;">
            <div style="display:flex; justify-content:space-between; margin-bottom:12px;">
                <span style="font-size:11px; font-weight:900; color:rgba(255,255,255,0.3);">Subtotal</span>
                <span id="checkout-subtotal" style="font-size:14px; font-weight:900; color:white/80;"></span>
            </div>
            <div style="display:flex; justify-content:space-between; margin-bottom:12px; padding-bottom:12px; border-bottom:1px solid rgba(255,255,255,0.05);">
                <span style="font-size:11px; font-weight:900; color:rgba(255,255,255,0.3);">Tax (GST @ 5.0%)</span>
                <span id="checkout-tax" style="font-size:14px; font-weight:900; color:white/80;"></span>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <span style="font-size:12px; font-weight:900; text-transform:uppercase; color:white;">Aggregate Total</span>
                <span id="checkout-total" style="font-size:26px; font-weight:900; color:#f97316; font-style:italic;"></span>
            </div>
        </div>

        <button id="final-confirm-btn" onclick="submitOrder()" style="width:100%; background:linear-gradient(135deg,#f97316,#e11d48); border:none; color:white; border-radius:24px; padding:22px; font-size:16px; font-weight:900; text-transform:uppercase; font-style:italic; box-shadow:0 15px 35px rgba(249,115,22,0.3);">
            Confirm Order →
        </button>
        <button onclick="closeCheckout()" style="width:100%; margin-top:20px; font-size:12px; font-weight:900; text-transform:uppercase; color:rgba(255,255,255,0.2); background:transparent; border:none;">Modify Items</button>
    </div>
  </div>

  <!-- APP HUB -->
  <div id="loading-screen" style="position:fixed; inset:0; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:20px; background:#05081a; z-index:1000;">
    <div class="loading-spinner"></div>
    <p style="color:rgba(255,255,255,0.3); font-size:11px; font-weight:900; text-transform:uppercase; letter-spacing:0.3em;">Syncing Menu Matrix...</p>
  </div>

  <div id="app" style="display:none; padding-bottom:140px;">
    <!-- UHD HEADER -->
    <header style="padding:40px 24px 24px; position:relative; overflow:hidden;">
        <div style="display:flex; align-items:center; justify-content:between;">
            <div>
                <h1 style="font-size:28px; font-weight:900; margin-bottom:4px;">Grand <span style="color:#f97316">Cafe</span></h1>
                <div style="display:flex; align-items:center; gap:8px;">
                    <div style="width:6px; height:6px; background:#10b981; border-radius:50%; box-shadow:0 0 10px #10b981;"></div>
                    <p style="font-size:10px; font-weight:900; color:rgba(255,255,255,0.3); text-transform:uppercase; letter-spacing:0.1em;">Table Node {tableId} · Live Now</p>
                </div>
            </div>
            <div style="margin-left:auto; width:56px; height:56px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:20px; display:flex; align-items:center; justify-content:center; font-size:24px;">🍱</div>
        </div>
    </header>

    <!-- SEARCH HUB -->
    <div style="padding:0 24px 24px;">
        <div style="position:relative; group">
            <span style="position:absolute; left:20px; top:50%; transform:translateY(-50%); opacity:0.3;">🔍</span>
            <input id="search-input" oninput="filterDishes()" type="text" placeholder="QUERY DISH..." style="width:100%; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:24px; padding:18px 24px 18px 52px; color:white; font-size:15px; font-weight:700; outline:none; focus:border-orange-500/50 transition-all" />
        </div>
    </div>

    <!-- CATEGORY SLIDER -->
    <div id="category-tabs" style="display:flex; gap:12px; overflow-x:auto; padding:0 24px 32px; -webkit-overflow-scrolling:touch;">
        <button class="cat-tab active" onclick="filterCategory('All', this)">Matrix_All</button>
    </div>

    <!-- UHD MENU GRID -->
    <div id="menu-grid" style="padding:0 24px; display:grid; gap:24px;"></div>
  </div>

  <!-- FLOATING CART BAR (GLASS) -->
  <div class="cart-bar hidden" id="cart-bar">
    <div onclick="openCheckout()" style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); backdrop-filter:blur(30px) saturate(1.5); border-radius:32px; padding:20px 24px; display:flex; align-items:center; justify-content:space-between; box-shadow:0 20px 50px rgba(0,0,0,0.6); active:scale-95 transition-all">
        <div style="display:flex; align-items:center; gap:16px;">
            <div style="position:relative;">
                <div id="cart-count-badge" style="position:absolute; -top:8px; -right:8px; background:#f97316; width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:900; border:2px solid #0a0e1f;">0</div>
                <div style="width:48px; height:48px; background:white/5; border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:20px;">🛒</div>
            </div>
            <div>
                <p style="font-size:11px; font-weight:900; color:rgba(255,255,255,0.4); text-transform:uppercase; letter-spacing:0.1em;">Order Total</p>
                <p id="cart-summary" style="font-size:20px; font-weight:900; color:white; font-style:italic;">₹0.00</p>
            </div>
        </div>
        <div style="display:flex; align-items:center; gap:8px; background:rgba(249,115,22,0.15); border:1px solid rgba(249,115,22,0.2); padding:10px 20px; border-radius:20px; color:#f97316; font-[11px] font-black uppercase italic tracking-widest">
            Review →
        </div>
    </div>
  </div>

  <div id="table-id-data" data-id={tableId} style="display:none"></div>

  <script is:inline>
    const TABLE_ID = document.getElementById('table-id-data').dataset.id;
    let allItems = [];
    let cart = {}; 
    let currentCategory = 'All';
    let activeOrderId = localStorage.getItem('active_order_id');
    let trackInterval = null;

    // ── DATA SYNC ──────────────────────────────────
    async function loadMenu() {
        try {
            const res = await fetch('/api/v2/restaurant/menu');
            const data = await res.json();
            allItems = [...data].sort((a,b) => b.id - a.id).slice(0, 250);
            
            buildCategoryTabs();
            renderMenu(allItems);
            
            document.getElementById('loading-screen').style.opacity = '0';
            setTimeout(() => {
                document.getElementById('loading-screen').style.display = 'none';
                document.getElementById('app').style.display = 'block';
                if(activeOrderId) startTracking(); // Resume track on reload
            }, 500);
        } catch(e) { console.error(e); }
    }

    function buildCategoryTabs() {
        const cats = ['All', ...new Set(allItems.map(i => i.category).filter(Boolean))];
        const container = document.getElementById('category-tabs');
        container.innerHTML = cats.map(cat => 
            `<button class="cat-tab ${cat === 'All' ? 'active' : ''}" onclick="filterCategory('${cat}', this)">${cat}</button>`
        ).join('');
    }

    window.filterCategory = function(cat, btn) {
        currentCategory = cat;
        document.querySelectorAll('.cat-tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilters();
    }

    window.filterDishes = function() { applyFilters(); }

    function applyFilters() {
        const search = document.getElementById('search-input').value.toLowerCase();
        let filtered = allItems;
        if (currentCategory !== 'All') filtered = filtered.filter(i => i.category === currentCategory);
        if (search) filtered = filtered.filter(i => i.name.toLowerCase().includes(search));
        renderMenu(filtered);
    }

    // ── UHD RENDER ──────────────────────────────────
    function renderMenu(items) {
        const grid = document.getElementById('menu-grid');
        grid.innerHTML = items.map((item, idx) => {
            const qty = cart[item.id] ? cart[item.id].qty : 0;
            return `
                <div class="dish-card slide-up" style="animation-delay: ${idx * 0.05}s">
                    <div class="dish-image-container">
                        <img class="dish-image" src="${item.image_url || 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=600'}" alt="${item.name}" />
                        <div style="position:absolute; top:16px; right:16px; background:rgba(0,0,0,0.6); backdrop-filter:blur(8px); padding:6px 14px; border-radius:12px; font-size:10px; font-weight:900; text-transform:uppercase; color:${item.type === 'veg' ? '#10b981' : '#f43f5e'}; border:1px solid ${item.type === 'veg' ? 'rgba(16,185,129,0.3)' : 'rgba(244,63,94,0.3)'};">
                            ${item.type}
                        </div>
                    </div>
                    <div style="padding:24px;">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                            <div style="flex:1; min-width:0;">
                                <h3 style="font-size:18px; font-weight:900; margin-bottom:4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${item.name}</h3>
                                <p style="font-size:11px; font-weight:900; color:rgba(255,255,255,0.3); text-transform:uppercase;">${item.category}</p>
                            </div>
                            <p style="font-size:22px; font-weight:900; color:#f97316; font-style:italic;">₹${item.price}</p>
                        </div>
                        
                        <div style="display:flex; justify-content:flex-end;">
                            ${qty === 0 
                                ? `<button class="add-btn" onclick="addToCart(${item.id})">
                                    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4" /></svg>
                                   </button>`
                                : `<div class="qty-ctrl">
                                    <button class="qty-btn" onclick="changeQty(${item.id}, -1)">−</button>
                                    <span style="font-size:16px; font-weight:900; min-width:24px; text-align:center;">${qty}</span>
                                    <button class="qty-btn" style="background:rgba(249,115,22,0.2); color:#f97316;" onclick="changeQty(${item.id}, 1)">+</button>
                                   </div>`
                            }
                        </div>
                    </div>
                </div>
            `;
        }).join('');
    }

    // ── CART & TAX ─────────────────────────────────────
    window.addToCart = function(id) {
        const item = allItems.find(i => Number(i.id) === Number(id));
        if (!item) return;
        cart[id] = { item, qty: 1 };
        updateUI();
    }

    window.changeQty = function(id, delta) {
        if (!cart[id]) return;
        cart[id].qty += delta;
        if (cart[id].qty <= 0) delete cart[id];
        updateUI();
    }

    function updateUI() {
        const items = Object.values(cart);
        const subtotal = items.reduce((s, {item, qty}) => s + (item.price * qty), 0);
        const gst = subtotal * 0.05;
        const total = subtotal + gst;
        const count = items.reduce((s, {qty}) => s + qty, 0);

        const bar = document.getElementById('cart-bar');
        if (count > 0) {
            bar.classList.remove('hidden');
            document.getElementById('cart-summary').textContent = `₹${total.toFixed(2)}`;
            document.getElementById('cart-count-badge').textContent = count;
        } else {
            bar.classList.add('hidden');
        }

        document.getElementById('checkout-subtotal').textContent = `₹${subtotal.toFixed(2)}`;
        document.getElementById('checkout-tax').textContent = `₹${gst.toFixed(2)}`;
        document.getElementById('checkout-total').textContent = `₹${total.toFixed(2)}`;
        
        applyFilters(); 
    }

    window.openCheckout = function() {
        const items = Object.values(cart);
        const container = document.getElementById('checkout-items');
        container.innerHTML = items.map(({item, qty}) => `
            <div style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); border-radius:24px; padding:16px; margin-bottom:12px; display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <p style="font-size:14px; font-weight:800; text-transform:uppercase;">${item.name}</p>
                    <p style="font-size:11px; font-weight:900; color:rgba(255,255,255,0.3); margin-top:4px;">Qty: ${qty} · ₹${item.price} each</p>
                </div>
                <p style="font-size:16px; font-weight:900; color:#f97316;">₹${(item.price * qty).toFixed(2)}</p>
            </div>
        `).join('');
        document.getElementById('checkout-modal').style.display = 'flex';
    }

    window.closeCheckout = function() {
        document.getElementById('checkout-modal').style.display = 'none';
    }

    // ── SUBMISSION & TRACKING ─────────────────────────
    window.submitOrder = async function() {
        const items = Object.values(cart);
        const btn = document.getElementById('final-confirm-btn');
        btn.textContent = '⏱ Committing to Matrix...';
        btn.disabled = true;

        try {
            const res = await fetch('/api/v2/restaurant/orders', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    table_id: TABLE_ID,
                    items: items.map(({item, qty}) => ({ menu_item_id: item.id, quantity: qty })),
                    order_source: 'QR'
                })
            });
            
            const data = await res.json();
            if (res.ok) {
                activeOrderId = data.id || data.order_id || (data.order && data.order.id);
                localStorage.setItem('active_order_id', activeOrderId);
                
                const total = items.reduce((s, {item, qty}) => s + (item.price * qty), 0) * 1.05;
                document.getElementById('success-total').textContent = `₹${total.toFixed(2)}`;
                document.getElementById('success-items').innerHTML = items.map(({item, qty}) => 
                    `<div style="display:flex; justify-content:space-between; font-size:13px; margin-bottom:8px;">
                        <span style="font-weight:900; opacity:0.6;">${item.name} × ${qty}</span>
                        <span style="font-weight:900; color:#f97316;">₹${(item.price * qty).toFixed(2)}</span>
                    </div>`
                ).join('');
                
                document.getElementById('order-success').style.display = 'flex';
                closeCheckout();
                startTracking();
            } else {
                alert("Matrix Sync Error. Please retry.");
                btn.textContent = 'Confirm Order →'; btn.disabled = false;
            }
        } catch(e) { alert("Offline Connectivity Detected."); btn.textContent = 'Confirm Order →'; btn.disabled = false; }
    }

    function startTracking() {
        if(trackInterval) clearInterval(trackInterval);
        trackInterval = setInterval(pollStatus, 3000);
        pollStatus();
    }

    async function pollStatus() {
        if(!activeOrderId) return;
        try {
            const res = await fetch(`/api/v2/restaurant/orders/${activeOrderId}`);
            const data = await res.json();
            updateStatusUI(data.status);
            
            // If delivered, keep it shown but maybe stop interval later
        } catch(e) {}
    }

    function updateStatusUI(status) {
        const icon = document.getElementById('status-icon');
        const title = document.getElementById('status-title');
        const desc = document.getElementById('status-desc');
        const badge = document.getElementById('status-badge');

        switch(status) {
            case 'pending_waiter':
                icon.textContent = '⏳';
                title.textContent = 'Awaiting Server';
                desc.textContent = 'Your request has reached the terminal. Waiting for staff acknowledgment.';
                badge.textContent = '🟡 Pending Waiter';
                badge.style.color = '#f97316';
                break;
            case 'confirmed':
                icon.textContent = '✅';
                title.textContent = 'Order Accepted!';
                desc.textContent = 'Your meal is officially in the queue. Chefs have been notified.';
                badge.textContent = '🟢 Confirmed';
                badge.style.color = '#10b981';
                break;
            case 'preparing':
                icon.textContent = '🔥';
                title.textContent = 'Crafting Meal';
                desc.textContent = 'High-intensity preparation active. Our chefs are on it!';
                badge.textContent = '👨‍🍳 In Kitchen';
                badge.style.color = '#f43f5e';
                break;
            case 'ready':
                icon.textContent = '🍽️';
                title.textContent = 'Ready to Serve';
                desc.textContent = 'Your food is ready! A waiter is bringing it to you right now.';
                badge.textContent = '⚡️ Ready';
                badge.style.color = '#8b5cf6';
                break;
        }
    }

    window.resetOrder = function() {
        if(trackInterval) clearInterval(trackInterval);
        localStorage.removeItem('active_order_id');
        activeOrderId = null;
        cart = {};
        document.getElementById('order-success').style.display = 'none';
        updateUI();
    }

    loadMenu();
  </script>
</body>
</html>
