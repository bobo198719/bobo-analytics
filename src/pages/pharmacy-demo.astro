---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Demo | Pharmacy Dashboard">
    <div class="dashboard">
        <div class="sidebar">
            <div class="brand">
                <span class="icon">💊</span>
                <h2>Bobo Analytics</h2>
            </div>
            <div class="demo-badge">DEMO MODE</div>
            <a href="#" class="active">Dashboard</a>
            <a href="#">Billing POS</a>
            <a href="#">Barcode Scanner</a>
            <a href="#">Inventory</a>
            <a href="#">Customers</a>
            <a href="#">Analytics</a>
            <a href="#">Settings</a>
        </div>
        <div class="content">
            <header class="top-header">
                <h1>Pharmacy Dashboard Overview</h1>
                <div class="user-info">
                    <span>Demo Pharmacy</span>
                    <div class="avatar">DP</div>
                </div>
            </header>
            
            <div class="quick-actions">
                <button class="action-btn primary">✨ New Bill</button>
                <button class="action-btn">📷 Scan Barcode</button>
                <button class="action-btn">📦 Add Medicine</button>
                <button class="action-btn">📄 Scan Retailer Bill</button>
            </div>
            
            <div class="stats">
                <div class="card">
                    <h3>Total Medicines</h3>
                    <p class="value">1,428</p>
                    <span class="trend positive">↑ 12 added today</span>
                </div>
                <div class="card">
                    <h3>Low Stock Alerts</h3>
                    <p class="value warning">18</p>
                    <span class="trend warning">Needs attention</span>
                </div>
                <div class="card">
                    <h3>Expiring Soon</h3>
                    <p class="value danger">5</p>
                    <span class="trend danger">Action required</span>
                </div>
                <div class="card">
                    <h3>Revenue Today</h3>
                    <p class="value">₹12,400</p>
                    <span class="trend positive">↑ 8% from yesterday</span>
                </div>
            </div>
            
            <div class="insights-grid">
                <div class="chart-section panel">
                    <h2>Sales Analytics</h2>
                    <canvas id="demoSalesChart"></canvas>
                </div>
                
                <div class="side-panel">
                    <div class="alerts panel">
                        <h2>⚠ AI Priority Alerts</h2>
                        <ul class="alert-list">
                            <li class="alert-item danger">
                                <strong>Paracetamol 500mg</strong>
                                <span>Expiring in 14 days (Batch #A102)</span>
                            </li>
                            <li class="alert-item warning">
                                <strong>Amoxicillin 250mg</strong>
                                <span>Low stock: Only 2 strips remaining</span>
                            </li>
                            <li class="alert-item info">
                                <strong>Vitamin C Supplements</strong>
                                <span>High demand trend detected this week</span>
                            </li>
                        </ul>
                    </div>
                    
                    <div class="top-selling panel">
                        <h2>Top Selling Medicines</h2>
                        <ul class="ranking-list">
                            <li><span class="rank">1</span> Paracetamol 500mg <span class="sales-vol">142 sold</span></li>
                            <li><span class="rank">2</span> Pantoprazole 40mg <span class="sales-vol">98 sold</span></li>
                            <li><span class="rank">3</span> Cetirizine 10mg <span class="sales-vol">85 sold</span></li>
                            <li><span class="rank">4</span> Atorvastatin 20mg <span class="sales-vol">64 sold</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .dashboard {
            display: flex;
            min-height: 100vh;
            background: #05081a;
            color: white;
            font-family: 'Inter', sans-serif;
            position: absolute;
            top: 0; left: 0; right: 0;
            z-index: 9999;
        }
        .sidebar {
            width: 250px;
            background: #0b112d;
            padding: 25px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            border-right: 1px solid rgba(255,255,255,0.05);
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 5px;
        }
        .brand .icon { font-size: 1.5rem; }
        .sidebar h2 {
            color: white;
            margin: 0;
            font-size: 1.2rem;
            font-weight: 700;
        }
        .demo-badge {
            background: rgba(99, 102, 241, 0.2);
            color: #818cf8;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 800;
            text-align: center;
            letter-spacing: 1px;
            margin-bottom: 20px;
            border: 1px solid rgba(99, 102, 241, 0.4);
        }
        .sidebar a {
            text-decoration: none;
            color: rgba(255,255,255,0.7);
            padding: 12px 16px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
        }
        .sidebar a:hover, .sidebar a.active {
            background: rgba(99, 102, 241, 0.1);
            color: #818cf8;
        }
        .content {
            flex: 1;
            padding: 30px 40px;
            overflow-y: auto;
            background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.05) 0%, transparent 50%);
        }
        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        .top-header h1 {
            font-size: 2rem;
            font-weight: 800;
            margin: 0;
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .avatar {
            width: 40px; height: 40px;
            background: #6366f1;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-weight: bold;
        }
        .quick-actions {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
        }
        .action-btn {
            padding: 12px 20px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .action-btn:hover {
            background: rgba(255,255,255,0.1);
            transform: translateY(-2px);
        }
        .action-btn.primary {
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            border: none;
        }
        .action-btn.primary:hover {
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
        }
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .card {
            background: rgba(255, 255, 255, 0.02);
            padding: 24px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .card h3 {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.5);
            margin: 0 0 10px 0;
            text-transform: uppercase;
        }
        .card .value {
            font-size: 2.2rem;
            font-weight: 800;
            margin: 0 0 8px 0;
        }
        .value.warning { color: #f59e0b; }
        .value.danger { color: #ef4444; }
        .trend { font-size: 0.85rem; }
        .trend.positive { color: #10b981; }
        .trend.warning { color: #f59e0b; }
        .trend.danger { color: #ef4444; }
        
        .insights-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 24px;
        }
        .panel {
            background: rgba(255, 255, 255, 0.02);
            padding: 24px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .panel h2 {
            font-size: 1.2rem;
            margin: 0 0 20px 0;
            font-weight: 600;
        }
        .side-panel {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        .alert-list {
            list-style: none; padding: 0; margin: 0;
            display: flex; flex-direction: column; gap: 12px;
        }
        .alert-item {
            padding: 12px;
            border-radius: 8px;
            display: flex; flex-direction: column; gap: 4px;
            font-size: 0.9rem;
        }
        .alert-item.danger { background: rgba(239, 68, 68, 0.1); border-left: 3px solid #ef4444; }
        .alert-item.warning { background: rgba(245, 158, 11, 0.1); border-left: 3px solid #f59e0b; }
        .alert-item.info { background: rgba(59, 130, 246, 0.1); border-left: 3px solid #3b82f6; }
        .alert-item strong { color: white; }
        .alert-item span { color: rgba(255,255,255,0.7); font-size: 0.85rem; }
        
        .ranking-list {
            list-style: none; padding: 0; margin: 0;
            display: flex; flex-direction: column; gap: 12px;
        }
        .ranking-list li {
            display: flex; align-items: center; gap: 12px;
            padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .ranking-list li:last-child { border: none; padding-bottom: 0; }
        .rank {
            background: rgba(255,255,255,0.1);
            width: 24px; height: 24px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 4px; font-weight: bold; font-size: 0.8rem;
        }
        .sales-vol {
            margin-left: auto;
            color: #10b981;
            font-size: 0.85rem;
            font-weight: 600;
        }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const ctx = document.getElementById("demoSalesChart");
            if (ctx) {
                // @ts-ignore
                new Chart(ctx, {
                    type: "line",
                    data: {
                        labels: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
                        datasets: [{
                            label: "Revenue (₹)",
                            data: [12000, 19000, 15000, 25000, 22000, 31000, 28000],
                            borderColor: "#6366f1",
                            backgroundColor: "rgba(99, 102, 241, 0.1)",
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: { grid: { color: "rgba(255,255,255,0.05)" } },
                            x: { grid: { display: false } }
                        }
                    }
                });
            }
        });
    </script>
</MainLayout>
