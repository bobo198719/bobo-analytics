            // EXPIRY ALERTS ENGINE
            // ==========================================
            let _expiryFullList = [];
            window.filterExpiry = function(filter) {
                const now = new Date(); now.setHours(0,0,0,0);
                let list = _expiryFullList;
                const title = document.getElementById('expiryTableTitle');
                if(filter === 'expired') { list = list.filter(i => i._days < 0); if(title) title.innerText = '🔴 Expired Medicines'; }
                else if(filter === '30') { list = list.filter(i => i._days >= 0 && i._days <= 30); if(title) title.innerText = '🟠 Expiring within 30 Days'; }
                else if(filter === '90') { list = list.filter(i => i._days > 30 && i._days <= 90); if(title) title.innerText = '🟡 Expiring within 90 Days'; }
                else if(filter === 'safe') { list = list.filter(i => i._days > 90); if(title) title.innerText = '🟢 Safe Stock'; }
                else { if(title) title.innerText = 'All Products — Expiry Status'; }
                renderExpiryTable(list);
            };
            function renderExpiryTable(list) {
                const tbody = document.getElementById('expiryTableBody');
                if(!tbody) return;
                if(list.length === 0) { tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#9ca3af;padding:32px;">No items match this filter.</td></tr>'; return; }
                tbody.innerHTML = list.map(i => {
                    const d = i._days;
                    const badge = d < 0 ? '<span style="background:#fee2e2;color:#ef4444;padding:3px 8px;border-radius:20px;font-size:0.75rem;font-weight:700;">EXPIRED</span>'
                        : d <= 30 ? '<span style="background:#fef3c7;color:#d97706;padding:3px 8px;border-radius:20px;font-size:0.75rem;font-weight:700;">CRITICAL</span>'
                        : d <= 90 ? '<span style="background:#fef9c3;color:#ca8a04;padding:3px 8px;border-radius:20px;font-size:0.75rem;font-weight:700;">WARNING</span>'
                        : '<span style="background:#d1fae5;color:#059669;padding:3px 8px;border-radius:20px;font-size:0.75rem;font-weight:700;">SAFE</span>';
                    return '<tr><td><strong>' + (i.name||'—') + '</strong></td><td>' + (i.batch_no||'—') + '</td><td>' + (i.expiry_date||'—') + '</td><td>' + (i.qty||0) + '</td><td>' + (d < 0 ? Math.abs(d) + ' days ago' : d + ' days') + '</td><td>' + badge + '</td></tr>';
                }).join('');
