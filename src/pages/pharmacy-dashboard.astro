                    listId: "SKU", listName: "Product", listQty: "In Stock", posTitle: "Retail Checkout Counter", posSub: "Scan products to finalize sale.",
                    scanTitle: "Barcode Scanner", scanDesc: "Scan barcode directly.",
                    categories: ["Electronics", "Home Goods", "Toys", "Office Supplies", "General Retail"]
