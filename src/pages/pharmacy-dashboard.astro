                if(!offer) return alert('No offer selected.');
                const raw = offer.msg || (offer.title + ' - Valid till ' + (offer.expiry || 'limited period') + '. Visit our pharmacy.');
                const msg = buildBrandedMessage(raw);
                if(channel === 'whatsapp') { window.open('https://api.whatsapp.com/send?text=' + encodeURIComponent(msg), '_blank'); }
