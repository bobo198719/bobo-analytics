                const monthly = computeMonthlyRevenueMap();
                const topProducts = computeTopProductMap();
                if (isSectionVisible('sec-overview')) {
                    upsertChart('overviewDonut', 'overviewDonutChart', 'doughnut', {
                        labels: catLabels.length ? catLabels : ['No Data'],
