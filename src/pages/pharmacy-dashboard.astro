                    '<div>🟢 CGST (2.5%)</div><div><strong>₹' + cgst.toFixed(2) + '</strong></div>' +
                    '<div>🔵 SGST (2.5%)</div><div><strong>₹' + sgst.toFixed(2) + '</strong></div>' +
                    '<div>📊 Total GST</div><div><strong>₹' + tax.toFixed(2) + '</strong></div></div>';
