---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Pharmacy Dashboard">

<div class="dashboard">

<!-- Sidebar -->

<div class="sidebar">

<h2>Bobo Analytics</h2>

<a href="/pharmacy-dashboard">Dashboard</a>

<a href="/inventory">Inventory</a>

<a href="#">Orders</a>

<a href="#">Sales Analytics</a>

<a href="#">Customers</a>

<a href="#">Reports</a>

<a href="#">Settings</a>

</div>

<!-- Main Content -->

<div class="content">

<h1>Pharmacy Dashboard</h1>

<div class="stats">

<div class="card">

<h3>Total Medicines</h3>

<p>128</p>

</div>

<div class="card">

<h3>Low Stock</h3>

<p>8</p>

</div>

<div class="card">

<h3>Expiring Soon</h3>

<p>5</p>

</div>

<div class="card">

<h3>Today's Sales</h3>

<p>₹12,450</p>

</div>

</div>

<div class="dashboard-section">

<h2>Quick Actions</h2>

<a class="btn" href="/inventory">Manage Inventory</a>

</div>

</div>

</div>

<style>

.dashboard{
display:flex;
min-height:100vh;
background:#0a0a0a;
color:white;
}

.sidebar{
width:220px;
background:#111;
padding:20px;
display:flex;
flex-direction:column;
gap:15px;
}

.sidebar h2{
color:#00ff88;
margin-bottom:20px;
}

.sidebar a{
color:white;
text-decoration:none;
padding:10px;
border-radius:6px;
}

.sidebar a:hover{
background:#1a1a1a;
}

.content{
flex:1;
padding:40px;
}

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-bottom:40px;
}

.card{
background:#111;
padding:25px;
border-radius:8px;
border:1px solid #222;
}

.card h3{
margin-bottom:10px;
}

.btn{
background:#00ff88;
padding:10px 20px;
border-radius:6px;
text-decoration:none;
color:black;
font-weight:bold;
}

</style>

</MainLayout>
