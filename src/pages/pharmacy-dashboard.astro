                const qty = parseInt(document.getElementById("invQty")?.value) || 1;
                const price = parseFloat(document.getElementById("invPrice")?.value) || 0;
                const mrp = parseFloat(document.getElementById("invMrp")?.value || price);
                const sell = parseFloat(document.getElementById("invSell")?.value || price);
                const mfr = document.getElementById("invMfr")?.value?.trim() || '';
                const hsn = document.getElementById("invHsn")?.value?.trim() || '';
                const pack = document.getElementById("invPack")?.value?.trim() || '';
                const gst = document.getElementById("invGst")?.value || '5';
                const expiry = document.getElementById("invExpiry")?.value?.trim() || '';

                const existing = dbData.inventory.find(i => i.barcode === barcode);
                const currentStock = existing ? intNum(existing.stock_qty ?? existing.qty, 0) : 0;
                upsertProductRecord({
                    product_id: existing?.product_id,
