                    const expiry = row.querySelector(".ai-edit-expiry")?.value || '';
                    const disc = num(row.querySelector(".ai-edit-disc")?.value, 0);
                    const taxableAmount = num(rate * qty * (1 - (disc / 100)));
                    const taxSplit = splitTax(taxableAmount, gst);
                    const totalAmount = num(taxableAmount + taxSplit.cgst + taxSplit.sgst + taxSplit.igst);

                    totalQty += qty;
