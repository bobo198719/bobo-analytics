                const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
                const mi = months.indexOf(month);
                _gstData = (dbData.bills||[]).filter(b => { const d=new Date(b.date||b.timestamp); return d.getMonth()===mi && d.getFullYear()===year; });
                let taxable=0, cgst=0, sgst=0;
                _gstData.forEach(b => { taxable += b.subtotal||b.total||0; cgst += b.cgst||0; sgst += b.sgst||0; });
                const tax = cgst+sgst;
                const s = (id,v) => { const el=document.getElementById(id); if(el) el.innerText=v; };
                s('gstTaxable','₹'+taxable.toFixed(2)); s('gstCgst','₹'+cgst.toFixed(2)); s('gstSgst','₹'+sgst.toFixed(2)); s('gstTotal','₹'+tax.toFixed(2));
