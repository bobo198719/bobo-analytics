            // ==========================================
            // PROFIT INTELLIGENCE ENGINE
            // ==========================================
            window.renderProfitTable = function() {
                const filter = document.getElementById('profitFilter')?.value || 'all';
                let items = dbData.inventory.map(i => {
                    const purchase = parseFloat(i.price || 0);
                    const selling = parseFloat(i.selling_price || i.mrp || purchase);
                    const mrp = parseFloat(i.mrp || selling);
                    const profit = selling - purchase;
                    const margin = purchase > 0 ? ((profit / purchase) * 100) : 0;
                    return { ...i, purchase, selling, mrp, profit, margin };
                });
                if(filter === 'best') items = items.sort((a,b)=>b.margin-a.margin).slice(0,10);
                else if(filter === 'loss') items = items.filter(i => i.profit <= 0);
                const tbody = document.getElementById('profitTableBody');
                if(!tbody) return;
                if(items.length === 0) { tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;color:#9ca3af;padding:32px;">No matching products.</td></tr>'; return; }
                tbody.innerHTML = items.map(i => {
                    const badge = i.profit < 0 ? '<span style="background:#fee2e2;color:#ef4444;padding:2px 7px;border-radius:20px;font-size:0.73rem;">Loss</span>'
                        : i.margin > 30 ? '<span style="background:#d1fae5;color:#059669;padding:2px 7px;border-radius:20px;font-size:0.73rem;">Best ⭐</span>'
                        : i.margin > 15 ? '<span style="background:#ede9fe;color:#7c3aed;padding:2px 7px;border-radius:20px;font-size:0.73rem;">Good</span>'
                        : '<span style="background:#fef3c7;color:#d97706;padding:2px 7px;border-radius:20px;font-size:0.73rem;">Low</span>';
                    return '<tr><td><strong>' + i.name + '</strong></td><td>' + (i.category||'—') + '</td><td>₹' + i.purchase.toFixed(2) + '</td><td>₹' + i.mrp.toFixed(2) + '</td><td>₹' + i.selling.toFixed(2) + '</td><td style="color:' + (i.profit<0?'#ef4444':'#10b981') + ';font-weight:700;">₹' + i.profit.toFixed(2) + '</td><td>' + i.margin.toFixed(1) + '%</td><td>' + (i.qty||0) + '</td><td>₹' + (i.purchase*(i.qty||0)).toFixed(0) + '</td><td>' + badge + '</td></tr>';
                }).join('');
            };
            function updateProfitSection() {
                let totalCost=0, totalSell=0;
                dbData.inventory.forEach(i => {
                    const p=parseFloat(i.price||0), s=parseFloat(i.selling_price||i.mrp||p), q=parseInt(i.qty||0);
                    totalCost += p*q; totalSell += s*q;
                });
                const gross = totalSell - totalCost;
                const avg = totalCost>0 ? ((gross/totalCost)*100).toFixed(1) : 0;
                const set = (id,v) => { const el=document.getElementById(id); if(el) el.innerText=v; };
                set('profCost','₹'+totalCost.toFixed(0)); set('profSell','₹'+totalSell.toFixed(0));
                set('profGross','₹'+gross.toFixed(0)); set('profAvgMargin',avg+'%');
                window.renderProfitTable();
            }
