                    downloadCSV(rows, _currentReportType+'_report.csv');
                } else if(format==='pdf') {
                    window.print();
                } else if(format==='excel') {
                    const headers = Array.from(document.querySelectorAll('#reportHead th')).map(t=>t.innerText);
                    const rows = [headers, ...Array.from(document.querySelectorAll('#reportBody tr')).map(r=>Array.from(r.querySelectorAll('td')).map(c=>c.innerText.trim()))];
                    const tsv = rows.map(r=>r.join('\t')).join('\n');
                    const blob = new Blob([tsv],{type:'application/vnd.ms-excel'});
                    const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=_currentReportType+'_report.xls'; a.click();
                }
            };
            // CSV Download utility
            function downloadCSV(rows, filename) {
                const csv = rows.map(r=>r.map(c=>'"'+String(c||'').replace(/"/g,'""')+'"').join(',')).join('\n');
                const blob = new Blob([csv],{type:'text/csv;charset=utf-8;'});
                const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=filename; a.click();
            }

            // ==========================================
            // MULTI-BRANCH ENGINE
            // ==========================================
            const branchForm = document.getElementById('branchForm');
            if(branchForm) branchForm.addEventListener('submit', e => {
                e.preventDefault();
                if(!dbData.branches) dbData.branches = [{ id:1, name:'Main Branch', manager:'Owner', city:'HQ', sales:0, inventory: dbData.inventory.length }];
                dbData.branches.push({ id: Date.now(), name: document.getElementById('branchName').value, manager: document.getElementById('branchManager').value, city: document.getElementById('branchCity').value, sales:0, inventory:0 });
                saveData(); renderBranchCards(); branchForm.reset();
            });
            function renderBranchCards() {
                if(!dbData.branches) dbData.branches = [{ id:1, name:'Main Branch', manager:'Owner', city:'HQ', sales: (dbData.bills||[]).reduce((s,b)=>s+(b.total||0),0), inventory: dbData.inventory.length }];
                const grid = document.getElementById('branchCardsGrid');
                if(!grid) return;
                const totalRev = dbData.branches.reduce((s,b)=>s+b.sales,0) + (dbData.bills||[]).reduce((s,b)=>s+(b.total||0),0);
                const set = (id,v) => { const el=document.getElementById(id); if(el) el.innerText=v; };
                set('branchCount', dbData.branches.length);
                set('branchTotalRev', '₹'+totalRev.toFixed(0));
                set('branchTotalInv', dbData.inventory.length);
                const colors = ['#6366f1','#10b981','#f59e0b','#a855f7','#ec4899'];
                grid.innerHTML = dbData.branches.map((b,i) => {
                    const mainSales = b.id===1 ? (dbData.bills||[]).reduce((s,bl)=>s+(bl.total||0),0) : b.sales;
                    return '<div class="action-panel" style="margin-bottom:0; border-top:4px solid '+colors[i%colors.length]+';"><div style="display:flex;justify-content:space-between;align-items:flex-start;"><div><strong style="font-size:1rem;">'+b.name+'</strong><br><small style="color:#6b7280;">'+b.city+' · Manager: '+b.manager+'</small></div><span style="background:'+colors[i%colors.length]+'20;color:'+colors[i%colors.length]+';padding:3px 10px;border-radius:20px;font-size:0.75rem;font-weight:700;">'+(b.id===1?'HQ':'Branch')+'</span></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px;"><div style="background:#f9fafb;padding:10px;border-radius:8px;"><div style="font-size:0.75rem;color:#6b7280;">Sales</div><div style="font-weight:700;font-size:1.1rem;color:'+colors[i%colors.length]+'">₹'+mainSales.toFixed(0)+'</div></div><div style="background:#f9fafb;padding:10px;border-radius:8px;"><div style="font-size:0.75rem;color:#6b7280;">Products</div><div style="font-weight:700;font-size:1.1rem;">'+(b.id===1?dbData.inventory.length:b.inventory||0)+'</div></div></div></div>';
                }).join('');
            }

            // ==========================================
            // AI ANALYTICS ENGINE
            // ==========================================
            function updateAiAnalytics() {
                // Top selling — from bills
                const prodSales = {};
                (dbData.bills||[]).forEach(b => { (b.items||[]).forEach(item => { prodSales[item.name] = (prodSales[item.name]||0) + (parseInt(item.qty||1)); }); });
                const topSelling = Object.entries(prodSales).sort((a,b)=>b[1]-a[1]).slice(0,5);
                const tsList = document.getElementById('topSellingList');
                if(tsList) tsList.innerHTML = topSelling.length===0 ? '<p style="color:#9ca3af;font-size:0.9rem;">Bill more items to see top sellers.</p>' :
                    topSelling.map(([name,qty],i) => '<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:'+(i===0?'#fef3c7':'#f9fafb')+';border-radius:8px;border-left:4px solid '+(i===0?'#f59e0b':'#e5e7eb')+'"><span style="font-size:0.88rem;font-weight:600;">'+(i+1)+'. '+name+'</span><span style="background:#ede9fe;color:#7c3aed;padding:3px 10px;border-radius:20px;font-size:0.8rem;font-weight:700;">'+qty+' sold</span></div>').join('');

                // Slow moving — products with no sales
                const soldNames = new Set(Object.keys(prodSales));
                const slowMoving = dbData.inventory.filter(i => !soldNames.has(i.name)).slice(0,5);
                const smList = document.getElementById('slowMovingList');
                if(smList) smList.innerHTML = slowMoving.length===0 ? '<p style="color:#10b981;font-size:0.9rem;">All products have recent sales. ✅</p>' :
                    slowMoving.map(i => '<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#fef2f2;border-radius:8px;border-left:4px solid #fca5a5;"><span style="font-size:0.88rem;font-weight:600;">'+i.name+'</span><span style="color:#ef4444;font-size:0.8rem;">'+i.qty+' in stock</span></div>').join('');

                // Buying patterns
                const custPattern = {};
                (dbData.bills||[]).forEach(b => { const k=b.customerPhone||b.customer; if(k&&k!=='Walk-in') { if(!custPattern[k]) custPattern[k]={name:b.customer||k,count:0,total:0,cats:[]}; custPattern[k].count++; custPattern[k].total+=b.total||0; } });
                const patterns = Object.values(custPattern).sort((a,b)=>b.count-a.count).slice(0,5);
                const bpList = document.getElementById('buyingPatternList');
                if(bpList) bpList.innerHTML = patterns.length===0 ? '<p style="color:#9ca3af;font-size:0.9rem;">Bill customers with phone numbers to see patterns.</p>' :
                    patterns.map(c => '<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#f0fdf4;border-radius:8px;border-left:4px solid #6ee7b7;"><span style="font-size:0.88rem;font-weight:600;">'+c.name+'</span><span style="color:#059669;font-size:0.8rem;">'+c.count+' visits · ₹'+c.total.toFixed(0)+'</span></div>').join('');
            }

            // Extend updateDashboardUI to call new engines
            const _origUpdate = updateDashboardUI;
            updateDashboardUI = function() {
                _origUpdate();
                updateExpirySection();
                updateProfitSection();
                renderOffers();
                renderBranchCards();
                updateAiAnalytics();
                loadReport('daily');
                scheduleChartRender();
            };

            // ==========================================
            // END SMART ENGINE
            // ==========================================
            updateDashboardUI();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initApp);
        } else {
            initApp();
        }
    </script>
</MainLayout>
