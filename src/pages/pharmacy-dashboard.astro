            const chartRefs = {};
            function upsertChart(key, canvasId, type, data, options) {
                if (!window.Chart) return;
                const canvas = document.getElementById(canvasId);
                if (!canvas) return;
                if (chartRefs[key]) chartRefs[key].destroy();
                chartRefs[key] = new window.Chart(canvas, { type, data, options });
            }
            function computeCategoryMap() {
                const map = {};
                (dbData.inventory || []).forEach(item => {
                    const cat = item.category || 'General';
                    const qty = intNum(item.stock_qty ?? item.qty, 0);
                    map[cat] = (map[cat] || 0) + qty;
                });
                return map;
            }
            function computeMonthlyRevenueMap() {
                const labels = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                const values = new Array(12).fill(0);
                (dbData.bills || []).forEach(b => {
                    const d = new Date(b.date || b.timestamp);
                    if (!Number.isNaN(d.getTime())) values[d.getMonth()] += num(b.total, 0);
                });
                return { labels, values };
            }
            function computeTopProductMap(limit = 6) {
                const map = {};
                (dbData.bills || []).forEach(b => (b.items || []).forEach(item => {
                    const name = item.name || item.product_name || 'Unknown';
                    map[name] = (map[name] || 0) + intNum(item.qty, 1);
                }));
                return Object.entries(map).sort((a,b)=>b[1]-a[1]).slice(0, limit);
            }
            let chartRenderTimer = null;
