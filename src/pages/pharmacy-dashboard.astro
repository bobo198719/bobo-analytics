---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Live Dashboard | BoboAnalytics CRM">
    <div class="live-dashboard" id="dashboardApp">
        <!-- Sidebar Navigation -->
        <aside class="dashboard-sidebar" id="sidebar">
            <div class="brand">
                <span class="icon" id="brandIcon">🏢</span>
                <h2 id="tenantNameHeader">Dashboard</h2>
            </div>
            <div class="live-badge" id="industryBadge">LIVE INSTANCE</div>
            <nav class="sidebar-nav" id="sidebarNav">
                <a href="#overview" class="nav-btn active" data-target="sec-overview">📊 Dashboard</a>
                <a href="#inventory" class="nav-btn" data-target="sec-inventory" id="navInventory">📦 Store Inventory</a>
                <a href="#scanners" class="nav-btn" data-target="sec-scanners" id="navScanners">🧾 AI Invoice Scanner</a>
                <a href="#billing" class="nav-btn" data-target="sec-billing" id="navBilling">🖥️ Barcode Billing</a>
                <a href="#expiry" class="nav-btn" data-target="sec-expiry" id="navExpiry">⏳ Expiry Alerts</a>
                <a href="#profit" class="nav-btn" data-target="sec-profit" id="navProfit">💰 Profit Intelligence</a>
                <a href="#offers" class="nav-btn" data-target="sec-offers" id="navOffers">🎁 Offers & Promotions</a>
                <a href="#gst" class="nav-btn" data-target="sec-gst" id="navGst">🧾 GST Filing</a>
                <a href="#reports" class="nav-btn" data-target="sec-reports" id="navReports">📈 Reports</a>
                <a href="#branches" class="nav-btn" data-target="sec-branches" id="navBranches">🏪 Multi-Branch</a>
                <a href="#crm" class="nav-btn" data-target="sec-crm" id="navCrm">👥 Customers & WhatsApp</a>
                <a href="#staff" class="nav-btn" data-target="sec-staff" id="navStaff">👨‍💼 Staff Roles</a>
                <a href="#ai" class="nav-btn" data-target="sec-ai" id="navAi">🧠 AI Analytics</a>
            </nav>
            <div class="sidebar-footer">
                <button id="logoutBtn" class="logout-btn">Log Out</button>
            </div>
        </aside>

        <!-- Main Workspace -->
        <main class="dashboard-workspace">
            <!-- OVERVIEW SECTION -->
            <section id="sec-overview" class="workspace-section active">
                <header class="workspace-header">
                    <h1 id="overviewTitle">Dashboard Overview</h1>
                    <p class="subtitle" id="overviewSubtitle">Real-time metrics for your business.</p>
                </header>

                <div class="stats-grid">
                    <div class="stat-card">
                        <h3 id="stat1Label">Today's Revenue</h3>
                        <p class="stat-value" id="statRevenue">₹0.00</p>
                    </div>
                    <div class="stat-card">
                        <h3 id="stat2Label">Transactions</h3>
                        <p class="stat-value" id="statTransactions">0</p>
                    </div>
                    <div class="stat-card">
                        <h3 id="stat3Label">Active Database</h3>
                        <p class="stat-value" id="statInventory">0</p>
                    </div>
                </div>

                <div class="empty-state" id="overviewEmptyState">
                    <div class="empty-icon" id="emptyStateIcon">🏢</div>
                    <h2 id="emptyStateTitle">Your Dashboard is Live!</h2>
                    <p id="emptyStateDesc">Start managing your records to see real-time analytics.</p>
                </div>

                <div class="recent-bills" id="recentBillsContainer" style="display: none;">
                    <h2 id="recentTransTitle">Recent Transactions</h2>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Txn No.</th>
                                <th>Time</th>
                                <th id="transCol3">Items</th>
                                <th>Total (₹)</th>
                            </tr>
                        </thead>
                        <tbody id="recentBillsTable">
                            <!-- Populated by JS -->
                        </tbody>
                    </table>
                </div>

                <div class="action-panel">
                    <h3 style="margin-bottom:14px;">Visual Analytics</h3>
                    <div id="overviewChartGrid" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:16px;">
                        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:12px;">
                            <h4 style="margin:0 0 10px; font-size:0.9rem;">Category Mix (Donut)</h4>
                            <canvas id="overviewDonutChart" height="180"></canvas>
                        </div>
                        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:10px; padding:12px;">
                            <h4 style="margin:0 0 10px; font-size:0.9rem;">Monthly Sales (Bar)</h4>
                            <canvas id="overviewBarChart" height="180"></canvas>
                        </div>
                    </div>
                </div>
            </section>

            <!-- INVENTORY / DATA SECTION -->
            <section id="sec-inventory" class="workspace-section">
                <header class="workspace-header">
                    <h1 id="inventoryTitle">Manage Records</h1>
                    <p class="subtitle" id="inventorySubtitle">Add new entries to your database.</p>
                </header>
                <div class="action-panel">
                    <h3 id="addFormTitle">Add New Entry</h3>
                    <form id="addInventoryForm" class="inline-form">
                        <div class="input-group">
                            <label id="invIdLabel">ID / Code</label>
                            <input type="text" id="invBarcode" required placeholder="1001" />
                        </div>
                        <div class="input-group">
                            <label>Category / Type</label>
                            <select id="invCategory" required></select>
                        </div>
                        <div class="input-group">
                            <label id="invNameLabel">Name</label>
                            <input type="text" id="invName" required placeholder="Enter name" />
                        </div>
                        <div class="input-group" id="invQtyGroup">
                            <label id="invQtyLabel">Stock / Count</label>
                            <input type="number" id="invQty" required min="1" value="10" />
                        </div>
                        <div class="input-group">
                            <label id="invPriceLabel">Value/Price (₹)</label>
                            <input type="number" id="invPrice" required min="0" step="0.1" value="50.00" />
                        </div>
                        <div class="input-group">
                            <label>MRP (Rs)</label>
                            <input type="number" id="invMrp" min="0" step="0.1" value="50.00" />
                        </div>
                        <div class="input-group">
                            <label>Selling Price (Rs)</label>
                            <input type="number" id="invSell" min="0" step="0.1" value="50.00" />
                        </div>
                        <div class="input-group">
                            <label>Manufacturer</label>
                            <input type="text" id="invMfr" placeholder="WS" />
                        </div>
                        <div class="input-group">
                            <label>HSN Code</label>
                            <input type="text" id="invHsn" placeholder="12345678" />
                        </div>
                        <div class="input-group">
                            <label>Pack Size</label>
                            <input type="text" id="invPack" placeholder="100ml" />
                        </div>
                        <div class="input-group">
                            <label>GST %</label>
                            <input type="number" id="invGst" min="0" step="0.1" value="5" />
                        </div>
                        <div class="input-group">
                            <label>Expiry Date</label>
                            <input type="text" id="invExpiry" placeholder="10-2025" />
                        </div>
                        <button type="submit" class="btn-primary" style="margin-top: 24px;" id="addFormBtn">Save Record</button>
                    </form>
                </div>

                <div class="inventory-list">
                    <h2 id="invListTitle">Current Database</h2>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th id="listCol1">Barcode</th>
                                <th id="listCol2">Product</th>
                                <th>Category</th>
                                <th>Manufacturer</th>
                                <th>HSN</th>
                                <th>Pack</th>
                                <th>MRP</th>
                                <th>Purchase</th>
                                <th>Selling</th>
                                <th id="listCol3">Stock Qty</th>
                                <th>Expiry</th>
                                <th id="listCol4">Action</th>
                            </tr>
                        </thead>
                        <tbody id="inventoryTable">
                        </tbody>
                    </table>
                </div>
            </section>

            

            <!-- AI INVOICE SCANNER SECTION -->
            <section id="sec-scanners" class="workspace-section">
                <header class="workspace-header">
                    <h1>🧾 AI Invoice Scanner</h1>
                    <p class="subtitle">Upload or snap a photo of any invoice — AI extracts header info, all line items, HSN, batch, expiry, GST. Review and edit before saving to inventory.</p>
                </header>

                <div style="display:flex; flex-wrap:wrap; gap:20px;">
                    <!-- LEFT: CAPTURE PANEL -->
                    <div class="action-panel" style="flex:1; min-width:280px; border-top:4px solid #6366f1;">
                        <h3>📷 Capture or Upload Invoice</h3>
                        <div style="width:100%; border-radius:8px; background:#111827; min-height:260px; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; margin-bottom:16px;">
                            <video id="invoiceVideo" style="width:100%; height:100%; object-fit:cover; display:none;" autoplay playsinline></video>
                            <canvas id="invoiceCanvas" style="display:none;"></canvas>
                            <img id="invoicePreview" style="width:100%; height:100%; object-fit:contain; display:none; background:#fff;" />
                            <span id="camPlaceholderText" style="color:#6b7280; font-size:0.9rem;">[ Camera Offline — Upload or Start Camera ]</span>
                        </div>
                        <div style="display:flex; gap:10px; margin-bottom:14px;">
                            <button type="button" id="startInvoiceCam" class="btn-secondary" style="flex:1;">📹 Live Camera</button>
                            <button type="button" id="captureInvoiceBtn" class="btn-primary" style="flex:1; display:none;">📸 Snap</button>
                        </div>
                        <hr style="border:none; border-top:1px dashed #e5e7eb; margin:12px 0;" />
                        <label style="font-size:0.85rem; font-weight:600; display:block; margin-bottom:8px;">📁 Upload Bill Image / PDF</label>
                        <input type="file" id="billInputStore" accept=".jpg,.jpeg,.png,.pdf,image/*,application/pdf" style="width:100%; margin-bottom:14px; font-size:0.85rem;" />
                        <button type="button" id="processAiBtn" class="btn-primary" style="width:100%; padding:14px; font-size:1rem; letter-spacing:0.5px;">🔍 Extract Bill Data with AI</button>
                        <div id="aiExtractionResults" style="margin-top:12px; font-size:0.85rem; font-weight:600; min-height:20px;"></div>
                    </div>

                    <!-- RIGHT: REVIEW PANEL -->
                    <div style="flex:2; min-width:320px; display:flex; flex-direction:column; gap:16px;">

                        <!-- Invoice Header extracted -->
                        <div id="invoiceHeaderBox" style="display:none; background:#f0f9ff; border:1px solid #bae6fd; border-radius:12px; padding:20px;">
                            <h3 style="margin:0 0 12px; font-size:1rem; color:#0369a1;">📋 Invoice Header — Extracted</h3>
                            <div id="invoiceHeaderGrid" style="display:grid; grid-template-columns:1fr 1fr; gap:8px 24px; font-size:0.82rem;"></div>
                        </div>

                        <!-- Line Items Review Table -->
                        <div id="aiCapturedReviewBox" style="display:none; background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:20px;">
                            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; flex-wrap:wrap; gap:8px;">
                                <h3 style="margin:0; font-size:1rem; color:#374151;">✏️ Review &amp; Edit Line Items</h3>
                                <button type="button" id="addAiRowBtn" class="btn-secondary" style="font-size:0.8rem; padding:6px 12px;">+ Add Row</button>
                            </div>
                            <div style="overflow-x:auto; max-height:340px; overflow-y:auto;">
                                <table style="width:100%; border-collapse:collapse; font-size:0.78rem;" id="aiReviewTable">
                                    <thead style="position:sticky; top:0; background:#f9fafb; z-index:1;">
                                        <tr>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap; text-align:left;">Product Name</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap;">HSN</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap;">Batch</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap;">Expiry</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap;">Qty</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap;">Free</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap;">MRP</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap;">Rate</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap;">Dis%</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap;">GST%</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb; white-space:nowrap;">Amount</th>
                                            <th style="padding:7px 6px; border:1px solid #e5e7eb;">Del</th>
                                        </tr>
                                    </thead>
                                    <tbody id="aiReviewTableBody"></tbody>
                                </table>
                            </div>
                            <div style="display:flex; gap:10px; margin-top:16px; flex-wrap:wrap;">
                                <button type="button" class="btn-primary" id="confirmAiPushBtn" style="flex:1; padding:12px;">✅ Confirm &amp; Save to Inventory</button>
                                <button type="button" id="cancelAiPushBtn" style="background:#fef2f2; color:#ef4444; border:1px solid #fca5a5; border-radius:8px; padding:12px 16px; cursor:pointer; flex:0.3;">Discard</button>
                            </div>
                        </div>

                        <!-- Empty placeholder -->
                        <div id="aiScannerEmpty" style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:300px; background:#f9fafb; border:2px dashed #e5e7eb; border-radius:12px; text-align:center; padding:32px;">
                            <div style="font-size:3.5rem; margin-bottom:16px;">🧾</div>
                            <p style="color:#6b7280; font-size:0.95rem; max-width:320px; line-height:1.6;">Upload or snap a photo of your pharmacy invoice.<br/>AI will extract <strong>Invoice Header</strong>, <strong>All Line Items</strong> with HSN, Batch, Expiry, GST — ready to review and save.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- BARCODE BILLING POS SECTION -->
            <section id="sec-billing" class="workspace-section">
                <header class="workspace-header">
                    <h1>🖥️ Barcode Billing POS</h1>
                    <p class="subtitle">Scan barcodes, search products, auto-calculate GST and generate professional invoices with WhatsApp delivery.</p>
                </header>
                <div style="display:flex; gap:20px; flex-wrap:wrap;">

                    <!-- Scanner Input -->
                    <div class="action-panel" style="flex:1; min-width:280px;">
                        <h3>📷 Live Barcode Scanner</h3>
                        <div id="barcode-reader" style="width:100%; border-radius:8px; background:#111827; min-height:220px; display:flex; align-items:center; justify-content:center; color:#6b7280; font-size:0.9rem; margin-bottom:14px;">[Camera Feed Offline]</div>
                        <div style="display:flex; gap:10px; margin-bottom:14px;">
                            <button type="button" id="startBarcodeCam" class="btn-primary" style="flex:1;">Start Camera</button>
                            <button type="button" id="stopBarcodeCam" class="btn-secondary" style="flex:1;" disabled>Stop</button>
                        </div>
                        <p id="barcodeStatusMsg" style="font-size:0.85rem; font-weight:600; min-height:20px;"></p>
                        <hr style="border:none; border-top:1px dashed #e5e7eb; margin:12px 0;" />
                        <h3>🔍 Manual Barcode / Product Search</h3>
                        <form id="scannerForm" style="display:flex; gap:8px; margin-bottom:8px;">
                            <input type="text" id="liveScannerInput" placeholder="Type or scan barcode..." style="flex:1; padding:10px 12px; border:1px solid #d1d5db; border-radius:8px; font-size:0.9rem;" />
                            <button type="submit" class="btn-primary" style="padding:10px 16px;">Add</button>
                        </form>
                        <p id="scannerMsg" style="font-size:0.85rem; font-weight:600; min-height:20px;"></p>
                    </div>

                    <!-- Live Bill -->
                    <div style="flex:2; min-width:320px; display:flex; flex-direction:column; gap:14px;">
                        <div class="action-panel" style="margin-bottom:0;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                                <h3 style="margin:0;">🧾 Current Bill</h3>
                                <span id="billInvoiceNo" style="font-size:0.8rem; color:#6b7280; background:#f3f4f6; padding:4px 10px; border-radius:6px;">Invoice #—</span>
                            </div>

                            <div id="billItems" style="min-height:120px; border:1px dashed #e5e7eb; border-radius:8px; padding:10px; margin-bottom:14px; max-height:260px; overflow-y:auto;">
                                <p id="emptyBillMsg" style="color:#9ca3af; text-align:center; margin-top:32px;">No items added yet. Scan or search a product.</p>
                            </div>

                            <!-- GST Summary -->
                            <div style="font-size:0.88rem; border-top:1px solid #f3f4f6; padding-top:12px;">
                                <div style="display:flex; justify-content:space-between; padding:3px 0; color:#6b7280;"><span>Subtotal</span><span id="billSubtotal">₹0.00</span></div>
                                <div style="display:flex; justify-content:space-between; padding:3px 0; color:#6b7280;"><span>Discount</span><span id="billDiscount">₹0.00</span></div>
                                <div style="display:flex; justify-content:space-between; padding:3px 0; color:#6b7280;"><span>CGST</span><span id="billCgst">₹0.00</span></div>
                                <div style="display:flex; justify-content:space-between; padding:3px 0; color:#6b7280;"><span>SGST</span><span id="billSgst">₹0.00</span></div>
                                <div style="display:flex; justify-content:space-between; padding:3px 0; color:#6b7280;"><span>Round Off</span><span id="billRoundOff">₹0.00</span></div>
                                <div style="display:flex; justify-content:space-between; padding:10px 0 6px; border-top:2px solid #e5e7eb; font-weight:800; font-size:1.15rem;"><span>Net Amount</span><span id="billTotal">₹0.00</span></div>
                            </div>

                            <!-- Customer -->
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:10px;">
                                <input type="text" id="billCustomerName" placeholder="Customer Name" style="padding:8px 12px; border:1px solid #d1d5db; border-radius:8px; font-size:0.85rem;" />
                                <input type="text" id="billCustomerPhone" placeholder="Phone Number" style="padding:8px 12px; border:1px solid #d1d5db; border-radius:8px; font-size:0.85rem;" />
                            </div>

                            <div style="display:flex; gap:10px; margin-top:14px; flex-wrap:wrap;">
                                <button id="generateBillBtn" class="btn-success" style="flex:2;" disabled>🖨 Generate Invoice</button>
                                <button id="waShareBtn" class="btn-secondary" style="flex:1; background:#25d366; color:#fff; border-color:#25d366;" disabled>💬 WhatsApp</button>
                                <button id="clearBillBtn" class="btn-secondary" style="flex:0.5;">🗑 Clear</button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- CRM / WHATSAPP SECTION -->
            <section id="sec-crm" class="workspace-section">
                <header class="workspace-header">
                    <h1 id="crmTitle">Customers & WhatsApp Integration</h1>
                    <p class="subtitle">Broadcast bills, offers, and manage audience.</p>
                </header>
                <div class="action-panel">
                    <h3>Send WhatsApp Campaign (API)</h3>
                    <form id="waForm" class="inline-form" style="flex-direction:column; gap:16px;">
                        <div class="input-group" style="width:100%;">
                            <label>Message Type</label>
                            <select id="waType">
                                <option value="offer">Marketing Offer / Discount</option>
                                <option value="reminder">Expiry / Refill Reminder</option>
                            </select>
                        </div>
                        <div class="input-group" style="width:100%;">
                            <label>Email Subject (for Email campaigns)</label>
                            <input type="text" id="waEmailSubject" style="padding:10px; border:1px solid #d1d5db; border-radius:8px;" placeholder="Special Offer from our pharmacy" />
                        </div>
                        <div class="input-group" style="width:100%;">
                            <label>Message Payload Content</label>
                            <textarea id="waMsg" rows="4" style="padding:10px; border:1px solid #d1d5db; border-radius:8px; font-family:sans-serif;" placeholder="Hello [Customer Name], Special Offer! 20% OFF on Baby Products valid returning today!"></textarea>
                        </div>
                        <div style="display:flex; gap:10px; flex-wrap:wrap;">
                            <button type="button" class="btn-primary" style="background:#25d366; border-color:#25d366;" onclick="sendCampaign('whatsapp')">Send WhatsApp</button>
                            <button type="button" class="btn-primary" onclick="sendCampaign('sms')">Send SMS</button>
                            <button type="button" class="btn-primary" style="background:#2563eb; border-color:#2563eb;" onclick="sendCampaign('email')">Send Email</button>
                        </div>
                    </form>
                </div>
                <div class="inventory-list">
                    <h2>Client Database</h2>
                    <table class="data-table">
                        <thead><tr><th>Customer Name</th><th>Phone</th><th>Total Spends</th></tr></thead>
                        <tbody>
                            <tr><td>Rajesh K.</td><td>+91 9988776655</td><td>₹4,500.00</td></tr>
                            <tr><td>Priya Sharma</td><td>+91 9876543210</td><td>₹2,120.00</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- STAFF MANAGEMENT SECTION -->
            <section id="sec-staff" class="workspace-section">
                <header class="workspace-header">
                    <h1>Staff Access Control</h1>
                    <p class="subtitle">Assign roles like Admin, Manager, Cashier, or Pharmacist.</p>
                </header>
                <div class="action-panel" style="max-width: 600px; margin-bottom: 30px;">
                    <h3>Provision New Staff</h3>
                    <form class="inline-form" onsubmit="event.preventDefault(); alert('Staff user created. Credentials emailed.');">
                        <div class="input-group"><label>Name</label><input type="text" required placeholder="Amit Singh"></div>
                        <div class="input-group">
                            <label>Role</label>
                            <select id="staffRoleDrop" style="padding:10px;border-radius:8px;border:1px solid #ccc;">
                                <option>Cashier (Billing Only)</option>
                                <option>Manager (Inventory + Reports)</option>
                                <option>Pharmacist (Medicine Inventory)</option>
                            </select>
                        </div>
                        <button type="submit" class="btn-primary" style="margin-top:24px;">Create Key</button>
                    </form>
                </div>
                <table class="data-table">
                    <thead><tr><th>Name</th><th>Role System</th><th>Status</th><th>Actions</th></tr></thead>
                    <tbody>
                        <tr><td>System Default</td><td><span class="badge" style="background:#818cf8;color:white;padding:4px 8px;border-radius:4px;">Owner (Full Access)</span></td><td>Active</td><td>-</td></tr>
                        <tr><td>Rahul Verma</td><td>Cashier</td><td>Active</td><td><button style="color:red;border:none;background:none;cursor:pointer;">Disable</button></td></tr>
                    </tbody>
                </table>
            </section>

            <!-- EXPIRY ALERTS SECTION -->
            <section id="sec-expiry" class="workspace-section">
                <header class="workspace-header">
                    <h1>⏳ Expiry Alerts</h1>
                    <p class="subtitle">Track medicines expiring soon. Act before loss hits your shelf.</p>
                </header>
                <div style="display:flex; gap:16px; flex-wrap:wrap; margin-bottom:24px;">
                    <div class="stat-card" style="border-top-color:#ef4444; flex:1; min-width:160px; cursor:pointer;" onclick="filterExpiry('expired')" id="expiredCard"><h3>🔴 Expired</h3><p class="stat-value" id="cntExpired">0</p></div>
