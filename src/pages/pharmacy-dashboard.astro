                    categories: ["Fresh Produce", "Dairy", "Meat & Poultry", "Bakery", "Dry Goods & Staples"]
                },
                "clothing-store": {
                    colorMain: "#ff4fd8", colorDark: "#2b001f", icon: "👕",
                    invNav: "👗 Apparel Catalog", posNav: "🛍️ Register",
                    crmNav: "👥 Catalog Drops", staffNav: "👨‍💼 Sales Reps", aiNav: "🧠 Trend AI",
                    overviewSub: "Trend analysis and size-wise stock management.",
                    stat3: "Garments Left", emptyDesc: "Add clothing lines across sizes.",
                    invTitle: "Apparel Management", invSub: "Manage fashion inventory by sizing.",
                    addTitle: "Add Garment", labelId: "Style No.", labelName: "Garment Name + Size", labelQty: "Stock", labelPrice: "MRP (₹)",
                    listId: "Style No.", listName: "Garment", listQty: "Remaining", posTitle: "Boutique Register", posSub: "Bill fashion accessories and apparel.",
                    scanTitle: "Style Scanner", scanDesc: "Scan clothing tags.",
                    categories: ["Men's Wear", "Women's Wear", "Kids Clothing", "Shoes", "Accessories"]
                },
                "stock-trading": {
                    colorMain: "#00e5ff", colorDark: "#001b2b", icon: "📉",
                    invNav: "📊 Equities", posNav: "💹 Trade Terminal",
                    crmNav: "👥 Margin Calls", staffNav: "👨‍💼 Traders", aiNav: "🧠 Bot Strategy",
                    overviewSub: "Portfolio analytics and real-time risk assessment.",
                    stat3: "Equities Held", emptyDesc: "Purchase stocks to populate portfolio.",
                    invTitle: "Market Equities", invSub: "Manage stored tickers and active blocks.",
                    addTitle: "Execute Block Purchase", labelId: "Ticker Symbol", labelName: "Company Name", labelQty: "Shares", labelPrice: "Buy Price (₹)",
                    listId: "Ticker", listName: "Company", listQty: "Shares", posTitle: "Sell / Liquidate Holdings", posSub: "Execute a block sale.",
                    scanTitle: "Ticker Lookup", scanDesc: "Enter exact Ticker Symbol.",
                    categories: ["Tech Stocks", "Blue Chips", "Penny Stocks", "ETFs", "Commodities"]
                }
            };

            const t = themes[industry] || themes['pharmacy'];

            // Apply Theme Options
            const dbApp = document.getElementById("dashboardApp");
            dbApp.style.setProperty("--brand-main", t.colorMain);
            dbApp.style.setProperty("--brand-dark", t.colorDark);
            document.getElementById("sidebar").style.background = t.colorDark;
            document.getElementById("industryBadge").innerText = `${industry.replace('-', ' ').toUpperCase()} LIVE`;

            document.getElementById("brandIcon").innerText = t.icon;
            document.getElementById("emptyStateIcon").innerText = t.icon;
            document.getElementById("navInventory").innerText = t.invNav;
            if(document.getElementById("navBilling")) document.getElementById("navBilling").innerText = t.posNav;
            if(t.crmNav) document.getElementById("navCrm").innerText = t.crmNav;
            if(t.staffNav) document.getElementById("navStaff").innerText = t.staffNav;
            if(t.aiNav) document.getElementById("navAi").innerText = t.aiNav;
            
            document.getElementById("overviewSubtitle").innerText = t.overviewSub;
            document.getElementById("stat3Label").innerText = t.stat3;
            document.getElementById("emptyStateDesc").innerText = t.emptyDesc;
            document.getElementById("inventoryTitle").innerText = t.invTitle;
            document.getElementById("inventorySubtitle").innerText = t.invSub;
            document.getElementById("addFormTitle").innerText = t.addTitle;
            document.getElementById("invIdLabel").innerText = t.labelId;
            document.getElementById("invNameLabel").innerText = t.labelName;
            document.getElementById("invQtyLabel").innerText = t.labelQty;
            document.getElementById("invPriceLabel").innerText = t.labelPrice;
            document.getElementById("listCol1").innerText = t.listId;
            document.getElementById("listCol3").innerText = t.listQty;
            if(document.getElementById("posTitle")) document.getElementById("posTitle").innerText = t.posTitle;
            if(document.getElementById("posSubtitle")) document.getElementById("posSubtitle").innerText = t.posSub;
            if(document.getElementById("scannerTitle")) document.getElementById("scannerTitle").innerText = t.scanTitle;
            if(document.getElementById("scannerDesc")) document.getElementById("scannerDesc").innerText = t.scanDesc;

            // Populate Category Select
            const catSelect = document.getElementById("invCategory");
            t.categories.forEach(cat => {
                 let opt = document.createElement("option");
                 opt.value = cat;
                 opt.innerText = cat;
                 catSelect.appendChild(opt);
            });

            // Database Sandbox (LocalStorage)
            const dbKey = `bobo_crm_db_${tenantInfo.id}`;
            let dbData = JSON.parse(localStorage.getItem(dbKey) || '{"inventory":[],"bills":[]}');
            function saveData() { localStorage.setItem(dbKey, JSON.stringify(dbData)); }
            window.deleteItem = function(barcode) {
                if(!confirm("Remove this product?")) return;
                dbData.inventory = dbData.inventory.filter(i => i.barcode !== barcode);
                saveData(); updateDashboardUI();
            };

            // Tab Navigation Logic
            const navBtns = document.querySelectorAll('.nav-btn');
            const sections = document.querySelectorAll('.workspace-section');
            const liveScannerInput = document.getElementById("liveScannerInput");

            navBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const targetId = btn.getAttribute('data-target');
                    if (!targetId) return; // Allow normal navigation for external links

                    e.preventDefault();
                    navBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    
                    sections.forEach(sec => {
                        sec.classList.remove('active');
                        if (sec.id === targetId) sec.classList.add('active');
                    });
                    if (targetId === "sec-inventory") { if(liveScannerInput) liveScannerInput.focus(); }
                });
            });

            // UI Updater
            function updateDashboardUI() {
                let totalRev = 0;
                dbData.bills.forEach(b => totalRev += b.total);
                document.getElementById("statRevenue").innerText = `₹${totalRev.toFixed(2)}`;
                document.getElementById("statTransactions").innerText = dbData.bills.length;
                document.getElementById("statInventory").innerText = dbData.inventory.length;

                const emptyState = document.getElementById("overviewEmptyState");
                const billsContainer = document.getElementById("recentBillsContainer");
                
                if (dbData.inventory.length > 0 || dbData.bills.length > 0) {
                    emptyState.style.display = "none";
                    if (dbData.bills.length > 0) {
                        billsContainer.style.display = "block";
                        const tableBody = document.getElementById("recentBillsTable");
                        let rowsHtml = "";
                        const recent = [...dbData.bills].reverse().slice(0, 5);
                        recent.forEach(b => {
                            rowsHtml += `<tr>
                                <td>#${b.id.substring(0,8)}</td>
                                <td>${new Date(b.date).toLocaleTimeString()}</td>
                                <td>${b.itemsCount}</td>
                                <td>₹${b.total.toFixed(2)}</td>
                            </tr>`;
                        });
                        tableBody.innerHTML = rowsHtml;
                    }
                } else {
                    emptyState.style.display = "block";
                    billsContainer.style.display = "none";
                }

                // AI Data & Inventory List (Full Schema)
                const invTable = document.getElementById("inventoryTable");
                let catCounts = {};
                let lowStock = 0;
                let expiryAlerts = 0;

                if (!invTable) return;

                if (dbData.inventory.length === 0) {
                    invTable.innerHTML = `<tr><td colspan="12" style="text-align:center; padding:32px; color:#9ca3af;">No products yet. Use the Add Product form or AI Invoice Scanner.</td></tr>`;
                    if(document.getElementById("aiTopCat")) document.getElementById("aiTopCat").innerText = "Not Enough Data";
                } else {
                    let invHtml = "";
                    dbData.inventory.forEach((item, idx) => {
                        const qty = parseInt(item.qty) || 0;
                        const mrp = parseFloat(item.mrp || item.price || 0);
                        const rate = parseFloat(item.selling_price || item.price || 0);
                        const gst = item.gst_percent || '5';
                        const isLow = qty < 10;
                        if(isLow) lowStock++;
                        catCounts[item.category] = (catCounts[item.category] || 0) + qty;

                        invHtml += `<tr>
                            <td><code style="background:#f3f4f6;padding:2px 5px;border-radius:4px;font-size:0.75rem;">${item.barcode||'—'}</code></td>
                            <td><strong>${item.name||'—'}</strong></td>
                            <td><small style="background:#ede9fe;color:#7c3aed;padding:2px 6px;border-radius:4px;font-size:0.75rem;">${item.category||'General'}</small></td>
                            <td style="font-size:0.82rem;">${item.manufacturer||'—'}</td>
                            <td style="font-size:0.82rem;">${item.hsn_code||'—'}</td>
                            <td style="font-size:0.82rem;">${item.pack_size||'—'}</td>
                            <td style="font-size:0.82rem;">₹${mrp.toFixed(2)}</td>
                            <td style="font-size:0.82rem;">₹${rate.toFixed(2)}</td>
                            <td style="font-size:0.82rem;">${gst}%</td>
                            <td><span style="color:${isLow?'#ef4444':'#10b981'};font-weight:700;">${qty}${isLow?' ⚠️':''}</span></td>
                            <td style="font-size:0.82rem;color:${item.expiry_date?'#6b7280':'#d1d5db'}">${item.expiry_date||'—'}</td>
                            <td><button onclick="window.deleteInvItem('${item.barcode}')" style="background:none;border:none;cursor:pointer;color:#ef4444;font-size:1rem;">🗑</button></td>
                        </tr>`;
                    });
                    invTable.innerHTML = invHtml;

                    if(document.getElementById("aiAlerts")) document.getElementById("aiAlerts").innerHTML = `<strong style="color:#ef4444;">${lowStock} Low Stock</strong> items need re-order.`;

                    let topCat = "No clear trend";
                    let highQty = 0;
                    for(let c in catCounts) { if(catCounts[c] > highQty) { highQty = catCounts[c]; topCat = c; } }
                    if(document.getElementById("aiTopCat")) document.getElementById("aiTopCat").innerHTML = `<strong>${topCat}</strong>`;
                }

                // Reports stats
                let todaySales = 0, monthSales = 0;
                const todayStr = new Date().toDateString();
                const thisMonth = new Date().getMonth();
                dbData.bills.forEach(b => {
                    if(new Date(b.date).toDateString() === todayStr) todaySales += b.total;
                    if(new Date(b.date).getMonth() === thisMonth) monthSales += b.total;
                });
                if(document.getElementById("repToday")) document.getElementById("repToday").innerText = "₹" + todaySales.toFixed(0);
                if(document.getElementById("repMonth")) document.getElementById("repMonth").innerText = "₹" + monthSales.toFixed(0);
                if(document.getElementById("repLowStock")) document.getElementById("repLowStock").innerText = lowStock;
            }

            // Delete inventory item
            window.deleteInvItem = function(barcode) {
                if(!confirm('Remove product ' + barcode + ' from inventory?')) return;
                dbData.inventory = dbData.inventory.filter(i => i.barcode !== barcode);
                saveData(); updateDashboardUI();
            };

            const addInvForm = document.getElementById("addInventoryForm");
            if(addInvForm) addInvForm.addEventListener("submit", (e) => {
                e.preventDefault();
                const barcode = document.getElementById("invBarcode")?.value.trim() || '';
                const name = document.getElementById("invName")?.value.trim() || '';
                if(!barcode || !name) return alert('Barcode and Product Name are required.');
                const category = document.getElementById("invCategory")?.value || 'Medicine';
                const qty = parseInt(document.getElementById("invQty")?.value) || 1;
                const price = parseFloat(document.getElementById("invPrice")?.value) || 0;
                const mrp = parseFloat(document.getElementById("invMrp")?.value || price);
                const sell = parseFloat(document.getElementById("invSell")?.value || price);
                const mfr = document.getElementById("invMfr")?.value?.trim() || '';
                const hsn = document.getElementById("invHsn")?.value?.trim() || '';
                const pack = document.getElementById("invPack")?.value?.trim() || '';
                const gst = document.getElementById("invGst")?.value || '5';
                const expiry = document.getElementById("invExpiry")?.value?.trim() || '';

                const existing = dbData.inventory.find(i => i.barcode === barcode);
                if (existing) {
                    existing.qty += qty; existing.price = price; existing.mrp = mrp; existing.selling_price = sell;
                    existing.category = category; existing.manufacturer = mfr; existing.hsn_code = hsn;
                    existing.pack_size = pack; existing.gst_percent = gst; existing.expiry_date = expiry;
                } else {
                    dbData.inventory.push({ barcode, name, category, qty, price, mrp, selling_price: sell, manufacturer: mfr, hsn_code: hsn, pack_size: pack, gst_percent: gst, expiry_date: expiry });
                }
                saveData();
                addInvForm.reset();
                updateDashboardUI();
            });

            // POS / Transaction Engine
            let currentBillItems = [];
            const billItemsList = document.getElementById("billItemsList");
            const scannerForm = document.getElementById("scannerForm");
            const scannerMsg = document.getElementById("scannerMsg");
            const generateBillBtn = document.getElementById("generateBillBtn");

            function renderBill() {
                if (currentBillItems.length === 0) {
                    billItemsList.innerHTML = `<p class="empty-bill-msg">No entries selected. Use Scanner to begin.</p>`;
                    document.getElementById("billSubtotal").innerText = "₹0.00";
                    document.getElementById("billTotal").innerText = "₹0.00";
                    generateBillBtn.disabled = true;
                    return;
                }

                let html = "";
                let subtotal = 0;
                
                currentBillItems.forEach(item => {
                    const rowTotal = item.qty * parseFloat(item.price);
                    subtotal += rowTotal;
                    html += `
                    <div class="bill-item-row">
                        <div>
                            <div class="bill-item-name">${item.name} (x${item.qty})</div>
                            <div class="bill-item-price">@ ₹${parseFloat(item.price).toFixed(2)} / unit</div>
                        </div>
                        <div class="bill-item-total">₹${rowTotal.toFixed(2)}</div>
                    </div>`;
                });

                billItemsList.innerHTML = html;
                document.getElementById("billSubtotal").innerText = `₹${subtotal.toFixed(2)}`;
                document.getElementById("billTotal").innerText = `₹${subtotal.toFixed(2)}`;
                generateBillBtn.disabled = false;
            }

            scannerForm.addEventListener("submit", (e) => {
                e.preventDefault();
                const barcode = liveScannerInput.value.trim();
                liveScannerInput.value = "";
                liveScannerInput.focus();

                if (!barcode) return;

                const foundItem = dbData.inventory.find(i => i.barcode === barcode);
                
                if (foundItem) {
                    if (foundItem.qty > 0) {
                        const inBill = currentBillItems.find(b => b.barcode === barcode);
                        if (inBill) {
                            if (foundItem.qty > inBill.qty) {
                                inBill.qty++;
                            } else {
                                scannerMsg.className = "scanner-feedback error";
                                scannerMsg.innerText = "❌ Stock limit reached!";
                                return;
                            }
                        } else {
                            currentBillItems.push({
                                barcode: foundItem.barcode,
                                name: foundItem.name,
                                price: foundItem.price,
                                qty: 1
                            });
                        }
                        
                        scannerMsg.className = "scanner-feedback success";
                        scannerMsg.innerText = `✅ Accepted ${foundItem.name}.`;
                        renderBill();
                    } else {
                        scannerMsg.className = "scanner-feedback error";
                        scannerMsg.innerText = "❌ Exceeded Stock Quantity! Cannot process.";
                    }
                } else {
                    scannerMsg.className = "scanner-feedback error";
                    scannerMsg.innerText = "❌ Unrecognized ID! Not in local system.";
                }

                setTimeout(() => { if(scannerMsg.innerText.includes(barcode)) scannerMsg.innerText = ""; }, 3000);
            });

            generateBillBtn.addEventListener("click", () => {
                if (currentBillItems.length === 0) return;

                let grandTotal = 0;
                let itemsCount = 0;
                let summaryString = "";
                
                currentBillItems.forEach(bItem => {
                    grandTotal += (bItem.qty * parseFloat(bItem.price));
                    itemsCount += bItem.qty;
                    summaryString += `\n- ${bItem.name} (x${bItem.qty})`;
                    const invItem = dbData.inventory.find(i => i.barcode === bItem.barcode);
                    if (invItem) invItem.qty -= bItem.qty;
                });

                const billData = {
                    id: Date.now().toString(),
                    date: new Date().toISOString(),
                    itemsCount: itemsCount,
                    total: grandTotal,
                    items: [...currentBillItems]
                };

                dbData.bills.push(billData);
                saveData();
                
                // Trigger simulated WhatsApp Bill payload immediately after successful transaction
                setTimeout(() => {
                    alert(`✅ Transaction Processed Successfully!\n\n*** WHATSAPP BILL ROUTING VIA BOBO ANALYTICS ***\n\nHello [Customer Name],\nThank you for shopping at ${tenantInfo.name}.\n\nBill Amount: ₹${grandTotal.toFixed(2)}\nItems Purchased:${summaryString}\n\nVisit again!\nPowered by BoboAnalytics`);
                }, 100);
                
                currentBillItems = [];
                renderBill();
                updateDashboardUI();
                
                scannerMsg.className = "scanner-feedback success";
                scannerMsg.innerText = "Ready for the next execution.";
            });

            document.getElementById("logoutBtn").addEventListener("click", () => {
                localStorage.removeItem("activeTenantContext");
                window.location.href = "/pharmacy-login";
            });

            
            
            // ==========================================
            // SMART CAMERA & AI SCANNER ENGINE
            // ==========================================
            let html5QrcodeScanner = null;
            const startBarcodeBtn = document.getElementById('startBarcodeCam');
            const stopBarcodeBtn = document.getElementById('stopBarcodeCam');
            const barcodeStatusMsg = document.getElementById('barcodeStatusMsg');

            if(startBarcodeBtn) {
                startBarcodeBtn.addEventListener('click', () => {
                    if(barcodeStatusMsg) { barcodeStatusMsg.innerText = "Starting camera..."; }
                    if (!html5QrcodeScanner && window.Html5Qrcode) {
                        html5QrcodeScanner = new window.Html5Qrcode("barcode-reader");
                    }
                    if(!html5QrcodeScanner) { if(barcodeStatusMsg) barcodeStatusMsg.innerText = "Library loading, try again."; return; }
                    
                    html5QrcodeScanner.start(
                        { facingMode: "environment" }, 
                        { fps: 10, qrbox: {width: 250, height: 250} },
                        (decodedText) => {
                            if(barcodeStatusMsg) { barcodeStatusMsg.innerText = "✅ Scanned: " + decodedText; barcodeStatusMsg.style.color = "#10b981"; }
                            const liveInput = document.getElementById("liveScannerInput");
                            if (liveInput) {
                                liveInput.value = decodedText;
                                const sf = document.getElementById("scannerForm");
                                if(sf) sf.dispatchEvent(new Event('submit', { cancelable: true, bubbles:true }));
                            }
                        },
                        () => {}
                    ).then(() => {
                        const barcodeReaderEl = document.getElementById('barcode-reader');
                        if(barcodeReaderEl) barcodeReaderEl.style.background = 'transparent';
                        if(barcodeStatusMsg) barcodeStatusMsg.innerText = "Camera active. Show barcode.";
                        startBarcodeBtn.disabled = true;
                        stopBarcodeBtn.disabled = false;
                    }).catch(() => {
                        if(barcodeStatusMsg) { barcodeStatusMsg.innerText = "Camera access denied."; barcodeStatusMsg.style.color = "red"; }
                    });
                });

                if(stopBarcodeBtn) stopBarcodeBtn.addEventListener('click', () => {
                    if(html5QrcodeScanner) {
                        html5QrcodeScanner.stop().then(() => {
                            startBarcodeBtn.disabled = false;
                            stopBarcodeBtn.disabled = true;
                            const br = document.getElementById('barcode-reader');
                            if(br) { br.style.background = '#111827'; br.innerHTML = '[Camera Feed Offline]'; }
                        });
                    }
                });
            }

            // AI INVOICE CAMERA
            const invoiceVideo = document.getElementById('invoiceVideo');
            const invoiceCanvas = document.getElementById('invoiceCanvas');
            const invoicePreview = document.getElementById('invoicePreview');
            const startInvoiceCam = document.getElementById('startInvoiceCam');
            const captureInvoiceBtn = document.getElementById('captureInvoiceBtn');
            const billInputStore = document.getElementById('billInputStore');
            const processAiBtn = document.getElementById('processAiBtn');
            const aiExtractionResults = document.getElementById('aiExtractionResults');
            const camPlaceholderText = document.getElementById('camPlaceholderText');
            
            let invoiceStream = null;
            let captureImageBlob = null;
            window.aiStagingBuffer = [];

            if (startInvoiceCam) {
                startInvoiceCam.addEventListener('click', async () => {
                    if (invoiceStream) {
                        invoiceStream.getTracks().forEach(t => t.stop());
                        invoiceStream = null;
                        if(invoiceVideo) invoiceVideo.style.display = 'none';
                        if(captureInvoiceBtn) captureInvoiceBtn.style.display = 'none';
                        if(camPlaceholderText) camPlaceholderText.style.display = 'block';
                        startInvoiceCam.innerText = "📹 Live Camera";
                    } else {
                        try {
                            invoiceStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment", width: { ideal: 1920 }, height: { ideal: 1080 } } });
                            if(invoiceVideo) { invoiceVideo.srcObject = invoiceStream; invoiceVideo.style.display = 'block'; }
                            if(invoicePreview) invoicePreview.style.display = 'none';
                            if(camPlaceholderText) camPlaceholderText.style.display = 'none';
                            captureImageBlob = null;
                            if(captureInvoiceBtn) captureInvoiceBtn.style.display = 'block';
                            startInvoiceCam.innerText = "Turn Off Camera";
                        } catch (err) { alert("Camera access denied or not found."); }
                    }
                });

                if(captureInvoiceBtn) captureInvoiceBtn.addEventListener('click', () => {
                    if(!invoiceCanvas || !invoiceVideo) return;
                    const ctx = invoiceCanvas.getContext('2d');
                    invoiceCanvas.width = invoiceVideo.videoWidth || 1280;
                    invoiceCanvas.height = invoiceVideo.videoHeight || 720;
                    ctx.drawImage(invoiceVideo, 0, 0, invoiceCanvas.width, invoiceCanvas.height);
                    if(invoicePreview) { invoicePreview.src = invoiceCanvas.toDataURL('image/png'); invoicePreview.style.display = 'block'; }
                    if(invoiceVideo) invoiceVideo.style.display = 'none';
                    captureInvoiceBtn.style.display = 'none';
                    startInvoiceCam.innerText = "📹 Retake";
                    if(invoiceStream) { invoiceStream.getTracks().forEach(t => t.stop()); invoiceStream = null; }
                    invoiceCanvas.toBlob(blob => { captureImageBlob = blob; });
                });
            }

            if(processAiBtn) processAiBtn.addEventListener('click', async () => {
                const fileOrBlob = (billInputStore && billInputStore.files[0]) ? billInputStore.files[0] : captureImageBlob;
                if (!fileOrBlob) return alert('Please capture a photo or upload a bill image first.');

                processAiBtn.innerText = "🔍 Extracting...";
                processAiBtn.disabled = true;
                if(aiExtractionResults) { aiExtractionResults.innerText = "AI engine scanning document..."; aiExtractionResults.style.color = "#6366f1"; }

                const emptyBox = document.getElementById("aiScannerEmpty");
                const headerBox = document.getElementById("invoiceHeaderBox");
                if(emptyBox) emptyBox.style.display = 'none';

                try {
                    const { data: { text } } = await window.Tesseract.recognize(fileOrBlob, 'eng', { logger: () => {} });
                    const lines = text.split('\n').map(l => l.trim()).filter(Boolean);
                    
                    // -------------------------------------------------------
                    // INVOICE HEADER EXTRACTION
                    // -------------------------------------------------------
                    const header = {};
                    const dateRgx = /\d{1,2}[-\/]\d{1,2}[-\/]\d{2,4}/;

                    lines.forEach(line => {
                        // Invoice number: grab only the trailing number after "No. :" or "No. -"
                        if(!header.invoice_no) {
                            const m = line.match(/invoice\s*[Nn]o\.?\s*[:\-\s]+(\w+)/i);
                            if(m && /\d/.test(m[1])) header.invoice_no = m[1].trim();
                        }
                        // Invoice date: skip "due date" lines
                        if(!header.invoice_date && /\bdate\b/i.test(line) && !/due\s*date/i.test(line)) {
                            const m = line.match(dateRgx); if(m) header.invoice_date = m[0];
                        }
                        // Due date
                        if(!header.due_date && /due\s*date/i.test(line)) {
                            const m = line.match(dateRgx); if(m) header.due_date = m[0];
                        }
                        // Ref No
                        if(!header.ref_no && /ref\.?\s*no/i.test(line)) {
                            const v = line.split(/[:=]/).pop();
                            if(v && v.trim().length < 20) header.ref_no = v.trim();
                        }
                        // Phone: 10 consecutive digits (Indian mobile)
                        if(!header.seller_phone) {
                            const m = line.match(/\b([6-9]\d{9})\b/);
                            if(m) header.seller_phone = m[1];
                        }
                        // GSTIN: strip ALL whitespace from line before matching to handle OCR gaps
                        if(!header.seller_gstin) {
                            const noSpace = line.replace(/\s/g, '').toUpperCase();
                            const m = noSpace.match(/\d{2}[A-Z]{5}\d{4}[A-Z][A-Z0-9]Z[A-Z0-9]/);
                            if(m) header.seller_gstin = m[0];
                        }
                        // Seller name: pharmacy keyword, short line, no GSTIN/digits block
                        if(!header.seller_name && /pharmacy|medical|chemist|drugs|health|clinic|mart|express|store|hospital/i.test(line)
                            && line.length < 60 && !/GSTIN|\d{6}/i.test(line)) {
                            header.seller_name = line.trim();
                        }
                        // Buyer name
                        if(!header.buyer_name && /\b(DR|MR|MRS|MS)\./i.test(line) && line.length < 80 && !/GSTIN/i.test(line)) {
                            header.buyer_name = line.replace(/buyer.?s?\s*detail/gi,'').trim() || undefined;
                        }
                        // Net Amount: ONLY lines that literally say "Net Amount" — take LAST number on that line
                        if(!header.net_amount && /net\s*amount/i.test(line)) {
                            const nums = line.match(/[\d,]+\.?\d{0,2}/g);
                            if(nums && nums.length > 0) {
                                header.net_amount = '₹' + nums[nums.length - 1].replace(/,/g, '');
                            }
                        }
                    });

                    if(headerBox) {
                        const grid = document.getElementById("invoiceHeaderGrid");
                        if(grid) {
                            const fields = [
                                ['Invoice No', header.invoice_no],
                                ['Invoice Date', header.invoice_date],
                                ['Due Date', header.due_date],
                                ['Ref No', header.ref_no],
                                ['Seller / Pharmacy', header.seller_name],
                                ['Buyer', header.buyer_name],
                                ['GSTIN', header.seller_gstin],
                                ['Phone', header.seller_phone],
                                ['Net Amount', header.net_amount]
                            ].filter(r => r[1]);
                            grid.innerHTML = fields.map(r =>
                                '<div style="padding:4px 0;"><span style="color:#6b7280;font-size:0.76rem;">' + r[0] +
                                '</span><br><strong style="font-size:0.88rem;">' + r[1] + '</strong></div>'
                            ).join('');
                            headerBox.style.display = fields.length ? 'block' : 'none';
                        }
                    }
                    
                    // -------------------------------------------------------
                    // LINE ITEM EXTRACTION — column-aware, bank-section aware
                    // -------------------------------------------------------
                    window.aiStagingBuffer = [];

                    // Hard stop when these footer/bank section keywords appear
                    const bankStopRgx = /bank\s*detail|bank\s*name|state\s*bank|icici|hdfc|sbin|sub\s*total|net\s*amount|taxable\s*amount|total\s*in\s*words|amount\s*in\s*words|two\s*thousand|three\s*thousand|page\s+\d+\s+of|for\s+go\s+gst|total\s*qty|grand\s*total/i;

                    // Line-level skip patterns
                    const skipRgx = /^\s*(sr|no\.?|s\.no|sl\.?\s*no|#)\s*$|^hsn|description|product|name\s*of|cgst|sgst|igst|gst\s*%|taxable|discount|round\s*off|ref\.?\s*no|dl\.?\s*no|subject\s*to|advance\s*pay|terms\s*&|authorized|signature|per\s+[A-Z]|certif|delivery|remarks|original|duplicate|phone\s*:|email\s*:|mob\s*:|e\s*mail/i;

                    let bankSectionStarted = false;
                    lines.forEach(line => {
                        if(bankStopRgx.test(line)) { bankSectionStarted = true; }
                        if(bankSectionStarted) return;
                        if(skipRgx.test(line)) return;

                        const tokens = line.split(/\s+/);

                        // Product name: tokens before first purely numeric token
                        const firstNumIdx = tokens.findIndex(t => /^\d+\.?\d*$/.test(t) && parseFloat(t) > 0);
                        if(firstNumIdx < 0) return; // no numbers = no line item

                        const nameParts = tokens.slice(0, firstNumIdx).filter(t => /^[A-Za-z\/\-]/.test(t) && t.length > 1);
                        if(nameParts.length === 0) return;

                        // Reject bank/account name starts
                        const firstName = nameParts[0].toLowerCase();
                        if(/^(ac|acct|account|ifsc|upi|bank|sbin|icici|hdfc|branch|for|per|dr$|ref|sub|note|page|terms|subject|advance|certif|state|name|address|place|supply)$/.test(firstName)) return;

                        const name = nameParts.join(' ').substring(0, 60).trim();
                        if(!name || name.length < 2) return;

                        // Collect numeric tokens after the name part
                        const numStrs = tokens.slice(firstNumIdx).filter(t => /^\d+\.?\d*$/.test(t) && parseFloat(t) > 0);
                        if(numStrs.length < 2) return;
                        const dataNums = numStrs.map(parseFloat);

                        // HSN: exactly 8 digits
                        const hsnM = line.match(/\b(\d{8})\b/);
                        const hsn = hsnM ? hsnM[1] : '';

                        // Expiry: MM-YYYY or MM/YYYY
                        const expiM = line.match(/\b(\d{1,2}[-\/]20\d{2})\b/);
                        const expiry = expiM ? expiM[1] : '';

                        // Batch: uppercase alphanumeric 4-10 chars
                        const batchM = line.match(/\b([A-Z][A-Z0-9]{3,9})\b/);
                        const batch = batchM && batchM[1] !== hsn ? batchM[1] : '';

                        // GST rate: one of standard GST slabs
                        const gstM = line.match(/\b(5|12|18|28)\b/);

                        // Exclude HSN from data numbers
                        const filteredNums = dataNums.filter(n => String(Math.floor(n)) !== hsn);

                        // Qty: smallest integer in range 1-9999, less than the largest value
                        const maxNum = Math.max(...filteredNums);
                        const qty = filteredNums.find(n => Number.isInteger(n) && n >= 1 && n < 10000 && n < maxNum) || 1;

                        // Amount: largest number (last column = total)
                        const amount = maxNum;

                        // Rate: closest to amount/qty among remaining numbers
                        const expectedRate = qty > 0 ? amount / qty : amount;
                        const remainNums = filteredNums.filter(n => n !== qty && n !== amount);
                        let rate = remainNums.find(n => Math.abs(n - expectedRate) < expectedRate * 0.6);
                        if(!rate && remainNums.length > 0) rate = remainNums[remainNums.length - 1];
                        if(!rate) rate = parseFloat((amount / (qty || 1)).toFixed(2));

                        // MRP: number larger than rate but not qty or amount
                        const mrp = remainNums.find(n => n >= rate && n !== rate) || amount;

                        // Sanity: skip if amount is impossibly large (OCR concat error — e.g., 148498 for 1484.98)
                        if(amount > 100000 && filteredNums.length <= 3) return;

                        window.aiStagingBuffer.push({
                            barcode: 'EXT-' + Math.floor(Math.random() * 90000 + 10000),
                            name, hsn_code: hsn, batch_no: batch, expiry_date: expiry,
                            qty, free_qty: 0, mrp,
                            price: parseFloat(rate.toFixed(2)),
                            selling_price: parseFloat(rate.toFixed(2)),
                            discount_percent: 0,
                            gst_percent: gstM ? gstM[1] : '5',
                            total_amount: parseFloat(amount.toFixed(2)),
                            category: 'AI Extracted'
                        });
                    });

                    window.renderAiReviewTable();
                    
                    if(aiExtractionResults) {
                        aiExtractionResults.innerText = window.aiStagingBuffer.length > 0 
                            ? ('✅ Extracted ' + window.aiStagingBuffer.length + ' line items. Review & edit below, then confirm to save.')
                            : '⚠️ No line items detected. Try a clearer, higher-resolution image with the full invoice visible.';
                        aiExtractionResults.style.color = window.aiStagingBuffer.length > 0 ? '#10b981' : '#f59e0b';
                    }
                    if(billInputStore) billInputStore.value = '';
                    captureImageBlob = null;

                } catch (e) {
                    if(aiExtractionResults) { aiExtractionResults.innerText = '❌ Error: ' + e.message; aiExtractionResults.style.color = '#ef4444'; }
                } finally {
                    if(processAiBtn) { processAiBtn.innerText = '🔍 Extract Bill Data with AI'; processAiBtn.disabled = false; }
                }
            });

            window.renderAiReviewTable = function() {
                const reviewBox = document.getElementById("aiCapturedReviewBox");
                const tbd = document.getElementById("aiReviewTableBody");
                if(!reviewBox || !tbd) return;

                if(!window.aiStagingBuffer || window.aiStagingBuffer.length === 0) {
                    reviewBox.style.display = 'none'; return;
                }

                tbd.innerHTML = window.aiStagingBuffer.map((item, idx) => 
                    '<tr data-idx="' + idx + '">' +
                    '<td><input type="text" class="ai-edit-name" data-idx="' + idx + '" value="' + (item.name||'') + '" style="width:110px;padding:3px;border:1px solid #d1d5db;border-radius:4px;font-size:0.76rem;" /></td>' +
                    '<td><input type="text" class="ai-edit-hsn" data-idx="' + idx + '" value="' + (item.hsn_code||'') + '" style="width:72px;padding:3px;border:1px solid #d1d5db;border-radius:4px;font-size:0.76rem;" /></td>' +
                    '<td><input type="text" class="ai-edit-batch" data-idx="' + idx + '" value="' + (item.batch_no||'') + '" style="width:55px;padding:3px;border:1px solid #d1d5db;border-radius:4px;font-size:0.76rem;" /></td>' +
                    '<td><input type="text" class="ai-edit-expiry" data-idx="' + idx + '" value="' + (item.expiry_date||'') + '" style="width:60px;padding:3px;border:1px solid #d1d5db;border-radius:4px;font-size:0.76rem;" /></td>' +
                    '<td><input type="number" class="ai-edit-qty" data-idx="' + idx + '" value="' + (item.qty||1) + '" style="width:46px;padding:3px;border:1px solid #d1d5db;border-radius:4px;font-size:0.76rem;" /></td>' +
                    '<td><input type="number" class="ai-edit-free" data-idx="' + idx + '" value="' + (item.free_qty||0) + '" style="width:38px;padding:3px;border:1px solid #d1d5db;border-radius:4px;font-size:0.76rem;" /></td>' +
                    '<td><input type="number" class="ai-edit-mrp" data-idx="' + idx + '" value="' + (item.mrp||0) + '" style="width:55px;padding:3px;border:1px solid #d1d5db;border-radius:4px;font-size:0.76rem;" /></td>' +
                    '<td><input type="number" class="ai-edit-rate" data-idx="' + idx + '" value="' + parseFloat(item.price||0).toFixed(2) + '" style="width:55px;padding:3px;border:1px solid #d1d5db;border-radius:4px;font-size:0.76rem;" /></td>' +
                    '<td><input type="number" class="ai-edit-disc" data-idx="' + idx + '" value="' + (item.discount_percent||0) + '" style="width:36px;padding:3px;border:1px solid #d1d5db;border-radius:4px;font-size:0.76rem;" /></td>' +
                    '<td><input type="number" class="ai-edit-gst" data-idx="' + idx + '" value="' + (item.gst_percent||5) + '" style="width:36px;padding:3px;border:1px solid #d1d5db;border-radius:4px;font-size:0.76rem;" /></td>' +
                    '<td style="font-size:0.76rem;">₹' + parseFloat(item.total_amount||0).toFixed(2) + '</td>' +
                    '<td><button type="button" onclick="window.aiStagingBuffer.splice(' + idx + ',1); window.renderAiReviewTable();" style="background:none;border:none;cursor:pointer;color:#ef4444;font-size:1rem;">🗑</button></td>' +
                    '</tr>'
                ).join('');

                reviewBox.style.display = 'block';

                const addRowBtn = document.getElementById("addAiRowBtn");
                if(addRowBtn) addRowBtn.onclick = () => {
                    window.aiStagingBuffer.push({ barcode: 'EXT-' + Math.floor(Math.random()*90000+10000), name:'New Product', hsn_code:'', batch_no:'', expiry_date:'', qty:1, free_qty:0, mrp:0, price:0, selling_price:0, gst_percent:'5', discount_percent:0, total_amount:0, category:'AI Extracted' });
                    window.renderAiReviewTable();
                };
            };

            const confirmAiPushBtn = document.getElementById("confirmAiPushBtn");
            if(confirmAiPushBtn) confirmAiPushBtn.addEventListener("click", () => {
                const rows = document.querySelectorAll("#aiReviewTableBody tr");
                let savedCount = 0;
                rows.forEach((row, idx) => {
                    if(!window.aiStagingBuffer[idx]) return;
                    const barcode = window.aiStagingBuffer[idx].barcode;
                    const name = row.querySelector(".ai-edit-name")?.value || '';
                    if(!name) return;
                    const qty = parseInt(row.querySelector(".ai-edit-qty")?.value) || 1;
                    const rate = parseFloat(row.querySelector(".ai-edit-rate")?.value) || 0;
                    const mrp = parseFloat(row.querySelector(".ai-edit-mrp")?.value) || 0;
                    const gst = row.querySelector(".ai-edit-gst")?.value || '5';
                    const hsn = row.querySelector(".ai-edit-hsn")?.value || '';
                    const batch = row.querySelector(".ai-edit-batch")?.value || '';
                    const expiry = row.querySelector(".ai-edit-expiry")?.value || '';
                    const disc = parseFloat(row.querySelector(".ai-edit-disc")?.value) || 0;

                    const finalItem = { barcode, name, hsn_code:hsn, batch_no:batch, expiry_date:expiry, qty, free_qty: parseInt(row.querySelector(".ai-edit-free")?.value)||0, mrp, price:rate, selling_price:rate, discount_percent:disc, gst_percent:gst, category:'AI Extracted', manufacturer:'', pack_size:'' };

                    const exist = dbData.inventory.find(i => i.barcode === barcode);
                    if(exist) exist.qty += qty; else dbData.inventory.push(finalItem);
                    savedCount++;
                });

                saveData(); updateDashboardUI();
                const rbox = document.getElementById("aiCapturedReviewBox");
                if(rbox) rbox.style.display = 'none';
                const hbox = document.getElementById("invoiceHeaderBox");
                if(hbox) hbox.style.display = 'none';
                const emptyBox = document.getElementById("aiScannerEmpty");
                if(emptyBox) emptyBox.style.display = 'flex';
                if(aiExtractionResults) { aiExtractionResults.innerText = '✅ ' + savedCount + ' products saved to inventory!'; aiExtractionResults.style.color = '#10b981'; }
                window.aiStagingBuffer = [];
                
                const invBtn = document.getElementById("navInventory");
                if(invBtn) invBtn.click();
            });

            const cancelAiPushBtn = document.getElementById("cancelAiPushBtn");
            if(cancelAiPushBtn) cancelAiPushBtn.addEventListener("click", () => {
                window.aiStagingBuffer = [];
                const rbox = document.getElementById("aiCapturedReviewBox");
                if(rbox) rbox.style.display = 'none';
                const hbox = document.getElementById("invoiceHeaderBox");
                if(hbox) hbox.style.display = 'none';
                const emptyBox = document.getElementById("aiScannerEmpty");
                if(emptyBox) emptyBox.style.display = 'flex';
                if(aiExtractionResults) aiExtractionResults.innerText = '';
            });
            // END SMART ENGINE
            // ==========================================
    
            updateDashboardUI();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initApp);
        } else {
            initApp();
        }
    </script>
</MainLayout>
