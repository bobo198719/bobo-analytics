                _expiryFullList.forEach(i => rows.push([i.name, i.batch_no||'', i.expiry_date||'', i.qty, i._days, i._days<0?'EXPIRED':i._days<=30?'CRITICAL':i._days<=90?'WARNING':'SAFE']));
                downloadCSV(rows, 'expiry_report.csv');
            };
            function updateExpirySection() {
                const now = new Date(); now.setHours(0,0,0,0);
                _expiryFullList = dbData.inventory.filter(i => i.expiry_date).map(i => {
                    const parts = i.expiry_date.split(/[-\/]/);
                    let expDate;
                    if(parts.length === 2) expDate = new Date(parseInt(parts[1]), parseInt(parts[0])-1, 1);
                    else expDate = new Date(i.expiry_date);
                    const days = Math.floor((expDate - now) / 86400000);
                    return { ...i, _days: days };
                });
                const ce = document.getElementById('cntExpired'); if(ce) ce.innerText = _expiryFullList.filter(i=>i._days<0).length;
                const c3 = document.getElementById('cnt30'); if(c3) c3.innerText = _expiryFullList.filter(i=>i._days>=0&&i._days<=30).length;
                const c9 = document.getElementById('cnt90'); if(c9) c9.innerText = _expiryFullList.filter(i=>i._days>30&&i._days<=90).length;
