            }
            window.sendCampaign = function(channel) {
                const msgBody = document.getElementById('waMsg')?.value || '';
                if(!msgBody.trim()) return alert('Please enter campaign message.');
                const branded = buildBrandedMessage(msgBody);
                const subject = document.getElementById('waEmailSubject')?.value || ('Offer from ' + (tenantInfo?.name || baseSellerName));
                if(channel === 'whatsapp') {
                    window.open('https://api.whatsapp.com/send?text=' + encodeURIComponent(branded), '_blank');
