                    customer_type: header.buyer_name ? 'Doctor / Retail' : ''
                });
                const roundOff = num((num(header.net_amount?.replace(/[^\d.]/g, ""), subtotal + cgstTotal + sgstTotal + igstTotal) - (subtotal + cgstTotal + sgstTotal + igstTotal)).toFixed(2));
                const netAmount = num(subtotal + cgstTotal + sgstTotal + igstTotal + roundOff);

