                }
            };

            const t = themes[industry] || themes['pharmacy'];

            // Apply Theme Options
            const dbApp = document.getElementById("dashboardApp");
            dbApp.style.setProperty("--brand-main", t.colorMain);
            dbApp.style.setProperty("--brand-dark", t.colorDark);
            document.getElementById("sidebar").style.background = t.colorDark;
            document.getElementById("industryBadge").innerText = `${industry.replace('-', ' ').toUpperCase()} LIVE`;

            document.getElementById("brandIcon").innerText = t.icon;
            document.getElementById("emptyStateIcon").innerText = t.icon;
            document.getElementById("navInventory").innerText = t.invNav;
            if(document.getElementById("navBilling")) document.getElementById("navBilling").innerText = t.posNav;
            if(t.crmNav) document.getElementById("navCrm").innerText = t.crmNav;
            if(t.staffNav) document.getElementById("navStaff").innerText = t.staffNav;
            if(t.aiNav) document.getElementById("navAi").innerText = t.aiNav;
            
            document.getElementById("overviewSubtitle").innerText = t.overviewSub;
            document.getElementById("stat3Label").innerText = t.stat3;
            document.getElementById("emptyStateDesc").innerText = t.emptyDesc;
            document.getElementById("inventoryTitle").innerText = t.invTitle;
            document.getElementById("inventorySubtitle").innerText = t.invSub;
            document.getElementById("addFormTitle").innerText = t.addTitle;
            document.getElementById("invIdLabel").innerText = t.labelId;
            document.getElementById("invNameLabel").innerText = t.labelName;
            document.getElementById("invQtyLabel").innerText = t.labelQty;
            document.getElementById("invPriceLabel").innerText = t.labelPrice;
            document.getElementById("listCol1").innerText = t.listId;
            document.getElementById("listCol3").innerText = t.listQty;
            if(document.getElementById("posTitle")) document.getElementById("posTitle").innerText = t.posTitle;
            if(document.getElementById("posSubtitle")) document.getElementById("posSubtitle").innerText = t.posSub;
            if(document.getElementById("scannerTitle")) document.getElementById("scannerTitle").innerText = t.scanTitle;
            if(document.getElementById("scannerDesc")) document.getElementById("scannerDesc").innerText = t.scanDesc;

            // Populate Category Select
            const catSelect = document.getElementById("invCategory");
            t.categories.forEach(cat => {
                 let opt = document.createElement("option");
                 opt.value = cat;
                 opt.innerText = cat;
                 catSelect.appendChild(opt);
            });

            // Database Sandbox (LocalStorage)
            const dbKey = `bobo_crm_db_${tenantInfo.id}`;
            let dbData = JSON.parse(localStorage.getItem(dbKey) || '{"inventory":[],"bills":[]}');
            const baseSellerName = tenantInfo?.name || tenantInfo?.pharmacy || "Bobo Pharmacy";
            const nowIso = () => new Date().toISOString();
            const num = (value, fallback = 0) => {
                const parsed = parseFloat(value);
                return Number.isFinite(parsed) ? parsed : fallback;
            };
            const intNum = (value, fallback = 0) => {
                const parsed = parseInt(value, 10);
                return Number.isFinite(parsed) ? parsed : fallback;
            };
            const nextId = (rows, field, start = 1) => rows.reduce((max, row) => Math.max(max, intNum(row?.[field], 0)), start - 1) + 1;
            const cleanText = (value) => String(value || "").trim();
            function toDisplayExpiry(value) {
                const raw = cleanText(value);
                if (!raw) return "";
                if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
                if (/^\d{2}[-/]\d{4}$/.test(raw)) return raw.replace("/", "-");
                return raw;
            }
            function normalizeProductRecord(record = {}) {
                const purchasePrice = num(record.purchase_price ?? record.price ?? record.rate ?? 0);
                const sellingPrice = num(record.selling_price ?? record.sell ?? record.mrp ?? purchasePrice);
                const stockQty = intNum(record.stock_qty ?? record.qty ?? record.quantity ?? 0);
                const normalized = {
                    product_id: intNum(record.product_id, nextId(dbData?.inventory || [], "product_id", 5001)),
                    barcode: cleanText(record.barcode) || `EXT-${Math.floor(Math.random() * 90000 + 10000)}`,
                    product_name: cleanText(record.product_name ?? record.name),
                    category: cleanText(record.category) || "Medicine",
                    manufacturer: cleanText(record.manufacturer),
                    hsn_code: cleanText(record.hsn_code),
                    pack_size: cleanText(record.pack_size ?? record.pack),
                    mrp: num(record.mrp ?? sellingPrice),
                    purchase_price: purchasePrice,
                    selling_price: sellingPrice,
                    gst_percent: num(record.gst_percent ?? 5),
                    stock_qty: stockQty,
                    expiry_date: toDisplayExpiry(record.expiry_date),
                    created_at: record.created_at || nowIso()
                };
                normalized.name = normalized.product_name;
                normalized.qty = normalized.stock_qty;
                normalized.price = normalized.purchase_price;
                normalized.pack = normalized.pack_size;
                return normalized;
            }
            function ensureDbShape(raw) {
                const data = raw || {};
                data.inventory = Array.isArray(data.inventory) ? data.inventory.map(normalizeProductRecord) : [];
                data.products = data.inventory;
                data.bills = Array.isArray(data.bills) ? data.bills : [];
                data.invoices = Array.isArray(data.invoices) ? data.invoices : [];
                data.invoice_items = Array.isArray(data.invoice_items) ? data.invoice_items : [];
                data.customers = Array.isArray(data.customers) ? data.customers.map(customer => ({
                    customer_id: intNum(customer.customer_id ?? customer.id, 0),
                    customer_name: cleanText(customer.customer_name ?? customer.name),
                    phone: cleanText(customer.phone),
                    email: cleanText(customer.email),
                    address: cleanText(customer.address),
                    gstin: cleanText(customer.gstin),
                    customer_type: cleanText(customer.customer_type) || "Retail"
                })) : [];
                data.staff = Array.isArray(data.staff) && data.staff.length > 0 ? data.staff : [{
                    staff_id: 1,
                    staff_name: "Owner",
                    role: "Admin",
                    phone: cleanText(tenantInfo?.phone),
                    login_email: cleanText(tenantInfo?.email),
                    password_hash: "",
                    permissions: "full control"
                }];
                data.gst_records = Array.isArray(data.gst_records) ? data.gst_records : [];
                data.ocr_extractions = Array.isArray(data.ocr_extractions) ? data.ocr_extractions : [];
                data.barcode_stock = Array.isArray(data.barcode_stock) ? data.barcode_stock : [];
                data.whatsapp_messages = Array.isArray(data.whatsapp_messages) ? data.whatsapp_messages : [];
                data.offers = Array.isArray(data.offers) ? data.offers : [];
                data.branches = Array.isArray(data.branches) ? data.branches : [];
                return data;
            }
            function syncBarcodeStock(product) {
                const existing = dbData.barcode_stock.find(row => row.barcode === product.barcode);
                const payload = {
                    barcode: product.barcode,
                    product_id: product.product_id,
                    stock: product.stock_qty,
                    value: num(product.purchase_price * product.stock_qty)
                };
                if (existing) Object.assign(existing, payload);
                else dbData.barcode_stock.push(payload);
            }
            function upsertProductRecord(record) {
                const incoming = normalizeProductRecord(record);
                const existing = dbData.inventory.find(item => item.barcode === incoming.barcode || item.product_id === incoming.product_id);
                if (existing) {
                    existing.product_name = incoming.product_name || existing.product_name;
                    existing.name = existing.product_name;
                    existing.category = incoming.category || existing.category;
                    existing.manufacturer = incoming.manufacturer || existing.manufacturer;
                    existing.hsn_code = incoming.hsn_code || existing.hsn_code;
                    existing.pack_size = incoming.pack_size || existing.pack_size;
                    existing.pack = existing.pack_size;
                    existing.mrp = incoming.mrp || existing.mrp;
                    existing.purchase_price = incoming.purchase_price;
                    existing.price = existing.purchase_price;
                    existing.selling_price = incoming.selling_price || existing.selling_price;
                    existing.gst_percent = incoming.gst_percent;
                    existing.stock_qty = incoming.stock_qty;
                    existing.qty = existing.stock_qty;
                    existing.expiry_date = incoming.expiry_date || existing.expiry_date;
                    syncBarcodeStock(existing);
                    return existing;
                }
                dbData.inventory.push(incoming);
                syncBarcodeStock(incoming);
                return incoming;
            }
            function upsertCustomer(record = {}) {
                if (!cleanText(record.customer_name) && !cleanText(record.phone)) return null;
                const existing = dbData.customers.find(item =>
                    (record.phone && item.phone === record.phone) ||
                    (record.customer_name && item.customer_name === record.customer_name)
                );
                if (existing) {
                    existing.customer_name = cleanText(record.customer_name) || existing.customer_name;
                    existing.phone = cleanText(record.phone) || existing.phone;
                    existing.email = cleanText(record.email) || existing.email || "";
                    existing.address = cleanText(record.address) || existing.address || "";
                    existing.gstin = cleanText(record.gstin) || existing.gstin || "";
                    existing.customer_type = cleanText(record.customer_type) || existing.customer_type || "Retail";
                    return existing;
                }
                const customer = {
                    customer_id: nextId(dbData.customers, "customer_id", 101),
                    customer_name: cleanText(record.customer_name),
                    phone: cleanText(record.phone),
                    email: cleanText(record.email),
                    address: cleanText(record.address),
                    gstin: cleanText(record.gstin),
                    customer_type: cleanText(record.customer_type) || "Retail"
                };
                dbData.customers.push(customer);
                return customer;
            }
            function splitTax(taxable, gstPercent) {
                const totalTax = num(taxable) * (num(gstPercent) / 100);
                return {
                    cgst: num(totalTax / 2),
                    sgst: num(totalTax / 2),
                    igst: 0
                };
            }
            dbData = ensureDbShape(dbData);
            function saveData() {
                dbData = ensureDbShape(dbData);
                localStorage.setItem(dbKey, JSON.stringify(dbData));
            }
            window.deleteItem = function(barcode) {
                if(!confirm("Remove this product?")) return;
                dbData.inventory = dbData.inventory.filter(i => i.barcode !== barcode);
                dbData.barcode_stock = dbData.barcode_stock.filter(i => i.barcode !== barcode);
                saveData(); updateDashboardUI();
            };

            // Tab Navigation Logic
            const navBtns = document.querySelectorAll('.nav-btn');
            const sections = document.querySelectorAll('.workspace-section');
            const liveScannerInput = document.getElementById("liveScannerInput");

            navBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const targetId = btn.getAttribute('data-target');
                    if (!targetId) return; // Allow normal navigation for external links

                    e.preventDefault();
                    navBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    
                    sections.forEach(sec => {
                        sec.classList.remove('active');
                        if (sec.id === targetId) sec.classList.add('active');
                    });
                    if (targetId === "sec-inventory") { if(liveScannerInput) liveScannerInput.focus(); }
                    if (targetId === "sec-overview" || targetId === "sec-reports") { scheduleChartRender(); }
                });
            });

            // UI Updater
            function updateDashboardUI() {
                let totalRev = 0;
                dbData.bills.forEach(b => totalRev += b.total);
                document.getElementById("statRevenue").innerText = `₹${totalRev.toFixed(2)}`;
                document.getElementById("statTransactions").innerText = dbData.bills.length;
                document.getElementById("statInventory").innerText = dbData.inventory.length;

                const emptyState = document.getElementById("overviewEmptyState");
                const billsContainer = document.getElementById("recentBillsContainer");
                
                if (dbData.inventory.length > 0 || dbData.bills.length > 0) {
                    emptyState.style.display = "none";
                    if (dbData.bills.length > 0) {
                        billsContainer.style.display = "block";
                        const tableBody = document.getElementById("recentBillsTable");
                        let rowsHtml = "";
                        const recent = [...dbData.bills].reverse().slice(0, 5);
                        recent.forEach(b => {
                            rowsHtml += `<tr>
                                <td>#${b.id.substring(0,8)}</td>
                                <td>${new Date(b.date).toLocaleTimeString()}</td>
                                <td>${b.itemsCount}</td>
                                <td>₹${b.total.toFixed(2)}</td>
                            </tr>`;
                        });
                        tableBody.innerHTML = rowsHtml;
                    }
                } else {
                    emptyState.style.display = "block";
                    billsContainer.style.display = "none";
                }

                // AI Data & Inventory List (Full Schema)
                const invTable = document.getElementById("inventoryTable");
                let catCounts = {};
                let lowStock = 0;
                let expiryAlerts = 0;

                if (!invTable) return;

                if (dbData.inventory.length === 0) {
                    invTable.innerHTML = `<tr><td colspan="12" style="text-align:center; padding:32px; color:#9ca3af;">No products yet. Use the Add Product form or AI Invoice Scanner.</td></tr>`;
                    if(document.getElementById("aiTopCat")) document.getElementById("aiTopCat").innerText = "Not Enough Data";
                } else {
                    let invHtml = "";
                    dbData.inventory.forEach((item, idx) => {
                        const qty = intNum(item.stock_qty ?? item.qty, 0);
                        const mrp = num(item.mrp || item.selling_price || 0);
                        const purchase = num(item.purchase_price ?? item.price ?? 0);
                        const rate = num(item.selling_price || item.price || 0);
                        const isLow = qty < 10;
                        if(isLow) lowStock++;
                        catCounts[item.category] = (catCounts[item.category] || 0) + qty;

                        invHtml += `<tr>
                            <td><code style="background:#f3f4f6;padding:2px 5px;border-radius:4px;font-size:0.75rem;">${item.barcode||'—'}</code></td>
                            <td><strong>${item.product_name||item.name||'—'}</strong></td>
                            <td><small style="background:#ede9fe;color:#7c3aed;padding:2px 6px;border-radius:4px;font-size:0.75rem;">${item.category||'General'}</small></td>
                            <td style="font-size:0.82rem;">${item.manufacturer||'—'}</td>
                            <td style="font-size:0.82rem;">${item.hsn_code||'—'}</td>
                            <td style="font-size:0.82rem;">${item.pack_size||'—'}</td>
