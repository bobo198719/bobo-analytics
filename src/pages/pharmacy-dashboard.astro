---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Pharmacy Dashboard">

<div class="dashboard">

<div class="sidebar">

<h2>Bobo Analytics</h2>

<a href="/pharmacy-dashboard">Dashboard</a>
<a href="/inventory">Inventory</a>
<a href="#">Orders</a>
<a href="#">Sales Analytics</a>
<a href="#">Customers</a>
<a href="#">Reports</a>
<a href="#">Settings</a>

</div>

<div class="content">

<h1>Pharmacy Dashboard</h1>

<div class="stats">

<div class="card">
<h3>Total Medicines</h3>
<p>128</p>
</div>

<div class="card">
<h3>Total Orders</h3>
<p>2458</p>
</div>

<div class="card">
<h3>Customers</h3>
<p>2102</p>
</div>

<div class="card">
<h3>Revenue</h3>
<p>$12,400</p>
</div>

</div>

<div class="analytics">

<div class="chart">

<h2>Sales Analytics</h2>

<canvas id="salesChart"></canvas>

</div>

<div class="top-selling">

<h2>Top Selling Medicines</h2>

<ul>

<li>Paracetamol</li>
<li>Omeprazole</li>
<li>Metformin</li>
<li>Atorvastatin</li>

</ul>

</div>

</div>

<div class="orders">

<h2>Latest Orders</h2>

<table>

<thead>
<tr>
<th>Order ID</th>
<th>Medicine</th>
<th>Price</th>
<th>Status</th>
</tr>
</thead>

<tbody>

<tr>
<td>#ORD121</td>
<td>Metformin</td>
<td>$10.50</td>
<td>Delivered</td>
</tr>

<tr>
<td>#ORD122</td>
<td>Omeprazole</td>
<td>$15.05</td>
<td>Delivered</td>
</tr>

<tr>
<td>#ORD123</td>
<td>Atorvastatin</td>
<td>$13.01</td>
<td>Pending</td>
</tr>

</tbody>

</table>

</div>

</div>

</div>

<style>

.dashboard{
display:flex;
min-height:100vh;
background:#0a0a0a;
color:white;
}

.sidebar{
width:220px;
background:#111;
padding:20px;
display:flex;
flex-direction:column;
gap:15px;
}

.sidebar h2{
color:#00ff88;
}

.sidebar a{
color:white;
text-decoration:none;
padding:10px;
border-radius:6px;
}

.sidebar a:hover{
background:#1a1a1a;
}

.content{
flex:1;
padding:40px;
}

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-bottom:40px;
}

.card{
background:#111;
padding:25px;
border-radius:8px;
border:1px solid #222;
}

.analytics{
display:grid;
grid-template-columns:2fr 1fr;
gap:20px;
margin-bottom:40px;
}

.chart{
background:#111;
padding:20px;
border-radius:8px;
}

.top-selling{
background:#111;
padding:20px;
border-radius:8px;
}

.orders table{
width:100%;
border-collapse:collapse;
background:#111;
}

.orders th,.orders td{
padding:12px;
border-bottom:1px solid #333;
}

</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const ctx=document.getElementById("salesChart");

new Chart(ctx,{
type:"bar",
data:{
labels:["Jan","Feb","Mar","Apr","May","Jun"],
datasets:[{
label:"Sales",
data:[120,190,300,250,220,400]
}]
}
});

</script>

</MainLayout>
