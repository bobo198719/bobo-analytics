---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Pharmacy Dashboard">

<section class="dashboard">

<h1>Pharmacy Dashboard</h1>

<div class="stats">

<div class="card">
<h2>₹52,340</h2>
<p>Today's Sales</p>
</div>

<div class="card">
<h2>120</h2>
<p>Medicines in Stock</p>
</div>

<div class="card">
<h2>8</h2>
<p>Expiry Alerts</p>
</div>

<div class="card">
<h2>34</h2>
<p>Invoices Generated</p>
</div>

</div>

<div class="analytics">

<h2>Inventory Insights</h2>

<div class="grid">

<div class="box">
<h3>Top Selling Medicine</h3>
<p>Paracetamol 650mg</p>
</div>

<div class="box">
<h3>Low Stock</h3>
<p>Amoxicillin Capsules</p>
</div>

<div class="box">
<h3>Upcoming Expiry</h3>
<p>Cetirizine Tablets</p>
</div>

<div class="box">
<h3>Monthly Revenue</h3>
<p>₹3,45,000</p>
</div>

</div>

</div>

</section>

</MainLayout>

<style>

.dashboard{
padding:100px 20px;
background:#0b0b0b;
color:white;
min-height:80vh;
}

.dashboard h1{
text-align:center;
margin-bottom:40px;
}

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-bottom:60px;
}

.card{
background:#151515;
padding:30px;
border-radius:12px;
text-align:center;

box-shadow:
0 0 10px rgba(0,255,150,0.3),
0 0 30px rgba(0,255,150,0.2);
}

.analytics{
max-width:1000px;
margin:auto;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-top:20px;
}

.box{
background:#1c1c1c;
padding:25px;
border-radius:10px;
}

</style>
