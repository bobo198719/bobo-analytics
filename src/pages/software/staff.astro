---
// Restaurant Management Software - Staff Management
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Staff Management - Restaurant OS | Bobo Analytics</title>
  <link rel="icon" href="/favicon.png" type="image/png">
  <meta name="theme-color" content="#0a0a0a">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0a0a0a; color: #fafafa; min-height: 100vh; }
    
    .app-layout { display: flex; min-height: 100vh; }
    
    /* Sidebar */
    .sidebar { width: 260px; background: #0f0f0f; border-right: 1px solid #1f1f1f; padding: 24px 16px; display: flex; flex-direction: column; position: fixed; height: 100vh; }
    .logo { display: flex; align-items: center; gap: 12px; padding: 0 8px; margin-bottom: 32px; }
    .logo-icon { width: 40px; height: 40px; background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius: 10px; display: flex; align-items: center; justify-content: center; }
    .logo-icon svg { width: 22px; height: 22px; color: white; }
    .logo-text { font-size: 18px; font-weight: 700; }
    .logo-sub { font-size: 11px; color: #71717a; }
    
    .nav-section { margin-bottom: 24px; }
    .nav-label { font-size: 11px; color: #52525b; text-transform: uppercase; letter-spacing: 0.5px; padding: 0 12px; margin-bottom: 8px; }
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 8px; color: #a1a1aa; text-decoration: none; font-size: 14px; margin-bottom: 4px; transition: all 0.2s; }
    .nav-item:hover { background: #1f1f1f; color: #fafafa; }
    .nav-item.active { background: rgba(99, 102, 241, 0.1); color: #a5b4fc; }
    .nav-item svg { width: 20px; height: 20px; }
    
    .sidebar-footer { margin-top: auto; padding-top: 16px; border-top: 1px solid #1f1f1f; }
    .user-info { display: flex; align-items: center; gap: 12px; padding: 12px; }
    .user-avatar { width: 36px; height: 36px; background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; }
    .user-details { flex: 1; }
    .user-name { font-size: 14px; font-weight: 600; }
    .user-role { font-size: 12px; color: #71717a; }
    
    /* Main Content */
    .main-content { flex: 1; margin-left: 260px; padding: 32px; }
    
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; }
    .page-title { font-size: 28px; font-weight: 700; }
    .header-actions { display: flex; gap: 12px; }
    .btn { display: flex; align-items: center; gap: 8px; padding: 12px 20px; border-radius: 8px; border: none; font-size: 14px; font-weight: 500; cursor: pointer; transition: all 0.2s; text-decoration: none; }
    .btn-secondary { background: #262626; color: #fafafa; }
    .btn-secondary:hover { background: #3f3f46; }
    .btn-primary { background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; }
    .btn-primary:hover { opacity: 0.9; }
    
    /* Stats */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card { background: #171717; border: 1px solid #262626; border-radius: 12px; padding: 20px; }
    .stat-value { font-size: 32px; font-weight: 700; margin-bottom: 4px; }
    .stat-label { font-size: 13px; color: #71717a; }
    .stat-change { font-size: 12px; margin-top: 8px; }
    .stat-change.positive { color: #22c55e; }
    .stat-change.negative { color: #ef4444; }
    
    /* Staff Grid */
    .staff-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
    
    .staff-card { background: #171717; border: 1px solid #262626; border-radius: 12px; overflow: hidden; transition: all 0.3s; }
    .staff-card:hover { border-color: #3f3f46; transform: translateY(-2px); }
    
    .staff-header { padding: 20px; display: flex; gap: 16px; align-items: center; border-bottom: 1px solid #1f1f1f; }
    .staff-avatar { width: 56px; height: 56px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 20px; color: white; }
    .staff-avatar.chef { background: linear-gradient(135deg, #f97316, #ea580c); }
    .staff-avatar.server { background: linear-gradient(135deg, #6366f1, #8b5cf6); }
    .staff-avatar.host { background: linear-gradient(135deg, #22c55e, #16a34a); }
    .staff-avatar.manager { background: linear-gradient(135deg, #3b82f6, #2563eb); }
    .staff-avatar.bartender { background: linear-gradient(135deg, #ec4899, #db2777); }
    
    .staff-info h3 { font-size: 16px; font-weight: 600; margin-bottom: 4px; }
    .staff-role { font-size: 13px; color: #a1a1aa; }
    .staff-status { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 20px; font-size: 12px; margin-top: 6px; }
    .staff-status.online { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
    .staff-status.offline { background: rgba(113, 113, 122, 0.1); color: #71717a; }
    .staff-status.break { background: rgba(249, 115, 22, 0.1); color: #f97316; }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; }
    .status-dot.online { background: #22c55e; }
    .status-dot.offline { background: #71717a; }
    .status-dot.break { background: #f97316; }
    
    .staff-body { padding: 20px; }
    .staff-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 16px; }
    .staff-stat { text-align: center; }
    .staff-stat-value { font-size: 18px; font-weight: 700; }
    .staff-stat-label { font-size: 11px; color: #71717a; }
    
    .staff-schedule { background: #0f0f0f; border-radius: 8px; padding: 12px; }
    .schedule-label { font-size: 11px; color: #71717a; margin-bottom: 6px; }
    .schedule-time { font-size: 14px; font-weight: 600; }
    
    .staff-actions { padding: 16px 20px; border-top: 1px solid #1f1f1f; display: flex; gap: 8px; }
    .staff-btn { flex: 1; padding: 10px; border-radius: 6px; border: none; font-size: 13px; font-weight: 500; cursor: pointer; transition: all 0.2s; }
    .staff-btn.view { background: #262626; color: #a1a1aa; }
    .staff-btn.view:hover { background: #3f3f46; color: #fafafa; }
    .staff-btn.message { background: rgba(99, 102, 241, 0.1); color: #a5b4fc; border: 1px solid rgba(99, 102, 241, 0.3); }
    .staff-btn.message:hover { background: rgba(99, 102, 241, 0.2); }
    
    /* Schedule Table */
    .schedule-section { margin-top: 40px; }
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .section-title { font-size: 20px; font-weight: 600; }
    
    .schedule-table { width: 100%; background: #171717; border: 1px solid #262626; border-radius: 12px; overflow: hidden; }
    .schedule-table th, .schedule-table td { padding: 14px 16px; text-align: left; border-bottom: 1px solid #1f1f1f; }
    .schedule-table th { background: #0f0f0f; font-size: 12px; font-weight: 600; color: #71717a; text-transform: uppercase; }
    .schedule-table tr:last-child td { border-bottom: none; }
    .schedule-table tr:hover td { background: rgba(255,255,255,0.02); }
    
    .shift-badge { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 500; }
    .shift-badge.morning { background: rgba(249, 115, 22, 0.1); color: #f97316; }
    .shift-badge.afternoon { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
    .shift-badge.evening { background: rgba(139, 92, 246, 0.1); color: #a78bfa; }
    .shift-badge.off { background: rgba(113, 113, 122, 0.1); color: #71717a; }
    
    @media (max-width: 1024px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .sidebar { display: none; }
      .main-content { margin-left: 0; }
      .stats-grid { grid-template-columns: 1fr; }
      .staff-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
