---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
---

<BakersOSLayout title="Recipe Costing | Baker OS">
    <div class="header-flex" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
        <div>
            <h1>Recipe Costing & AI Pricing</h1>
            <p style="color: var(--text-muted);">Calculate costs, margins, and get AI-suggested selling prices.</p>
        </div>
        <a href="/bakers-os/portfolio" class="hb-btn secondary" style="padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; border: 1px solid var(--border); background: rgba(255,255,255,0.05); color: white; text-decoration: none;">View Portfolio</a>
    </div>

    <div class="costing-grid" style="display: grid; grid-template-columns: 2fr 1fr; gap: 32px;">
        <div class="glass-card" style="padding: 32px;">
            <!-- SEARCH SECTION -->
            <div class="search-box" style="margin-bottom: 24px; position: relative;">
                <label style="display: block; font-size: 0.75rem; color: var(--primary); margin-bottom: 8px; text-transform: uppercase; font-weight: 800;">Recipe Search & Presets</label>
                <div style="display: flex; gap: 12px;">
                    <input type="text" id="searchRecipe" placeholder="Search cake presets (e.g. Black Forest)" oninput="showSuggestions()" style="flex: 1; background: rgba(99, 102, 241, 0.1); border: 1px solid var(--primary); padding: 14px; border-radius: 12px; color: white; font-size: 1rem; outline: none;" />
                </div>
                <div id="suggestions" style="position: absolute; top: 100%; left: 0; right: 0; background: #1e293b; border: 1px solid var(--border); border-radius: 12px; margin-top: 4px; z-index: 100; max-height: 200px; overflow-y: auto; display: none; box-shadow: 0 10px 25px rgba(0,0,0,0.5);"></div>
            </div>

            <div class="f-group" style="margin-bottom: 24px;">
                <label style="display: block; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase; font-weight: 800;">Recipe Name</label>
                <input type="text" id="recipeName" placeholder="Enter recipe name..." style="width: 100%; background: rgba(255,255,255,0.03); border: 1px solid var(--border); padding: 14px; border-radius: 12px; color: white; font-size: 1.1rem;" />
            </div>

            <div class="ingredients-section">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                    <h3 style="font-size: 1rem; color: var(--primary);">Ingredients</h3>
                    <button onclick="addIngredient()" style="background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--border); padding: 6px 12px; border-radius: 8px; cursor: pointer; font-weight: 700; font-size: 0.8rem;">+ Add Item</button>
                </div>
                
                <div class="ingredients-header" style="display: grid; grid-template-columns: 2fr 1fr 1fr 40px; gap: 12px; margin-bottom: 8px; padding: 0 4px;">
                    <span style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; font-weight: 800;">Ingredient Name</span>
                    <span style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; font-weight: 800;">Grams (qty)</span>
                    <span style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; font-weight: 800;">Price (per kg)</span>
                    <span></span>
                </div>
                
                <div id="ingredients" style="display: flex; flex-direction: column; gap: 12px;">
                    <!-- Ingredients rendered here -->
                </div>
            </div>

            <div class="overhead-section" style="margin-top: 32px; padding-top: 32px; border-top: 1px solid var(--border); display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="f-group">
                    <label style="display: block; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase;">Packaging Cost (₹)</label>
                    <input type="number" id="packaging" value="20" oninput="calculate()" style="width: 100%; background: rgba(0,0,0,0.2); border: 1px solid var(--border); padding: 12px; border-radius: 10px; color: white;" />
                </div>
                <div class="f-group">
                    <label style="display: block; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase;">Labour/Utility (₹)</label>
                    <input type="number" id="labour" value="50" oninput="calculate()" style="width: 100%; background: rgba(0,0,0,0.2); border: 1px solid var(--border); padding: 12px; border-radius: 10px; color: white;" />
                </div>
            </div>
        </div>

        <div class="results-sidebar">
            <div class="glass-card" style="padding: 32px; position: sticky; top: 20px; display: flex; flex-direction: column; gap: 24px;">
                <div id="alert" style="padding: 12px; border-radius: 8px; text-align: center; font-weight: 700; font-size: 0.85rem; background: rgba(255,255,255,0.03);">
                    Start calculating...
                </div>

                <div class="stat">
                    <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Total Production Cost</span>
                    <h2 style="font-size: 2.5rem; font-family: 'Outfit';">₹<span id="productionCost">0</span></h2>
                </div>

                <div class="stat">
                    <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Suggested Selling Price</span>
                    <h2 style="font-size: 2rem; color: var(--primary); font-family: 'Outfit';">₹<span id="suggestedPrice">0</span></h2>
                </div>

                <div class="mini-stats" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                    <div style="background: rgba(255,255,255,0.03); padding: 16px; border-radius: 12px;">
                        <span style="display: block; font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase;">Net Profit</span>
                        <strong id="profit" style="font-size: 1.1rem; color: #10b981;">₹0</strong>
                    </div>
                    <div style="background: rgba(255,255,255,0.03); padding: 16px; border-radius: 12px;">
                        <span style="display: block; font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase;">Margin</span>
                        <strong id="margin" style="font-size: 1.1rem; color: #10b981;">0%</strong>
                    </div>
                </div>

                <button onclick="saveRecipe()" id="saveBtn" style="width: 100%; background: var(--primary); color: white; border: none; padding: 16px; border-radius: 12px; font-weight: 800; cursor: pointer; font-size: 1rem; margin-top: 12px;">Save to Portfolio</button>
            </div>
        </div>
    </div>


    <style>
        @keyframes spin { to { transform: rotate(360deg); } }
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .suggestion-item:hover { background: rgba(99, 102, 241, 0.1) !important; color: var(--primary); }
    </style>

    <script is:inline>
        let ingredients = [];


        const recipesDB = [
            "Black Forest Cake",
            "Belgium Chocolate Truffle",
            "Biscoff Cheesecake",
            "Red Velvet Cake",
            "Pineapple Fresh Cream",
            "Butterscotch Delight",
            "Mango Seasonal Special",
            "Vanilla Classic Bean"
        ];

        // AI SUGGESTIONS ENGINE
        function showSuggestions() {
            const input = document.getElementById("searchRecipe").value.toLowerCase();
            const box = document.getElementById("suggestions");
            
            if (!input) {
                box.style.display = "none";
                return;
            }

            const matches = recipesDB.filter(item => item.toLowerCase().includes(input));
            
            if (matches.length > 0) {
                box.innerHTML = matches.map(item => `
                    <div class="suggestion-item" onclick="selectRecipe('${item}')"
                        style="cursor:pointer; padding:12px; border-bottom:1px solid rgba(255,255,255,0.05); color:white; font-size:0.9rem; transition:0.2s;">
                        ${item}
                    </div>
                `).join('');
                box.style.display = "block";
            } else {
                box.style.display = "none";
            }
        }

        function selectRecipe(name) {
            document.getElementById("searchRecipe").value = name;
            document.getElementById("recipeName").value = name;
            document.getElementById("suggestions").style.display = "none";
            // Manual Preset Generation based on name
            generateRecipeFromPreset(name);
        }

        // PRESET RECIPE GENERATOR
        function generateRecipeFromPreset(name) {
            name = name.toLowerCase();
            const kg = 1; // Default to 1kg for presets
            const type = "eggless"; // Default to eggless for presets

            // CLEAR EXISTING
            ingredients = [];

            // BASE RECIPES (1KG STANDARDS)
            let baseRecipe = [];

            if (name.includes("black forest")) {
                baseRecipe = [
                    { name: "Chocolate Flour Mix", qty: 250, cost: 80 },
                    { name: "Whipped Cream", qty: 400, cost: 240 },
                    { name: "Cherry Filling", qty: 100, cost: 450 },
                    { name: "Chocolate Flakes", qty: 50, cost: 600 },
                    { name: "Sugar Syrup", qty: 100, cost: 40 }
                ];
            } else if (name.includes("truffle")) {
                baseRecipe = [
                    { name: "Dark Chocolate (55%)", qty: 300, cost: 950 },
                    { name: "Fresh Cream", qty: 200, cost: 260 },
                    { name: "Chocolate Spone Mix", qty: 300, cost: 90 },
                    { name: "Unsalted Butter", qty: 50, cost: 650 }
                ];
            } else if (name.includes("red velvet")) {
                baseRecipe = [
                    { name: "Red Velvet Base", qty: 350, cost: 120 },
                    { name: "Cream Cheese", qty: 150, cost: 1400 },
                    { name: "Refined Oil", qty: 100, cost: 180 },
                    { name: "Whipped Topping", qty: 300, cost: 220 }
                ];
            } else if (name.includes("biscoff")) {
                baseRecipe = [
                    { name: "Biscoff Spread", qty: 200, cost: 1100 },
                    { name: "Biscoff Biscuits", qty: 150, cost: 900 },
                    { name: "Cream Cheese", qty: 300, cost: 1400 },
                    { name: "Sour Cream", qty: 100, cost: 380 }
                ];
            } else {
                // DEFAULT GENERIC CAKE
                baseRecipe = [
                    { name: "Cake Flour", qty: 300, cost: 60 },
                    { name: "Granulated Sugar", qty: 200, cost: 45 },
                    { name: "Whipped Cream", qty: 300, cost: 240 },
                    { name: "Flavour Essence", qty: 10, cost: 800 }
                ];
            }

            // DIETARY LOGIC (EGG vs EGGLESS)
            if (type === "egg") {
                baseRecipe.push({ name: "Fresh Eggs", qty: (4 * 50), cost: 140 }); // ~4 eggs, 200g
            } else {
                baseRecipe.push({ name: "Condensed Milk / Curd", qty: 200, cost: 260 });
                baseRecipe.push({ name: "Baking Powder/Soda", qty: 10, cost: 30 });
            }

            // SCALE BY KG
            baseRecipe.forEach(item => {
                ingredients.push({
                    name: item.name,
                    qty: Math.round(item.qty * kg),
                    cost: item.cost
                });
            });

            // UPDATE UI & CALCULATE
            render();
            calculate();

            // SUCCESS FEEDBACK
            const alertBox = document.getElementById("alert");
            alertBox.innerText = "✨ Preset Loaded";
            alertBox.style.color = "var(--primary)";
            alertBox.style.backgroundColor = "rgba(99, 102, 241, 0.1)";

            // Update recipe name to include kg and type
            document.getElementById("recipeName").value = 
                document.getElementById("searchRecipe").value + " (1kg, EGGLESS)";
        }

        // ADD INGREDIENT
        function addIngredient() {
            ingredients.push({ name: "", qty: 0, cost: 0 });
            render();
        }

        // REMOVE INGREDIENT
        function removeIngredient(i) {
            ingredients.splice(i, 1);
            render();
            calculate();
        }

        // RENDER UI
        function render() {
            const container = document.getElementById("ingredients");
            container.innerHTML = "";

            if (ingredients.length === 0) {
                container.innerHTML = `<div style="text-align:center; padding:32px; color:var(--text-muted); font-size:0.9rem; border:1px dashed var(--border); border-radius:12px;">
                    Search for a cake above or manually add items to start.
                </div>`;
                return;
            }

            ingredients.forEach((item, i) => {
                const div = document.createElement('div');
                div.className = "row";
                div.style = "display: grid; grid-template-columns: 2fr 1fr 1fr 40px; gap: 12px; align-items: center; animation: slideDown 0.2s ease;";
                div.innerHTML = `
                    <input type="text" placeholder="Ingredient" value="${item.name}" 
                        oninput="ingredients[${i}].name=this.value" 
                        style="background:rgba(255,255,255,0.05); border:1px solid var(--border); padding:10px; border-radius:8px; color:white; width:100%"/>
                    
                    <input type="number" placeholder="Qty (g)" value="${item.qty}"
                        oninput="ingredients[${i}].qty=this.value; calculate()"
                        style="background:rgba(255,255,255,0.05); border:1px solid var(--border); padding:10px; border-radius:8px; color:white; width:100%"/>
                    
                    <input type="number" placeholder="Cost per kg" value="${item.cost}"
                        oninput="ingredients[${i}].cost=this.value; calculate()"
                        style="background:rgba(255,255,255,0.05); border:1px solid var(--border); padding:10px; border-radius:8px; color:white; width:100%"/>
                    
                    <button onclick="removeIngredient(${i})" style="background:none; border:none; color:#ef4444; cursor:pointer; font-size:1.2rem; transition:0.2s;">×</button>
                `;
                container.appendChild(div);
            });
        }

        // MAIN CALCULATION (REAL AI ENGINE)
        function calculate() {
            let total = 0;

            // COST CALCULATION
            ingredients.forEach(i => {
                const qty = Number(i.qty || 0);
                const cost = Number(i.cost || 0);
                // convert kg → gram logic
                total += (qty * cost) / 1000;
            });

            // ADD OVERHEADS
            const packaging = Number(document.getElementById("packaging").value || 0);
            const labour = Number(document.getElementById("labour").value || 0);

            total += packaging + labour;

            // DISPLAY COST
            document.getElementById("productionCost").innerText = Math.round(total);

            // RUN AI ENGINE
            runAI(total);
        }

        // SMART PRICING ENGINE
        function runAI(cost) {
            if (cost <= 0) return;
            let margin;
            // AI logic (dynamic)
            if (cost < 200) {
                margin = 1.2; // 120%
            } else if (cost < 500) {
                margin = 0.9;
            } else if (cost < 1000) {
                margin = 0.7;
            } else {
                margin = 0.6;
            }

            const price = cost + (cost * margin);

            // UPDATE UI
            document.getElementById("suggestedPrice").innerText = Math.round(price);
            document.getElementById("profit").innerText = Math.round(price - cost);

            const marginPercent = cost > 0 ? ((price - cost) / cost) * 100 : 0;
            document.getElementById("margin").innerText = Math.round(marginPercent) + "%";

            // STATUS BADGE
            const alertBox = document.getElementById("alert");
            if (marginPercent < 20) {
                alertBox.innerText = "⚠️ Low Profit";
                alertBox.style.color = "#ef4444";
                alertBox.style.backgroundColor = "rgba(239, 68, 68, 0.1)";
            } else if (marginPercent < 50) {
                alertBox.innerText = "👍 Normal Profit";
                alertBox.style.color = "#fb923c";
                alertBox.style.backgroundColor = "rgba(251, 146, 60, 0.1)";
            } else {
                alertBox.innerText = "💎 Excellent Profit";
                alertBox.style.color = "#10b981";
                alertBox.style.backgroundColor = "rgba(16, 185, 129, 0.1)";
            }
        }

        // SAVE FUNCTION
        async function saveRecipe() {
            try {
                const payload = {
                    recipeName: document.getElementById("recipeName").value,
                    ingredients,
                    productionCost: Number(document.getElementById("productionCost").innerText),
                    sellingPrice: Number(document.getElementById("suggestedPrice").innerText),
                    profit: Number(document.getElementById("profit").innerText),
                    margin: Number(document.getElementById("margin").innerText.replace('%', ''))
                };

                // VALIDATION
                if (!payload.recipeName) {
                    alert("Enter or Generate recipe name first");
                    return;
                }
                if (ingredients.length === 0) {
                    alert("Add ingredients first");
                    return;
                }

                const saveBtn = document.getElementById("saveBtn");
                saveBtn.innerText = "Saving...";
                saveBtn.disabled = true;

                const res = await fetch("/api/recipes/save", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                const data = await res.json();

                if (data.success) {
                    alert("✅ Recipe Saved to Portfolio");
                    // RESET FORM
                    ingredients = [];
                    document.getElementById("recipeName").value = "";
                    document.getElementById("searchRecipe").value = "";
                    document.getElementById("configBox").style.display = "none";
                    render();
                    calculate();
                } else {
                    alert("❌ Save Failed");
                }
            } catch (err) {
                console.log(err);
                alert("🚨 Server Error");
            } finally {
                const saveBtn = document.getElementById("saveBtn");
                saveBtn.innerText = "Save to Portfolio";
                saveBtn.disabled = false;
            }
        }

        render();
        calculate();
    </script>
</BakersOSLayout>
