---
import MainLayout from "../../layouts/MainLayout.astro";

// Server-side detection of subdomain
const host = Astro.url.host;
const isSubdomain = host.split('.').length > 2 && !host.includes('localhost') && !host.includes('vercel.app');
const subdomain = isSubdomain ? host.split('.')[0] : null;

// Format subdomain for display (e.g. "triviabaker" -> "Trivia Baker")
const dynamicName = subdomain ? subdomain.charAt(0).toUpperCase() + subdomain.slice(1).replace(/-/g, ' ') : "Artisanal Bakes";
---

<MainLayout title={`${dynamicName} | Home Bakery & Custom Cakes`} hideNav={true}>
    <div class="website-container">
        <!-- NAVIGATION -->
        <nav class="glass-nav">
            <div class="nav-content">
                <div class="logo">🧁 {dynamicName}</div>
                <div class="nav-links">
                    <a href="#about">Our Story</a>
                    <a href="#menu">Menu</a>
                    <a href="#gallery">Gallery</a>
                    <a href={`/bakers-os/order-online`} class="btn-order-nav">Order Now</a>
                </div>
            </div>
        </nav>

        <!-- HERO SECTION -->
        <section class="hero">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <span class="badge">Freshly Baked Daily</span>
                <h1>Crafting <span class="accent">Sweet Memories</span> with Every Bite</h1>
                <p>Artisanal cakes, handcrafted pastries, and custom treats made with love and the finest ingredients.</p>
                <div class="hero-cta">
                    <a href="/bakers-os/order-online" class="btn-primary-website">Browse Menu & Order</a>
                    <a href="#about" class="btn-secondary-website">Our Story</a>
                </div>
            </div>
            <div class="scroll-indicator">↓</div>
        </section>

        <!-- STATS / WHY US -->
        <section class="why-us">
            <div class="stat-card">
                <h3>100%</h3>
                <p>Natural Ingredients</p>
            </div>
            <div class="stat-card">
                <h3>250+</h3>
                <p>Cakes Delivered</p>
            </div>
            <div class="stat-card">
                <h3>4.9/5</h3>
                <p>Customer Rating</p>
            </div>
        </section>

        <!-- GALLERY PREVIEW -->
        <section id="gallery" class="gallery-section">
            <div class="section-header">
                <h2>Our Creations</h2>
                <p>A glimpse into our kitchen's most beloved bakes.</p>
            </div>
            <div class="gallery-grid">
                <div class="g-item" style="background-image: url('https://images.unsplash.com/photo-1578985545062-69928b1d9587?auto=format&fit=crop&w=800&q=80')">
                    <div class="g-overlay"><span>Wedding Cakes</span></div>
                </div>
                <div class="g-item" style="background-image: url('https://images.unsplash.com/photo-1488477181946-6428a0291777?auto=format&fit=crop&w=800&q=80')">
                    <div class="g-overlay"><span>Artisanal Pastries</span></div>
                </div>
                <div class="g-item" style="background-image: url('https://images.unsplash.com/photo-1550617931-e17a7b70dce2?auto=format&fit=crop&w=800&q=80')">
                    <div class="g-overlay"><span>Custom Cupcakes</span></div>
                </div>
                <div class="g-item" style="background-image: url('https://images.unsplash.com/photo-1519340333755-5672c7ec9aa2?auto=format&fit=crop&w=800&q=80')">
                    <div class="g-overlay"><span>Celebration Treats</span></div>
                </div>
            </div>
        </section>

        <!-- ABOUT SECTION -->
        <section id="about" class="about-section">
            <div class="about-grid">
                <div class="about-image">
                    <img src="https://images.unsplash.com/photo-1556910103-1c02745aae4d?auto=format&fit=crop&w=800&q=80" alt="Baking with passion" />
                </div>
                <div class="about-text">
                    <span class="sub">Passion for Excellence</span>
                    <h2>Meet Your Baker</h2>
                    <p>What started as a childhood hobby in a small kitchen has grown into a mission to bring joy to our community through the art of baking.</p>
                    <p>We believe that every celebration deserves a centerpiece that tastes as good as it looks. That's why we meticulously source our butter, chocolate, and seasonal fruits to ensure excellence in every crumb.</p>
                    <a href="/bakers-os/order-online" class="btn-text">View Price List &rarr;</a>
                </div>
            </div>
        </section>

        <!-- FOOTER -->
        <footer class="website-footer">
            <div class="footer-top">
                <div class="f-brand">
                    <div class="logo">🧁 {dynamicName}</div>
                    <p>Making life sweeter, one cake at a time.</p>
                </div>
                <div class="f-contact">
                    <h4>Contact Us</h4>
                    <p>📍 Available for collection & delivery</p>
                    <p>📞 Order via WhatsApp: +91 73870 21958</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 {dynamicName}. Powered by Bobo Platform.</p>
            </div>
        </footer>
    </div>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const webData = JSON.parse(localStorage.getItem('bobo_website_data'));
            const products = JSON.parse(localStorage.getItem('bobo_products') || "[]");

            if (webData) {
                // Update Hero
                if (webData.heroTitle) document.querySelector('.hero-content h1').innerHTML = webData.heroTitle.replace(/\{(.*?)\}/g, '<span class="accent">$1</span>');
                if (webData.heroSubtitle) document.querySelector('.hero-content p').innerText = webData.heroSubtitle;
                if (webData.heroBg) document.querySelector('.hero').style.backgroundImage = `url('${webData.heroBg}')`;

                // Update About
                if (webData.aboutTitle) document.querySelector('.about-text h2').innerText = webData.aboutTitle;
                if (webData.aboutP1) document.querySelector('.about-text p').innerText = webData.aboutP1;
                if (webData.aboutImg) document.querySelector('.about-image img').src = webData.aboutImg;

                // Update Footer/Contact
                if (webData.contactAddress) document.querySelector('.f-contact p:first-of-type').innerText = `📍 ${webData.contactAddress}`;
                if (webData.contactPhone) {
                    document.querySelector('.f-contact p:last-of-type').innerText = `📞 Order via WhatsApp: ${webData.contactPhone}`;
                }
            }

            // Optional: Inject some real products into the gallery or a new section if desired
            // For now, these are the primary customizations requested.
        });
    </script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');

        :root {
            --primary: #f472b6;
            --primary-dark: #db2777;
            --surface: #fffafd;
            --text-dark: #2d1a12;
            --text-light: #8d5d46;
        }

        .website-container {
            font-family: 'Outfit', sans-serif;
            background: var(--surface);
            color: var(--text-dark);
            scroll-behavior: smooth;
        }

        /* NAVIGATION */
        .glass-nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 20px 0;
            background: rgba(255, 250, 253, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(244, 114, 182, 0.1);
        }

        .nav-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--primary-dark);
            font-family: 'Playfair Display', serif;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 40px;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-dark);
            font-weight: 600;
            font-size: 0.95rem;
            transition: 0.3s;
        }

        .nav-links a:hover {
            color: var(--primary);
        }

        .btn-order-nav {
            background: var(--primary);
            color: white !important;
            padding: 10px 24px;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(244, 114, 182, 0.3);
        }

        /* HERO */
        .hero {
            height: 90vh;
            min-height: 700px;
            background-image: url('https://images.unsplash.com/photo-1540331547168-8b63109225b7?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            padding: 0 20px;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(45, 26, 18, 0.6), rgba(45, 26, 18, 0.3));
        }

        .hero-content {
            position: relative;
            z-index: 10;
            max-width: 800px;
            color: white;
            animation: fadeInUp 1s ease-out;
        }

        .badge {
            display: inline-block;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(5px);
            padding: 8px 16px;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 24px;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 8vw, 4.5rem);
            line-height: 1.1;
            margin-bottom: 24px;
        }

        .accent {
            color: var(--primary);
            font-style: italic;
        }

        .hero-content p {
            font-size: 1.25rem;
            opacity: 0.9;
            margin-bottom: 40px;
            font-weight: 300;
        }

        .hero-cta {
            display: flex;
            gap: 20px;
            justify-content: center;
        }

        .btn-primary-website {
            background: var(--primary);
            color: white;
            padding: 18px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 800;
            font-size: 1.1rem;
            transition: 0.3s;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .btn-primary-website:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(244, 114, 182, 0.4);
        }

        .btn-secondary-website {
            border: 2px solid white;
            color: white;
            padding: 18px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 800;
            font-size: 1.1rem;
            transition: 0.3s;
        }

        .btn-secondary-website:hover {
            background: white;
            color: var(--text-dark);
        }

        .scroll-indicator {
            position: absolute;
            bottom: 40px;
            font-size: 2rem;
            color: white;
            animation: bounce 2s infinite;
        }

        /* WHY US */
        .why-us {
            max-width: 1000px;
            margin: -60px auto 100px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            position: relative;
            z-index: 20;
            padding: 0 20px;
        }

        .stat-card {
            background: white;
            padding: 40px;
            border-radius: 24px;
            text-align: center;
            box-shadow: 0 20px 60px rgba(0,0,0,0.05);
            border-bottom: 4px solid var(--primary);
        }

        .stat-card h3 {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--primary-dark);
            margin-bottom: 8px;
        }

        .stat-card p {
            font-size: 0.9rem;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        /* GALLERY */
        .gallery-section {
            padding: 100px 40px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-header {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            margin-bottom: 16px;
        }

        .section-header p {
            font-size: 1.1rem;
            color: var(--text-light);
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: repeat(2, 350px);
            gap: 24px;
        }

        .g-item {
            border-radius: 24px;
            background-size: cover;
            background-position: center;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .g-item:nth-child(2) { grid-row: span 2; height: auto; }

        .g-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: 0.4s;
        }

        .g-item:hover .g-overlay { opacity: 1; }

        .g-overlay span {
            color: white;
            font-weight: 800;
            font-size: 1.5rem;
            transform: translateY(20px);
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .g-item:hover .g-overlay span { transform: translateY(0); }

        /* ABOUT */
        .about-section {
            padding: 100px 40px;
            background: #fff5f8;
        }

        .about-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
        }

        .about-image img {
            width: 100%;
            border-radius: 32px;
            box-shadow: 0 40px 80px rgba(0,0,0,0.1);
        }

        .about-text .sub {
            color: var(--primary);
            font-weight: 800;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            display: block;
            margin-bottom: 16px;
        }

        .about-text h2 {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            margin-bottom: 24px;
        }

        .about-text p {
            font-size: 1.1rem;
            line-height: 1.8;
            color: var(--text-light);
            margin-bottom: 24px;
        }

        .btn-text {
            color: var(--primary-dark);
            text-decoration: none;
            font-weight: 800;
            font-size: 1.1rem;
            transition: 0.3s;
        }

        .btn-text:hover {
            color: var(--text-dark);
            padding-left: 10px;
        }

        /* FOOTER */
        .website-footer {
            background: var(--text-dark);
            color: white;
            padding: 100px 40px 40px;
        }

        .footer-top {
            max-width: 1200px;
            margin: 0 auto 80px;
            display: flex;
            justify-content: space-between;
        }

        .f-brand .logo {
            color: white;
            font-size: 2rem;
            margin-bottom: 16px;
        }

        .f-brand p {
            color: rgba(255,255,255,0.5);
        }

        .f-contact h4 {
            margin-bottom: 24px;
            font-size: 1.2rem;
        }

        .f-contact p {
            margin-bottom: 12px;
            color: rgba(255,255,255,0.7);
        }

        .footer-bottom {
            max-width: 1200px;
            margin: 0 auto;
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 40px;
            text-align: center;
            color: rgba(255,255,255,0.4);
            font-size: 0.9rem;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
            40% {transform: translateY(-10px);}
            60% {transform: translateY(-5px);}
        }

        @media (max-width: 1024px) {
            .about-grid { grid-template-columns: 1fr; gap: 40px; }
            .hero { height: auto; padding: 160px 20px 100px; }
            .gallery-grid { grid-template-columns: 1fr; grid-template-rows: auto; }
            .g-item:nth-child(2) { height: 350px; }
        }

        @media (max-width: 768px) {
            .nav-links { display: none; }
            .why-us { grid-template-columns: 1fr; }
            .stat-card { padding: 30px; }
        }
    </style>
</MainLayout>
