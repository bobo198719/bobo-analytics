---
import MainLayout from "../../layouts/MainLayout.astro";

// Server-side detection of subdomain
const host = Astro.url.host;
const isSubdomain = host.split('.').length > 2 && !host.includes('localhost') && !host.includes('vercel.app');
const subdomain = isSubdomain ? host.split('.')[0] : null;

// Format subdomain for display (e.g. "triviabaker" -> "Trivia Baker")
const dynamicName = subdomain ? subdomain.charAt(0).toUpperCase() + subdomain.slice(1).replace(/-/g, ' ') : "Artisanal Bakes";
---

<MainLayout title={`${dynamicName} | Home Bakery & Custom Cakes`} hideNav={true}>
    <div class="website-container">
        <!-- NAVIGATION -->
        <nav class="glass-nav">
            <div class="nav-content">
                <div class="logo">🧁 {dynamicName}</div>
                <div class="nav-links">
                    <a href="#about">Our Story</a>
                    <a href="#menu">Menu</a>
                    <a href={`/bakers-os/order-online`} class="btn-order-nav">Order Now</a>
                </div>
                <button class="cart-trigger" onclick="toggleCart()">
                    🛒 <span id="cart-count">0</span>
                </button>
            </div>
        </nav>

        <!-- HERO SECTION -->
        <section class="hero">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <span class="badge">Freshly Baked Daily</span>
                <h1>Crafting <span class="accent">Sweet Memories</span> with Every Bite</h1>
                <p>Artisanal cakes, handcrafted pastries, and custom treats made with love and the finest ingredients.</p>
                <div class="hero-cta">
                    <a href="/bakers-os/order-online" class="btn-primary-website">Browse Menu & Order</a>
                    <a href="#about" class="btn-secondary-website">Our Story</a>
                </div>
            </div>
            <div class="scroll-indicator">↓</div>
        </section>

        <!-- STATS / WHY US -->
        <section class="why-us">
            <div class="stat-card">
                <h3>100%</h3>
                <p>Natural Ingredients</p>
            </div>
            <div class="stat-card">
                <h3>250+</h3>
                <p>Cakes Delivered</p>
            </div>
            <div class="stat-card">
                <h3>4.9/5</h3>
                <p>Customer Rating</p>
            </div>
        </section>

        <!-- MENU SECTION -->
        <section id="menu" class="menu-section">
            <div class="section-header">
                <span class="sub">Fresh from the Oven</span>
                <h2>Our Signature Menu</h2>
                <p>Discover our range of handcrafted cakes and pastries.</p>
            </div>

            <div class="menu-categories" id="menu-tabs">
                <!-- Categories injected via JS -->
            </div>

            <div class="menu-grid" id="menu-container">
                <!-- Grid controlled by CSS: 3 columns desktop, 2 tablet, 1 mobile -->
            </div>
        </section>

        <!-- CART SIDEBAR -->
        <div id="cart-sidebar" class="cart-sidebar">
            <div class="cart-header">
                <h3>Your Sweet Box</h3>
                <button class="close-cart" onclick="toggleCart()">&times;</button>
            </div>
            <div id="cart-items" class="cart-items">
                <!-- Items injected via JS -->
            </div>
            <div class="cart-footer">
                <div class="total">
                    <span>Total:</span>
                    <span id="cart-total">₹0</span>
                </div>
                <a href="/bakers-os/order-online" class="btn-checkout">Checkout Now</a>
            </div>
        </div>

        <!-- ABOUT SECTION -->
        <section id="about" class="about-section">
            <div class="about-grid">
                <div class="about-image">
                    <img src="https://images.unsplash.com/photo-1556910103-1c02745aae4d?auto=format&fit=crop&w=800&q=80" alt="Baking with passion" />
                </div>
                <div class="about-text">
                    <span class="sub">Passion for Excellence</span>
                    <h2>Meet Your Baker</h2>
                    <p>What started as a childhood hobby in a small kitchen has grown into a mission to bring joy to our community through the art of baking.</p>
                    <p>We believe that every celebration deserves a centerpiece that tastes as good as it looks. That's why we meticulously source our butter, chocolate, and seasonal fruits to ensure excellence in every crumb.</p>
                    <a href="/bakers-os/order-online" class="btn-text">View Price List &rarr;</a>
                </div>
            </div>
        </section>

        <!-- FOOTER -->
        <footer class="website-footer">
            <div class="footer-top">
                <div class="f-brand">
                    <div class="logo">🧁 {dynamicName}</div>
                    <p>Making life sweeter, one cake at a time.</p>
                </div>
                <div class="f-contact">
                    <h4>Contact Us</h4>
                    <p>📍 Available for collection & delivery</p>
                    <p>📞 Order via WhatsApp: +91 73870 21958</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 {dynamicName}. Powered by Bobo Platform.</p>
            </div>
        </footer>
    </div>

    <script is:inline>
        // ── Shared IndexedDB helpers (mirrors products.astro) ───────────────
        const IDB_NAME  = 'bobo_image_store';
        const IDB_STORE = 'images';

        function openImageDB() {
            return new Promise((resolve, reject) => {
                const req = indexedDB.open(IDB_NAME, 1);
                req.onupgradeneeded = e => {
                    if (!e.target.result.objectStoreNames.contains(IDB_STORE))
                        e.target.result.createObjectStore(IDB_STORE, { keyPath: 'id' });
                };
                req.onsuccess = e => resolve(e.target.result);
                req.onerror   = e => reject(e);
            });
        }

        async function getImageFromDB(imageId) {
            if (!imageId) return null;
            try {
                const db = await openImageDB();
                return new Promise(resolve => {
                    const req = db.transaction(IDB_STORE, 'readonly').objectStore(IDB_STORE).get(imageId);
                    req.onsuccess = e => resolve(e.target.result || null);
                    req.onerror   = () => resolve(null);
                });
            } catch(e) { return null; }
        }
        // ────────────────────────────────────────────────────────────────────

        let cart = JSON.parse(localStorage.getItem('bobo_cart') || "[]");

        document.addEventListener('DOMContentLoaded', () => {
            // ── ROBUST PRODUCT LOADING ──────────────────────────────────────
            // Old uploads stored 1080px base64 images (2-5 MB each) causing
            // silent localStorage failures. This strips oversized images and
            // re-saves a clean, small version so the website always renders.
            let products = [];
            try {
                const raw = localStorage.getItem('bobo_products');
                if (raw) {
                    const parsed = JSON.parse(raw);
                    if (Array.isArray(parsed) && parsed.length > 0) {
                        // A 200px JPEG thumbnail is ~8-20 KB. Anything over 100 KB
                        // is a full-res image from the old system — strip it.
                        const tooBig = (s) => s && s.startsWith('data:') && s.length > 100000;
                        products = parsed.map(p => ({
                            ...p,
                            status: p.status || 'approved',
                            image_url: tooBig(p.image_url) ? '' : (p.image_url || p.image || ''),
                            thumbnail_url: tooBig(p.thumbnail_url) ? '' : (p.thumbnail_url || p.image_url || p.image || ''),
                        }));
                        // Re-save slim version so future loads succeed
                        try { localStorage.setItem('bobo_products', JSON.stringify(products)); } catch(e) {}
                    }
                }
            } catch(e) {
                console.warn('bobo_products corrupted — resetting.', e);
                localStorage.removeItem('bobo_products');
                products = [];
            }

            // ── SAMPLE PRODUCTS (shown when no products exist) ──────────────
            if (products.length === 0) {
                products = [
                    { id: 'p1', name: 'Belgium Truffle Cake', cat: 'Chocolate Cakes', image_url: 'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=600', thumbnail_url: 'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=300', price: 1200, prep: '4h', desc: 'Dense chocolate sponge with 70% dark Belgian chocolate.', status: 'approved' },
                    { id: 'p2', name: 'Biscoff Cheesecake',   cat: 'Vanilla Cakes',   image_url: 'https://images.unsplash.com/photo-1533134242443-d4fd215305ad?w=600', thumbnail_url: 'https://images.unsplash.com/photo-1533134242443-d4fd215305ad?w=300', price: 1500, prep: '6h', desc: 'Baked New York style cheesecake with Lotus spread.', status: 'approved' },
                    { id: 'p3', name: 'Red Velvet Box',       cat: 'Cupcakes',        image_url: 'https://images.unsplash.com/photo-1550617931-e17a7b70dce2?w=600', thumbnail_url: 'https://images.unsplash.com/photo-1550617931-e17a7b70dce2?w=300', price: 850,  prep: '3h', desc: 'Box of 6 premium red velvet cupcakes with cream cheese.', status: 'approved' },
                    { id: 'p4', name: 'Strawberry Dream',     cat: 'Fruit Cakes',     image_url: 'https://images.unsplash.com/photo-1565958011703-44f9829ba187?w=600', thumbnail_url: 'https://images.unsplash.com/photo-1565958011703-44f9829ba187?w=300', price: 1350, prep: '5h', desc: 'Fresh strawberry layer cake with whipped cream frosting.', status: 'approved' }
                ];
                try { localStorage.setItem('bobo_products', JSON.stringify(products)); } catch(e) {}
            }

            // ── FIX LEGACY DATA ─────────────────────────────────────────────
            products = products.map(p => ({
                ...p,
                status: p.status || 'approved',
                image_url: p.image_url || p.image || '',
                thumbnail_url: p.thumbnail_url || p.image_url || p.image || ''
            }));

            // ── APPLY WEBSITE CUSTOMISATION ─────────────────────────────────
            const webData = (() => { try { return JSON.parse(localStorage.getItem('bobo_website_data')); } catch(e) { return null; } })();
            if (webData) {
                if (webData.heroTitle) document.querySelector('.hero-content h1').innerHTML = webData.heroTitle.replace(/\{(.*?)\}/g, '<span class="accent">$1</span>');
                if (webData.heroSubtitle) document.querySelector('.hero-content p').innerText = webData.heroSubtitle;
                if (webData.heroBg) document.querySelector('.hero').style.backgroundImage = `url('${webData.heroBg}')`;
                if (webData.aboutTitle) document.querySelector('.about-text h2').innerText = webData.aboutTitle;
                if (webData.aboutP1) document.querySelector('.about-text p').innerText = webData.aboutP1;
                if (webData.aboutImg) document.querySelector('.about-image img').src = webData.aboutImg;
                if (webData.contactAddress) document.querySelector('.f-contact p:first-of-type').innerText = `📍 ${webData.contactAddress}`;
                if (webData.contactPhone) document.querySelector('.f-contact p:last-of-type').innerText = `📞 Order via WhatsApp: ${webData.contactPhone}`;
            }

            // ── BUILD MENU ──────────────────────────────────────────────────
            const approvedProducts = products.filter(p => p.status === 'approved');
            const categories = [...new Set(approvedProducts.map(p => p.cat))];
            const menuTabs = document.getElementById('menu-tabs');

            if (approvedProducts.length === 0) {
                document.getElementById('menu-container').innerHTML = `
                    <div style="grid-column:1/-1;text-align:center;padding:80px 20px;color:#8d5d46;">
                        <p style="font-size:2rem;">🧁</p>
                        <p style="font-weight:700;margin-top:12px;">Menu coming soon!</p>
                        <p style="font-size:0.9rem;margin-top:8px;opacity:0.7;">Check back shortly.</p>
                    </div>`;
            } else {
                if (categories.length > 0) {
                    menuTabs.innerHTML = `
                        <button class="tab-btn active" onclick="filterMenu('all')">All Delights</button>
                        ${categories.map(cat => `<button class="tab-btn" onclick="filterMenu('${cat}')">${cat}</button>`).join('')}
                    `;
                }
                renderMenu(approvedProducts);
            }
            updateCartUI();
        });

        function renderMenu(items) {
            const menuContainer = document.getElementById('menu-container');
            if (!items || items.length === 0) {
                menuContainer.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px;color:#8d5d46;"><p>No products in this category.</p></div>';
                return;
            }
            // Render immediately with thumbnail fallback (fast)
            menuContainer.innerHTML = items.map(p => `
                <div class="product-card-website" id="wcard-${p.id}">
                    <div class="pw-image" id="wpimg-${p.id}" style="background-image: url('${p.thumbnail_url || p.medium_url || ''}')">
                        <span class="pw-tag">${p.cat}</span>
                    </div>
                    <div class="pw-content">
                        <h3>${p.name}</h3>
                        <p>${p.desc}</p>
                        <div class="pw-footer">
                            <span class="pw-price">₹${p.price}</span>
                            <button class="pw-add" onclick="addToCart('${p.id}')">Add to Cart</button>
                        </div>
                    </div>
                </div>
            `).join('');

            // Async upgrade: load medium-res from IndexedDB for uploaded products
            items.forEach(p => {
                if (p.image_id) {
                    getImageFromDB(p.image_id).then(img => {
                        if (!img) return;
                        const el = document.getElementById(`wpimg-${p.id}`);
                        if (el) el.style.backgroundImage = `url('${img.medium || img.thumbnail}')`;
                    });
                }
            });
        }

        window.filterMenu = category => {
            let allProducts = [];
            try {
                const tooBig = s => s && s.startsWith('data:') && s.length > 50000;
                allProducts = JSON.parse(localStorage.getItem('bobo_products') || '[]')
                    .filter(p => p.status === 'approved')
                    .map(p => ({
                        ...p,
                        thumbnail_url: tooBig(p.thumbnail_url) ? '' : (p.thumbnail_url || ''),
                    }));
            } catch(e) { allProducts = []; }
            const btns = document.querySelectorAll('.tab-btn');
            btns.forEach(b => b.classList.remove('active'));
            if (window.event) window.event.target.classList.add('active');
            renderMenu(category === 'all' ? allProducts : allProducts.filter(p => p.cat === category));
        };


        window.toggleCart = () => {
            document.getElementById('cart-sidebar').classList.toggle('active');
        };

        window.addToCart = (id) => {
            const products = JSON.parse(localStorage.getItem('bobo_products') || "[]");
            const product = products.find(p => p.id == id || p.id === id);
            if (!product) return;

            const existing = cart.find(item => item.id == id);
            if (existing) {
                existing.qty += 1;
            } else {
                cart.push({ ...product, qty: 1 });
            }

            localStorage.setItem('bobo_cart', JSON.stringify(cart));
            updateCartUI();
            if (!document.getElementById('cart-sidebar').classList.contains('active')) {
                toggleCart();
            }
        };

        function updateCartUI() {
            const itemsContainer = document.getElementById('cart-items');
            const count = document.getElementById('cart-count');
            const total = document.getElementById('cart-total');

            count.innerText = cart.reduce((acc, item) => acc + item.qty, 0);
            
            itemsContainer.innerHTML = cart.map((item, i) => `
                <div class="cart-item">
                    <div class="ci-image" style="background-image: url('${item.thumbnail_url || item.image_url || item.image}')"></div>
                    <div class="ci-info">
                        <h4>${item.name}</h4>
                        <p>₹${item.price} x ${item.qty}</p>
                    </div>
                    <button class="ci-remove" onclick="removeFromCart(${i})">&times;</button>
                </div>
            `).join('');

            const sum = cart.reduce((acc, item) => acc + (item.price * item.qty), 0);
            total.innerText = `₹${sum}`;
        }

        window.removeFromCart = (index) => {
            cart.splice(index, 1);
            localStorage.setItem('bobo_cart', JSON.stringify(cart));
            updateCartUI();
        };
    </script>

    <style is:inline>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');

        :root {
            --primary: #f472b6;
            --primary-dark: #db2777;
            --surface: #fffafd;
            --text-dark: #2d1a12;
            --text-light: #8d5d46;
        }

        .website-container {
            font-family: 'Outfit', sans-serif;
            background: var(--surface);
            color: var(--text-dark);
            scroll-behavior: smooth;
        }

        /* NAVIGATION */
        .glass-nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            padding: 20px 0;
            background: rgba(255, 250, 253, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(244, 114, 182, 0.1);
        }

        .nav-content {
            max-width: 1200px; margin: 0 auto; padding: 0 40px;
            display: flex; justify-content: space-between; align-items: center;
        }

        .logo { font-size: 1.5rem; font-weight: 800; color: var(--primary-dark); font-family: 'Playfair Display', serif; }
        .nav-links { display: flex; align-items: center; gap: 30px; }
        .nav-links a { text-decoration: none; color: var(--text-dark); font-weight: 600; font-size: 0.95rem; }
        
        .cart-trigger { 
            background: white; border: 1px solid var(--primary); padding: 8px 16px; border-radius: 50px; 
            cursor: pointer; font-weight: 700; display: flex; gap: 8px; align-items: center;
        }

        /* MENU SECTION */
        .menu-section { padding: 100px 40px; max-width: 1200px; margin: 0 auto; }
        .section-header { text-align: center; margin-bottom: 40px; }
        .section-header .sub { color: var(--primary); font-weight: 800; text-transform: uppercase; letter-spacing: 2px; }
        .section-header h2 { font-family: 'Playfair Display', serif; font-size: 3rem; margin: 10px 0; }

        .menu-categories { display: flex; justify-content: center; gap: 15px; margin-bottom: 40px; flex-wrap: wrap; }
        .tab-btn { background: white; border: 1.5px solid #eee; padding: 10px 24px; border-radius: 50px; cursor: pointer; font-weight: 600; transition: 0.3s; }
        .tab-btn.active { background: var(--primary); border-color: var(--primary); color: white; }

        .menu-grid { 
            display: grid !important; 
            grid-template-columns: repeat(3, 1fr) !important; 
            gap: 30px !important; 
        }

        @media (max-width: 1024px) {
            .menu-grid { grid-template-columns: repeat(2, 1fr) !important; }
        }

        @media (max-width: 640px) {
            .menu-grid { grid-template-columns: 1fr !important; }
        }
        .product-card-website { background: white; border-radius: 24px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border: 1px solid #f0f0f0; transition: 0.3s; }
        .product-card-website:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(244, 114, 182, 0.1); }
        
        .pw-image { 
            width: 100% !important; 
            height: 300px !important; 
            background-size: cover !important; 
            background-position: center !important; 
            position: relative; 
            background-color: #f9f9f9; 
            display: block !important;
        }
        .pw-tag { position: absolute; top: 15px; left: 15px; background: rgba(255,255,255,0.9); padding: 4px 12px; border-radius: 50px; font-size: 0.7rem; font-weight: 800; color: var(--primary-dark); }
        
        .pw-content { padding: 24px; }
        .pw-content h3 { font-family: 'Playfair Display', serif; font-size: 1.4rem; margin-bottom: 10px; }
        .pw-content p { color: var(--text-light); font-size: 0.9rem; line-height: 1.5; height: 3em; overflow: hidden; }
        
        .pw-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 20px; }
        .pw-price { font-size: 1.3rem; font-weight: 800; color: var(--text-dark); }
        .pw-add { background: var(--primary); color: white; border: none; padding: 10px 20px; border-radius: 50px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .pw-add:hover { background: var(--primary-dark); }

        /* HERO & OTHERS */
        .hero { height: 80vh; min-height: 600px; background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center; text-align: center; position: relative; }
        .hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.3); }
        .hero-content { position: relative; z-index: 10; color: white; max-width: 800px; }
        .hero-content h1 { font-family: 'Playfair Display', serif; font-size: 4rem; margin-bottom: 20px; }
        
        .btn-primary-website { background: var(--primary); color: white; padding: 16px 40px; border-radius: 50px; text-decoration: none; font-weight: 800; display: inline-block; }

        /* CART SIDEBAR */
        .cart-sidebar { 
            position: fixed; top: 0; right: -400px; width: 400px; height: 100vh; background: white; 
            z-index: 2000; box-shadow: -10px 0 50px rgba(0,0,0,0.1); padding: 40px; 
            transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); display: flex; flex-direction: column;
        }
        .cart-sidebar.active { right: 0; }
        .cart-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 20px; }
        .close-cart { background: none; border: none; font-size: 2rem; cursor: pointer; }
        
        .cart-items { flex: 1; overflow-y: auto; padding: 20px 0; }
        .cart-item { display: flex; gap: 15px; align-items: center; margin-bottom: 20px; }
        .ci-image { width: 60px; height: 60px; border-radius: 12px; background-size: cover; }
        .ci-info h4 { font-size: 1rem; margin-bottom: 4px; }
        .ci-info p { color: var(--text-light); font-size: 0.85rem; }
        .ci-remove { background: none; border: none; color: #ccc; cursor: pointer; margin-left: auto; }

        .cart-footer { border-top: 1px solid #eee; padding-top: 20px; }
        .total { display: flex; justify-content: space-between; font-weight: 800; font-size: 1.2rem; margin-bottom: 20px; }
        .btn-checkout { background: var(--text-dark); color: white; display: block; text-align: center; padding: 16px; border-radius: 12px; text-decoration: none; font-weight: 700; }

        /* ABOUT */
        .about-section { padding: 100px 40px; background: #fff5f8; }
        .about-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
        .about-image img { width: 100%; border-radius: 32px; box-shadow: 0 40px 80px rgba(0,0,0,0.1); }
        .about-text h2 { font-family: 'Playfair Display', serif; font-size: 3rem; margin-bottom: 24px; }
        .about-text p { font-size: 1.1rem; line-height: 1.8; color: var(--text-light); margin-bottom: 24px; }

        /* FOOTER */
        .website-footer { background: var(--text-dark); color: white; padding: 100px 40px 40px; }
        .footer-top { max-width: 1200px; margin: 0 auto 80px; display: flex; justify-content: space-between; }
        .footer-bottom { max-width: 1200px; margin: 0 auto; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 40px; text-align: center; color: rgba(255,255,255,0.4); }

        @keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }

        @media (max-width: 1024px) {
            .about-grid { grid-template-columns: 1fr; gap: 40px; }
            .hero { height: auto; padding: 160px 20px 100px; }
        }

        @media (max-width: 768px) {
            .nav-links { display: none; }
            .cart-sidebar { width: 100%; right: -100%; }
        }
    </style>
</MainLayout>
