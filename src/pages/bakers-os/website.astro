---
import MainLayout from "../../layouts/MainLayout.astro";

// Server-side detection of subdomain
const host = Astro.url.host;
const isSubdomain = host.split('.').length > 2 && !host.includes('localhost') && !host.includes('vercel.app');
const subdomain = isSubdomain ? host.split('.')[0] : null;

// Format subdomain for display (e.g. "triviabaker" -> "Trivia Baker")
const dynamicName = subdomain ? subdomain.charAt(0).toUpperCase() + subdomain.slice(1).replace(/-/g, ' ') : "Trivia Bakes";
---

<MainLayout title={`${dynamicName} | Premium Home Bakery`} hideNav={true}>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <div class="website-container">
        <!-- NAVIGATION -->
        <nav class="glass-nav">
            <div class="nav-content">
                <div class="logo" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
                    <img src="/bakers-logo.png" alt="Trivia Bakes Logo" class="logo-img" />
                    <span class="brand-text">Trivia Bakes</span>
                </div>
                <div class="nav-links">
                    <a href="#about">Our Story</a>
                    <a href="#menu">Menu</a>
                    <a href="#gallery">Gallery</a>
                    <a href="#footer">Contact</a>
                    <a href={`/bakers-os/order-online`} class="btn-order-nav">Order Now</a>
                </div>
                <button class="cart-trigger" onclick="toggleCart()">
                    <span class="cart-icon">🛒</span>
                    <span id="cart-count">0</span>
                </button>
            </div>
        </nav>

        <!-- HERO SECTION -->
        <section class="hero-premium-v2">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <h1>Freshly Baked <span class="accent-text">Happiness</span> Every Day</h1>
                <p>Experience the magic of handcrafted indulgence delivered from our heart to your home.</p>
                <div class="hero-actions">
                    <a href="#menu" class="btn-hero-main">Order Cakes</a>
                    <button class="btn-hero-outline" onclick="openBuilder()">Design Custom Cake</button>
                    <a href="#menu" class="btn-hero-link">View Menu</a>
                </div>
            </div>
        </section>

        <!-- SEARCH & FILTER BAR -->
        <div class="shop-controls-v2">
            <div class="controls-container">
                <div class="search-section">
                    <div class="search-bar-v2">
                        <input type="text" id="product-search" placeholder="Search cakes, pastries..." onkeyup="handleSearch(this.value)" />
                        <span class="search-icon">🔍</span>
                    </div>
                    <div class="category-filters-v2" id="category-tabs">
                        <button class="cat-tab active" onclick="filterMenu('all')">All Delights</button>
                        <button class="cat-tab" onclick="filterMenu('Cakes')">Cakes</button>
                        <button class="cat-tab" onclick="filterMenu('Cupcakes')">Cupcakes</button>
                        <button class="cat-tab" onclick="filterMenu('Desserts')">Desserts</button>
                        <button class="cat-tab" onclick="filterMenu('Pastries')">Pastries</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- STATS / WHY US -->
        <section class="why-us">
            <div class="stat-card">
                <h3>100%</h3>
                <p>Natural Ingredients</p>
            </div>
            <div class="stat-card">
                <h3>250+</h3>
                <p>Cakes Delivered</p>
            </div>
            <div class="stat-card">
                <h3>4.9/5</h3>
                <p>Customer Rating</p>
            </div>
        </section>

        <!-- MENU SECTION -->
        <section id="menu" class="menu-section">
            <div class="section-header">
                <span class="sub">Fresh from the Oven</span>
                <h2>Our Signature Menu</h2>
                <p>Discover our range of handcrafted cakes and pastries.</p>
            </div>

            <div class="menu-categories" id="menu-tabs">
                <!-- Categories injected via JS -->
            </div>

            <div class="menu-grid" id="menu-container">
                <!-- Grid controlled by CSS: 3 columns desktop, 2 tablet, 1 mobile -->
            </div>
        </section>

        <!-- CART SIDEBAR -->
        <div id="cart-sidebar" class="cart-sidebar">
            <div class="cart-header">
                <h3>Your Sweet Box</h3>
                <button class="close-cart" onclick="toggleCart()">&times;</button>
            </div>
            <div id="cart-items" class="cart-items">
                <!-- Items injected via JS -->
            </div>
            <div class="cart-footer">
                <div class="total">
                    <span>Total:</span>
                    <span id="cart-total">₹0</span>
                </div>
                <a href="/bakers-os/order-online" class="btn-checkout">Checkout Now</a>
            </div>
        </div>

        <!-- GALLERY SECTION -->
        <section id="gallery" class="gallery-section">
            <div class="section-header">
                <span class="sub">Visual Indulgence</span>
                <h2>Our Creation Gallery</h2>
            </div>
            <div class="gallery-grid-v2" id="gallery-container">
                <!-- Gallery injected via JS -->
            </div>
        </section>

        <!-- LIGHTBOX -->
        <div id="lightbox" class="lightbox-overlay" onclick="closeLightbox()">
            <img id="lightbox-img" src="" />
            <button class="close-lightbox">&times;</button>
        </div>

        <!-- TRACK ORDER SECTION -->
        <section class="track-section-v2">
            <div class="track-card-v2">
                <h3>Track Your Order</h3>
                <p>Enter your Order ID to check real-time status.</p>
                <div class="track-input-group">
                    <input type="text" placeholder="Enter Order ID (e.g. ord_123)" id="order-search-id" />
                    <button onclick="trackOrder()">Track Order</button>
                </div>
                <div id="track-result"></div>
            </div>
        </section>

        <!-- QUICK VIEW MODAL -->
        <div id="quickview-modal" class="modal-overlay">
            <div class="modal-content quickview-card">
                <button class="close-modal" onclick="closeModals()">&times;</button>
                <div id="quickview-body"></div>
            </div>
        </div>

        <!-- CUSTOM BUILDER MODAL -->
        <div id="builder-modal" class="modal-overlay">
            <div class="modal-content builder-card">
                <button class="close-modal" onclick="closeModals()">&times;</button>
                <div class="builder-layout">
                    <div class="builder-preview">
                        <img id="cake-preview" src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=600" />
                    </div>
                    <div class="builder-options">
                        <h2>Custom Cake Designer</h2>
                        <div class="b-field">
                            <label>Base Flavor</label>
                            <select id="cake-flavor">
                                <option>Belgian Chocolate</option>
                                <option>Vanilla Bean</option>
                                <option>Red Velvet</option>
                                <option>Butterscotch</option>
                                <option>Blueberry</option>
                            </select>
                        </div>
                        <div class="b-field">
                            <label>Cake Weight</label>
                            <div class="weight-pills">
                                <button class="active" onclick="setWeight(0.5, this)">0.5 KG</button>
                                <button onclick="setWeight(1, this)">1.0 KG</button>
                                <button onclick="setWeight(2, this)">2.0 KG</button>
                            </div>
                        </div>
                        <div class="b-field">
                            <label>Message on Cake</label>
                            <input type="text" id="cake-msg" placeholder="Happy Birthday..." />
                        </div>
                        <div class="b-field">
                            <label>Upload Reference Photo</label>
                            <input type="file" id="cake-photo" accept="image/*" />
                        </div>
                        <button class="btn-add-custom" onclick="addCustomCake()">Add Custom Cake to Cart</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ABOUT SECTION -->
        <section id="about" class="about-section">
            <div class="about-grid">
                <div class="about-image">
                    <img src="https://images.unsplash.com/photo-1556910103-1c02745aae4d?auto=format&fit=crop&w=800&q=80" alt="Baking with passion" />
                </div>
                <div class="about-text">
                    <span class="sub">Passion for Excellence</span>
                    <h2>The Story of Trivia Bakes</h2>
                    <p>What started as a childhood hobby in a small kitchen has grown into a mission to bring joy to our community through the art of baking.</p>
                    <p>We believe that every celebration deserves a centerpiece that tastes as good as it looks. That's why we meticulously source our butter, chocolate, and seasonal fruits to ensure excellence in every crumb.</p>
                    <a href="#menu" class="btn-text" onclick="window.scrollTo(0, document.querySelector('#menu').offsetTop - 100); return false;">View Fresh Menu &rarr;</a>
                </div>
            </div>
        </section>

        <!-- FOOTER -->
        <footer class="website-footer-v2" id="footer">
            <div class="footer-grid">
                <div class="f-info-side">
                    <h2 class="brand-text">Trivia Bakes</h2>
                    <p>Making life sweeter, one cake at a time.</p>
                    <div class="f-socials">
                        <span>Instagram</span> <span>Facebook</span>
                    </div>
                </div>
                <div class="f-contact-side">
                    <h3>Contact</h3>
                    <p>Available for collection & delivery</p>
                    <div class="f-wa">
                        <p>WhatsApp Order:</p>
                        <a href="https://wa.me/917387021958" class="wa-link">+91 73870 21958</a>
                    </div>
                </div>
            </div>
            <div class="footer-credits">
                <p>&copy; Trivia Bakes. Powered by Bobo Platform.</p>
            </div>
        </footer>
    </div>

    <script is:inline>
        let cart = [];
        try { 
            cart = JSON.parse(localStorage.getItem('bobo_cart') || "[]"); 
            if (!Array.isArray(cart)) cart = [];
        } catch(e) { 
            cart = []; 
            localStorage.removeItem('bobo_cart');
        }

        document.addEventListener('DOMContentLoaded', () => {
            // 1. Load Custom Website Data
            const customData = JSON.parse(localStorage.getItem('bobo_website_data') || '{}');
            
            // Apply Branding
            const bizLogo = customData.bizLogo || '/bakers-logo.png';
            const bizName = customData.bizName || 'Trivia Bakes';
            
            document.querySelectorAll('.brand-text').forEach(el => el.innerText = bizName);
            document.querySelectorAll('.logo-img').forEach(el => el.src = bizLogo);
            
            // Apply Hero
            if (customData.heroTitle) document.querySelector('.hero-content h1').innerHTML = customData.heroTitle.replace('Happiness', `<span class="accent-text">Happiness</span>`);
            if (customData.heroSubtitle) document.querySelector('.hero-content p').innerText = customData.heroSubtitle;
            if (customData.heroBg) document.querySelector('.hero-premium-v2').style.backgroundImage = `linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('${customData.heroBg}')`;
            
            // Apply About
            if (customData.aboutTitle) document.querySelector('.about-text h2').innerText = customData.aboutTitle;
            if (customData.aboutP1) document.querySelector('.about-text p').innerText = customData.aboutP1;
            if (customData.aboutImg) document.querySelector('.about-image img').src = customData.aboutImg;
            
            // Apply Contact
            if (customData.contactPhone) {
                const waLink = document.querySelector('.wa-link');
                if (waLink) {
                    waLink.innerText = customData.contactPhone;
                    waLink.href = `https://wa.me/${customData.contactPhone.replace(/\D/g, '')}`;
                }
            }
            if (customData.contactAddress) {
                const addr = document.querySelector('.f-contact-side p');
                if (addr) addr.innerText = customData.contactAddress;
            }

            // 2. Load Products
            let products = [];
            try {
                const raw = localStorage.getItem('bobo_products');
                if (raw) {
                    products = JSON.parse(raw);
                }
            } catch(e) {
                console.warn('bobo_products corrupted', e);
                products = [];
            }

            // MIGRATION: If the user has old generic data, force sync to the new high-quality ones
            const hasHighRes = products.some(p => p.name && p.name.includes('Spider-Man'));
            if (!hasHighRes || products.length <= 3) {
                console.log("Upgrading to high-quality cake images...");
                products = [
                    { id:'p1', name:'Spider-Man Theme Cake', cat:'Chocolate Cakes', price:1800, desc:'Premium chocolate sponge with hand-piped Spider-man web design.', status:'approved', image_url:'/menu-images/whatsapp-image-2026-03-13-at-10-59-57-jpeg-1773564631013.webp' },
                    { id:'p2', name:'Classic Smiley Cake',   cat:'Vanilla Cakes',   price:1200, desc:'Joyful vanilla cream cake with a classic smiley face design.',    status:'approved', image_url:'/menu-images/ww-jpeg-1773564633537.webp' },
                    { id:'p3', name:'Luxury Cupcake Box',    cat:'Cupcakes',        price:950,  desc:'Set of 6 gourmet cupcakes with fresh berries and rich frosting.', status:'approved', image_url:'/menu-images/cake2-png-1773563690213.webp' },
                    { id:'p4', name:'Doraemon Dream Cake',   cat:'Fruit Cakes',     price:1500, desc:'Bespoke buttercream cake featuring full Doraemon edible art.', status:'approved', image_url:'/menu-images/wewre-jpeg-1773564630497.webp' },
                    { id:'p5', name:'Belgium Truffle Cake',  cat:'Chocolate Cakes', price:1450, desc:'Dense chocolate sponge with 70% dark Belgian chocolate.', status:'approved', image_url:'/menu-images/whatsapp-image-2026-03-13-at-10-59-51-jpeg-1773564630772.webp' },
                    { id:'p6', name:'Biscoff Cheesecake',    cat:'Desserts',        price:1600, desc:'Creamy Biscoff-infused cheesecake.', status:'approved', image_url:'/menu-images/whatsapp-image-2026-03-13-at-11-00-07-jpeg-1773564632288.webp' }
                ];
                localStorage.setItem('bobo_products', JSON.stringify(products));
            }

            const approved = products.filter(p => !p.status || p.status === 'approved');
            renderMenu(approved);
            renderGallery(approved);
            updateCartUI();
        });

        function renderGallery(items) {
            const container = document.getElementById('gallery-container');
            if (!container) return;
            const fallback = '/assets/cake-placeholder.png';
            
            // Show latest 8 approved items in gallery
            const galleryItems = items.slice(0, 8);
            
            if (galleryItems.length === 0) {
                container.innerHTML = '<p>Gallery will be populated as you add products.</p>';
                return;
            }

            container.innerHTML = galleryItems.map(p => `
                <div class="gallery-item-v2" onclick="openLightbox(this)">
                    <img src="${p.image_url || p.high_res_url || p.medium_url || p.thumbnail_url || fallback}" 
                         onerror="this.src='${fallback}'" 
                         loading="lazy" />
                </div>
            `).join('');
        }

        function renderMenu(items) {
            const menuContainer = document.getElementById('menu-container');
            if (!menuContainer) return;
            if (!items || items.length === 0) {
                menuContainer.innerHTML = '<p>No items found.</p>';
                return;
            }
            
            menuContainer.innerHTML = items.map(p => {
                const fallback = '/assets/cake-placeholder.png';
                const imgPath = p.image_url || p.high_res_url || p.medium_url || p.thumbnail_url || fallback;
                return `
                <div class="bake-card-v2">
                    <div class="bake-img-box">
                        <img src="${imgPath}" onerror="this.src='${fallback}'" alt="${p.name}" loading="lazy" />
                        <div class="bake-badge">${p.cat}</div>
                        <button class="bake-qv-btn" onclick="openQuickView('${p.id}')">Quick View</button>
                    </div>
                    <div class="bake-info">
                        <h3>${p.name}</h3>
                        <p>${p.desc}</p>
                        <div class="bake-meta">
                            <span class="price">₹${p.price}</span>
                            <button class="btn-add-cart-v2" onclick="addToCart('${p.id}')">Add to Cart</button>
                        </div>
                    </div>
                </div>
                `;
            }).join('');
        }

        window.handleSearch = val => {
            const products = JSON.parse(localStorage.getItem('bobo_products') || "[]");
            const q = val.toLowerCase();
            const filtered = products.filter(p => p.name.toLowerCase().includes(q) || p.cat.toLowerCase().includes(q));
            renderMenu(filtered);
        };

        window.filterMenu = cat => {
            const products = JSON.parse(localStorage.getItem('bobo_products') || "[]");
            if (cat === 'all') return renderMenu(products);
            const filtered = products.filter(p => p.cat === cat);
            renderMenu(filtered);
            
            document.querySelectorAll('.cat-tab').forEach(btn => {
                btn.classList.remove('active');
                if (btn.innerText.includes(cat) || (cat === 'all' && btn.innerText.includes('All'))) btn.classList.add('active');
            });
        };

        window.addToCart = (id, q = 1) => {
            const products = JSON.parse(localStorage.getItem('bobo_products') || "[]");
            const p = products.find(i => i.id == id);
            if (!p) return;

            const existing = cart.find(item => item.id == id);
            if (existing) {
                existing.qty += q;
            } else {
                cart.push({ ...p, qty: q });
            }
            localStorage.setItem('bobo_cart', JSON.stringify(cart));
            updateCartUI();
            if (!document.getElementById('cart-sidebar').classList.contains('active')) toggleCart();
        };

        function updateCartUI() {
            const container = document.getElementById('cart-items');
            const count = document.getElementById('cart-count');
            const total = document.getElementById('cart-total');
            if (count) count.innerText = cart.reduce((a, b) => a + b.qty, 0);
            if (container) {
                container.innerHTML = cart.map((item, i) => `
                    <div class="cart-item">
                        <div class="ci-info">
                            <h4>${item.name}</h4>
                            <p>₹${item.price} x ${item.qty}</p>
                        </div>
                        <button onclick="removeFromCart(${i})">&times;</button>
                    </div>
                `).join('');
            }
            if (total) total.innerText = '₹' + cart.reduce((a, b) => a + (b.price * b.qty), 0);
        }

        window.removeFromCart = i => {
            cart.splice(i, 1);
            localStorage.setItem('bobo_cart', JSON.stringify(cart));
            updateCartUI();
        };

        window.toggleCart = () => {
            document.getElementById('cart-sidebar').classList.toggle('active');
        };

        window.openQuickView = id => {
            const products = JSON.parse(localStorage.getItem('bobo_products') || "[]");
            const p = products.find(i => i.id == id);
            if (!p) return;
            const modal = document.getElementById('quickview-modal');
            const body = document.getElementById('quickview-body');
            const fallback = '/assets/cake-placeholder.png';
            body.innerHTML = `
                <div class="qv-content" style="padding: 40px; display: flex; gap: 30px; align-items: center;">
                    <div style="width: 400px; aspect-ratio: 1; overflow: hidden; border-radius: 24px; flex-shrink: 0;">
                        <img src="${p.image_url || p.medium_url || fallback}" 
                             onerror="this.src='${fallback}'"
                             style="width: 100%; height: 100%; object-fit: cover;" />
                    </div>
                    <div>
                        <h2>${p.name}</h2>
                        <p style="font-size: 1.5rem; color: var(--primary-dark); font-weight: 800; margin: 10px 0;">₹${p.price}</p>
                        <p>${p.desc}</p>
                        <button class="btn-hero-main" style="margin-top: 20px;" onclick="addToCart('${p.id}'); closeModals()">Add to Cart</button>
                    </div>
                </div>
            `;
            modal.classList.add('active');
        };

        window.closeModals = () => {
            document.querySelectorAll('.modal-overlay').forEach(m => m.classList.remove('active'));
        };

        window.openLightbox = (el) => {
            const img = el.querySelector('img');
            const lb = document.getElementById('lightbox');
            const lbImg = document.getElementById('lightbox-img');
            if (img && lb && lbImg) {
                lbImg.src = img.src;
                lb.classList.add('active');
            }
        };

        window.closeLightbox = () => {
            document.getElementById('lightbox').classList.remove('active');
        };
    </script>

    <style is:inline>
        :root {
            --primary: #F48FB1;
            --primary-light: #FFF0F6;
            --primary-dark: #C2185B;
            --accent: #C2185B;
            --bg: #FFFFFF;
            --text: #2D2D2D;
            --text-muted: #666666;
            --white: #ffffff;
            --shadow: 0 10px 30px rgba(244, 143, 177, 0.1);
            --radius: 24px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Poppins', sans-serif; background: var(--bg); color: var(--text); overflow-x: hidden; }
        h1, h2, h3, h4 { font-family: 'Playfair Display', serif; }

        .website-container { position: relative; }

        /* NAVBAR */
        .glass-nav { 
            position: fixed; top: 0; left: 0; right: 0; z-index: 2000; 
            background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(15px); 
            border-bottom: 1px solid var(--primary-light); transition: 0.3s;
        }
        .nav-content { max-width: 1400px; margin: 0 auto; padding: 15px 40px; display: flex; justify-content: space-between; align-items: center; }
        .logo { display: flex; align-items: center; gap: 12px; cursor: pointer; }
        .logo-img { height: 45px; width: auto; }
        .brand-text { font-size: 1.5rem; font-weight: 700; color: var(--primary-dark); letter-spacing: -0.5px; }
        .nav-links { display: flex; gap: 30px; align-items: center; }
        .nav-links a { text-decoration: none; color: var(--text); font-weight: 500; font-size: 0.95rem; transition: 0.3s; }
        .nav-links a:hover { color: var(--primary); }
        .btn-order-nav { background: var(--primary); color: var(--white) !important; padding: 10px 24px; border-radius: 50px; }
        .btn-order-nav:hover { background: var(--primary-dark); transform: translateY(-2px); }

        .cart-trigger { background: none; border: none; font-size: 1.5rem; cursor: pointer; position: relative; }
        #cart-count { position: absolute; top: -5px; right: -10px; background: var(--primary-dark); color: white; font-size: 0.7rem; padding: 2px 6px; border-radius: 50%; }

        /* HERO */
        .hero-premium-v2 { 
            height: 80vh; 
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=1600&q=80') center/cover;
            display: flex; align-items: center; justify-content: center; text-align: center; position: relative; color: white;
        }
        .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(244, 143, 177, 0.3)); }
        .hero-content { position: relative; z-index: 10; padding: 0 20px; }
        .hero-content h1 { font-size: 4.5rem; line-height: 1.1; margin-bottom: 20px; }
        .accent-text { color: #fdf2f8; text-shadow: 0 2px 10px rgba(0,0,0,0.2); }
        .hero-content p { font-size: 1.2rem; max-width: 700px; margin: 0 auto 40px; opacity: 0.9; }
        .hero-actions { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }
        .btn-hero-main { background: var(--primary); border: none; color: white; padding: 16px 40px; border-radius: 50px; font-weight: 700; text-decoration: none; transition: 0.3s; cursor: pointer; display: inline-block; }
        .btn-hero-outline { background: rgba(255,255,255,0.15); border: 2px solid white; color: white; padding: 16px 40px; border-radius: 50px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .btn-hero-link { color: white; text-decoration: none; font-weight: 600; border-bottom: 2px solid var(--primary); padding-bottom: 5px; }

        /* SHOP CONTROLS */
        .shop-controls-v2 { padding: 40px 20px; background: var(--primary-light); }
        .search-section { max-width: 1000px; margin: 0 auto; display: flex; flex-direction: column; gap: 25px; align-items: center; }
        .search-bar-v2 { width: 100%; max-width: 600px; position: relative; }
        .search-bar-v2 input { width: 100%; padding: 15px 15px 15px 50px; border-radius: 50px; border: 2px solid white; outline: none; font-size: 1rem; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
        .search-bar-v2 .search-icon { position: absolute; left: 20px; top: 50%; transform: translateY(-50%); }
        .category-filters-v2 { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
