---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
import BakerSubNav from "../../components/BakerSubNav.astro";

// Mock baker customers for initial render, real data via JS
---

<BakersOSLayout title="Baker CRM | Bobo OS">
  <BakerSubNav active="customers" />
  <div class="header-flex" style="margin-top: 20px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
      <div>
          <h1>Customer Database</h1>
          <p style="color: var(--text-muted);">Manage relationships and reward your loyal dessert lovers.</p>
      </div>
      <div class="hb-actions" style="display: flex; gap: 12px;">
          <button class="hb-btn secondary" style="padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; border: 1px solid var(--border); background: rgba(255,255,255,0.05); color: white;">Broadcast WhatsApp</button>
          <button class="hb-btn primary" onclick="addLead()" style="padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; border: none; background: var(--primary); color: white;">+ Add Lead</button>
      </div>
  </div>

  <div class="crm-stats grid-4" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 32px;">
      <div class="stat-card glass-card" style="padding: 24px; display: flex; flex-direction: column; gap: 8px;">
          <span class="sl" style="font-size: 0.75rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">Total Customers</span>
          <span class="sv" id="stat-total-cust" style="font-size: 1.5rem; font-weight: 900; font-family: 'Outfit';">...</span>
      </div>
      <div class="stat-card glass-card" style="padding: 24px; display: flex; flex-direction: column; gap: 8px;">
          <span class="sl" style="font-size: 0.75rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">Top Spender</span>
          <span class="sv" id="stat-top-spend" style="font-size: 1.5rem; font-weight: 900; font-family: 'Outfit';">...</span>
      </div>
      <div class="stat-card glass-card" style="padding: 24px; display: flex; flex-direction: column; gap: 8px;">
          <span class="sl" style="font-size: 0.75rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">Repeat Rate</span>
          <span class="sv" style="font-size: 1.5rem; font-weight: 900; font-family: 'Outfit';">84%</span>
      </div>
      <div class="stat-card glass-card" style="padding: 24px; display: flex; flex-direction: column; gap: 8px;">
          <span class="sl" style="font-size: 0.75rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">Last Order</span>
          <span class="sv" id="stat-last-order" style="font-size: 1.5rem; font-weight: 900; font-family: 'Outfit';">...</span>
      </div>
  </div>

  <div class="crm-table-card glass-card" style="padding: 32px;">
      <div class="table-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
          <h3>Customer List</h3>
          <div class="table-tools" style="display: flex; gap: 12px;">
              <input type="text" id="cust-search" placeholder="Search customers..." style="background: rgba(255,255,255,0.05); border: 1px solid var(--border); padding: 10px 16px; border-radius: 10px; color: white; width: 240px;" oninput="renderCustomers()" />
              <button class="filter-btn" style="background: transparent; border: 1px solid var(--border); color: white; padding: 10px 16px; border-radius: 10px; font-weight: 700; cursor: pointer;">Filters</button>
          </div>
      </div>

      <table class="crm-table" style="width: 100%; border-collapse: collapse;">
          <thead>
              <tr>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Customer Name</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Contact Info</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Orders</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Total Spent</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Last Order</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Engagement</th>
              </tr>
          </thead>
          <tbody id="cust-body">
              <tr><td colspan="6" style="text-align: center; padding: 40px; color: var(--text-muted);">Fetching your customer base...</td></tr>
          </tbody>
      </table>
  </div>

  <style>
      .c-info-cell { display: flex; align-items: center; gap: 12px; }
      .c-avatar { width: 36px; height: 36px; background: rgba(99, 102, 241, 0.2); color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.8rem; }
      .c-name { font-weight: 700; }

      .contact-cell { display: flex; flex-direction: column; gap: 2px; }
      .c-phone { font-weight: 600; font-size: 0.9rem; }
      .c-email { font-size: 0.75rem; color: var(--text-muted); }

      .o-count { font-weight: 700; color: var(--primary); font-size: 0.85rem; }
      .spent-val { font-weight: 800; font-family: 'Outfit'; }
      .last-val { font-size: 0.85rem; color: var(--text-muted); }

      .engage-actions { display: flex; gap: 8px; }
      .e-btn { width: 32px; height: 32px; border-radius: 8px; border: 1px solid var(--border); background: rgba(255,255,255,0.03); color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; }
      .e-btn.wa { color: #25d366; }
      .e-btn.confirm { color: var(--primary); }
  </style>

  <script is:inline>
      let customers = [];

      async function init() {
          await loadData();
      }

      async function loadData() {
          try {
              const res = await fetch('/api/orders');
              const orders = await res.json();
              
              const custMap = {};
              orders.forEach(o => {
                  const key = o.phone || 'unknown';
                  if (!custMap[key]) {
                      custMap[key] = {
                          name: o.customer_name || o.customer || 'Unknown',
                          phone: o.phone || 'N/A',
                          email: o.email || 'N/A',
                          orders: 0,
                          spent: 0,
                          lastDate: new Date(0)
                      };
                  }
                  custMap[key].orders += 1;
                  custMap[key].spent += parseFloat(o.amount || 0);
                  const oDate = new Date(o.created_at || Date.now());
                  if (oDate > custMap[key].lastDate) custMap[key].lastDate = oDate;
              });

              customers = Object.values(custMap).sort((a,b) => b.spent - a.spent);
              renderCustomers();
              updateStats(customers);
          } catch (e) {
              console.error(e);
          }
      }

      function updateStats(data) {
          document.getElementById('stat-total-cust').innerText = data.length;
          document.getElementById('stat-top-spend').innerText = data.length > 0 ? '₹' + data[0].spent.toLocaleString() : '₹0';
          document.getElementById('stat-last-order').innerText = data.length > 0 ? data[0].lastDate.toLocaleDateString('en-IN', {day:'2-digit', month:'short'}) : 'N/A';
      }

      function renderCustomers() {
          const body = document.getElementById('cust-body');
          const search = document.getElementById('cust-search').value.toLowerCase();
          
          const filtered = customers.filter(c => 
              c.name.toLowerCase().includes(search) || 
              c.phone.includes(search)
          );

          if (filtered.length === 0) {
              body.innerHTML = '<tr><td colspan="6" style="text-align: center; padding: 40px; color: var(--text-muted);">No customers found.</td></tr>';
              return;
          }

          body.innerHTML = filtered.map(c => `
              <tr>
                  <td>
                      <div class="c-info-cell">
                          <div class="c-avatar">${c.name[0]}</div>
                          <span class="c-name">${c.name}</span>
                      </div>
                  </td>
                  <td>
                      <div class="contact-cell">
                          <span class="c-phone">${c.phone}</span>
                          <span class="c-email">${c.email}</span>
                      </div>
                  </td>
                  <td><span class="o-count">${c.orders} Orders</span></td>
                  <td><span class="spent-val">₹${c.spent.toLocaleString()}</span></td>
                  <td><span class="last-val">${c.lastDate.getFullYear() > 1970 ? c.lastDate.toLocaleDateString('en-IN', {day:'2-digit', month:'short'}) : 'N/A'}</span></td>
                  <td>
                      <div class="engage-actions">
                          <button class="e-btn wa" title="Quick WhatsApp" onclick="window.open('https://wa.me/${c.phone.replace(/\D/g, '')}')">💬</button>
                          <button class="e-btn confirm" title="Update Status">🔔</button>
                          <button class="e-btn more">···</button>
                      </div>
                  </td>
              </tr>
          `).join('');
      }

      window.addLead = async () => {
          const name = prompt("Enter customer name:");
          if (!name) return;
          const phone = prompt("Enter phone number:");
          
          try {
              const res = await fetch("/api/customers/add", {
                  method: "POST",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify({ name, phone })
              });
              if (res.ok) {
                  alert("Lead added successfully!");
                  loadData();
              }
          } catch (e) {
              alert("Failed to add lead");
          }
      };

      window.whatsappCustomer = (phone) => {
          if (!phone || phone === 'N/A') return alert("No phone number available");
          const cleanPhone = phone.replace(/\D/g, '');
          window.open(`https://wa.me/${cleanPhone}`, '_blank');
      };

      init();
  </script>
</BakersOSLayout>
