---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
---

<BakersOSLayout title="Customer CRM | Home Bakers OS">
    <div class="header">
        <div class="title-area">
            <h1>Customer Database</h1>
            <p>Manage relationships and loyalty history.</p>
        </div>
        <div class="actions">
            <button class="btn btn-primary" onclick="openCustomerModal()">+ Add New Client</button>
        </div>
    </div>

    <div class="glass-card table-card">
        <div class="table-filters">
            <input type="text" placeholder="Search by name, phone or neighborhood..." id="clientSearch" />
        </div>

        <table class="hb-table">
            <thead>
                <tr>
                    <th>Customer Name</th>
                    <th>Contact</th>
                    <th>Default Address</th>
                    <th>Frequency</th>
                    <th>LTV (Total)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="client-body">
                <!-- Data via JS -->
            </tbody>
        </table>
    </div>

    <style>
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
        .btn-primary { background: var(--primary); color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; border: none; cursor: pointer; }
        
        .table-card { padding: 0; overflow: hidden; }
        .table-filters { padding: 20px; border-bottom: 1px solid var(--border); }
        .table-filters input { width: 100%; background: rgba(0,0,0,0.2); border: 1px solid var(--border); padding: 12px; border-radius: 8px; color: white; }

        .hb-table { width: 100%; border-collapse: collapse; text-align: left; }
        .hb-table th { padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border); }
        .hb-table td { padding: 16px; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.9rem; }
        
        .freq-badge { background: rgba(244, 114, 182, 0.1); color: var(--primary); padding: 2px 8px; border-radius: 4px; font-weight: 800; font-size: 0.7rem; margin-left: 8px; }
        
        .row-actions { display: flex; gap: 12px; }
        .act-btn { background: none; border: none; color: var(--text-muted); cursor: pointer; }
    </style>

    <script is:inline>
        let clients = [
            { id: 1, name: 'Anjali Sharma', phone: '+91 98234 56789', address: 'Viman Nagar, Pune', orders: 12, ltv: 18450, loyal: true },
            { id: 2, name: 'Rahul Verma', phone: '+91 77234 12345', address: 'Kalyani Nagar, Pune', orders: 3, ltv: 4200, loyal: false },
            { id: 3, name: 'Priya Iyer', phone: '+91 99345 67890', address: 'Magarpatta City, Pune', orders: 24, ltv: 32800, loyal: true }
        ];

        function renderClients() {
            const tbody = document.getElementById('client-body');
            tbody.innerHTML = clients.map(c => `
                <tr>
                    <td>
                        <strong>${c.name}</strong>
                        ${c.loyal ? '<span class="freq-badge">LOYALIST</span>' : ''}
                    </td>
                    <td>${c.phone}</td>
                    <td>${c.address}</td>
                    <td>${c.orders} Orders</td>
                    <td><strong>₹${c.ltv.toLocaleString()}</strong></td>
                    <td>
                        <div class="row-actions">
                            <button class="act-btn" onclick="history('${c.id}')">👁️</button>
                            <button class="act-btn" onclick="edit('${c.id}')">✏️</button>
                            <button class="act-btn" onclick="del('${c.id}')">🗑️</button>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        window.del = (id) => {
            clients = clients.filter(x => x.id != id);
            renderClients();
        };

        window.openCustomerModal = () => alert('Customer CRM Form: Name, Phone, Delivery Address, Social Link.');

        document.addEventListener('DOMContentLoaded', renderClients);
    </script>
</BakersOSLayout>
