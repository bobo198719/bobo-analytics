---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
---

<BakersOSLayout title="Website Editor | Trivia">
    <div class="editor-header">
        <div class="title-area">
            <h1>Website Customizer</h1>
            <p>Edit your public website's text, photos, and prices in real-time.</p>
        </div>
        <div class="actions">
            <a href="/bakers-os/website" target="_blank" class="btn btn-secondary">View Live Site ↗</a>
            <button class="btn btn-secondary" onclick="resetDefaults()" style="margin-right: 12px;">Reset Defaults</button>
            <button class="btn btn-primary" onclick="saveWebsiteData()">Save Changes</button>
        </div>
    </div>

    <div class="editor-grid">
        <!-- FORM SIDE -->
        <div class="editor-form glass-card">
            <section class="form-section">
                <h3>1. Business Identity</h3>
                <div class="input-group">
                    <label>Bakery / Business Name</label>
                    <input type="text" id="biz-name" placeholder="e.g. Trivia Bakes" />
                </div>
                <div class="input-group">
                    <label>Store Logo (Optional)</label>
                    <div class="file-upload-wrapper">
                        <input type="file" id="biz-logo-file" accept="image/*" onchange="handleFileUpload(this, 'biz-logo')" />
                        <div class="file-preview" id="biz-logo-preview"></div>
                    </div>
                </div>
            </section>

            <section class="form-section">
                <h3>2. Hero Section</h3>
                <div class="input-group">
                    <label>Main Headline</label>
                    <input type="text" id="hero-title" placeholder="e.g. Crafting Sweet Memories" />
                </div>
                <div class="input-group">
                    <label>Sub-headline</label>
                    <textarea id="hero-subtitle" rows="3"></textarea>
                </div>
                <div class="input-group">
                    <label>Hero Background Image</label>
                    <div class="file-upload-wrapper">
                        <input type="file" id="hero-bg-file" accept="image/*" capture="environment" onchange="handleFileUpload(this, 'hero-bg')" />
                        <div class="file-preview" id="hero-bg-preview"></div>
                    </div>
                </div>
            </section>

            <section class="form-section">
                <h3>2. About Your Business</h3>
                <div class="input-group">
                    <label>About Title</label>
                    <input type="text" id="about-title" />
                </div>
                <div class="input-group">
                    <label>Description Paragraph 1</label>
                    <textarea id="about-p1" rows="4"></textarea>
                </div>
                <div class="input-group">
                    <label>Featured Image</label>
                    <div class="file-upload-wrapper">
                        <input type="file" id="about-img-file" accept="image/*" capture="environment" onchange="handleFileUpload(this, 'about-img')" />
                        <div class="file-preview" id="about-img-preview"></div>
                    </div>
                </div>
            </section>

             <section class="form-section">
                <h3>3. Contact Details</h3>
                <div class="input-group">
                    <label>WhatsApp Number (with country code)</label>
                    <input type="text" id="contact-phone" placeholder="+91..." />
                </div>
                <div class="input-group">
                    <label>Business Address / Location</label>
                    <input type="text" id="contact-address" />
                </div>
            </section>
        </div>

        <!-- PREVIEW/TIPS SIDE -->
        <div class="editor-sidebar">
            <div class="glass-card tip-card">
                <h4>✨ Pro Tips</h4>
                <ul>
                    <li>Use high-resolution images for the Hero background (at least 1920px wide).</li>
                    <li>Keep your headline short and punchy.</li>
                    <li>Ensure your WhatsApp number is correct so customers can reach you.</li>
                </ul>
            </div>

            <div class="glass-card sync-card">
                <h4>📦 Product Sync</h4>
                <p>Prices and items are managed in the <a href="/bakers-os/products">Product Catalogue</a>. They update automatically on your website's ordering portal.</p>
            </div>
        </div>
    </div>

    <style>
        .editor-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
        .btn { padding: 12px 24px; border-radius: 12px; font-weight: 700; border: none; cursor: pointer; text-decoration: none; display: inline-block; font-family: 'Outfit'; }
        .btn-primary { background: var(--primary); color: white; }
        .btn-secondary { background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--border); margin-right: 12px; }

        .editor-grid { display: grid; grid-template-columns: 1fr 350px; gap: 32px; }
        
        .form-section { margin-bottom: 40px; padding-bottom: 40px; border-bottom: 1px solid var(--border); }
        .form-section:last-child { border-bottom: none; }
        .form-section h3 { margin-bottom: 24px; color: var(--primary); }

        .input-group { margin-bottom: 20px; }
        .input-group label { display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 8px; font-weight: 600; }
        .input-group input, .input-group textarea {
            width: 100%;
            background: rgba(0,0,0,0.2);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px;
            color: white;
            font-family: 'Outfit';
            font-size: 1rem;
        }
        .input-group input:focus, .input-group textarea:focus { border-color: var(--primary); outline: none; background: rgba(0,0,0,0.3); }

        .file-upload-wrapper {
            position: relative;
            background: rgba(0,0,0,0.2);
            border: 2px dashed var(--border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            transition: 0.3s;
        }
        .file-upload-wrapper:hover { border-color: var(--primary); }
        .file-upload-wrapper input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
        }
        .file-preview {
            width: 100%;
            height: 120px;
            background-size: cover;
            background-position: center;
            border-radius: 8px;
            display: none;
            margin-top: 10px;
        }

        .editor-sidebar { display: flex; flex-direction: column; gap: 24px; }
        .tip-card { border-left: 4px solid var(--primary); }
        .tip-card h4 { margin-bottom: 12px; }
        .tip-card ul { padding-left: 20px; color: var(--text-muted); font-size: 0.9rem; }
        .tip-card li { margin-bottom: 8px; }

        .sync-card a { color: var(--primary); text-decoration: none; font-weight: 700; }
    </style>

    <script is:inline>
        let isUploading = false;
        const DEFAULT_DATA = {
            bizName: "Trivia Bakes",
            bizLogo: "/bakers-logo.png",
            heroTitle: "Crafting Sweet Memories with Every Bite",
            heroSubtitle: "Artisanal cakes, handcrafted pastries, and custom treats made with love and the finest ingredients.",
            heroBg: "https://images.unsplash.com/photo-1540331547168-8b63109225b7?auto=format&fit=crop&w=1920&q=80",
            aboutTitle: "Meet Your Baker",
            aboutP1: "What started as a childhood hobby in a small kitchen has grown into a mission to bring joy to our community through the art of baking.",
            aboutImg: "https://images.unsplash.com/photo-1556910103-1c02745aae4d?auto=format&fit=crop&w=800&q=80",
            contactPhone: "+91 73870 21958",
            contactAddress: "Available for collection & delivery"
        };

        let uploadedImages = {};

        /**
         * CLIENT-SIDE IMAGE OPTIMIZER
         * Resizes to 1080x1080 (or hero size), converts to WebP, and compresses.
         */
        async function optimizeImageClient(file, targetWidth = 1080) {
            return new Promise((resolve) => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const img = new Image();
                    img.onload = () => {
                        const canvas = document.createElement('canvas');
                        // Calculate aspect ratio maintained size
                        const ratio = img.width / img.height;
                        canvas.width = targetWidth;
                        canvas.height = targetWidth / ratio;
                        
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                        
                        const dataUrl = canvas.toDataURL('image/webp', 0.82);
                        resolve(dataUrl);
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            });
        }

        async function uploadImageToServer(blob) {
            const formData = new FormData();
            formData.append('image', blob);

            const response = await fetch('/api/upload-product-image', {
                method: 'POST',
                body: formData
            });

            if (!response.ok) throw new Error('Upload failed');
            return await response.json();
        }

        async function handleFileUpload(input, key) {
            const file = input.files[0];
            if (!file) return;

            if (isUploading) return alert('An upload is already in progress...');
            isUploading = true;

            const preview = document.getElementById(key + '-preview');
            preview.style.opacity = '0.5';
            preview.style.display = 'block';
            preview.innerText = 'Optimizing...';

            try {
                // 1. Optimize on client
                const targetWidth = key === 'hero-bg' ? 1920 : 1080;
                const optimizedDataUrl = await optimizeImageClient(file, targetWidth);
                
                // Show instant preview
                preview.style.backgroundImage = `url('${optimizedDataUrl}')`;
                preview.style.opacity = '0.7';
                preview.innerText = 'Uploading...';

                // 2. Upload to production storage
                const blobRes = await fetch(optimizedDataUrl);
                const blob = await blobRes.blob();
                const result = await uploadImageToServer(blob);
                
                const finalUrl = result.url || result.image_url;
                uploadedImages[key] = finalUrl;
                
                preview.style.backgroundImage = `url('${finalUrl}')`;
                preview.style.opacity = '1';
                preview.innerText = '';
            } catch (e) {
                console.error(e);
                alert('Upload failed: ' + e.message);
                preview.style.display = 'none';
            } finally {
                isUploading = false;
            }
        }

        const host = window.location.host;
        const isSubdomain = host.split('.').length > 2 && !host.includes('localhost') && !host.includes('vercel.app');
        const tenantInfo = JSON.parse(localStorage.getItem("activeTenantContext"));
        const tenantId = isSubdomain ? host.split('.')[0] : (tenantInfo ? tenantInfo.id : 'default_baker');
        const API_BASE = '/api';

        async function loadData() {
            try {
                const response = await fetch(`${API_BASE}/settings/${tenantId}`);
                if (response.ok) {
                    const data = await response.json();
                    applyDataToForm(data);
                } else {
                    // Fallback to local or default
                    const localData = JSON.parse(localStorage.getItem('bobo_website_data') || JSON.stringify(DEFAULT_DATA));
                    applyDataToForm(localData);
                }
            } catch (err) {
                console.error("Load Fail:", err);
                applyDataToForm(DEFAULT_DATA);
            }
        }

        function applyDataToForm(data) {
            document.getElementById('biz-name').value = data.bizName || DEFAULT_DATA.bizName;
            document.getElementById('hero-title').value = data.heroTitle || DEFAULT_DATA.heroTitle;
            document.getElementById('hero-subtitle').value = data.heroSubtitle || DEFAULT_DATA.heroSubtitle;
            document.getElementById('about-title').value = data.aboutTitle || DEFAULT_DATA.aboutTitle;
            document.getElementById('about-p1').value = data.aboutP1 || DEFAULT_DATA.aboutP1;
            document.getElementById('contact-phone').value = data.contactPhone || DEFAULT_DATA.contactPhone;
            document.getElementById('contact-address').value = data.contactAddress || DEFAULT_DATA.contactAddress;

            // Load previews
            if (data.bizLogo) {
                const lp = document.getElementById('biz-logo-preview');
                lp.style.backgroundImage = `url('${data.bizLogo}')`;
                lp.style.display = 'block';
                uploadedImages['biz-logo'] = data.bizLogo;
            }
            if (data.heroBg) {
                const hp = document.getElementById('hero-bg-preview');
                hp.style.backgroundImage = `url('${data.heroBg}')`;
                hp.style.display = 'block';
                uploadedImages['hero-bg'] = data.heroBg;
            }
            if (data.aboutImg) {
                const ap = document.getElementById('about-img-preview');
                ap.style.backgroundImage = `url('${data.aboutImg}')`;
                ap.style.display = 'block';
                uploadedImages['about-img'] = data.aboutImg;
            }
        }

        window.saveWebsiteData = async () => {
            if (isUploading) {
                alert('Please wait for the photo to finish uploading before saving.');
                return;
            }
            const data = {
                bizName: document.getElementById('biz-name').value,
                bizLogo: uploadedImages['biz-logo'] || DEFAULT_DATA.bizLogo,
                heroTitle: document.getElementById('hero-title').value,
                heroSubtitle: document.getElementById('hero-subtitle').value,
                heroBg: uploadedImages['hero-bg'] || DEFAULT_DATA.heroBg,
                aboutTitle: document.getElementById('about-title').value,
                aboutP1: document.getElementById('about-p1').value,
                aboutImg: uploadedImages['about-img'] || DEFAULT_DATA.aboutImg,
                contactPhone: document.getElementById('contact-phone').value,
                contactAddress: document.getElementById('contact-address').value
            };

            try {
                const btn = document.querySelector(".btn-primary");
                btn.innerText = "Saving to Server...";
                
                const response = await fetch(`${API_BASE}/settings`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ tenantId, settings: data })
                });

                if (response.ok) {
                    localStorage.setItem('bobo_website_data', JSON.stringify(data));
                    alert('Website updated successfully on Bobo Server!');
                    window.location.href = '/bakers-os/website';
                } else {
                    throw new Error("Server save failed");
                }
            } catch (err) {
                console.error("Save Error:", err);
                localStorage.setItem('bobo_website_data', JSON.stringify(data));
                alert('Saved locally. Server sync failed.');
            } finally {
                document.querySelector(".btn-primary").innerText = "Save Changes";
            }
        };

        window.resetDefaults = () => {
            if (confirm("Reset all website settings to original Trivia Bakes theme?")) {
                applyDataToForm(DEFAULT_DATA);
                uploadedImages = {};
                alert("Defaults applied. Click 'Save Changes' to push to server.");
            }
        };

        document.addEventListener('DOMContentLoaded', loadData);
    </script>
</BakersOSLayout>
