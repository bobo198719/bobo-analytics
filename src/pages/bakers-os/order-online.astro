---
import MainLayout from "../../layouts/MainLayout.astro";

const host = Astro.url.host;
const isSubdomain = host.split('.').length > 2 && !host.includes('localhost') && !host.includes('vercel.app');
const subdomain = isSubdomain ? host.split('.')[0] : null;
const dynamicName = subdomain ? subdomain.charAt(0).toUpperCase() + subdomain.slice(1).replace(/-/g, ' ') : "Trivia Bakes";
---

<MainLayout title={`Checkout | ${dynamicName}`} hideNav={true}>
    <div class="checkout-portal">
        <header class="c-header">
            <a href="/bakers-os/website" class="back-link">← Back to Bakery</a>
            <div class="logo">🧁 {dynamicName}</div>
        </header>

        <main class="c-container">
            <div class="c-steps">
                <div class="c-step active" id="s1">1. Summary</div>
                <div class="c-step" id="s2">2. Delivery</div>
                <div class="c-step" id="s3">3. Payment</div>
            </div>

            <!-- STEP 1: SUMMARY -->
            <div id="step-1" class="step-view active">
                <div class="glass-card">
                    <h3>Your Sweet Box</h3>
                    <div id="summary-items" class="summary-list"></div>
                    <div class="summary-total">
                        <span>Grand Total</span>
                        <span id="final-total">₹0</span>
                    </div>
                    <button class="btn-primary" onclick="nextStep(2)">Confirm Items & Continue</button>
                    <p class="empty-msg" id="cart-empty" style="display:none;">Your box is empty! Go back and add some treats.</p>
                </div>
            </div>

            <!-- STEP 2: DETAILS -->
            <div id="step-2" class="step-view">
                <div class="glass-card">
                    <h3>Delivery Details</h3>
                    <form id="checkout-form">
                        <div class="f-row">
                            <div class="f-group">
                                <label>Recipient Name</label>
                                <input type="text" id="c-name" placeholder="John Doe" required />
                            </div>
                            <div class="f-group">
                                <label>WhatsApp Number</label>
                                <input type="tel" id="c-phone" placeholder="+91 XXXX XXX XXX" required />
                            </div>
                        </div>
                        <div class="f-group">
                            <label>Delivery Address</label>
                            <textarea id="c-address" placeholder="Flat, Street, Landmark, City..." required></textarea>
                        </div>
                        <div class="f-row">
                            <div class="f-group">
                                <label>Delivery Date</label>
                                <input type="date" id="c-date" required />
                            </div>
                            <div class="f-group">
                                <label>Preferred Time Slot</label>
                                <select id="c-time">
                                    <option>Standard (10 AM - 9 PM)</option>
                                    <option>Morning (10 AM - 1 PM)</option>
                                    <option>Afternoon (1 PM - 5 PM)</option>
                                    <option>Evening (5 PM - 9 PM)</option>
                                    <option>Midnight (Extra ₹250 applicable)</option>
                                </select>
                            </div>
                        </div>
                        <div class="f-group">
                            <label>Special Instructions / Message on Cake</label>
                            <textarea id="c-notes" placeholder="Any allergy info or text to write on the cake?"></textarea>
                        </div>
                        <button type="submit" class="btn-primary">Proceed to Payment</button>
                    </form>
                </div>
            </div>

            <!-- STEP 3: PAYMENT -->
            <div id="step-3" class="step-view">
                <div class="glass-card">
                    <h3>Select Payment Method</h3>
                    <div class="payment-grid">
                        <div class="pay-option" onclick="placeOrder('UPI')">
                            <div class="p-icon">💸</div>
                            <div class="p-info">
                                <strong>UPI / Google Pay</strong>
                                <span>Fast & Secure</span>
                            </div>
                        </div>
                        <div class="pay-option" onclick="placeOrder('Card')">
                            <div class="p-icon">💳</div>
                            <div class="p-info">
                                <strong>Debit / Credit Card</strong>
                                <span>Powered by Bobo Pay</span>
                            </div>
                        </div>
                        <div class="pay-option" onclick="placeOrder('COD')">
                            <div class="p-icon">💵</div>
                            <div class="p-info">
                                <strong>Cash on Delivery</strong>
                                <span>Available locally</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 4: SUCCESS -->
            <div id="step-4" class="step-view">
                <div class="glass-card success-view">
                    <div class="check-anim">✨</div>
                    <h2>Baketastic! Order Placed.</h2>
                    <p>Your Order ID is <strong id="order-id">#10293</strong></p>
                    <div class="success-actions">
                        <button class="btn-whatsapp" onclick="sendWhatsApp()">Confirm On WhatsApp</button>
                        <a href="/bakers-os/website" class="btn-outline">Back to Home</a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <style>
        :root { 
            --primary: #F48FB1; 
            --primary-dark: #C2185B; 
            --bg: #FFFFFF; 
            --primary-light: #FFF0F6;
            --text: #2D2D2D; 
        }
        .checkout-portal { min-height: 100vh; background: var(--bg); color: var(--text); font-family: 'Poppins', sans-serif; }
        .c-header { padding: 30px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--primary-light); }
        .back-link { text-decoration: none; color: var(--primary-dark); font-weight: 700; }
        .logo { font-size: 1.5rem; font-weight: 800; font-family: 'Playfair Display', serif; color: var(--primary-dark); }

        .c-container { max-width: 800px; margin: 0 auto; padding: 40px 20px; }
        .c-steps { display: flex; justify-content: center; gap: 40px; margin-bottom: 50px; }
        .c-step { opacity: 0.3; font-weight: 800; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; }
        .c-step.active { opacity: 1; color: var(--primary-dark); }

        .step-view { display: none; }
        .step-view.active { display: block; animation: slideUp 0.4s ease; }
        @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .glass-card { background: white; border-radius: 30px; padding: 40px; border: 1px solid var(--primary-light); box-shadow: 0 20px 40px rgba(244, 143, 177, 0.08); }
        h3 { font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 30px; color: var(--text); }

        .summary-list { border-bottom: 2px dashed var(--primary-light); padding-bottom: 20px; margin-bottom: 20px; }
        .summary-item { display: flex; justify-content: space-between; margin-bottom: 15px; }
        .summary-item span:first-child { opacity: 0.7; }
        .summary-total { display: flex; justify-content: space-between; font-size: 1.5rem; font-weight: 800; margin-bottom: 30px; color: var(--primary-dark); }

        .f-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .f-group { margin-bottom: 20px; }
        .f-group label { display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px; opacity: 0.6; }
        .f-group input, .f-group textarea, .f-group select { width: 100%; padding: 14px 20px; border-radius: 12px; border: 2px solid var(--primary-light); outline: none; font-family: inherit; font-size: 1rem; }
        .f-group input:focus, .f-group textarea:focus { border-color: var(--primary); }

        .btn-primary { width: 100%; background: var(--primary); color: white; border: none; padding: 18px; border-radius: 50px; font-weight: 800; font-size: 1.1rem; cursor: pointer; transition: 0.3s; }
        .btn-primary:hover { background: var(--primary-dark); transform: translateY(-3px); }

        .payment-grid { display: grid; gap: 15px; }
        .pay-option { display: flex; align-items: center; gap: 20px; padding: 25px; border: 2px solid var(--primary-light); border-radius: 20px; cursor: pointer; transition: 0.3s; }
        .pay-option:hover { border-color: var(--primary); background: var(--primary-light); }
        .p-icon { font-size: 2rem; }
        .p-info strong { display: block; font-size: 1.1rem; }
        .p-info span { font-size: 0.85rem; opacity: 0.6; }

        .success-view { text-align: center; }
        .check-anim { font-size: 5rem; margin-bottom: 20px; }
        .success-actions { display: flex; flex-direction: column; gap: 15px; margin-top: 40px; }
        .btn-whatsapp { background: #25d366; color: white; border: none; padding: 18px; border-radius: 50px; font-weight: 800; cursor: pointer; width: 100%; }
        .btn-outline { border: 2px solid var(--primary-light); color: var(--text); padding: 15px; border-radius: 50px; text-decoration: none; font-weight: 700; }

        @media (max-width: 600px) {
            .f-row { grid-template-columns: 1fr; }
        }
    </style>

    <script is:inline>
        let cart = [];
        let orderDetails = {};
        let finalOrderId = '';

        document.addEventListener('DOMContentLoaded', () => {
            loadCart();
            document.getElementById('checkout-form').addEventListener('submit', (e) => {
                e.preventDefault();
                saveDetails();
                nextStep(3);
            });
        });

        function loadCart() {
            cart = JSON.parse(localStorage.getItem('bobo_cart') || "[]");
            const list = document.getElementById('summary-items');
            const totalEl = document.getElementById('final-total');
            
            if (cart.length === 0) {
                document.getElementById('cart-empty').style.display = 'block';
                document.querySelector('.btn-primary').disabled = true;
                return;
            }

            let total = 0;
            list.innerHTML = cart.map(item => {
                total += (parseFloat(item.price) * item.qty);
                return `<div class="summary-item">
                    <span>${item.name} x ${item.qty}</span>
                    <strong>₹${item.price * item.qty}</strong>
                </div>`;
            }).join('');
            
            totalEl.innerText = `₹${total}`;
            orderDetails.total = total;
            orderDetails.items = cart;
        }

        window.nextStep = (n) => {
            document.querySelectorAll('.step-view').forEach(v => v.classList.remove('active'));
            document.getElementById('step-' + n).classList.add('active');
            
            document.querySelectorAll('.c-step').forEach(s => s.classList.remove('active'));
            if (n <= 3) document.getElementById('s' + n).classList.add('active');
        }

        function saveDetails() {
            orderDetails.customerName = document.getElementById('c-name').value;
            orderDetails.customerPhone = document.getElementById('c-phone').value;
            orderDetails.address = document.getElementById('c-address').value;
            orderDetails.date = document.getElementById('c-date').value;
            orderDetails.timeSlot = document.getElementById('c-time').value;
            orderDetails.notes = document.getElementById('c-notes').value;
        }

        window.placeOrder = async (method) => {
            const orderObj = {
                date: new Date().toISOString(),
                deliveryDate: orderDetails.date,
                customer: orderDetails.customerName,
                phone: orderDetails.customerPhone,
                address: orderDetails.address,
                items: orderDetails.items.map(i => i.name).join(', '),
                total: orderDetails.total,
                status: 'Order Received',
                payment: method === 'COD' ? 'Pending (COD)' : 'Paid (' + method + ')',
                notes: orderDetails.notes,
                source: 'Trivia Bakes Website'
            };

            try {
                const res = await fetch('/api/orders', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(orderObj)
                });

                if (res.ok) {
                    const result = await res.json();
                    finalOrderId = result.order.id;
                    
                    // Clear Cart
                    localStorage.removeItem('bobo_cart');

                    document.getElementById('order-id').innerText = '#' + finalOrderId;
                    nextStep(4);
                } else {
                    alert("Failed to securely save your order. Please try again or contact us.");
                }
            } catch (e) {
                console.error("Order error:", e);
                alert("Connection error. Your order could not be placed.");
            }
        }

        window.sendWhatsApp = () => {
            const firstItem = orderDetails.items[0]?.name || "Treats";
            const msg = encodeURIComponent(`Hello! I just placed an order from Trivia Bakes.\n\n Order ID: #${finalOrderId}\n Name: ${orderDetails.customerName}\n Items: ${orderDetails.items.map(i => i.name).join(', ')}\n Total: ₹${orderDetails.total}\n Address: ${orderDetails.address}\n\n Please confirm my order!`);
            window.open(`https://wa.me/917387021958?text=${msg}`, '_blank');
        }
    </script>
</MainLayout>
