---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
import BakerSubNav from "../../components/BakerSubNav.astro";

// Stats will be loaded via JS
---

<BakersOSLayout title="Baker Command Center | Baker OS">
  <BakerSubNav active="dashboard" />
  <div class="hb-header" style="margin-top: 20px;">
      <div>
          <span class="hb-badge">Home Bakers Module</span>
          <h1>Baker Intelligence Dashboard</h1>
          <p style="color: var(--text-muted);">Manage your home-based bakery business with real-time insights.</p>
      </div>
      <div class="hb-actions">
          <button class="hb-btn profile" onclick="window.location.href='/bakers-os/profile'">View Public Profile</button>
          <button class="hb-btn primary" onclick="window.location.href='/bakers-os/orders'">+ New Order</button>
      </div>
  </div>

  <!-- Stats Grid -->
  <div class="stats-grid">
      <div class="stat-card glass-card">
          <div class="stat-icon">📦</div>
          <div class="stat-info">
              <span class="stat-label">Total Orders</span>
              <span class="stat-value" id="val-total-orders">0</span>
              <span class="stat-change" id="change-total">Calculating...</span>
          </div>
      </div>
      <div class="stat-card glass-card">
          <div class="stat-icon">🔥</div>
          <div class="stat-info">
              <span class="stat-label">Orders Today</span>
              <span class="stat-value" id="val-orders-today">0</span>
              <span class="stat-change" id="change-today">Live</span>
          </div>
      </div>
      <div class="stat-card glass-card">
          <div class="stat-icon">⏳</div>
          <div class="stat-info">
              <span class="stat-label">Pending</span>
              <span class="stat-value" id="val-pending">0</span>
              <span class="stat-change">Active bakes</span>
          </div>
      </div>
      <div class="stat-card glass-card">
          <div class="stat-icon">✅</div>
          <div class="stat-info">
              <span class="stat-label">Completed</span>
              <span class="stat-value" id="val-completed">0</span>
              <span class="stat-change">Success rate</span>
          </div>
      </div>
      <div class="stat-card glass-card">
          <div class="stat-icon">💰</div>
          <div class="stat-info">
              <span class="stat-label">Revenue</span>
              <span class="stat-value" id="val-revenue">₹0</span>
              <span class="stat-change">Total earned</span>
          </div>
      </div>
      <div class="stat-card glass-card">
          <div class="stat-icon">⭐</div>
          <div class="stat-info">
              <span class="stat-label">Rating</span>
              <span class="stat-value">4.9</span>
              <span class="stat-change">Top rated</span>
          </div>
      </div>
  </div>

  <div class="dashboard-content">
      <!-- Left: Charts & Trends -->
      <div class="charts-column">
          <div class="chart-card glass-card">
              <div class="chart-header">
                  <h3>7-Day Sales Velocity</h3>
                  <select class="chart-select">
                      <option>Daily</option>
                      <option>Weekly</option>
                  </select>
              </div>
              <div class="chart-mock">
                  <div class="bars" id="sales-bars">
                      {Array(7).fill(0).map((_, i) => <div class="bar" style={`height: ${Math.random() * 50 + 20}%`}></div>)}
                  </div>
                  <div class="labels">
                      <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                  </div>
              </div>
          </div>

          <div class="charts-row">
              <div class="chart-card glass-card half">
                  <h3>Catalog Mix</h3>
                  <div class="donut-mock">
                      <div class="donut-inner">
                          <span class="val" id="cat-percent">--%</span>
                          <span class="lab">Top Cat</span>
                      </div>
                  </div>
                  <div class="legend" id="cat-legend">
                      <div class="leg-item"><span class="dot cakes" style="background: #6366f1;"></span> Cakes</div>
                      <div class="leg-item"><span class="dot cookies" style="background: #fb923c;"></span> Cookies</div>
                      <div class="leg-item"><span class="dot others" style="background: #94a3b8;"></span> Others</div>
                  </div>
              </div>

              <div class="chart-card glass-card half">
                  <h3>Customer Interest</h3>
                  <div class="repeat-meter">
                      <div class="meter-bar">
                          <div class="meter-fill" style="width: 72%"></div>
                      </div>
                      <span class="repeat-val">High Demand Detected</span>
                  </div>
                  <p class="chart-desc">Based on recent catalog views and orders. Focus on celebration cakes this week.</p>
              </div>
          </div>
      </div>

      <!-- Right: Top Selling & Recent Activity -->
      <div class="activity-column">
          <div class="ranking-card glass-card">
              <h3>Trending Items</h3>
              <div class="ranking-list" id="trending-list">
                  <p style="color: var(--text-muted); padding: 20px; text-align: center;">Calculating trends...</p>
              </div>
          </div>

          <div class="recent-orders-card glass-card">
              <div class="card-header">
                  <h3>Live Order Feed</h3>
                  <a href="/bakers-os/orders" class="view-all">Full Hub →</a>
              </div>
              <div class="order-mini-list" id="mini-order-list">
                  <p style="color: var(--text-muted); padding: 20px; text-align: center;">Fetching live feed...</p>
              </div>
          </div>
      </div>
  </div>

  <style>
      .hb-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
      .hb-badge { background: rgba(99, 102, 241, 0.1); color: #6366f1; padding: 4px 12px; border-radius: 30px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px; display: inline-block; }
      .hb-actions { display: flex; gap: 12px; }
      .hb-btn { padding: 10px 20px; border-radius: 12px; font-weight: 700; cursor: pointer; transition: 0.2s; border: 1px solid var(--border); background: rgba(255,255,255,0.05); color: white; }
      .hb-btn.primary { background: #6366f1; border: none; }
      .hb-btn:hover { transform: translateY(-2px); }

      .stats-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px; margin-bottom: 32px; }
      .stat-card { padding: 20px; display: flex; align-items: center; gap: 16px; }
      .stat-icon { font-size: 1.5rem; width: 44px; height: 44px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; border-radius: 10px; }
      .stat-info { display: flex; flex-direction: column; }
      .stat-label { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; }
      .stat-value { font-size: 1.1rem; font-weight: 800; font-family: 'Outfit'; }
      .stat-change { font-size: 0.65rem; font-weight: 700; }
      .stat-change.up { color: #10b981; }
      .stat-change.down { color: #ef4444; }

      .dashboard-content { display: grid; grid-template-columns: 1fr 400px; gap: 32px; }
      
      .charts-column { display: flex; flex-direction: column; gap: 32px; }
      .chart-card { padding: 32px; }
      .chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
      .chart-select { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 4px 8px; border-radius: 8px; font-size: 0.8rem; }
      
      .chart-mock { height: 200px; display: flex; flex-direction: column; }
      .bars { flex: 1; display: flex; align-items: flex-end; gap: 12px; margin-bottom: 12px; }
      .bar { flex: 1; background: #6366f1; border-radius: 4px 4px 0 0; opacity: 0.7; transition: 0.3s; }
      .bar:hover { opacity: 1; background: #4f46e5; }
      .labels { display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); }

      .charts-row { display: flex; gap: 24px; }
      .chart-card.half { flex: 1; }

      .donut-mock { width: 120px; height: 120px; border-radius: 50%; border: 12px solid #6366f1; border-left-color: #fb923c; border-bottom-color: #94a3b8; margin: 20px auto; display: flex; align-items: center; justify-content: center; }
      .donut-inner { text-align: center; }
      .donut-inner .val { display: block; font-weight: 800; font-size: 1.2rem; }
      .donut-inner .lab { font-size: 0.7rem; color: var(--text-muted); }

      .legend { display: flex; flex-direction: column; gap: 8px; font-size: 0.8rem; }
      .leg-item { display: flex; align-items: center; gap: 8px; }
      .dot { width: 8px; height: 8px; border-radius: 50%; }

      .repeat-meter { margin: 24px 0; }
      .meter-bar { height: 12px; background: rgba(255,255,255,0.05); border-radius: 10px; overflow: hidden; margin-bottom: 8px; }
      .meter-fill { height: 100%; background: linear-gradient(90deg, #6366f1, #4f46e5); border-radius: 10px; }
      .repeat-val { font-weight: 700; font-size: 0.9rem; }
      .chart-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; }

      .activity-column { display: flex; flex-direction: column; gap: 32px; }
      .ranking-card { padding: 32px; }
      .ranking-list { display: flex; flex-direction: column; gap: 16px; margin-top: 24px; }
      .rank-item { display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
      .rank-info { display: flex; flex-direction: column; }
      .rank-name { font-weight: 700; font-size: 0.95rem; }
      .rank-meta { font-size: 0.75rem; color: var(--text-muted); }
      .rank-stat { display: flex; flex-direction: column; align-items: flex-end; }
      .rank-rev { font-weight: 800; font-family: 'Outfit'; font-size: 1rem; }
      .rank-trend { font-weight: 800; font-size: 0.8rem; }
      .rank-trend.up { color: #10b981; }
      .rank-trend.down { color: #ef4444; }

      .recent-orders-card { padding: 32px; }
      .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
      .view-all { font-size: 0.8rem; color: #6366f1; font-weight: 700; text-decoration: none; }
      .order-mini-list { display: flex; flex-direction: column; gap: 12px; }
      .order-mini-item { display: flex; align-items: center; gap: 12px; padding: 12px; background: rgba(255,255,255,0.03); border-radius: 10px; font-size: 0.85rem; }
      .om-id { font-weight: 800; color: #6366f1; opacity: 0.8; }
      .om-name { flex: 1; font-weight: 600; }
      .om-status { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; padding: 2px 8px; border-radius: 30px; }
      .om-status.preparing { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
      .om-status.ready { background: rgba(16, 185, 129, 0.1); color: #10b981; }
      .om-status.new { background: rgba(99, 102, 241, 0.1); color: #6366f1; }

      @media (max-width: 1400px) {
          .stats-grid { grid-template-columns: repeat(3, 1fr); }
      }
  </style>

  <script is:inline>
      async function init() {
          await loadDashboardData();
      }

      async function loadDashboardData() {
          try {
              const [ordersRes, productsRes] = await Promise.all([
                  fetch('/api/orders'),
                  fetch('/api/products')
              ]);
              
              const orders = await ordersRes.json();
              const products = await productsRes.json();
              
              if (Array.isArray(orders)) {
                  updateStats(orders);
                  updateMiniOrders(orders);
                  updateTrending(orders, products);
              }
          } catch (e) {
              console.error('Dashboard load error:', e);
          }
      }

      function updateStats(orders) {
          const today = new Date().toDateString();
          const todayOrders = orders.filter(o => new Date(o.created_at || Date.now()).toDateString() === today);
          const pending = orders.filter(o => !['Delivered', 'Cancelled'].includes(o.status));
          const completed = orders.filter(o => o.status === 'Delivered');
          const totalRevenue = orders.reduce((sum, o) => sum + parseFloat(o.amount || 0), 0);
          
          document.getElementById('val-total-orders').innerText = orders.length;
          document.getElementById('val-orders-today').innerText = todayOrders.length;
          document.getElementById('val-pending').innerText = pending.length;
          document.getElementById('val-completed').innerText = completed.length;
          document.getElementById('val-revenue').innerText = '₹' + totalRevenue.toLocaleString();
          
          document.getElementById('change-total').innerText = orders.length > 0 ? '+100% Growth' : 'Starting up';
          document.getElementById('change-total').classList.add('up');
      }

      function updateMiniOrders(orders) {
          const list = document.getElementById('mini-order-list');
          const recent = orders.slice(0, 3);
          
          if (recent.length === 0) {
              list.innerHTML = '<p style="color: var(--text-muted); text-align: center; padding: 20px;">No active orders yet.</p>';
              return;
          }
          
          list.innerHTML = recent.map(o => `
              <div class="order-mini-item">
                  <span class="om-id">#${o.id}</span>
                  <span class="om-name">${o.customer || 'Guest'}</span>
                  <span class="om-status ${(o.status || 'new').toLowerCase()}">${o.status || 'New'}</span>
              </div>
          `).join('');
      }

      function updateTrending(orders, products) {
          const list = document.getElementById('trending-list');
          // Mocking trending for now based on catalog
          const top = products.slice(0, 4);
          
          if (top.length === 0) {
              list.innerHTML = '<p style="color: var(--text-muted); text-align: center; padding: 20px;">Catalog your bakes to see trends!</p>';
              return;
          }
          
          list.innerHTML = top.map(p => `
              <div class="rank-item">
                  <div class="rank-info">
                      <span class="rank-name">${p.name}</span>
                      <span class="rank-meta">${p.cat || 'Custom Bake'}</span>
                  </div>
                  <div class="rank-stat">
                      <span class="rank-rev">₹${p.price}</span>
                      <span class="rank-trend up">↑</span>
                  </div>
              </div>
          `).join('');
      }

      init();
  </script>
</BakersOSLayout>

