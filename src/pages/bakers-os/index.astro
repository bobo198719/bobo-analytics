---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
import BakersDashboard from "../../components/baker/Dashboard.jsx";
---

<BakersOSLayout title="Baker Intelligence Hub | Baker OS">
  
  <!-- DASHBOARD SECTION (Intelligence) -->
  <div id="dashboardSection" class="section">
    <BakersDashboard client:load />
  </div>

  <!-- ORDERS SECTION (Pipeline) -->
  <div id="ordersSection" class="section hidden">
    <div class="p-20 text-center opacity-20">
        <h2 class="text-6xl font-black italic uppercase italic">Order Pipeline Hub</h2>
        <p class="text-[10px] font-black uppercase tracking-[1em] mt-4">Node Active | Syncing Live Feed</p>
    </div>
  </div>

  <!-- BAKE LAB SECTION (Costing) -->
  <div id="costingSection" class="section hidden">
    <div class="p-20 text-center opacity-20 text-indigo-400">
        <h2 class="text-6xl font-black italic uppercase italic">Bake Lab Node</h2>
        <p class="text-[10px] font-black uppercase tracking-[1em] mt-4">Recipe Costing | Lab Environment</p>
    </div>
  </div>

  <style is:global>
    .hidden { display: none !important; }
    .section { animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
  </style>

</BakersOSLayout>

