---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
import BakersSubNav from "../../components/BakersSubNav.astro";

const baker = {
  name: "Sarah Jenkins",
  business: "Jenkin's Gourmet Cakes",
  phone: "+91 98765 43210",
  address: "123 Baker St, Green Meadows",
  city: "Gurgaon",
  rating: 4.9,
  specialties: ["Cakes", "Cupcakes", "Cookies"]
};
---

<BakersOSLayout title="Baker Profile | Home Bakers OS">
  <BakersSubNav active="profile" />
  
  <div class="profile-hero glass-card">
      <div class="hero-bg"></div>
      <div class="hero-content">
          <div class="avatar-lg">SJ</div>
          <div class="hero-meta">
              <h1>{baker.business}</h1>
              <div class="hero-badges">
                  <span>Verified 🍰</span>
                  <span>{baker.city} 📍</span>
              </div>
          </div>
          <div class="hero-actions">
              <button class="primary-btn">Edit Profile</button>
              <button class="secondary-btn">Share Page</button>
          </div>
      </div>
  </div>

  <div class="profile-grid">
      <div class="main-info">
          <div class="card-section glass-card">
              <h3>About the Patisserie</h3>
              <p>Specializing in Belgian Chocolate and custom celebration cakes. Using only premium ingredients and a lot of love.</p>
              <div class="spec-tags">
                  {baker.specialties.map(s => <span class="tag">{s}</span>)}
              </div>
          </div>

          <div class="card-section glass-card">
              <h3>Contact Details</h3>
              <div class="contact-list">
                  <div class="c-item"><strong>Phone:</strong> {baker.phone}</div>
                  <div class="c-item"><strong>Address:</strong> {baker.address}</div>
              </div>
          </div>
      </div>

      <div class="side-info">
          <div class="card-section glass-card">
              <h3>Quick Settings</h3>
              <div class="quick-toggle">
                  <span>Accepting Orders</span>
                  <div class="toggle active"></div>
              </div>
          </div>
      </div>
  </div>

  <style>
      .profile-hero { height: 350px; overflow: hidden; position: relative; margin-bottom: 32px; padding: 0; }
      .hero-bg { height: 180px; background: linear-gradient(135deg, var(--primary), var(--secondary)); opacity: 0.3; }
      .hero-content { padding: 0 40px; display: flex; align-items: flex-end; gap: 32px; position: relative; top: -40px; }
      
      .avatar-lg { width: 140px; height: 140px; border-radius: 20px; background: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 3rem; font-weight: 800; border: 4px solid var(--bg-dark); }
      .hero-meta h1 { font-family: 'Outfit'; font-size: 2.2rem; margin-bottom: 8px; }
      .hero-badges { display: flex; gap: 12px; color: var(--text-muted); font-size: 0.9rem; font-weight: 700; }
      
      .hero-actions { flex: 1; display: flex; justify-content: flex-end; gap: 12px; padding-bottom: 12px; }
      .primary-btn { background: white; color: black; border: none; padding: 10px 20px; border-radius: 10px; font-weight: 700; cursor: pointer; }
      .secondary-btn { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 10px 20px; border-radius: 10px; font-weight: 700; cursor: pointer; }

      .profile-grid { display: grid; grid-template-columns: 1fr 350px; gap: 32px; }
      .main-info { display: flex; flex-direction: column; gap: 32px; }
      .card-section { padding: 32px; }
      .card-section h3 { font-family: 'Outfit'; margin-bottom: 24px; color: var(--primary); border-bottom: 1px solid var(--border); padding-bottom: 12px; }

      .spec-tags { display: flex; gap: 10px; margin-top: 20px; }
      .tag { background: rgba(244, 114, 182, 0.1); color: var(--primary); padding: 4px 12px; border-radius: 8px; font-weight: 700; font-size: 0.85rem; }

      .contact-list { display: flex; flex-direction: column; gap: 16px; }
      .c-item strong { color: var(--text-muted); margin-right: 8px; }

      .quick-toggle { display: flex; justify-content: space-between; align-items: center; }
      .toggle { width: 44px; height: 22px; background: rgba(255,255,255,0.1); border-radius: 30px; position: relative; cursor: pointer; }
      .toggle::after { content: ''; position: absolute; left: 4px; top: 3px; width: 16px; height: 16px; background: #64748b; border-radius: 50%; transition: 0.3s; }
      .toggle.active { background: var(--primary); }
      .toggle.active::after { left: 24px; background: white; }
  </style>
</BakersOSLayout>
