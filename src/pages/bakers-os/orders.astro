---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
import BakerSubNav from "../../components/BakerSubNav.astro";
---

<BakersOSLayout title="Bakers Order Management | Bobo OS">
  <BakerSubNav active="orders" />
  <div class="header-flex" style="margin-top: 20px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
      <div>
          <h1>Bakes & Orders</h1>
          <p style="color: var(--text-muted);">Track custom requests and daily deliveries.</p>
      </div>
      <div class="order-tabs" style="display: flex; background: rgba(255,255,255,0.05); padding: 6px; border-radius: 14px; gap: 4px;">
          <button class="o-tab active" onclick="filterOrders('Current', this)">Current</button>
          <button class="o-tab" onclick="filterOrders('Upcoming', this)">Upcoming</button>
          <button class="o-tab" onclick="filterOrders('Past', this)">Past</button>
      </div>
  </div>

  <div class="orders-table-card glass-card" style="padding: 32px; margin-bottom: 32px; overflow-x: auto;">
      <div class="table-header-row" style="display: flex; justify-content: space-between; margin-bottom: 32px; gap: 20px; flex-wrap: wrap;">
          <div class="search-box">
              <input type="text" id="order-search" placeholder="Search by name, ID or phone..." oninput="renderOrders()" style="min-width: 300px; background: rgba(255,255,255,0.05); border: 1px solid var(--border); padding: 12px; border-radius: 12px; color: white;" />
          </div>
          <div class="filter-row" style="display: flex; gap: 12px;">
              <select id="status-filter" onchange="renderOrders()" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 10px; border-radius: 10px; font-weight: 600;"><option value="all">Status: All</option></select>
              <select id="payment-filter" onchange="renderOrders()" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 10px; border-radius: 10px; font-weight: 600;"><option value="all">Payment: All</option></select>
          </div>
      </div>

      <table class="hb-order-table" style="width: 100%; border-collapse: collapse; min-width: 800px;">
          <thead>
              <tr>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Order ID</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Customer</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Product Details</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Delivery Date</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Status</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Payment</th>
                  <th style="text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border);">Actions</th>
              </tr>
          </thead>
          <tbody id="orders-body">
              <!-- Orders will be loaded here via JS -->
          </tbody>
      </table>
      <div id="orders-loading" class="loading-state" style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px; color: var(--text-muted);">
          <div class="spinner"></div>
          <p>Syncing with your kitchen...</p>
      </div>
  </div>

  <div class="custom-requests glass-card" style="padding: 32px;">
      <div class="cr-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
          <h3>Custom Cake Requests (Unconfirmed)</h3>
          <span class="cr-count" id="request-count" style="background: #ef4444; color: white; padding: 4px 12px; border-radius: 30px; font-size: 0.75rem; font-weight: 800;">0 New Requests</span>
      </div>
      <div class="cr-list" id="request-list">
          <p style="color: var(--text-muted); text-align: center; padding: 20px;">No new custom requests at the moment.</p>
      </div>
  </div>

  <style>
      .o-tab { background: transparent; border: none; color: var(--text-muted); padding: 8px 16px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; }
      .o-tab.active { background: var(--primary); color: white; }

      .spinner { width: 30px; height: 30px; border: 3px solid rgba(99, 102, 241, 0.2); border-left-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 12px; }
      @keyframes spin { to { transform: rotate(360deg); } }

      .o-id { font-weight: 800; color: var(--primary); }
      .customer-cell, .product-cell { display: flex; flex-direction: column; gap: 4px; }
      .c-name, .p-name { font-weight: 700; font-size: 0.95rem; }
      .c-phone, .p-qty { font-size: 0.8rem; color: var(--text-muted); }
      .o-date { font-weight: 600; font-size: 0.9rem; }

      .o-status { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; padding: 4px 10px; border-radius: 30px; }
      .status-new { background: rgba(99, 102, 241, 0.1); color: var(--primary); }
      .status-preparing { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
      .status-ready { background: rgba(16, 185, 129, 0.1); color: #10b981; }
      .status-delivered { background: rgba(107, 114, 128, 0.1); color: #9ca3af; }

      .payment-paid { color: #10b981; }
      .payment-pending { color: #fb923c; }

      .a-btn { padding: 8px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 700; cursor: pointer; border: 1px solid var(--border); background: rgba(255,255,255,0.05); color: white; }
      .a-btn.wa { color: #10b981; background: rgba(16, 185, 129, 0.05); border-color: rgba(16, 185, 129, 0.2); }
  </style>

  <script is:inline>
      let orders = [];
      let currentTab = 'Current';

      async function init() {
          await loadOrders();
      }

      async function loadOrders() {
          const loading = document.getElementById('orders-loading');
          try {
              const res = await fetch('/api/orders');
              if (!res.ok) throw new Error('API down');
              orders = await res.json();
              if (!Array.isArray(orders)) orders = [];
              renderOrders();
              loading.style.display = 'none';
          } catch (e) {
              console.error('Fetch error:', e);
              loading.innerHTML = `<p>❌ Failed to load orders.</p>`;
          }
      }

      function renderOrders() {
          const body = document.getElementById('orders-body');
          const search = document.getElementById('order-search').value.toLowerCase();
          
          let filtered = orders.filter(o => {
              const matchesSearch = (o.customer_name || o.customer || "").toLowerCase().includes(search) || 
                                   (o.id || "").toString().includes(search) ||
                                   (Array.isArray(o.products) ? o.products.join(' ') : (o.products || o.product || "")).toLowerCase().includes(search);
              
              const matchesTab = (currentTab === 'Current' && (o.status === 'New' || o.status === 'Preparing' || o.status === 'Ready' || !o.status)) ||
                                (currentTab === 'Upcoming' && o.status === 'Upcoming') ||
                                (currentTab === 'Past' && (o.status === 'Delivered' || o.status === 'Cancelled' || o.status === 'completed'));
              
              return matchesSearch && matchesTab;
          });

          body.innerHTML = filtered.map(o => `
              <tr>
                  <td><span class="o-id">#${o.id || o.order_id}</span></td>
                  <td>
                      <div class="customer-cell">
                          <span class="c-name">${o.customer_name || o.customer || 'Guest'}</span>
                          <span class="c-phone">${o.phone || ''}</span>
                      </div>
                  </td>
                  <td>
                      <div class="product-cell">
                          <span class="p-name">${Array.isArray(o.products) ? o.products.join(', ') : (o.products || o.product || 'Treat')}</span>
                          <span class="p-qty">Amount: ₹${o.amount || 0}</span>
                      </div>
                  </td>
                  <td><span class="o-date">${new Date(o.created_at || Date.now()).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })}</span></td>
                  <td>
                      <select onchange="updateOrderStatus('${o.id || o.order_id}', this.value)" class="o-status status-${(o.status || 'new').toLowerCase()}" style="border: none; cursor: pointer; background: rgba(255,255,255,0.1); color: white; font-weight: 800; font-size: 0.7rem; padding: 4px 10px; border-radius: 30px;">
                          <option value="New" ${o.status === 'New' ? 'selected' : ''}>New</option>
                          <option value="Preparing" ${o.status === 'Preparing' ? 'selected' : ''}>Preparing</option>
                          <option value="Ready" ${o.status === 'Ready' ? 'selected' : ''}>Ready</option>
                          <option value="Delivered" ${o.status === 'Delivered' || o.status === 'completed' ? 'selected' : ''}>Delivered</option>
                          <option value="Cancelled" ${o.status === 'Cancelled' ? 'selected' : ''}>Cancelled</option>
                      </select>
                  </td>
                  <td><span class="o-payment payment-${(o.payment_status || 'pending').toLowerCase()}">${o.payment_status || 'Pending'}</span></td>
                  <td>
                      <div class="action-cell" style="display: flex; gap: 8px;">
                          <button class="a-btn wa" onclick="whatsappCustomer('${o.phone}', '${o.customer_name || o.customer}', '${o.id || o.order_id}')" title="Message on WhatsApp">💬 Msg</button>
                          <button class="a-btn" onclick="deleteOrder('${o.id || o.order_id}')">🗑️</button>
                      </div>
                  </td>
              </tr>
          `).join('');
      }

      window.filterOrders = (tab, btn) => {
          currentTab = tab;
          document.querySelectorAll('.o-tab').forEach(t => t.classList.remove('active'));
          btn.classList.add('active');
          renderOrders();
      };

      window.updateOrderStatus = async (id, status) => {
          try {
              const res = await fetch('/api/orders', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ id, status, update_status_only: true })
              });
              if (res.ok) {
                  await loadOrders();
              }
          } catch (e) {
              alert('Update failed');
          }
      };

      window.deleteOrder = async (id) => {
          if (!confirm('Delete this order?')) return;
          try {
              const res = await fetch(\`/api/orders?id=\${id}\`, { method: 'DELETE' });
              if (res.ok) await loadOrders();
          } catch (e) { console.error(e); }
      };

      window.whatsappCustomer = (phone, name, id) => {
          if (!phone) return alert('No phone number found.');
          const cleanPhone = phone.replace(/\D/g, '');
          const message = encodeURIComponent(\`Hi \${name}! Regarding your order #\${id} from Trivia Bakery.\`);
          window.open(\`https://wa.me/\${cleanPhone}?text=\${message}\`, '_blank');
      };

      init();
  </script>
</BakersOSLayout>

