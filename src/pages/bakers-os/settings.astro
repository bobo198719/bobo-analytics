---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
---

<BakersOSLayout title="Portal Settings | Baker OS">
    <div class="header">
        <h1>Portal Configuration</h1>
        <p>Manage your business identity and automation settings.</p>
    </div>

    <div class="settings-grid">
        <!-- Business Profile -->
        <div class="glass-card settings-section">
            <h3>Visual Identity</h3>
            <div class="form-body">
                <div class="avatar-upload">
                    <div class="preview" id="logo-preview">🧁</div>
                    <button class="btn-s">Change Logo</button>
                </div>
                <div class="f-group">
                    <label>Business Display Name</label>
                    <input type="text" id="biz-name-input" value="Jenkin's Gourmet Cakes" />
                </div>
                <div class="f-group">
                    <label>Brand Primary Color</label>
                    <div class="color-pick">
                        <input type="color" value="#6366f1" />
                        <code>#6366f1</code>
                    </div>
                </div>
            </div>
            <button class="btn-save" onclick="window.saveSettings()">Update Identity</button>
        </div>

        <!-- Automation -->
        <div class="glass-card settings-section">
            <h3>WhatsApp Automation</h3>
            <div class="form-body">
                <div class="toggle-item">
                    <div class="info">
                        <strong>Order Confirmation</strong>
                        <span>Send auto-message when order is created</span>
                    </div>
                    <input type="checkbox" checked />
                </div>
                <div class="toggle-item">
                    <div class="info">
                        <strong>Kitchen Reminder</strong>
                        <span>Notify customer when preparation starts</span>
                    </div>
                    <input type="checkbox" checked />
                </div>
                <div class="toggle-item">
                    <div class="info">
                        <strong>Out for Delivery</strong>
                        <span>Send real-time tracking when dispatched</span>
                    </div>
                    <input type="checkbox" checked />
                </div>
                
                <div class="wa-config mt-24">
                    <label>WhatsApp API Key (Twilio/Meta)</label>
                    <input type="password" value="************************" />
                </div>
            </div>
        </div>

        <!-- Data & Payments -->
        <div class="glass-column">
            <div class="glass-card settings-section">
                <h3>Payment Integrations</h3>
                <div class="form-body">
                    <div class="payment-method active" style="flex-direction: column; align-items: flex-start; gap: 16px;">
                        <div class="p-info" style="width:100%;">
                            <strong style="font-size: 1.1rem; color: #10b981; display: block;">Integrated UPI / GPay</strong>
                            <span style="font-size: 0.8rem; opacity: 0.7;">Direct to Bank Transfer</span>
                            <div class="mt-24">
                                <label style="display:block; font-size:0.65rem; color:var(--text-muted); margin-bottom:8px; text-transform: uppercase; font-weight: 900;">UPI ID (e.g. baker@upi)</label>
                                <input type="text" id="upi-input" placeholder="Enter UPI ID" style="width:100%; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.1); padding:12px; border-radius:10px; color:white; font-size: 1rem;" />
                            </div>
                        </div>
                        <button class="btn-save" id="upi-btn" style="margin-top:10px; width:100%; padding:16px; position: relative; z-index: 100; cursor: pointer !important; display: block;" onclick="console.log('UPI_CLICKED'); window.saveUPI();">Update UPI</button>
                    </div>
                    <div class="payment-method">
                        <div class="p-info">
                            <strong>Razorpay / Stripe</strong>
                            <span>Cards & Netbanking</span>
                        </div>
                        <button class="btn-s">Connect</button>
                    </div>
                </div>
            </div>

            <div class="glass-card settings-section danger">
                <h3>Data Management</h3>
                <div class="form-body">
                    <p style="color:var(--text-muted); font-size:0.85rem;">Resetting your data will clear all orders, products, and analytics locally.</p>
                    <button class="btn-s" style="margin-top:16px; border-color:#ef4444; color:#ef4444; width:100%;" onclick="resetAllData()">🔥 Reset All Business Data</button>
                </div>
            </div>
        </div>
    </div>

    <style>
        .header { margin-bottom: 32px; }
        .settings-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 32px; }
        .glass-column { display: flex; flex-direction: column; gap: 32px; }
        .settings-section { padding: 32px; display: flex; flex-direction: column; gap: 24px; height: 100%; }
        .settings-section h3 { font-size: 1.1rem; color: var(--primary); font-family: 'Outfit'; }
        .settings-section.danger { border-color: rgba(239, 68, 68, 0.2); }

        .avatar-upload { display: flex; align-items: center; gap: 20px; margin-bottom: 24px; border-bottom: 1px solid var(--border); padding-bottom: 24px; }
        .preview { width: 80px; height: 80px; background: rgba(255,255,255,0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; border: 2px dashed var(--border); }
        .btn-s { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 8px 16px; border-radius: 8px; cursor: pointer; font-size: 0.8rem; }
        
        .f-group { margin-bottom: 20px; }
        .f-group label { display: block; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase; font-weight: 800; }
        .f-group input { width: 100%; background: rgba(0,0,0,0.2); border: 1px solid var(--border); padding: 12px; border-radius: 10px; color: white; }
        
        .color-pick { display: flex; align-items: center; gap: 12px; }
        .color-pick input { width: 40px; height: 40px; padding: 2px; border: none; background: none; }
        
        .toggle-item { display: flex; justify-content: space-between; align-items: center; padding: 16px; background: rgba(255,255,255,0.02); border-radius: 12px; border: 1px solid var(--border); margin-bottom: 12px; }
        .toggle-item strong { display: block; font-size: 0.9rem; }
        .toggle-item span { font-size: 0.75rem; color: var(--text-muted); }
        
        .payment-method { display: flex; justify-content: space-between; align-items: center; padding: 20px; background: rgba(0,0,0,0.1); border-radius: 16px; border: 1px solid var(--border); margin-bottom: 16px; }
        .payment-method.active { border-color: #10b981; background: rgba(16, 185, 129, 0.05); }
        .payment-method .status { font-size: 0.7rem; font-weight: 900; color: #10b981; }
        
        .btn-save { background: var(--primary); color: white; border: none; padding: 16px; border-radius: 12px; font-weight: 800; cursor: pointer; margin-top: auto; }
        .mt-24 { margin-top: 24px; }
        .wa-config label { display: block; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase; font-weight: 800; }
        .wa-config input { width: 100%; background: rgba(0,0,0,0.2); border: 1px solid var(--border); padding: 12px; border-radius: 10px; color: white; }
    </style>

    <script is:inline>
        const DEFAULT_BAKER = {
            business: "Jenkin's Gourmet Cakes",
            city: "Gurgaon",
            bio: "Specializing in Belgian Chocolate and custom celebration cakes. Using only premium ingredients and a lot of love.",
            phone: "+91 98765 43210",
            address: "123 Baker St, Green Meadows",
            specialties: ["Cakes", "Cupcakes", "Cookies"],
            acceptingOrders: true
        };

        function getProfile() {
            const saved = localStorage.getItem('bobo_baker_profile');
            return saved ? JSON.parse(saved) : DEFAULT_BAKER;
        }

        function init() {
            const baker = getProfile();
            document.getElementById('biz-name-input').value = baker.business;
        }

        window.saveSettings = () => {
            const newName = document.getElementById('biz-name-input').value;
            const baker = getProfile();
            baker.business = newName;
            localStorage.setItem('bobo_baker_profile', JSON.stringify(baker));
            alert(`Identity Updated to: ${newName}. Refreshing layout...`);
            window.location.reload();
        }

        window.resetAllData = () => {
            if (confirm("CRITICAL: Are you sure you want to delete ALL business orders and local data? This cannot be undone.")) {
                localStorage.removeItem('bobo_orders');
                localStorage.removeItem('bobo_products');
                localStorage.removeItem('bobo_baker_profile');
                alert("Platform data has been reset to defaults.");
                window.location.href = "/bakers-os";
            }
        }

        function getTenantId() {
            try {
                const host = window.location.host;
                const parts = host.split('.');
                // If it's a subdomain (e.g., myshop.boboanalytics.com) but not 'www'
                if (parts.length > 2 && !host.includes('localhost') && !host.includes('vercel.app') && parts[0] !== 'www') {
                    return parts[0];
                }
                return 'default_baker';
            } catch(e) {
                return 'default_baker';
            }
        }
        
        window.saveUPI = async () => {
            const btn = document.getElementById('upi-btn');
            const upiInput = document.getElementById('upi-input');
            const upi = upiInput.value;
            
            if (!upi) return alert("Please enter a valid UPI ID");

            const tenantId = getTenantId();
            console.log("Saving for tenant:", tenantId);
            
            btn.innerText = "Saving...";
            btn.style.opacity = "0.7";
            btn.disabled = true;

            try {
                const res = await fetch("/api/settings/upi", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ upi, tenantId: tenantId })
                });
                const data = await res.json();
                if (res.ok) {
                    alert("✅ UPI Connected Successfully!");
                } else {
                    alert("❌ Error: " + (data.error || data.message || "Failed to save UPI"));
                }
            } catch (e) {
                alert("🆘 Failed to connect UPI (Network Error)");
            } finally {
                btn.innerText = "Update UPI";
                btn.style.opacity = "1";
                btn.disabled = false;
            }
        };

        async function loadSettings() {
            const tenantId = getTenantId();
            try {
                const res = await fetch(`/api/settings/${tenantId}`);
                if (res.ok) {
                    const settings = await res.json();
                    if (settings.upi) {
                        document.getElementById('upi-input').value = settings.upi;
                    }
                }
            } catch(e) {}
        }

        init();
        loadSettings();
    </script>
</BakersOSLayout>
