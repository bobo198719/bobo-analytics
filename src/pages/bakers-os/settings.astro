---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
import BakersSubNav from "../../components/BakersSubNav.astro";
---

<BakersOSLayout title="Baker Settings | Home Bakers OS">
  <BakersSubNav active="settings" />
  
  <div class="settings-wrapper">
      <div class="settings-header">
          <h1 style="font-size: 2.2rem; font-weight: 800; font-family: 'Outfit'; letter-spacing: -0.02em;">Store <span class="gradient-text">Configuration</span></h1>
          <p style="color: var(--text-muted); font-size: 1.1rem;">Customize your patisserie's digital identity and system behavior.</p>
      </div>

      <div class="settings-sections">
          <div class="settings-card glass-card">
              <div class="card-title-row">
                  <div class="icon-wrap">🏪</div>
                  <h3>General Configuration</h3>
              </div>
              <div class="form-grid">
                  <div class="input-group">
                      <label>Patisserie Name</label>
                      <input type="text" value="Sarah's Patisserie" />
                  </div>
                  <div class="input-group">
                      <label>Business Email</label>
                      <input type="email" value="sarah@bakersos.com" />
                  </div>
                  <div class="input-group">
                      <label>Currency</label>
                      <select>
                          <option>INR (₹)</option>
                          <option>USD ($)</option>
                          <option>GBP (£)</option>
                      </select>
                  </div>
                  <div class="input-group">
                      <label>Timezone</label>
                      <select>
                          <option>(GMT+5:30) Mumbai, Kolkata</option>
                          <option>(GMT+0:00) London</option>
                      </select>
                  </div>
              </div>
          </div>

          <div class="settings-card glass-card">
              <div class="card-title-row">
                  <div class="icon-wrap">🎨</div>
                  <h3>Branding & Aesthetics</h3>
              </div>
              <div class="branding-grid">
                  <div class="logo-upload">
                      <div class="logo-preview">🧁</div>
                      <button class="hb-btn-sm">Change Logo</button>
                  </div>
                  <div class="theme-picker">
                      <label>Brand Accent Color</label>
                      <div class="color-options">
                          <div class="color-dot active" style="background: #f472b6;"></div>
                          <div class="color-dot" style="background: #fb923c;"></div>
                          <div class="color-dot" style="background: #a855f7;"></div>
                          <div class="color-dot" style="background: #10b981;"></div>
                          <div class="color-dot" style="background: #d4af37;"></div>
                      </div>
                  </div>
              </div>
          </div>

          <div class="settings-card glass-card">
              <h3>Notification Preferences</h3>
              <div class="toggle-list">
                  <div class="toggle-item">
                      <div class="info">
                          <span class="t-title">Order Alerts</span>
                          <span class="t-desc">Receive notifications for new orders on WhatsApp.</span>
                      </div>
                      <div class="switch active"></div>
                  </div>
                  <div class="toggle-item">
                      <div class="info">
                          <span class="t-title">Stock Reminders</span>
                          <span class="t-desc">Alert when ingredients are running low.</span>
                      </div>
                      <div class="switch"></div>
                  </div>
              </div>
          </div>

          <div class="danger-zone">
              <button class="delete-btn">Deactivate Baker Account</button>
          </div>
      </div>
  </div>

  <style>
      .gradient-text { background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
      .settings-wrapper { max-width: 900px; padding-bottom: 100px; }
      .settings-header { margin-bottom: 48px; }
      .settings-sections { display: flex; flex-direction: column; gap: 32px; }
      
      .settings-card { padding: 40px; border-radius: 24px; border: 1px solid var(--border); transition: 0.3s; }
      .settings-card:hover { border-color: rgba(244, 114, 182, 0.3); }
      
      .card-title-row { display: flex; align-items: center; gap: 16px; margin-bottom: 32px; }
      .icon-wrap { width: 44px; height: 44px; background: rgba(255,255,255,0.05); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; border: 1px solid var(--border); }
      .settings-card h3 { margin: 0; font-family: 'Outfit'; font-size: 1.5rem; letter-spacing: -0.01em; }
      
      .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
      .input-group { display: flex; flex-direction: column; gap: 10px; }
      .input-group label { font-size: 0.7rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
      .input-group input, .input-group select { background: rgba(0,0,0,0.2); border: 1px solid var(--border); padding: 14px; border-radius: 12px; color: white; font-size: 0.95rem; transition: 0.2s; }
      .input-group input:focus { border-color: var(--primary); outline: none; }

      .branding-grid { display: flex; gap: 48px; align-items: center; }
      .logo-upload { display: flex; flex-direction: column; align-items: center; gap: 16px; }
      .logo-preview { width: 80px; height: 80px; background: rgba(255,255,255,0.03); border: 2px dashed var(--border); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; }
      .hb-btn-sm { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 8px 16px; border-radius: 8px; font-size: 0.8rem; font-weight: 700; cursor: pointer; }

      .color-options { display: flex; gap: 12px; margin-top: 12px; }
      .color-dot { width: 32px; height: 32px; border-radius: 50%; cursor: pointer; border: 2px solid transparent; transition: 0.2s; }
      .color-dot:hover { transform: scale(1.1); }
      .color-dot.active { border-color: white; transform: scale(1.1); box-shadow: 0 0 15px rgba(255,255,255,0.2); }

      .toggle-list { display: flex; flex-direction: column; gap: 24px; }
      .toggle-item { display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.02); padding: 20px; border-radius: 16px; border: 1px solid var(--border); }
      .t-title { display: block; font-weight: 700; font-size: 1.1rem; margin-bottom: 4px; }
      .t-desc { font-size: 0.9rem; color: var(--text-muted); }

      .switch { width: 48px; height: 26px; background: rgba(255,255,255,0.1); border-radius: 30px; position: relative; cursor: pointer; transition: 0.3s; }
      .switch.active { background: var(--primary); box-shadow: 0 0 15px rgba(244, 114, 182, 0.4); }
      .switch::after { content: ""; position: absolute; left: 4px; top: 4px; width: 18px; height: 18px; background: white; border-radius: 50%; transition: 0.3s; }
      .switch.active::after { left: 26px; }

      .danger-zone { margin-top: 64px; border-top: 1px solid var(--border); padding-top: 48px; }
      .delete-btn { background: transparent; border: 1px solid #ef4444; color: #ef4444; padding: 14px 28px; border-radius: 14px; font-weight: 700; cursor: pointer; transition: 0.2s; font-family: 'Outfit'; }
      .delete-btn:hover { background: rgba(239, 68, 68, 0.1); transform: translateY(-2px); }
  </style>
</BakersOSLayout>
