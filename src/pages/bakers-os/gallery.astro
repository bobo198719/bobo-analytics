---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
import BakersSubNav from "../../components/BakersSubNav.astro";

const gallery = [
  { id: 1, name: "Celestial Wedding Cake", category: "Cakes", desc: "4-tier vanilla bean cake with gold leaf finish." },
  { id: 2, name: "Panda Themed Birthday", category: "Cakes", desc: "Cute fondant panda cake for kids." },
  { id: 3, name: "Galaxy Cupcake Set", category: "Cupcakes", desc: "Deep space colored buttercream with edible glitter." }
];
---

<BakersOSLayout title="Baker Gallery | Baker OS">
  <BakersSubNav active="gallery" />
  
  <div class="gallery-grid" id="gallery-list">
      <!-- Dynamic Content -->
  </div>

  <script is:inline>
      async function loadGallery() {
          const list = document.getElementById('gallery-list');
          try {
              // Add Matrix Time-Sync to bypass stale cache echoes
              const res = await fetch(`/api/products?t=${Date.now()}`);
              
              if (!res.ok) {
                  throw new Error(`Sync Failure: ${res.status}`);
              }
              
              const products = await res.json();
              
              if (!Array.isArray(products) || products.length === 0) {
                  list.innerHTML = `
                    <div style="grid-column: 1/-1; text-align: center; padding: 100px; background: rgba(255,255,255,0.02); border: 2px dashed rgba(255,255,255,0.1); border-radius: 40px;">
                        <div style="font-size: 4rem; opacity: 0.2; margin-bottom: 24px;">🍰</div>
                        <p style="font-size: 1.2rem; font-weight: 700; color: rgba(255,255,255,0.4);">No creations in your gallery yet.</p>
                        <button onclick="window.location.href='/bakers-os/products'" style="margin-top: 24px; padding: 12px 32px; background: var(--primary); color: white; border: none; border-radius: 12px; font-weight: 900; cursor: pointer;">+ New Bake</button>
                    </div>`;
                  return;
              }

              list.innerHTML = products.map(p => {
                  const category = p.category || p.cat || 'General';
                  const description = p.description || p.desc || 'No description available for this masterpiece.';
                  
                  // Normalize Image Path Matrix
                  let rawImg = p.image_url || p.image_path || "";
                  let fullImgUrl = "/assets/cake-placeholder.png";
                  if (rawImg) {
                      if (rawImg.startsWith('http')) {
                          fullImgUrl = rawImg;
                      } else {
                          fullImgUrl = "/api" + (rawImg.startsWith('/') ? '' : '/') + rawImg;
                      }
                  }

                  return `
                    <div class="gallery-card glass-card">
                        <div class="g-img">
                            <img src="${fullImgUrl}" 
                                 style="width: 100%; height: 100%; object-fit: cover;" 
                                 onerror="this.src='/assets/cake-placeholder.png'"
                                 loading="lazy" />
                        </div>
                        <div class="g-info">
                            <div class="g-top">
                                <h3 style="font-weight: 900; tracking-tighter;">${p.name}</h3>
                                <span class="tag">${category}</span>
                            </div>
                            <p style="font-size: 0.8rem; margin-top: 4px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">${description}</p>
                            <div class="g-actions">
                                <button onclick="window.location.href='/bakers-os/products'" style="font-weight: 900;">✏️ Edit</button>
                                <a href="/bakers-os/website" target="_blank" class="view-btn" style="font-weight: 900;">🌎 Live Site</a>
                            </div>
                        </div>
                    </div>`;
              }).join('') + `
                  <div class="add-gallery-card glass-card" onclick="window.location.href='/bakers-os/products'" style="min-height: 480px; border: 3px dashed rgba(255,255,255,0.05); background: rgba(255,255,255,0.01);">
                      <div class="add-ic" style="font-size: 3rem; color: var(--primary);">+</div>
                      <p style="font-weight: 900; uppercase; tracking-widest; color: rgba(255,255,255,0.3);">Add to Portfolio</p>
                  </div>`;
          } catch (e) {
              console.error('Gallery Sync Error:', e);
              list.innerHTML = `
                <div style="grid-column: 1/-1; text-align: center; padding: 100px; background: rgba(239, 68, 68, 0.05); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 40px;">
                    <div style="font-size: 3rem; margin-bottom: 24px;">⛔</div>
                    <p style="font-weight: 900; color: #ef4444; uppercase; tracking-widest;">Gallery Link Severed</p>
                    <p style="font-size: 0.8rem; color: rgba(255,255,255,0.3); margin-top: 10px;">The Matrix is unable to fetch your creations. Please check your internet or retry sync.</p>
                    <button onclick="loadGallery()" style="margin-top: 24px; padding: 10px 24px; border: 1px solid #ef4444; color: #ef4444; background: transparent; border-radius: 8px; font-weight: 900; cursor: pointer;">Retry Sync</button>
                </div>`;
          }
      }
      document.addEventListener('DOMContentLoaded', loadGallery);
  </script>

  <style>
      .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
      .add-btn { background: var(--primary); border: none; color: white; padding: 12px 24px; border-radius: 12px; cursor: pointer; font-weight: 700; }

      .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
      .gallery-card { overflow: hidden; display: flex; flex-direction: column; transition: 0.3s; }
      .gallery-card:hover { transform: translateY(-8px); border-color: var(--primary); }
      
      .g-img { height: 260px; background: rgba(0,0,0,0.1); display: flex; align-items: center; justify-content: center; font-size: 4rem; }
      .g-info { padding: 24px; display: flex; flex-direction: column; gap: 12px; }
      .g-top { display: flex; justify-content: space-between; align-items: center; }
      .g-top h3 { font-family: 'Outfit'; font-size: 1.25rem; }
      .tag { background: rgba(244, 114, 182, 0.1); color: var(--primary); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; padding: 4px 10px; border-radius: 30px; }
      .g-info p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.5; }

      .g-actions { display: flex; gap: 12px; margin-top: 12px; }
      .g-actions button, .g-actions .view-btn { flex: 1; background: transparent; border: 1px solid var(--border); color: var(--text-muted); padding: 8px; border-radius: 8px; font-weight: 700; cursor: pointer; text-decoration: none; text-align: center; font-size: 0.8rem; }
      .g-actions .view-btn { background: var(--primary); color: white; border: none; }

      .add-gallery-card { border: 2px dashed var(--border); background: transparent; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; cursor: pointer; }
      .add-ic { font-size: 2.5rem; }
  </style>
</BakersOSLayout>
