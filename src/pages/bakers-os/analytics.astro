---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
---

<BakersOSLayout title="Sales Intelligence | Home Bakers OS">
    <div class="header">
        <h1>Sales Intelligence</h1>
        <p>Deep dive into your business growth and trends.</p>
    </div>

    <!-- Quick Insights -->
    <div class="insight-cards">
        <div class="glass-card insight">
            <span class="l">Year-on-Year Growth</span>
            <div class="v">+32.5%</div>
            <div class="sparkline"><div class="fill" style="width: 70%"></div></div>
        </div>
        <div class="glass-card insight">
            <span class="l">Avg. Ticket Size</span>
            <div class="v">₹1,450</div>
            <p>Up ₹120 this month</p>
        </div>
        <div class="glass-card insight highlight">
            <span class="l">Most Sold Category</span>
            <div class="v">Custom Cakes</div>
            <p>42% Contribution</p>
        </div>
        <div class="glass-card insight highlight">
            <span class="l">Bestselling Bake</span>
            <div class="v">Biscoff Cheesecake</div>
            <p>84 Units Sold</p>
        </div>
    </div>

    <div class="analytics-main">
        <!-- Revenue Chart -->
        <div class="glass-card chart-hero">
            <div class="chart-header">
                <h3>Revenue Trend (6 Months)</h3>
                <div class="selectors">
                    <span class="active">Monthly</span>
                    <span>Weekly</span>
                </div>
            </div>
            <div class="line-chart">
                <!-- Mock Line Chart -->
                <svg viewBox="0 0 1000 300" preserveAspectRatio="none">
                    <path d="M0,250 Q100,260 200,180 T400,200 T600,80 T800,100 T1000,20" fill="none" stroke="var(--primary)" stroke-width="6" />
                    <circle cx="0" cy="250" r="8" fill="var(--primary)" />
                    <circle cx="200" cy="180" r="8" fill="var(--primary)" />
                    <circle cx="400" cy="200" r="8" fill="var(--primary)" />
                    <circle cx="600" cy="80" r="8" fill="var(--primary)" />
                    <circle cx="800" cy="100" r="8" fill="var(--primary)" />
                    <circle cx="1000" cy="20" r="8" fill="var(--primary)" />
                </svg>
                <div class="labels">
                    <span>Oct</span><span>Nov</span><span>Dec</span><span>Jan</span><span>Feb</span><span>Mar</span>
                </div>
            </div>
        </div>

        <!-- Secondary Stats -->
        <div class="stats-side">
            <div class="glass-card leaderboard">
                <h3>Top Performing Bakes</h3>
                <div class="rank-list">
                    <div class="rank-item">
                        <div class="n">01</div>
                        <div class="d">
                            <strong>Lotus Biscoff Cheesecake</strong>
                            <span>₹1,12,000 Revenue</span>
                        </div>
                    </div>
                    <div class="rank-item">
                        <div class="n">02</div>
                        <div class="d">
                            <strong>Belgian Dark Truffle</strong>
                            <span>₹94,500 Revenue</span>
                        </div>
                    </div>
                    <div class="rank-item">
                        <div class="n">03</div>
                        <div class="d">
                            <strong>Classic Red Velvet</strong>
                            <span>₹72,000 Revenue</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .header { margin-bottom: 32px; }
        
        .insight-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 32px; }
        .insight { padding: 32px; text-align: center; }
        .insight .l { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 800; display: block; margin-bottom: 12px; }
        .insight .v { font-size: 1.8rem; font-weight: 900; color: white; display: block; margin-bottom: 8px; }
        .insight p { font-size: 0.8rem; color: var(--text-muted); }
        .insight.highlight { border-color: var(--primary); }
        .insight.highlight .v { color: var(--primary); }
        
        .sparkline { height: 4px; background: rgba(255,255,255,0.05); border-radius: 2px; margin-top: 16px; position: relative; }
        .sparkline .fill { height: 100%; background: #4ade80; border-radius: 2px; }

        .analytics-main { display: grid; grid-template-columns: 1fr 340px; gap: 32px; }
        
        .chart-hero { padding: 40px; }
        .chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
        .chart-header h3 { font-size: 1.1rem; }
        .selectors { background: rgba(0,0,0,0.2); padding: 4px; border-radius: 8px; display: flex; gap: 4px; }
        .selectors span { padding: 6px 16px; font-size: 0.8rem; cursor: pointer; border-radius: 6px; }
        .selectors span.active { background: var(--primary); color: white; }

        .line-chart { height: 300px; display: flex; flex-direction: column; justify-content: space-between; }
        .line-chart svg { width: 100%; height: 240px; filter: drop-shadow(0 10px 10px rgba(244, 114, 182, 0.2)); }
        .labels { display: flex; justify-content: space-between; padding: 0 10px; font-size: 0.75rem; color: var(--text-muted); font-weight: 700; }

        .leaderboard { padding: 32px; }
        .leaderboard h3 { font-size: 1rem; margin-bottom: 24px; color: var(--primary); }
        .rank-list { display: flex; flex-direction: column; gap: 20px; }
        .rank-item { display: flex; gap: 16px; align-items: center; }
        .rank-item .n { font-size: 1.5rem; font-weight: 900; color: white; opacity: 0.2; }
        .rank-item .d strong { display: block; font-size: 0.85rem; }
        .rank-item .d span { font-size: 0.75rem; color: var(--text-muted); }

        @media (max-width: 1200px) {
            .insight-cards { grid-template-columns: repeat(2, 1fr); }
            .analytics-main { grid-template-columns: 1fr; }
        }
    </style>
</BakersOSLayout>
