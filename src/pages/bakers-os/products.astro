---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
---

<BakersOSLayout title="Product Menu | Trivia">
    <div class="header">
        <div class="title-area">
            <h1>Product Catalogue</h1>
            <p>Manage your signature bakes and pricing.</p>
        </div>
        <div class="actions" style="display: flex; gap: 12px; position: relative; z-index: 1000;">
            <button class="btn btn-secondary" onclick="resetDatabase(this)" style="cursor: pointer; pointer-events: auto; position: relative; z-index: 1001;" title="Clear all and sync defaults">🔄 Reset</button>
            <div class="bulk-upload-wrapper">
                <button class="btn btn-secondary" onclick="document.getElementById('bulk-upload-input').click()">
                    <span>📦 Bulk Images</span>
                </button>
                <input type="file" id="bulk-upload-input" multiple accept="image/jpeg,image/png,image/webp" style="display: none;" onchange="handleBulkUpload(this)" />
            </div>
            <button class="btn btn-primary" onclick="openProductModal()">+ New Bake</button>
        </div>
    </div>

    <!-- Status Tabs -->
    <div class="status-tabs-container">
        <div class="status-tabs" id="status-tabs">
            <button class="s-tab active" onclick="filterByStatus('all', this)">All Products (<span id="count-all">0</span>)</button>
            <button class="s-tab" onclick="filterByStatus('pending', this)">Review Gallery (<span id="count-pending">0</span>)</button>
            <button class="s-tab" onclick="filterByStatus('approved', this)">Live on Site (<span id="count-approved">0</span>)</button>
        </div>
        <div id="bulk-actions" style="display: none;">
            <button class="btn btn-primary" onclick="bulkApprove()">👌 Publish All Pending</button>
        </div>
    </div>

    <!-- Product Grid -->
    <div class="product-grid" id="product-list">
        <!-- Data via JS -->
    </div>

    <!-- Add/Edit Modal -->
    <div id="product-modal" class="modal-overlay">
        <div class="modal-content glass-card">
            <div class="modal-header">
                <h2 id="modal-title">New Signature Bake</h2>
                <button class="close-btn" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="m-row">
                    <div class="input-group">
                        <label>Cake/Bake Name</label>
                        <input type="text" id="p-name" placeholder="e.g. Belgian Truffle" />
                    </div>
                    <div class="input-group">
                        <label>Rate (₹)</label>
                        <input type="number" id="p-price" value="1200" />
                    </div>
                </div>
                <div class="input-group">
                    <label>Cake Description</label>
                    <textarea id="p-desc" rows="3" placeholder="Describe the flavors and layers..."></textarea>
                </div>
                <div class="m-row">
                    <div class="input-group">
                        <label>Category</label>
                        <select id="p-cat">
                            <option>Chocolate Cakes</option>
                            <option>Vanilla Cakes</option>
                            <option>Fruit Cakes</option>
                            <option>Cheesecakes</option>
                            <option>Tiered Celebration Cakes</option>
                            <option>Cupcakes & Muffins</option>
                            <option>Brownies & Blondies</option>
                            <option>Cookies & Macarons</option>
                            <option>Pastries & Tarts</option>
                            <option>Bread & Savory Bakes</option>
                            <option>Gifting Hampers</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>Prep Time</label>
                        <input type="text" id="p-prep" placeholder="e.g. 4h" />
                    </div>
                </div>
                <div class="input-group">
                    <label>Product Image (Studio Quality)</label>
                    <div class="file-upload-wrapper">
                        <input type="file" id="p-image-file" accept="image/jpeg,image/png,image/webp" onchange="previewProductImage(this)" />
                        <div class="file-preview" id="p-image-preview"></div>
                        <p style="font-size: 0.7rem; color: var(--text-muted); margin-top: 8px;">Supports JPG, PNG, WEBP. AI background removal will be applied.</p>
                    </div>
                </div>
                <button class="btn btn-primary w-full" style="margin-top: 20px;" onclick="saveProduct()">Save Product Details</button>
            </div>
        </div>
    </div>

    <!-- Processing Overlay -->
    <div id="processing-overlay" class="modal-overlay" style="z-index: 3000;">
        <div class="processing-content glass-card" style="text-align: center; padding: 40px; max-width: 400px; width: 100%;">
            <div class="ai-spinner"></div>
            <h2 style="margin-top: 24px;">AI Image Processing</h2>
            <p style="color: var(--text-muted); margin-top: 12px; font-size: 0.9rem;">Enhancing details, removing backgrounds, and optimizing architecture...</p>
            <div class="progress-bar-container" style="width: 100%; height: 6px; background: rgba(255,255,255,0.1); border-radius: 10px; margin-top: 24px; overflow: hidden;">
                <div id="processing-progress" style="width: 0%; height: 100%; background: var(--primary); transition: width 0.3s;"></div>
            </div>
            <p id="processing-status" style="font-size: 0.7rem; margin-top: 12px; color: var(--primary);">0 / 0 processed</p>
        </div>
    </div>

    <style is:inline>
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
        .btn-primary { background: var(--primary); color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; border: none; cursor: pointer; transition: 0.3s; }
        .btn-primary:hover { opacity: 0.9; transform: translateY(-2px); }
        .btn-secondary { background: rgba(255,255,255,0.05); color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; border: 1px solid var(--border); cursor: pointer; }
        .w-full { width: 100%; }

        .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }
        
        .product-card { 
            background: var(--bg-card); 
            border: 1px solid var(--border); 
            border-radius: 20px; 
            overflow: hidden;
            display: flex; 
            flex-direction: column; 
            transition: 0.3s;
        }
        .product-card:hover { transform: translateY(-8px); border-color: var(--primary); }
        
        .p-image { 
            width: 100% !important; 
            aspect-ratio: 1 / 1 !important; 
            background-size: cover !important; 
            background-position: center !important; 
            position: relative; 
            background-color: #1a1a1a; 
            display: block !important;
            border-bottom: 1px solid var(--border);
        }
        .p-body { padding: 20px; display: flex; flex-direction: column; gap: 12px; flex: 1; }

        .p-top { display: flex; justify-content: space-between; align-items: flex-start; }
        .p-cat { font-size: 0.65rem; background: rgba(244, 114, 182, 0.2); color: var(--primary); padding: 4px 10px; border-radius: 20px; font-weight: 800; text-transform: uppercase; }
        .p-prep { font-size: 0.75rem; color: var(--text-muted); }

        .p-info h3 { font-size: 1.1rem; font-family: 'Outfit'; margin-bottom: 4px; }
        .p-info p { font-size: 0.8rem; color: var(--text-muted); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        
        .p-footer { display: flex; flex-direction: column; gap: 12px; margin-top: auto; padding-top: 16px; border-top: 1px dashed var(--border); }
        .p-price { font-size: 1.25rem; font-weight: 900; color: white; margin-bottom: 5px; }
        
        .p-actions { display: flex; gap: 8px; width: 100%; flex-wrap: wrap; }
        .p-btn { border: 1px solid var(--border); background: rgba(255,255,255,0.05); color: white; padding: 10px 15px; border-radius: 12px; cursor: pointer; flex: 1; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; transition: 0.2s; min-width: 80px; }
        .p-btn:hover { background: rgba(255,255,255,0.1); border-color: var(--primary); }
        .p-btn.approve { background: var(--primary); color: white; border: none; font-weight: 800; }
        .p-btn.approve:hover { filter: brightness(1.1); }

        .status-tabs-container { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; border-bottom: 1px solid var(--border); }
        .status-tabs { display: flex; gap: 24px; }
        .s-tab { background: none; border: none; color: var(--text-muted); font-weight: 700; cursor: pointer; padding: 16px 0; position: relative; font-size: 0.95rem; }
        .s-tab.active { color: var(--primary); }
        .s-tab.active::after { content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 3px; background: var(--primary); border-radius: 10px; }
        .s-tab span { font-size: 0.8rem; opacity: 0.7; }

        .pending-review-card { border: 2px solid #fb923c; background: rgba(251, 146, 60, 0.05); }

        .image-status-badge { position: absolute; top: 12px; right: 12px; padding: 4px 12px; border-radius: 50px; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; z-index: 5; }
        .status-pending { background: #fb923c; color: white; }
        .status-approved { background: #4ade80; color: white; }

        /* Modal */
        .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); z-index: 2000; display: none; align-items: center; justify-content: center; padding: 20px; }
        .modal-content { max-width: 500px; width: 100%; padding: 32px; border: 1px solid var(--border); }
        .modal-header { display: flex; justify-content: space-between; margin-bottom: 24px; }
        .close-btn { background: none; border: none; color: white; font-size: 2rem; cursor: pointer; }
        .m-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

        .input-group { margin-bottom: 16px; }
        .input-group label { display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 6px; }
        .input-group input, .input-group textarea, .input-group select {
            width: 100%;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px;
            color: white;
            font-family: inherit;
        }

        .file-upload-wrapper {
            position: relative;
            background: rgba(255,255,255,0.03);
            border: 2px dashed var(--border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
        }
        .file-upload-wrapper input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
        .file-preview { width: 100%; aspect-ratio: 1/1; max-height: 150px; background-size: cover; background-position: center; margin-top: 10px; border-radius: 8px; display: none; background-color: white; }
        
        .ai-spinner {
            width: 40px; height: 40px; border: 3px solid rgba(244, 114, 182, 0.1); border-left-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>

    <script is:inline>
        // ═══════════════════════════════════════════════════════════════════
        //  IndexedDB image store — legacy support for older uploads
        //  New uploads are stored on the backend in /public/uploads/products
        //  localStorage only holds lightweight product metadata (no blobs)
        // ═══════════════════════════════════════════════════════════════════
        const IDB_NAME    = 'bobo_image_store';
        const IDB_VERSION = 1;
        const IDB_STORE   = 'images';

        function openImageDB() {
            return new Promise((resolve, reject) => {
                const req = indexedDB.open(IDB_NAME, IDB_VERSION);
                req.onupgradeneeded = e => {
                    if (!e.target.result.objectStoreNames.contains(IDB_STORE))
                        e.target.result.createObjectStore(IDB_STORE, { keyPath: 'id' });
                };
                req.onsuccess = e => resolve(e.target.result);
                req.onerror   = e => reject(e);
            });
        }

        async function saveImageToDB(imageId, thumbnail, medium, highRes) {
            const db = await openImageDB();
            return new Promise((resolve, reject) => {
                const tx = db.transaction(IDB_STORE, 'readwrite');
                tx.objectStore(IDB_STORE).put({ id: imageId, thumbnail, medium, high_res: highRes });
                tx.oncomplete = resolve;
                tx.onerror    = reject;
            });
        }

        async function getImageFromDB(imageId) {
            if (!imageId) return null;
            const db = await openImageDB();
            return new Promise(resolve => {
                const req = db.transaction(IDB_STORE, 'readonly').objectStore(IDB_STORE).get(imageId);
                req.onsuccess = e => resolve(e.target.result || null);
                req.onerror   = () => resolve(null);
            });
        }

        async function deleteImageFromDB(imageId) {
            if (!imageId) return;
            const db = await openImageDB();
            return new Promise(resolve => {
                const tx = db.transaction(IDB_STORE, 'readwrite');
                tx.objectStore(IDB_STORE).delete(imageId);
                tx.oncomplete = resolve;
                tx.onerror    = resolve;
            });
        }

        // ═══════════════════════════════════════════════════════════════════
        //  Backend image upload — generates 400 / 1024 / 2048 px square files
        //  Stored under /public/uploads/products on the server
        // ═══════════════════════════════════════════════════════════════════
        // Use native Astro API routes for full production/Vercel support
        const API_BASE = 'https://www.boboanalytics.com/api';
        const products_table = [];       /**
         * CLIENT-SIDE IMAGE OPTIMIZER
         * Resizes to 1080x1080, converts to WebP, and compresses.
         */
        async function optimizeImageClient(file) {
            return new Promise((resolve) => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const img = new Image();
                    img.onload = () => {
                        const canvas = document.createElement('canvas');
                        const size = 1080;
                        canvas.width = size;
                        canvas.height = size;
                        const ctx = canvas.getContext('2d');
                        
                        // Square crop / contain logic
                        const min = Math.min(img.width, img.height);
                        const startX = (img.width - min) / 2;
                        const startY = (img.height - min) / 2;
                        
                        ctx.drawImage(img, startX, startY, min, min, 0, 0, size, size);
                        
                        // Sharpness improvement (subtle)
                        ctx.globalAlpha = 0.1;
                        ctx.drawImage(canvas, 0, 0); 
                        ctx.globalAlpha = 1.0;

                        const dataUrl = canvas.toDataURL('image/webp', 0.8);
                        resolve(dataUrl);
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            });
        }

        async function uploadImageToServer(file) {
            const formData = new FormData();
            formData.append('image', file);

            try {
                const response = await fetch(`${API_BASE}/upload-cake-image`, {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('Upload failed status:', response.status, errorText);
                    throw new Error(`Server Error (${response.status}): ${errorText.substring(0, 50)}...`);
                }
                const data = await response.json();
                
                // Return full data object for bulk/metadata compatibility
                return data;
            } catch (error) {
                console.error('Upload error:', error);
                throw error;
            }
        }

        // ═══════════════════════════════════════════════════════════════════
        //  Product state (metadata only — no blobs in localStorage)
        // ═══════════════════════════════════════════════════════════════════
        let products = [];
        let isUploading = false; 
        let currentUploadedImageId   = null;   // legacy image_id for IndexedDB-backed images
        let currentUploadedUrl       = null;   // Cloudinary secure URL
        let editingIndex = null;
        let currentFilter = 'all';

        const TEMPLATES = [
            "Freshly baked premium {name} made with high quality ingredients, soft texture, rich flavor, and beautifully crafted decoration. Perfect for celebrations and special occasions.",
            "Our exquisite {name} is a true delight. Handcrafted using traditional methods and the finest seasonal ingredients to ensure a premium bakery experience.",
            "Indulge in the rich, delicious taste of our {name}. Featuring a soft texture and elegant design, it's the perfect centrepiece for your next big event.",
            "A bakery classic with a gourmet twist. Each {name} is meticulously prepared by our head baker to deliver a professional high-end studio quality dessert."
        ];

        const DEFAULTS = [
            { id:'p1', name:'Spider-Man Theme Cake', cat:'Chocolate Cakes', price:1800, prep:'6h', desc:'Premium chocolate sponge with hand-piped Spider-man web design.', status:'approved', image_url:'/menu-images/whatsapp-image-2026-03-13-at-10-59-57-jpeg-1773564631013.webp' },
            { id:'p2', name:'Classic Smiley Cake',   cat:'Vanilla Cakes',   price:1200, prep:'4h', desc:'Joyful vanilla cream cake with a classic smiley face design.',    status:'approved', image_url:'/menu-images/ww-jpeg-1773564633537.webp' },
            { id:'p3', name:'Luxury Cupcake Box',    cat:'Cupcakes & Muffins',        price:950,  prep:'3h', desc:'Set of 6 gourmet cupcakes with fresh berries and rich frosting.', status:'approved', image_url:'/menu-images/cake2-png-1773563690213.webp' },
            { id:'p4', name:'Doraemon Dream Cake',   cat:'Fruit Cakes',     price:1500, prep:'5h', desc:'Bespoke buttercream cake featuring full Doraemon edible art.', status:'approved', image_url:'/menu-images/wewre-jpeg-1773564630497.webp' },
            { id:'p5', name:'Belgium Truffle Cake',  cat:'Chocolate Cakes', price:1450, prep:'4h', desc:'Dense chocolate sponge with 70% dark Belgian chocolate and silk ganache.', status:'approved', image_url:'/menu-images/whatsapp-image-2026-03-13-at-10-59-51-jpeg-1773564630772.webp' },
            { id:'p6', name:'Biscoff Cheesecake',    cat:'Cheesecakes',        price:1600, prep:'8h', desc:'Creamy Biscoff-infused cheesecake with a crunchy speculoos base.',  status:'approved', image_url:'/menu-images/whatsapp-image-2026-03-13-at-11-00-07-jpeg-1773564632288.webp' },
            { id:'p7', name:'Red Velvet Duo',        cat:'Cupcakes & Muffins',        price:850,  prep:'2h', desc:'Signature red velvet sponge with rich cream cheese frosting.', status:'approved', image_url:'/menu-images/cake3-png-1773563690485.webp' },
            { id:'p8', name:'Mango Delight Cake',    cat:'Fruit Cakes',     price:1350, prep:'5h', desc:'Fresh Alphonso mango chunks layered with soft vanilla sponge.', status:'approved', image_url:'/menu-images/whatsapp-image-2026-03-13-at-11-00-02-jpeg-1773564631780.webp' },
        ];

        async function loadProducts() {
            try {
                const res = await fetch('/api/products');
                const data = await res.json();
                if (Array.isArray(data) && data.length > 0) {
                    products = data;
                } else {
                    products = JSON.parse(JSON.stringify(DEFAULTS));
                    // Optionally save defaults to DB if new account
                }
                renderProducts();
            } catch(e) {
                console.warn('API Error, falling back to defaults:', e);
                products = JSON.parse(JSON.stringify(DEFAULTS));
                renderProducts();
            }
        }

        function safeStorageSet(data) {
            try {
                localStorage.setItem('bobo_products', JSON.stringify(data));
                return true;
            } catch(e) {
                console.error('localStorage full — images should be in IndexedDB, not inline:', e);
                alert('⚠️ Storage is full. Please use the Reset button and re-upload images.');
                return false;
            }
        }

        // ═══════════════════════════════════════════════════════════════════
        //  Render product grid — prefers medium URL, falls back to legacy IDB
        // ═══════════════════════════════════════════════════════════════════
        async function renderProducts() {
            const list     = document.getElementById('product-list');
            const filtered = currentFilter === 'all' ? products : products.filter(p => p.status === currentFilter);

            document.getElementById('count-all').innerText     = products.length;
            document.getElementById('count-pending').innerText = products.filter(p => p.status === 'pending').length;
            document.getElementById('count-approved').innerText= products.filter(p => p.status === 'approved').length;
            document.getElementById('bulk-actions').style.display =
                (currentFilter === 'pending' && products.some(p => p.status === 'pending')) ? 'block' : 'none';

            if (filtered.length === 0) {
                list.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:80px;background:rgba(255,255,255,0.02);border-radius:20px;border:2px dashed var(--border);">
                    <p style="font-size:1.2rem;color:var(--text-muted);">No products in this section.</p></div>`;
                return;
            }

            list.innerHTML = filtered.map(p => {
                const gi        = products.findIndex(x => x.id === p.id);
                const isPending = p.status === 'pending';
                const imgUrl    = p.medium_url || p.thumbnail_url || '';
                return `
                <div class="product-card ${isPending ? 'pending-review-card' : ''}" id="card-${p.id}">
                    <div class="p-image" id="pimg-${p.id}" style="overflow: hidden;">
                        <img src="${p.image_url || p.medium_url || p.thumbnail_url || '/assets/cake-placeholder.png'}" 
                             style="width: 100%; height: 100%; object-fit: cover;" 
                             onerror="this.src='/assets/cake-placeholder.png'"
                             loading="lazy" />
                        <span class="image-status-badge status-${p.status}">${isPending ? '⏳ Review' : '🌎 Live'}</span>
                    </div>
                    <div class="p-body">
                        <div class="p-top">
                            <span class="p-cat">${p.cat}</span>
                            <span class="p-prep">⏱️ ${p.prep}</span>
                        </div>
                        <div class="p-info">
                            <h3>${p.name}</h3>
                            <p>${p.desc}</p>
                        </div>
                        <div class="p-footer">
                            <div class="p-price">₹${p.price}</div>
                            <div class="p-actions">
                                ${isPending ? `<button class="p-btn approve" onclick="approveProduct(${gi})">👌 Publish</button>` : ''}
                                <button class="p-btn" onclick="openProductModal(${gi})">✏️ Edit</button>
                                <button class="p-btn" onclick="del(${gi})">🗑️</button>
                            </div>
                        </div>
                    </div>
                </div>`;
            }).join('');

            // Async: upgrade placeholder to medium-res image from legacy IndexedDB (older uploads only)
            for (const p of filtered) {
                if (!p.medium_url && p.image_id) {
                    getImageFromDB(p.image_id).then(img => {
                        if (!img) return;
                        const el = document.getElementById(`pimg-${p.id}`);
                        if (el) el.style.backgroundImage = `url('${img.medium || img.thumbnail}')`;
                    });
                }
            }
        }

        window.filterByStatus = (status, el) => {
            currentFilter = status;
            document.querySelectorAll('.s-tab').forEach(t => t.classList.remove('active'));
            if (el) el.classList.add('active');
            renderProducts();
        };

        window.bulkApprove = () => {
            products.forEach(p => { if (p.status === 'pending') p.status = 'approved'; });
            safeStorageSet(products);
            renderProducts();
            alert('✅ All products are now LIVE on your website!');
        };

        window.approveProduct = index => {
            products[index].status = 'approved';
            safeStorageSet(products);
            renderProducts();
        };

        // ═══════════════════════════════════════════════════════════════════
        //  Product image preview in modal — uploads to backend and shows high-res
        // ═══════════════════════════════════════════════════════════════════
        window.previewProductImage = async input => {
            const file = input.files[0];
            if (!file) return;

            if (isUploading) return alert('An upload is already in progress. Please wait.');
            isUploading = true;

            const status   = document.getElementById('processing-status');
            const progress = document.getElementById('processing-progress');
            const overlay  = document.getElementById('processing-overlay');
            const preview  = document.getElementById('p-image-preview');

            // Show instant local preview
            const reader = new FileReader();
            reader.onload = e => {
                preview.style.backgroundImage = `url('${e.target.result}')`;
                preview.style.display = 'block';
            };
            reader.readAsDataURL(file);

            overlay.style.display = 'flex';
            status.innerText = 'Optimizing for 1080x1080 WebP…';
            progress.style.width = '30%';

            try {
                // 1. Client-side optimization (Reduces 10MB -> 200KB)
                const optimizedDataUrl = await optimizeImageClient(file);
                
                // Convert DataURL to Blob for FormData
                const response = await fetch(optimizedDataUrl);
                const optimizedBlob = await response.blob();
                
                status.innerText = 'Uploading to production storage…';
                progress.style.width = '60%';

                const result = await uploadImageToServer(optimizedBlob);
                currentUploadedUrl = result.url || result.image_url;

                if (currentUploadedUrl) {
                    preview.style.backgroundImage = `url('${currentUploadedUrl}')`;
                    preview.style.display = 'block';
                    overlay.style.display = 'none';
                }

                progress.style.width = '100%';
            } catch(e) {
                console.error(e);
                alert(`Image upload failed: ${e.message}\n\nPlease check your internet connection and try again.`);
                overlay.style.display = 'none';
            } finally {
                isUploading = false;
            }

            setTimeout(() => {
                overlay.style.display = 'none';
                progress.style.width = '0%';
            }, 400);
        };

        // ═══════════════════════════════════════════════════════════════════
        //  Modal open / close / save
        // ═══════════════════════════════════════════════════════════════════
        window.openProductModal = async (index = null) => {
            editingIndex       = index;
            currentUploadedUrl = null;

            if (index !== null) {
                const p = products[index];
                document.getElementById('modal-title').innerText = 'Edit Signature Bake';
                document.getElementById('p-name').value  = p.name;
                document.getElementById('p-price').value = p.price;
                document.getElementById('p-desc').value  = p.desc;
                document.getElementById('p-cat').value   = p.cat;
                document.getElementById('p-prep').value  = p.prep;

                const preview = document.getElementById('p-image-preview');
                preview.style.display = 'block';
                // Prefer stored URLs; fall back to legacy IndexedDB for older records
                if (p.high_res_url || p.medium_url || p.thumbnail_url) {
                    preview.style.backgroundImage = `url('${p.high_res_url || p.medium_url || p.thumbnail_url || ''}')`;
                } else if (p.image_id) {
                    const img = await getImageFromDB(p.image_id);
                    if (img) {
                        preview.style.backgroundImage = `url('${img.high_res || img.medium || img.thumbnail}')`;
                    } else {
                        preview.style.display = 'none';
                    }
                } else {
                    preview.style.display = 'none';
                }
            } else {
                document.getElementById('modal-title').innerText = 'New Signature Bake';
                document.getElementById('p-name').value  = '';
                document.getElementById('p-price').value = '1200';
                document.getElementById('p-desc').value  = '';
                document.getElementById('p-image-preview').style.display = 'none';
            }
            document.getElementById('product-modal').style.display = 'flex';
        };

        window.closeModal = () => {
            document.getElementById('product-modal').style.display = 'none';
        };

        window.saveProduct = async () => {
            if (isUploading) {
                alert('Still uploading image... Please wait for the upload to complete before saving.');
                return;
            }
            const name  = document.getElementById('p-name').value.trim();
            const price = document.getElementById('p-price').value;
            if (!name || !price) return alert('Name and Price are required.');

            document.getElementById('processing-overlay').style.display = 'flex';
            document.getElementById('processing-status').innerText = 'Securing Product in Database…';

            const existing = editingIndex !== null ? products[editingIndex] : null;
            
            // Prefer the newly uploaded URL, otherwise keep the existing one
            const finalImageUrl = currentUploadedUrl || existing?.image_url || existing?.high_res_url || existing?.medium_url || existing?.thumbnail_url || '';

            const productData = {
                id           : existing?.id, // Let API generate if null
                name, 
                price        : parseFloat(price),
                desc         : document.getElementById('p-desc').value || TEMPLATES[0].replace('{name}', name),
                cat          : document.getElementById('p-cat').value,
                prep         : document.getElementById('p-prep').value || '4h',
                status       : existing?.status || 'approved',
                image_url    : finalImageUrl,
                thumbnail_url: finalImageUrl,
                medium_url   : finalImageUrl,
                high_res_url : finalImageUrl
            };

            try {
                const res = await fetch('/api/products', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(productData)
                });

                if (res.ok) {
                    await loadProducts();
                    closeModal();
                } else {
                    alert('Failed to save product to database.');
                }
            } catch (e) {
                console.error(e);
            } finally {
                document.getElementById('processing-overlay').style.display = 'none';
            }
        };

        // ═══════════════════════════════════════════════════════════════════
        //  Bulk upload — sends each image to backend for 400/1024/2048 px
        // ═══════════════════════════════════════════════════════════════════
        window.handleBulkUpload = async input => {
            const files = Array.from(input.files);
            if (!files.length) return;

            const overlay  = document.getElementById('processing-overlay');
            const progress = document.getElementById('processing-progress');
            const status   = document.getElementById('processing-status');
            overlay.style.display = 'flex';

            let successCount = 0;
            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                status.innerText = `Processing ${i + 1} / ${files.length}: ${file.name}`;
                progress.style.width = `${Math.round(((i) / files.length) * 100)}%`;

                try {
                    // 1. Client-side optimization (Reduces 10MB -> 200KB)
                    const optimizedDataUrl = await optimizeImageClient(file);
                    const response = await fetch(optimizedDataUrl);
                    const optimizedBlob = await response.blob();

                    // Small delay to prevent UI freezing and allow redraw
                    await new Promise(r => setTimeout(r, 100));
                    
                    const result = await uploadImageToServer(optimizedBlob);
                    if (!result || (!result.url && !result.image_url && !result.files)) throw new Error('Invalid response');
                    
                    const imgs = result.files || result; // Handle both direct result and nested files object
                    const fileName = file.name.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ')
                        .split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
                    const desc = TEMPLATES[Math.floor(Math.random() * TEMPLATES.length)].replace('{name}', fileName);

                    products.unshift({
                        id           : 'bulk_' + Date.now() + '_' + Math.random().toString(36).substr(2, 5),
                        name         : fileName,
                        price        : 1500,
                        desc,
                        cat          : 'Chocolate Cakes',
                        prep         : '4h',
                        status       : 'pending',
                        image_id     : null,
                        image_url    : imgs.url || imgs.image_url || imgs.thumbnailUrl || '',
                        thumbnail_url: imgs.url || imgs.image_url || imgs.thumbnailUrl || '',
                        medium_url   : imgs.url || imgs.image_url || imgs.mediumUrl   || imgs.thumbnailUrl || '',
                        high_res_url : imgs.url || imgs.image_url || imgs.highResUrl  || imgs.mediumUrl   || imgs.thumbnailUrl || '',
                    });
                    successCount++;
                } catch(err) {
                    console.error(`Failed to process ${file.name}:`, err);
                    status.innerText = `⚠️ Error uploading ${file.name}... skipping.`;
                    await new Promise(r => setTimeout(r, 1000));
                }
                progress.style.width = `${Math.round(((i + 1) / files.length) * 100)}%`;
            }

            status.innerText = `✅ Finished! ${successCount} of ${files.length} images processed.`;
            const saved = safeStorageSet(products);

            setTimeout(() => {
                overlay.style.display = 'none';
                progress.style.width  = '0%';
                if (saved && successCount > 0) {
                    currentFilter = 'pending';
                    document.querySelectorAll('.s-tab').forEach(t => t.classList.remove('active'));
                    const pendingTab = document.querySelector('button[onclick*="pending"]');
                    if (pendingTab) pendingTab.classList.add('active');
                    alert(`✅ ${successCount} image(s) uploaded successfully!\nThey are now in "Review Gallery". Click 👌 Publish to go live.`);
                }
            renderProducts();
                input.value = '';
            }, 800);
        };


        // ═══════════════════════════════════════════════════════════════════
        //  Initialization
        // ═══════════════════════════════════════════════════════════════════
        window.del = async index => {
            if (!confirm('Delete this bake PERMANENTLY from the database?')) return;
            const p = products[index];
            
            try {
                const res = await fetch(`/api/products?id=${p.id}`, { method: 'DELETE' });
                if (res.ok) {
                    await loadProducts();
                } else {
                    alert('Failed to delete product.');
                }
            } catch (e) {
                console.error(e);
            }
        };

        // ═══════════════════════════════════════════════════════════════════
        //  Reset to defaults
        // ═══════════════════════════════════════════════════════════════════
        window.resetDatabase = function(btn) {
            console.log("Reset triggered");
            if (!confirm('CAUTION: This will delete ALL your products and images. Are you sure?')) return;
            
            if (btn && typeof btn === 'object') {
                btn.innerText = "Cleaning...";
                btn.disabled = true;
            }

            try {
                // Wipe LocalStorage first (instant)
                localStorage.removeItem('bobo_products');
                localStorage.removeItem('bobo_website_data');
                localStorage.removeItem('bobo_cart');
                
                // Wipe IndexedDB
                if (window.indexedDB) {
                    // Force close any internal connections we might have
                    const deleteRequest = indexedDB.deleteDatabase(IDB_NAME);
                    
                    deleteRequest.onsuccess = function() {
                        console.log("DB deleted successfully");
                        window.location.href = window.location.pathname + '?r=' + Date.now();
                    };
                    
                    deleteRequest.onerror = function() {
                        console.warn("DB delete error - falling back to reload");
                        window.location.href = window.location.pathname + '?r=' + Date.now();
                    };
                    
                    deleteRequest.onblocked = function() {
                        console.warn("DB delete blocked - forcing reload anyway");
                        window.location.href = window.location.pathname + '?r=' + Date.now();
                    };
                    
                    // Fallback timeout in case IDB hangs
                    setTimeout(() => {
                        window.location.href = window.location.pathname + '?r=' + Date.now();
                    }, 1000);
                } else {
                    window.location.href = window.location.pathname + '?r=' + Date.now();
                }
            } catch(e) {
                console.error("Reset script error:", e);
                window.location.href = window.location.pathname + '?r=' + Date.now();
            }
        };

        // Global recovery for severe JS errors
        window.onerror = function(msg, url, line) {
            console.error("Critical error:", msg, "at", line);
            // If the script crashes, we at least want to show the Reset button as a recovery path
            return false;
        };

        // ── Bootstrap ──────────────────────────────────────────────────────
        loadProducts();
        document.addEventListener('DOMContentLoaded', renderProducts);
    </script>
</BakersOSLayout>
