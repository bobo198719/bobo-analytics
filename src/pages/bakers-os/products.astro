---
import BakersOSLayout from "../../layouts/BakersOSLayout.astro";
---

<BakersOSLayout title="Product Menu | Home Bakers OS">
    <div class="header">
        <div class="title-area">
            <h1>Product Catalogue</h1>
            <p>Manage your signature bakes and pricing.</p>
        </div>
        <div class="actions">
            <button class="btn btn-primary" onclick="openProductModal()">+ Create New Bake</button>
        </div>
    </div>

    <!-- Product Grid -->
    <div class="product-grid" id="product-list">
        <!-- Data via JS -->
    </div>

    <style>
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
        .btn-primary { background: var(--primary); color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; border: none; cursor: pointer; }

        .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
        
        .product-card { 
            background: var(--bg-card); 
            border: 1px solid var(--border); 
            border-radius: 20px; 
            padding: 24px; 
            display: flex; 
            flex-direction: column; 
            gap: 16px; 
            transition: 0.3s;
        }
        .product-card:hover { transform: translateY(-8px); border-color: var(--primary); }
        
        .p-top { display: flex; justify-content: space-between; align-items: flex-start; }
        .p-cat { font-size: 0.65rem; background: rgba(255,255,255,0.1); padding: 4px 10px; border-radius: 20px; font-weight: 800; text-transform: uppercase; }
        .p-prep { font-size: 0.75rem; color: var(--text-muted); }

        .p-info h3 { font-size: 1.25rem; font-family: 'Outfit'; margin-bottom: 4px; }
        .p-info p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; }
        
        .p-flavor { font-size: 0.8rem; background: rgba(244, 114, 182, 0.1); color: var(--primary); padding: 6px 12px; border-radius: 8px; font-weight: 700; align-self: flex-start; }
        
        .p-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 16px; border-top: 1px dashed var(--border); }
        .p-price { font-size: 1.3rem; font-weight: 900; color: white; }
        
        .p-actions { display: flex; gap: 8px; }
        .p-btn { background: none; border: 1px solid var(--border); color: white; padding: 8px; border-radius: 8px; cursor: pointer; }
        .p-btn:hover { background: var(--border); }
    </style>

    <script is:inline>
        let products = [
            { id: 1, name: 'Belgium Truffle Cake', cat: 'Signature Cakes', flavor: 'Dark Ganache', price: 1200, prep: '4h', desc: 'Dense chocolate sponge with 70% dark Belgian chocolate.' },
            { id: 2, name: 'Biscoff Cheesecake', cat: 'Cheesecakes', flavor: 'Lotus Biscoff', price: 1500, prep: '6h', desc: 'Baked New York style cheesecake with Lotus spread.' },
            { id: 3, name: 'Red Velvet Box (6)', cat: 'Cupcakes', flavor: 'Classic Velvet', price: 450, prep: '2h', desc: 'Classic red velvet with cream cheese frosting.' }
        ];

        function renderProducts() {
            const list = document.getElementById('product-list');
            list.innerHTML = products.map(p => `
                <div class="product-card">
                    <div class="p-top">
                        <span class="p-cat">${p.cat}</span>
                        <span class="p-prep">⏱️ ${p.prep}</span>
                    </div>
                    <div class="p-info">
                        <h3>${p.name}</h3>
                        <p>${p.desc}</p>
                    </div>
                    <div class="p-flavor">${p.flavor}</div>
                    <div class="p-footer">
                        <div class="p-price">₹${p.price}</div>
                        <div class="p-actions">
                            <button class="p-btn" onclick="edit(${p.id})">✏️</button>
                            <button class="p-btn" onclick="del(${p.id})">🗑️</button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        window.del = (id) => {
            products = products.filter(x => x.id != id);
            renderProducts();
        };

        window.openProductModal = () => alert('Product Entry: Name, Category, Flavor, Price, Image, Prep Time.');

        document.addEventListener('DOMContentLoaded', renderProducts);
    </script>
</BakersOSLayout>
