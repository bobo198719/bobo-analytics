---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="My Bobo Workspace | Cloud Command" hideNav={true}>
  <div class="portal-container">
    <aside class="portal-sidebar">
      <div class="sidebar-top">
        <div class="biz-logo">B</div>
        <div class="biz-meta">
            <strong id="sideBizName">My Business</strong>
            <span class="tag trial" id="sideStatus">TRIAL</span>
        </div>
      </div>
      <nav class="portal-nav">
          <a href="#" class="nav-item active">Dashboard</a>
          <a href="#" class="nav-item">Usage & Limits</a>
          <a href="#" class="nav-item">Billing & Invoices</a>
          <a href="#" class="nav-item">Team Settings</a>
          <hr style="opacity:0.05; margin:20px 0;">
          <a href="/" class="nav-item" style="color:var(--primary)">Launch Industry OS →</a>
      </nav>
      <div class="sidebar-footer">
          <button id="portalLogout" class="btn-logout">Sign Out</button>
      </div>
    </aside>

    <main class="portal-main">
        <header class="portal-header">
            <div>
                <h1 id="welcomeMsg">Welcome, Owner</h1>
                <p>Manage your enterprise subscription and workspace resources.</p>
            </div>
            <div class="header-tools">
                <button class="btn-upgrade">🚀 Upgrade Plan</button>
            </div>
        </header>

        <div class="portal-grid">
            <!-- RESOURCE USAGE -->
            <div class="portal-card">
                <h3>Subscription & Usage</h3>
                <div class="usage-meter mt-20">
                    <div class="meter-info"><span>Active Plan:</span> <strong id="planName">...</strong></div>
                    <div class="meter-info"><span>Team Members:</span> <span id="userUsage">...</span></div>
                    <div class="progress-bar"><div class="fill" id="userFill" style="width: 0%"></div></div>
                    
                    <div class="meter-info mt-20"><span>Cloud Storage:</span> <span id="storageUsage">...</span></div>
                    <div class="progress-bar"><div class="fill" id="storageFill" style="width: 0%"></div></div>
                </div>
            </div>

            <!-- WORKSPACE DETAILS -->
            <div class="portal-card">
                <h3>Workspace Configuration</h3>
                <div class="workspace-details mt-20">
                    <div class="detail-row"><span>ID:</span> <code id="bizId">...</code></div>
                    <div class="detail-row"><span>Domain:</span> <code id="bizDomain">...</code></div>
                    <div class="detail-row"><span>Region:</span> <strong>Mumbai (India-1)</strong></div>
                    <div class="detail-row"><span>Database:</span> <strong>Isolated MongoDB</strong></div>
                </div>
            </div>

            <!-- LATEST INVOICES -->
            <div class="portal-card full-width">
                <h3>Recent Billing Activities</h3>
                <table class="portal-table mt-20">
                    <thead><tr><th>Date</th><th>Description</th><th>Amount</th><th>Status</th><th>Receipt</th></tr></thead>
                    <tbody>
                        <tr><td>Mar 12, 2026</td><td>Trial Activation</td><td>₹0</td><td><span class="tag-paid">COMPLETED</span></td><td><button class="btn-sm">PDF</button></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
  </div>
</MainLayout>

<style>
    :root {
        --primary: #6366f1;
        --bg: #05081a;
        --card-bg: rgba(255,255,255,0.03);
        --border: rgba(255,255,255,0.1);
        --text: #ffffff;
        --text-muted: rgba(255,255,255,0.6);
    }
    body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; margin:0;}
    .portal-container { display: flex; height: 100vh; }

    /* Sidebar */
    .portal-sidebar { width: 280px; background: #0f172a; border-right: 1px solid var(--border); padding: 32px 20px; display:flex; flex-direction:column; }
    .sidebar-top { display:flex; align-items:center; gap:16px; margin-bottom:40px; }
    .biz-logo { width:48px; height:48px; background:var(--primary); border-radius:12px; display:flex; align-items:center; justify-content:center; font-weight:900; font-size:1.5rem;}
    .biz-meta strong { display:block; font-size:1.1rem;}
    .tag.trial { background: #451a03; color: #f59e0b; font-size: 0.65rem; padding:2px 8px; border-radius:4px; font-weight:800;}

    .portal-nav { flex:1; }
    .nav-item { display:block; padding:12px 16px; border-radius:12px; color:var(--text-muted); text-decoration:none; font-weight:600; margin-bottom:4px; transition:0.2s;}
    .nav-item:hover, .nav-item.active { background:rgba(99,102,241,0.1); color:var(--primary); }

    /* Main Area */
    .portal-main { flex:1; padding:60px; overflow-y:auto;}
    .portal-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:48px;}
    .portal-header h1 { font-size:2.5rem; font-weight:800; margin:0;}
    .portal-header p { color:var(--text-muted); margin-top:8px;}

    .btn-upgrade { background: var(--primary); color:white; border:none; padding:12px 24px; border-radius:12px; font-weight:700; cursor:pointer;}

    .portal-grid { display:grid; grid-template-columns: 1fr 1fr; gap:32px;}
    .portal-card { background:var(--card-bg); border: 1px solid var(--border); border-radius:24px; padding:32px;}
    .portal-card.full-width { grid-column: span 2; }
    .portal-card h3 { margin:0; font-size:1.25rem;}

    .usage-meter .meter-info { display:flex; justify-content:space-between; font-size:0.9rem; margin-bottom:8px;}
    .progress-bar { height:8px; background:rgba(255,255,255,0.05); border-radius:4px; margin-bottom:12px; }
    .fill { height:100%; border-radius:4px; background:var(--primary); box-shadow: 0 0 10px var(--primary); transition: 1s ease-out;}

    .detail-row { display:flex; justify-content:space-between; padding:12px 0; border-bottom:1px solid rgba(255,255,255,0.05);}
    .detail-row span { color:var(--text-muted); }

    .portal-table { width:100%; border-collapse:collapse; text-align:left;}
    .portal-table th { padding:16px; font-size:0.75rem; color:var(--text-muted); text-transform:uppercase; border-bottom:1px solid var(--border);}
    .portal-table td { padding:16px; border-bottom:1px solid rgba(255,255,255,0.05);}
    
    .tag-paid { color:#10b981; font-weight:800; font-size:0.75rem;}
    .btn-sm { background:rgba(255,255,255,0.05); border:1px solid var(--border); color:white; padding:4px 12px; border-radius:8px; cursor:pointer;}

    .mt-20 { margin-top:20px;}
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Find most recent account on this device
        const accounts = JSON.parse(localStorage.getItem('bobo_accounts') || '[]');
        if(accounts.length === 0) {
            window.location.href = "/signup";
            return;
        }

        const client = accounts[accounts.length - 1]; // Assume last created
        
        document.getElementById('welcomeMsg').innerText = `Welcome, ${client.ownerName.split(' ')[0]}`;
        document.getElementById('sideBizName').innerText = client.businessName;
        document.getElementById('bizId').innerText = client.id;
        document.getElementById('bizDomain').innerText = client.businessName.toLowerCase().replace(/\s+/g,'') + ".boboanalytics.com";
        document.getElementById('planName').innerText = client.plan.toUpperCase();
        
        // Dynamic limits based on plan
        const limits = {
            starter: { users: 3, storage: 5 },
            professional: { users: 10, storage: 50 },
            enterprise: { users: 100, storage: 1000 }
        };

        const l = limits[client.plan] || limits.professional;
        const uUsage = 1; // Current session
        const sUsage = 0.2; // Mock

        document.getElementById('userUsage').innerText = `${uUsage} / ${l.users === 100 ? '∞' : l.users}`;
        document.getElementById('storageUsage').innerText = `${sUsage}GB / ${l.storage === 1000 ? 'Unlimited' : l.storage + 'GB'}`;

        setTimeout(() => {
            document.getElementById('userFill').style.width = (uUsage / l.users * 100) + "%";
            document.getElementById('storageFill').style.width = (sUsage / l.storage * 100) + "%";
        }, 300);

        document.getElementById('portalLogout').addEventListener('click', () => {
            window.location.href = "/signup";
        });
    });
</script>
