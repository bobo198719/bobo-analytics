---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="POS | Restaurant OS">
    <div class="h-screen bg-gray-100 flex flex-col text-gray-900">
        <!-- Header -->
        <header class="bg-indigo-700 text-white p-4 flex justify-between shadow-md">
            <h1 class="text-2xl font-bold tracking-tight">QuickServe POS</h1>
            <div class="flex gap-4">
                <button class="bg-indigo-600 px-4 py-2 rounded-lg font-medium shadow-sm hover:bg-indigo-500 transition">Sync Menus</button>
                <div class="bg-indigo-800 px-4 py-2 rounded-lg font-medium shadow-inner flex items-center">
                    User: Waiter #1
                </div>
            </div>
        </header>

        <!-- Main Body -->
        <main class="flex-1 flex overflow-hidden">
            <!-- Left: Categories & Items -->
            <section class="flex-1 p-6 overflow-y-auto">
                <h2 class="text-xl font-bold mb-4 text-gray-800">CATEGORIES</h2>
                <div class="grid grid-cols-4 gap-4 mb-6" id="kiosk-categories">
                    <!-- Dynamic from Schedule Menu -->
                    <div class="bg-white p-4 rounded-xl shadow-sm text-center font-semibold cursor-pointer border-2 border-transparent hover:border-indigo-500 transition">Breakfast</div>
                    <div class="bg-white p-4 rounded-xl shadow-sm text-center font-semibold cursor-pointer border-2 border-transparent hover:border-indigo-500 transition">Lunch</div>
                    <div class="bg-white p-4 rounded-xl shadow-sm text-center font-semibold cursor-pointer border-2 border-transparent hover:border-indigo-500 transition">Dinner</div>
                    <div class="bg-white p-4 rounded-xl shadow-sm text-center font-semibold cursor-pointer border-2 border-transparent hover:border-indigo-500 transition">Drinks</div>
                </div>

                <h2 class="text-xl font-bold mb-4 text-gray-800">MENU ITEMS</h2>
                <div class="grid grid-cols-3 gap-6" id="pos-menu-grid">
                    <!-- Products map here -->
                    <div class="bg-white rounded-2xl shadow-sm overflow-hidden hover:shadow-md transition cursor-pointer">
                        <div class="h-32 bg-gray-200"></div>
                        <div class="p-4">
                            <h3 class="font-bold text-lg">Avocado Toast</h3>
                            <div class="flex justify-between items-center mt-2">
                                <span class="text-indigo-600 font-bold">$12.00</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Right: Current Ticket context -->
            <aside class="w-1/3 bg-white shadow-xl flex flex-col z-10 border-l border-gray-200">
                <div class="p-4 bg-gray-50 border-b flex justify-between items-center">
                    <h2 class="text-lg font-bold">Current Ticket</h2>
                    <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-xs font-bold uppercase">Table 12</span>
                </div>
                
                <div class="flex-1 overflow-y-auto p-4 flex flex-col gap-3" id="pos-cart">
                    <!-- Cart Items go here -->
                </div>

                <!-- Footer (Totals & Pay) -->
                <div class="border-t p-4 bg-gray-50">
                    <div class="flex justify-between mb-2 text-gray-600"><p>Subtotal</p><p>$0.00</p></div>
                    <div class="flex justify-between mb-2 text-gray-600"><p>Tax / Fees</p><p>$0.00</p></div>
                    <div class="flex justify-between font-bold text-xl mb-4 border-t pt-2"><p>Cash Total</p><p>$0.00</p></div>
                    <div class="flex justify-between font-bold text-lg mb-4 text-gray-500"><p>Card Total</p><p>$0.00</p></div>
                    
                    <div class="grid grid-cols-2 gap-2 mb-2">
                        <button class="bg-gray-200 text-gray-800 p-3 rounded-xl font-bold hover:bg-gray-300">Split Bill</button>
                        <button class="bg-gray-200 text-gray-800 p-3 rounded-xl font-bold hover:bg-gray-300">Discount</button>
                    </div>
                    <button class="w-full bg-indigo-600 text-white p-4 rounded-xl font-bold text-lg shadow hover:bg-indigo-700 transition">Place Order & Pay</button>
                </div>
            </aside>
        </main>
    </div>
</MainLayout>
