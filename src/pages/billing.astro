---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Billing POS">

<div class="billing">

<h1>Pharmacy Billing</h1>

<div class="scanner">

<input id="barcode" placeholder="Scan barcode">
<button onclick="addItem()">Add Item</button>

</div>

<table id="billTable">

<thead>
<tr>
<th>Medicine</th>
<th>Price</th>
<th>Qty</th>
<th>Total</th>
</tr>
</thead>

<tbody></tbody>

</table>

<div class="gst">

<p>Subtotal: ₹<span id="subtotal">0</span></p>
<p>CGST (6%): ₹<span id="cgst">0</span></p>
<p>SGST (6%): ₹<span id="sgst">0</span></p>

<h2>Total: ₹<span id="grandTotal">0</span></h2>

</div>

<div class="actions">

<button onclick="printBill()">Print Invoice</button>
<button onclick="sendBill()">Send WhatsApp Bill</button>

</div>

</div>

<style>

.billing{
max-width:900px;
margin:auto;
padding:40px;
}

.scanner{
margin-bottom:20px;
}

input{
padding:10px;
width:250px;
}

button{
padding:10px 20px;
margin:10px;
background:#00ff88;
border:none;
border-radius:6px;
cursor:pointer;
}

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
}

th,td{
border-bottom:1px solid #ddd;
padding:10px;
}

.gst{
margin-top:30px;
}

.actions{
margin-top:20px;
}

</style>

<script>

let bill=[];

function addItem(){

const barcode=document.getElementById("barcode").value;

const medicineDB={
"123":"Paracetamol",
"456":"Metformin",
"789":"Aspirin"
};

const priceDB={
"123":20,
"456":40,
"789":50
};

const medicine=medicineDB[barcode];

if(!medicine){
alert("Medicine not found");
return;
}

const price=priceDB[barcode];

bill.push({
name:medicine,
price:price,
qty:1
});

renderBill();

document.getElementById("barcode").value="";

}

function renderBill(){

const tbody=document.querySelector("#billTable tbody");

tbody.innerHTML="";

let subtotal=0;

bill.forEach(item=>{

const total=item.price*item.qty;

subtotal+=total;

const row=document.createElement("tr");

row.innerHTML=`
<td>${item.name}</td>
<td>₹${item.price}</td>
<td>${item.qty}</td>
<td>₹${total}</td>
`;

tbody.appendChild(row);

});

document.getElementById("subtotal").innerText=subtotal;

const cgst=subtotal*0.06;
const sgst=subtotal*0.06;

document.getElementById("cgst").innerText=cgst.toFixed(2);
document.getElementById("sgst").innerText=sgst.toFixed(2);

const grandTotal=subtotal+cgst+sgst;

document.getElementById("grandTotal").innerText=grandTotal.toFixed(2);

}

function printBill(){

window.print();

}

async function sendBill(){

const phone=prompt("Enter customer WhatsApp number");

const total=document.getElementById("grandTotal").innerText;

await fetch("/api/whatsapp/send-bill",{

method:"POST",

headers:{
"Content-Type":"application/json"
},

body:JSON.stringify({
pharmacyId:"abc001",
customerPhone:phone,
items:bill,
total:total
})

});

alert("Bill sent on WhatsApp");

}

</script>

</MainLayout>