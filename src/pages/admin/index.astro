---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Admin Dashboard">
    <section class="admin-panel">
        <h1>Admin Dashboard</h1>
        
        <div class="admin-grid">
            <div class="admin-card create-user">
                <h2>Create Industry User</h2>
                <form id="createUserForm">
                    <input type="text" id="newUsername" placeholder="Username" required />
                    <input type="password" id="newPassword" placeholder="Password" required />
                    <select id="industrySelect" required>
                        <option value="">Select Industry</option>
                        <option value="healthcare">Healthcare</option>
                        <option value="pharmacy">Pharmacy</option>
                        <option value="retail">Retail</option>
                        <option value="finance">Finance</option>
                        <option value="groceries">Groceries</option>
                        <option value="clothing-store">Clothing Store</option>
                        <option value="stock-trading">Stock Trading</option>
                        <option value="bakers">Small to Big Business</option>
                        <option value="all">All (Admin)</option>
                    </select>
                    <button type="submit">Create User</button>
                </form>
                <p id="createMsg" class="msg"></p>
            </div>

            <div class="admin-card stats">
                <h2>System Stats</h2>
                <div class="stats-mini">
                    <div class="s-item"><span>Industries</span><strong>8</strong></div>
                    <div class="s-item"><span>Total Users</span><strong id="userCount">...</strong></div>
                </div>
            </div>
        </div>
    </section>

    <style>
        .admin-panel { padding: 80px 20px; background: #0b0b0b; min-height: 80vh; color: white; }
        .admin-panel h1 { text-align: center; margin-bottom: 40px; font-size: 2.5rem; }
        
        .admin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .admin-card {
            background: #151515;
            padding: 30px;
            border-radius: 12px;
            border: 1px solid #333;
        }
        
        .admin-card h2 { margin-bottom: 20px; font-size: 1.5rem; color: #00ff96; }
        
        form { display: flex; flex-direction: column; gap: 15px; }
        input, select { padding: 12px; border-radius: 8px; border: 1px solid #333; background: #0b0b0b; color: white; }
        button { 
            padding: 12px; 
            background: #4f46e5; 
            color: white; 
            border: none; 
            border-radius: 8px; 
            font-weight: 700; 
            cursor: pointer;
        }
        
        .msg { margin-top: 15px; text-align: center; font-size: 0.9rem; }
        .msg.success { color: #00ff96; }
        .msg.error { color: #ff4d4d; }

        .stats-mini { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .s-item { background: #0b0b0b; padding: 20px; border-radius: 10px; text-align: center; }
        .s-item span { display: block; color: #888; font-size: 0.8rem; margin-bottom: 5px; }
        .s-item strong { font-size: 1.8rem; color: #00ff96; }
    </style>

    <script>
        const form = document.getElementById('createUserForm');
        const msgEl = document.getElementById('createMsg');

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const username = document.getElementById('newUsername').value;
            const password = document.getElementById('newPassword').value;
            const industry = document.getElementById('industrySelect').value;

            try {
                const res = await fetch('/api/admin/create-user', {
                    method: 'POST',
                    body: JSON.stringify({ username, password, industry })
                });
                const data = await res.json();

                if (res.ok) {
                    msgEl.className = 'msg success';
                    msgEl.textContent = 'User created successfully!';
                    form.reset();
                } else {
                    msgEl.className = 'msg error';
                    msgEl.textContent = data.error || 'Failed to create user';
                }
            } catch (err) {
                msgEl.className = 'msg error';
                msgEl.textContent = 'Server error';
            }
        });
    </script>
</MainLayout>
