---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Admin Dashboard" hideNav={true}>
    <section class="admin-panel">
        <h1>Admin Dashboard</h1>
        
        <div class="admin-grid">
            <div class="admin-card stats">
                <h2>System Stats</h2>
                <div class="stats-mini">
                    <div class="s-item"><span>Industries</span><strong>8</strong></div>
                    <div class="s-item"><span>Active Nodes</span><strong id="nodeCount">...</strong></div>
                </div>
            </div>

            <div class="admin-card action">
                <h2>Management</h2>
                <p>Access the core SaaS provisioning engine to manage accounts, environments, and subscriptions.</p>
                <a href="/admin/control-panel" class="btn-primary-link">
                    <span>Open Control Panel</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                </a>
            </div>

            <div class="admin-card action saas">
                <h2>SaaS Registry</h2>
                <p>Manage the central user registry, track revenue, and monitor subscription health.</p>
                <a href="/admin/saas" class="btn-primary-link saas-link">
                    <span>SaaS Dashboard</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                </a>
            </div>
        </div>
    </section>

    <style>
        .admin-panel { padding: 80px 20px; background: #0b0b0b; min-height: 80vh; color: white; }
        .admin-panel h1 { text-align: center; margin-bottom: 40px; font-size: 2.5rem; }
        
        .admin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .admin-card {
            background: #151515;
            padding: 30px;
            border-radius: 12px;
            border: 1px solid #333;
        }
        
        .admin-card h2 { margin-bottom: 20px; font-size: 1.5rem; color: #00ff96; }
        .admin-card p { color: #888; font-size: 0.9rem; margin-bottom: 20px; line-height: 1.6; }
        
        .btn-primary-link { 
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 14px 28px; 
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%); 
            color: white; 
            text-decoration: none;
            border-radius: 12px; 
            font-weight: 700; 
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 15px rgba(79, 70, 229, 0.3);
        }
        .btn-primary-link:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 8px 25px rgba(79, 70, 229, 0.5);
            filter: brightness(1.1);
        }
        .btn-primary-link svg { transition: transform 0.3s; }
        .btn-primary-link:hover svg { transform: translateX(5px); }
        .stats-mini { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .s-item { background: #0b0b0b; padding: 20px; border-radius: 10px; text-align: center; }
        .s-item span { display: block; color: #888; font-size: 0.8rem; margin-bottom: 5px; }
        .s-item strong { font-size: 1.8rem; color: #00ff96; }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tenants = JSON.parse(localStorage.getItem('bobo_tenants') || '[]');
            const countEl = document.getElementById('nodeCount');
            if (countEl) countEl.innerText = tenants.length.toString();
        });
    </script>
</MainLayout>
