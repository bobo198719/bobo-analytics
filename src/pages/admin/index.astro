---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Admin Dashboard">
    <section class="admin-panel">
        <h1>Admin Dashboard</h1>
        
        <div class="admin-grid">
            <div class="admin-card stats">
                <h2>System Stats</h2>
                <div class="stats-mini">
                    <div class="s-item"><span>Industries</span><strong>8</strong></div>
                    <div class="s-item"><span>Active Nodes</span><strong id="nodeCount">...</strong></div>
                </div>
            </div>

            <div class="admin-card action">
                <h2>Management</h2>
                <p>Access the core SaaS provisioning engine to manage accounts, environments, and subscriptions.</p>
                <a href="/admin" class="btn-primary-link">Open Control Panel</a>
            </div>
        </div>
    </section>

    <style>
        .admin-panel { padding: 80px 20px; background: #0b0b0b; min-height: 80vh; color: white; }
        .admin-panel h1 { text-align: center; margin-bottom: 40px; font-size: 2.5rem; }
        
        .admin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .admin-card {
            background: #151515;
            padding: 30px;
            border-radius: 12px;
            border: 1px solid #333;
        }
        
        .admin-card h2 { margin-bottom: 20px; font-size: 1.5rem; color: #00ff96; }
        .admin-card p { color: #888; font-size: 0.9rem; margin-bottom: 20px; line-height: 1.6; }
        
        .btn-primary-link { 
            display: inline-block;
            padding: 12px 24px; 
            background: #4f46e5; 
            color: white; 
            text-decoration: none;
            border-radius: 8px; 
            font-weight: 700; 
            transition: 0.2s;
        }
        .btn-primary-link:hover { background: #4338ca; transform: translateY(-2px); }

        .stats-mini { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .s-item { background: #0b0b0b; padding: 20px; border-radius: 10px; text-align: center; }
        .s-item span { display: block; color: #888; font-size: 0.8rem; margin-bottom: 5px; }
        .s-item strong { font-size: 1.8rem; color: #00ff96; }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tenants = JSON.parse(localStorage.getItem('bobo_tenants') || '[]');
            const countEl = document.getElementById('nodeCount');
            if (countEl) countEl.innerText = tenants.length.toString();
        });
    </script>
</MainLayout>
