---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo SaaS Admin CRM | Platform Control Center">
  <div class="admin-crm-container" id="adminApp">
    <!-- 1. TOP NAVIGATION BAR -->
    <header class="admin-top-nav">
      <div class="nav-left">
        <div class="crm-logo">
          <img src="/logo.png" alt="Bobo" />
          <span>Bobo <span class="platform-badge">SaaS Platform</span></span>
        </div>
      </div>
      
      <div class="nav-center">
        <div class="search-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" placeholder="Search businesses, users, or audit logs..." id="globalSearch" />
        </div>
      </div>
      
      <div class="nav-right">
        <button class="nav-icon-btn" title="System Notifications">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
            <span class="pulse-dot"></span>
        </button>
        <div class="admin-profile">
            <div class="profile-info">
                <span class="admin-name">System Master</span>
                <span class="admin-role">Super Admin</span>
            </div>
            <div class="admin-avatar">SM</div>
            <button id="logoutBtn" class="logout-btn-nav" title="Logout">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </button>
        </div>
      </div>
    </header>

    <div class="admin-body">
      <!-- 2. SIDEBAR NAVIGATION -->
      <aside class="admin-sidebar" id="sidebar">
        <nav class="sidebar-nav">
          <div class="nav-group">
            <a href="#dashboard" class="nav-item active" data-screen="dashboard">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
              <span>Dashboard</span>
            </a>
          </div>

          <div class="nav-label">Core Provisioning</div>
          <div class="nav-group">
            <a href="#accounts" class="nav-item" data-screen="accounts">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Account Provisioning</span>
            </a>
            <a href="#industries" class="nav-item" data-screen="industries">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 10a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10z"/><path d="M6 4h12"/><path d="M10 2h4"/></svg>
              <span>Industry Verticals</span>
            </a>
            <a href="#modules" class="nav-item" data-screen="modules">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
              <span>Modular Plugins</span>
            </a>
          </div>

          <div class="nav-label">Billing & Growth</div>
          <div class="nav-group">
            <a href="#plans" class="nav-item" data-screen="plans">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>
              <span>Subscription Plans</span>
            </a>
            <a href="#revenue" class="nav-item" data-screen="revenue">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/></svg>
              <span>Revenue Tracking</span>
            </a>
          </div>

          <div class="nav-label">System</div>
          <div class="nav-group">
            <a href="#themes" class="nav-item" data-screen="themes">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2v20"/><path d="M12 12 2.1 14.9"/><path d="M12 12 14.9 21.9"/><path d="M12 12 21.9 9.1"/><path d="M12 12 9.1 2.1"/></svg>
              <span>Experience Center</span>
            </a>
            <a href="#security" class="nav-item" data-screen="security">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>Security & Compliance</span>
            </a>
            <a href="#logs" class="nav-item" data-screen="logs">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span>System Audit Logs</span>
            </a>
          </div>
        </nav>
      </aside>

      <!-- 3. MAIN CONTENT AREA -->
      <main class="admin-main" id="mainContent">
        
        <!-- SCREEN: DASHBOARD OVERVIEW -->
        <div id="screen-dashboard" class="screen active">
          <div class="screen-header">
            <div>
              <h1>SaaS Orchestration Dashboard</h1>
              <p>Platform-wide health and business environment distribution.</p>
            </div>
            <div class="header-actions">
              <button class="btn-primary" onclick="switchScreen('accounts')">Provision New Account</button>
            </div>
          </div>

          <!-- ENVIRONMENT STATS WIDGETS -->
          <div class="stats-grid">
            <div class="stat-card live-border">
              <div class="card-icon green"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              <div class="card-data">
                <span class="label">Live Environments</span>
                <span class="value" id="statLive">0</span>
                <span class="trend up">Revenue Paying</span>
              </div>
            </div>
            <div class="stat-card trial-border">
              <div class="card-icon orange"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
              <div class="card-data">
                <span class="label">Trial Environments</span>
                <span class="value" id="statTrial">0</span>
                <span class="trend">Limited Window</span>
              </div>
            </div>
            <div class="stat-card test-border">
              <div class="card-icon blue"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
              <div class="card-data">
                <span class="label">Test Environments</span>
                <span class="value" id="statTest">0</span>
                <span class="trend">Internal / Demo</span>
              </div>
            </div>
            <div class="stat-card">
              <div class="card-icon purple"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
              <div class="card-data">
                <span class="label">Total SaaS Rev</span>
                <span class="value" id="totalMRR">₹0</span>
                <span class="trend up">Platform Wide</span>
              </div>
            </div>
          </div>

          <div class="data-card">
              <div class="card-header">
                  <h3>Recent Provisioning Events</h3>
              </div>
              <div class="log-console-mini" id="miniAuditLog">
                  <!-- Recent logs -->
              </div>
          </div>
        </div>

        <!-- SCREEN: ACCOUNT PROVISIONING -->
        <div id="screen-accounts" class="screen">
          <div class="screen-header">
            <div>
              <h1>Industry Account Provisioning</h1>
              <p>Create and manage isolated business environments.</p>
            </div>
            <button class="btn-primary" onclick="openProvisionModal()">+ New Account</button>
          </div>

          <!-- Account Table -->
          <div class="filter-bar">
              <div class="filter-group">
                  <label>Industry</label>
                  <select id="filterIndustry" onchange="filterAccounts()">
                      <option value="all">All Industries</option>
                      <option value="pharmacy">Pharmacy</option>
                      <option value="healthcare">Healthcare</option>
                      <option value="retail">Retail</option>
                      <option value="bakers">Small to Big Business</option>
                  </select>
              </div>
              <div class="filter-group">
                  <label>Environment</label>
                  <select id="filterEnv" onchange="filterAccounts()">
                      <option value="all">All Envs</option>
                      <option value="live">Live only</option>
                      <option value="trial">Trial only</option>
                      <option value="test">Test only</option>
                  </select>
              </div>
              <div class="filter-group">
                  <label>Status</label>
                  <select id="filterStatus" onchange="filterAccounts()">
                      <option value="all">All Status</option>
                      <option value="Active">Active</option>
                      <option value="Suspended">Suspended</option>
                      <option value="Archived">Archived</option>
                  </select>
              </div>
          </div>

          <div class="data-card overflow-x">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Business / Owner</th>
                  <th>Industry</th>
                  <th>Username / Subdomain</th>
                  <th>Env</th>
                  <th>Plan</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="accountsTableBody">
                <!-- Sync with localStorage: business_accounts -->
              </tbody>
            </table>
          </div>

          <!-- Account History Logs -->
          <div class="history-section mt-30">
              <div class="section-header">
                  <h2>Provisioning History & Audit</h2>
                  <p>Immutable log of account life-cycle actions.</p>
              </div>
              <div class="data-card">
                  <table class="data-table small">
                      <thead>
                          <tr>
                              <th>Timestamp</th>
                              <th>Account ID</th>
                              <th>Action</th>
                              <th>Env</th>
                              <th>Admin</th>
                          </tr>
                      </thead>
                      <tbody id="historyTableBody">
                          <!-- Sync with localStorage: account_history -->
                      </tbody>
                  </table>
              </div>
          </div>
        </div>

        <!-- SCREEN: LOGS -->
        <div id="screen-logs" class="screen">
          <div class="screen-header">
            <h1>Platform Audit Engine</h1>
          </div>
          <div class="log-console" id="systemLog">[SYSTEM] Bobo SaaS Kernel initialized...</div>
        </div>

        <!-- STRETCH SCREENS -->
        <div id="screen-industries" class="screen"><div class="screen-header"><h1>Industry Verticals</h1></div><div class="data-card"><p>Define baseline schemas for different industries.</p></div></div>
        <div id="screen-modules" class="screen"><div class="screen-header"><h1>Modular Plugins</h1></div><div class="data-card"><p>Plugin registry and entitlement manager.</p></div></div>
        <div id="screen-plans" class="screen"><div class="screen-header"><h1>Subscription Plans</h1></div><div class="data-card"><p>Pricing strategy and quota management.</p></div></div>
        <div id="screen-revenue" class="screen"><div class="screen-header"><h1>Revenue Insights</h1></div><div class="data-card"><p>Advanced financial analytics.</p></div></div>
        <div id="screen-themes" class="screen"><div class="screen-header"><h1>Experience Center</h1></div><div class="data-card"><p>Global UI/UX and brand consistency control.</p></div></div>
        <div id="screen-security" class="screen"><div class="screen-header"><h1>Platform Security</h1></div><div class="data-card"><p>MFA, rate limiting, and encrypted storage settings.</p></div></div>

      </main>
    </div>

    <!-- MODAL: ACCOUNT PROVISIONING -->
    <div id="provisionModal" class="modal-overlay">
       <div class="modal-content large">
          <div class="modal-header">
            <h2>Deploy Industry Business Environment</h2>
            <button class="close-btn" onclick="closeProvisionModal()">×</button>
          </div>
          <form id="provisionForm" class="tenant-form">
              <div class="form-grid-3">
                <div class="form-group">
                    <label>Industry Vertical</label>
                    <select id="pIndustry" required>
                        <option value="pharmacy">Pharmacy</option>
                        <option value="healthcare">Healthcare</option>
                        <option value="retail">Retail POS</option>
                        <option value="bakers">Small to Big Business</option>
                        <option value="stock">TradeGuard AI</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Business Name</label>
                    <input type="text" id="pBusinessName" placeholder="e.g. LifeCare Pharmacy" required />
                </div>
                <div class="form-group">
                    <label>Owner Full Name</label>
                    <input type="text" id="pOwnerName" placeholder="e.g. John Doe" required />
                </div>
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" id="pEmail" required />
                </div>
                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="text" id="pPhone" required />
                </div>
                <div class="form-group">
                    <label>Desired Username</label>
                    <input type="text" id="pUsername" placeholder="lifecare_adm" required />
                </div>
                <div class="form-group">
                    <label>Account Password</label>
                    <input type="password" id="pPassword" placeholder="Minimum 8 chars" required />
                </div>
                <div class="form-group">
                    <label>Environment Type</label>
                    <select id="pEnv" required class="env-selector">
                        <option value="test">Test Environment</option>
                        <option value="trial">Trial (14-Day)</option>
                        <option value="live">Live Production</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Subscription Plan</label>
                    <select id="pPlan">
                        <option value="starter">Starter</option>
                        <option value="professional" selected>Professional</option>
                        <option value="enterprise">Enterprise</option>
                    </select>
                </div>
              </div>

              <div class="form-group mt-20">
                  <label>Module Entitlements (Initial)</label>
                  <div class="checkbox-grid">
                      <label><input type="checkbox" checked /> Inventory</label>
                      <label><input type="checkbox" checked /> POS</label>
                      <label><input type="checkbox" checked /> CRM</label>
                      <label><input type="checkbox" /> AI Insights</label>
                      <label><input type="checkbox" /> Multi-Branch</label>
                  </div>
              </div>

              <div id="provisionStatus" style="display:none; color:var(--secondary); padding:10px; text-align:center; font-weight:700;">
                  ✅ Provising Node... 
              </div>

              <button type="submit" class="btn-primary full-width mt-20">Deploy Environment Architecture</button>
          </form>
       </div>
    </div>
  </div>

  <style>
    /* SAAS PROVISIONING ENGINE STYLES */
    :root {
      --primary: #6366f1;
      --secondary: #10b981;
      --test-color: #3b82f6;
      --trial-color: #f59e0b;
      --live-color: #10b981;
      --bg: #05081a;
      --sidebar-bg: #0f172a;
      --card-bg: #1e293b;
      --card-border: rgba(255,255,255,0.1);
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
    }

    body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text-main); height: 100vh; overflow: hidden; }
    .admin-crm-container { display: flex; flex-direction: column; height: 100%; }

    /* Nav */
    .admin-top-nav { height: 64px; background: rgba(15,23,42,0.8); backdrop-filter: blur(12px); display: flex; align-items: center; justify-content: space-between; padding: 0 24px; border-bottom: 1px solid var(--card-border); z-index: 100; }
    .crm-logo { display:flex; align-items:center; gap:12px; font-weight:800; font-size:1.3rem; letter-spacing: -0.5px; }
    .crm-logo img { 
        height: 42px; 
        width: auto; 
        border-radius: 8px; 
        transition: transform 0.3s ease;
        filter: drop-shadow(0 0 8px var(--primary));
        animation: logoGlow 2s infinite alternate ease-in-out;
    }
    .crm-logo img:hover { transform: scale(1.05); }

    @keyframes logoGlow {
        from { filter: drop-shadow(0 0 5px var(--primary)); brightness: 1; }
        to { filter: drop-shadow(0 0 15px var(--primary)); brightness: 1.2; }
    }
    .platform-badge { background: var(--primary); font-size: 0.6rem; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; }
    .nav-center .search-wrapper { background: rgba(255,255,255,0.05); border: 1px solid var(--card-border); border-radius: 8px; padding: 6px 12px; width: 400px; display: flex; gap: 8px; }
    .search-wrapper input { background: transparent; border: none; color: white; outline: none; width: 100%; }
    .admin-profile { display:flex; align-items:center; gap:12px; }
    .admin-avatar { width:32px; height:32px; background:var(--primary); border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:800;}
    .logout-btn-nav { background: transparent; border: none; color: var(--text-muted); cursor: pointer; padding: 5px; }
    .logout-btn-nav:hover { color: #ef4444; }

    /* Layout */
    .admin-body { display: flex; flex: 1; overflow: hidden; }
    .admin-sidebar { width: 250px; background: var(--sidebar-bg); border-right: 1px solid var(--card-border); overflow-y: auto; padding: 20px 10px; }
    .nav-label { font-size: 0.65rem; color: #64748b; text-transform: uppercase; font-weight: 700; margin: 20px 0 8px 12px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px; border-radius: 8px; color: #94a3b8; text-decoration: none; font-size: 0.9rem; transition: 0.2s; }
    .nav-item:hover, .nav-item.active { background: rgba(99,102,241,0.1); color: var(--primary); }
    .admin-main { flex: 1; overflow-y: auto; padding: 32px; }

    /* Screens */
    .screen { display: none; animation: fadeIn 0.3s; }
    .screen.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
    .screen-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; }
    .screen-header h1 { font-size: 1.75rem; font-weight: 800; margin: 0; }
    .screen-header p { color: var(--text-muted); font-size: 0.9rem; margin-top: 5px; }

    /* Stats Widgets */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px; }
    .stat-card { background: var(--card-bg); border: 1px solid var(--card-border); padding: 20px; border-radius: 16px; display: flex; gap: 16px; transition: 0.2s; }
    .stat-card:hover { transform: translateY(-4px); border-color: var(--primary); }
    .live-border { border-left: 4px solid var(--live-color); }
    .trial-border { border-left: 4px solid var(--trial-color); }
    .test-border { border-left: 4px solid var(--test-color); }
    .card-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.05); }
    .card-data .label { font-size: 0.7rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; }
    .card-data .value { display: block; font-size: 1.6rem; font-weight: 800; margin: 4px 0; }
    .trend { font-size: 0.75rem; color: var(--secondary); font-weight: 600; }

    /* Data Tables */
    .data-card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; overflow: hidden; }
    .overflow-x { overflow-x: auto; }
    .data-table { width: 100%; border-collapse: collapse; text-align: left; }
    .data-table th { padding: 14px 20px; font-size: 0.75rem; color: var(--text-muted); border-bottom: 1px solid var(--card-border); background:rgba(0,0,0,0.2); text-transform: uppercase; font-weight: 700; }
    .data-table td { padding: 14px 20px; border-bottom: 1px solid var(--card-border); font-size: 0.85rem; vertical-align: middle; }
    .data-table tr:hover { background: rgba(255,255,255,0.02); }
    .data-table.small td { padding: 10px 20px; font-size: 0.8rem; }

    /* Filter Bar */
    .filter-bar { display: flex; gap: 20px; background: rgba(255,255,255,0.03); padding: 15px 20px; border-radius: 12px; margin-bottom: 20px; border: 1px solid var(--card-border); }
    .filter-group { display: flex; flex-direction: column; gap: 5px; }
    .filter-group label { font-size: 0.7rem; font-weight: 700; color: var(--text-muted); }
    .filter-group select { background: #0f172a; border: 1px solid #334155; color: white; padding: 6px 12px; border-radius: 6px; font-size: 0.85rem; }

    /* Badges */
    .tag { padding: 4px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; }
    .tag.live { background: rgba(16,185,129,0.1); color: var(--live-color); border: 1px solid rgba(16,185,129,0.2); }
    .tag.trial { background: rgba(245,158,11,0.1); color: var(--trial-color); border: 1px solid rgba(245,158,11,0.2); }
    .tag.test { background: rgba(59,130,246,0.1); color: var(--test-color); border: 1px solid rgba(59,130,246,0.2); }
    
    .status-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 0.75rem; font-weight: 600; }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; }
    .status-Active .status-dot { background: var(--secondary); box-shadow: 0 0 10px var(--secondary); }
    .status-Suspended .status-dot { background: #ef4444; }
    .status-Archived .status-dot { background: #64748b; }

    /* Modal Styling */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; z-index: 1000; }
    .modal-content { background: #0f172a; border: 1px solid var(--card-border); border-radius: 20px; width: 500px; padding: 32px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); }
    .modal-content.large { width: 800px; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .modal-header h2 { font-size: 1.25rem; margin:0; }
    .close-btn { background: transparent; border: none; color: white; font-size: 1.5rem; cursor: pointer; }

    /* Forms */
    .form-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .form-group label { display: block; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 6px; font-weight: 600; }
    .form-group input, .form-group select { width: 100%; background: #1e293b; border: 1px solid #334155; padding: 10px 12px; border-radius: 8px; color: white; font-size: 0.9rem; transition: 0.2s; }
    .form-group input:focus { border-color: var(--primary); outline: none; box-shadow: 0 0 0 3px rgba(99,102,241,0.2); }
    .checkbox-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px; margin-top: 5px; }
    .checkbox-grid label { display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: white; cursor: pointer; }
    
    .btn-primary { background: var(--primary); color: white; border: none; padding: 10px 20px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-primary:hover { background: #4f46e5; transform: translateY(-1px); }
    .btn-primary.full-width { width: 100%; }
    .btn-action-sm { padding: 4px 8px; font-size: 0.75rem; border-radius: 6px; margin-right: 4px; }
    
    .mt-20 { margin-top: 20px; }
    .mt-30 { margin-top: 30px; }

    .log-console { background: #000; color: #10b981; font-family: 'Fira Code', monospace; padding: 15px; border-radius: 12px; height: 400px; overflow-y: auto; font-size: 0.8rem; line-height: 1.5; border: 1px solid #333; }
    .log-console-mini { background: #000; color: #10b981; font-family: monospace; padding: 12px; border-radius: 8px; height: 150px; overflow-y: auto; font-size: 0.75rem; border: 1px solid #222; }

    /* Environment Colors */
    .env-selector option[value="test"] { color: var(--test-color); }
    .env-selector option[value="trial"] { color: var(--trial-color); }
    .env-selector option[value="live"] { color: var(--live-color); }
  </style>

  <script>
    // SAAS PROVISIONING ARCHITECTURE
    document.addEventListener("DOMContentLoaded", () => {
        // Auth Guard
        if (!localStorage.getItem("adminAuth")) window.location.href = "/admin-login";

        // Navigation Engine
        window.switchScreen = function(screenId) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            document.getElementById('screen-' + screenId)?.classList.add('active');
            document.querySelector(`[data-screen="${screenId}"]`)?.classList.add('active');
        };

        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', () => {
                const screen = item.getAttribute('data-screen');
                if(screen) switchScreen(screen);
            });
        });

        // Modal Controls
        window.openProvisionModal = () => document.getElementById('provisionModal').style.display='flex';
        window.closeProvisionModal = () => document.getElementById('provisionModal').style.display='none';

        // Load Platform State
        refreshPlatform();
    });

    function refreshPlatform() {
        const accounts = JSON.parse(localStorage.getItem('bobo_accounts') || '[]');
        const history = JSON.parse(localStorage.getItem('bobo_history') || '[]');
        
        // Update Stats
        const liveCount = accounts.filter(a => a.environment === 'live').length;
        const trialCount = accounts.filter(a => a.environment === 'trial').length;
        const testCount = accounts.filter(a => a.environment === 'test').length;
        
        document.getElementById('statLive').innerText = liveCount;
        document.getElementById('statTrial').innerText = trialCount;
        document.getElementById('statTest').innerText = testCount;
        
        let mrr = 0;
        accounts.filter(a => a.environment === 'live').forEach(a => {
            if(a.plan === 'starter') mrr += 4999;
            else if(a.plan === 'enterprise') mrr += 19999;
            else mrr += 9999;
        });
        document.getElementById('totalMRR').innerText = `₹${mrr.toLocaleString('en-IN')}`;

        renderAccountsTable(accounts);
        renderHistoryTable(history);
        renderMiniLogs(history);
    }

    function renderAccountsTable(accounts) {
        const tbody = document.getElementById('accountsTableBody');
        if(!tbody) return;

        const fInd = document.getElementById('filterIndustry')?.value || 'all';
        const fEnv = document.getElementById('filterEnv')?.value || 'all';
        const fStat = document.getElementById('filterStatus')?.value || 'all';

        const filtered = accounts.filter(a => {
            if(fInd !== 'all' && a.industry !== fInd) return false;
            if(fEnv !== 'all' && a.environment !== fEnv) return false;
            if(fStat !== 'all' && a.status !== fStat) return false;
            return true;
        });

        tbody.innerHTML = filtered.map(a => `
            <tr>
                <td><strong>${a.businessName}</strong><br><span style="font-size:0.7rem; color:var(--text-muted)">${a.ownerName}</span></td>
                <td><span style="text-transform:capitalize">${a.industry}</span></td>
                <td><code>${a.username}</code><br><span style="font-size:0.7rem; color:var(--text-muted)">${a.username}.boboanalytics.com</span></td>
                <td><span class="tag ${a.environment}">${a.environment}</span></td>
                <td><span style="font-size:0.75rem; font-weight:700">${a.plan.toUpperCase()}</span></td>
                <td>
                    <div class="status-badge status-${a.status}">
                        <div class="status-dot"></div> ${a.status}
                    </div>
                </td>
                <td>
                    <button class="btn-primary btn-action-sm" onclick="manageAccount('${a.id}', 'reset')">Reset</button>
                    ${a.status === 'Active' ? 
                        `<button class="btn-primary btn-action-sm" style="background:#ef4444" onclick="manageAccount('${a.id}', 'Suspend')">Suspend</button>` :
                        `<button class="btn-primary btn-action-sm" style="background:var(--secondary)" onclick="manageAccount('${a.id}', 'Active')">Activate</button>`
                    }
                    <button class="btn-primary btn-action-sm" style="background:#64748b" onclick="manageAccount('${a.id}', 'Archived')">Archive</button>
                </td>
            </tr>
        `).join('') || '<tr><td colspan="7" style="text-align:center; padding:40px; color:var(--text-muted)">No accounts match these filters.</td></tr>';
    }

    function renderHistoryTable(history) {
        const tbody = document.getElementById('historyTableBody');
        if(!tbody) return;
        tbody.innerHTML = [...history].reverse().slice(0, 15).map(h => `
            <tr>
                <td style="font-size:0.75rem">${new Date(h.timestamp).toLocaleString()}</td>
                <td><code>${h.businessId}</code></td>
                <td><strong>${h.action}</strong></td>
                <td><span class="tag ${h.environment_type}">${h.environment_type}</span></td>
                <td>${h.performed_by}</td>
            </tr>
        `).join('');
    }

    function renderMiniLogs(history) {
        const logBox = document.getElementById('miniAuditLog');
        if(!logBox) return;
        logBox.innerHTML = history.slice(-10).reverse().map(h => `
            <div style="margin-bottom:4px;">[${new Date(h.timestamp).toLocaleTimeString()}] ${h.performed_by} ${h.action} for ${h.businessId} (${h.environment_type})</div>
        `).join('') || 'No recent activity.';
    }

    window.filterAccounts = () => refreshPlatform();

    // PROVISIONING LOGIC
    const provForm = document.getElementById('provisionForm');
    provForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const stat = document.getElementById('provisionStatus');
        stat.style.display = 'block';

        const newAcc = {
            id: 'BIZ-' + Math.random().toString(36).substr(2, 9).toUpperCase(),
            industry: document.getElementById('pIndustry').value,
            businessName: document.getElementById('pBusinessName').value,
            ownerName: document.getElementById('pOwnerName').value,
            email: document.getElementById('pEmail').value,
            phone: document.getElementById('pPhone').value,
            username: document.getElementById('pUsername').value,
            password_hash: 'SHA256_HIDDEN_' + btoa(document.getElementById('pPassword').value),
            environment: document.getElementById('pEnv').value,
            plan: document.getElementById('pPlan').value,
            status: 'Active',
            created_at: new Date().toISOString()
        };

        // Simulated provision delay
        await new Promise(r => setTimeout(r, 1500));

        let accounts = JSON.parse(localStorage.getItem('bobo_accounts') || '[]');
        accounts.push(newAcc);
        localStorage.setItem('bobo_accounts', JSON.stringify(accounts));

        // Registry History
        logHistory(newAcc.id, 'Account Created', newAcc.environment);

        stat.style.display = 'none';
        closeProvisionModal();
        provForm.reset();
        refreshPlatform();
        alert('Infrastructure provisioned successfully. Environment: ' + newAcc.environment.toUpperCase());
    });

    function logHistory(bizId, action, env) {
        let history = JSON.parse(localStorage.getItem('bobo_history') || '[]');
        history.push({
            id: Date.now(),
            businessId: bizId,
            action: action,
            environment_type: env,
            performed_by: 'Super Admin',
            timestamp: new Date().toISOString()
        });
        localStorage.setItem('bobo_history', JSON.stringify(history));
    }

    window.manageAccount = (id, action) => {
        let accounts = JSON.parse(localStorage.getItem('bobo_accounts') || '[]');
        const accIdx = accounts.findIndex(a => a.id === id);
        if(accIdx === -1) return;

        if(action === 'reset') {
            const newPass = prompt("Enter new password for " + accounts[accIdx].username);
            if(newPass) {
                accounts[accIdx].password_hash = 'SHA256_HIDDEN_' + btoa(newPass);
                logHistory(id, 'Password Reset', accounts[accIdx].environment);
                alert("Password updated.");
            }
        } else {
            const oldStatus = accounts[accIdx].status;
            accounts[accIdx].status = action;
            logHistory(id, `Status changed from ${oldStatus} to ${action}`, accounts[accIdx].environment);
        }

        localStorage.setItem('bobo_accounts', JSON.stringify(accounts));
        refreshPlatform();
    };

    document.getElementById('logoutBtn')?.addEventListener('click', () => {
        localStorage.removeItem("adminAuth");
        window.location.href = "/admin-login";
    });
  </script>
</MainLayout>
