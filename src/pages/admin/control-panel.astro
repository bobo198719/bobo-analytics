---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Platform Admin | Enterprise SaaS Control Center" hideNav={true}>
  <div class="admin-crm-container" id="adminApp">
    <!-- 1. TOP NAVIGATION BAR (Admin Specific) -->
    <header class="admin-top-nav">
      <div class="nav-left">
        <div class="crm-logo">
          <img src="/logo.png" alt="Bobo" />
          <span>Bobo <span class="platform-badge">SaaS Admin</span></span>
        </div>
      </div>
      
      <div class="nav-center">
        <div class="search-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" placeholder="Search businesses, users, industries..." id="globalSearch" />
        </div>
      </div>
      
      <div class="nav-right">
        <div class="ai-status-pill">
          <span class="pulse-dot green"></span>
          AI Insights Active
        </div>
        <button class="nav-icon-btn" title="System Notifications">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
        </button>
        <div class="admin-profile">
            <div class="profile-info">
                <span class="admin-name">System Master</span>
                <span class="admin-role">Super Admin</span>
            </div>
            <div class="admin-avatar">SM</div>
            <button id="logoutBtn" class="logout-btn-nav" title="Logout">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </button>
        </div>
      </div>
    </header>

    <div class="admin-body">
      <!-- 2. SIDEBAR NAVIGATION -->
      <aside class="admin-sidebar" id="sidebar">
        <nav class="sidebar-nav">
          <div class="nav-group">
            <a href="#dashboard" class="nav-item active" data-screen="dashboard">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
              <span>Dashboard</span>
            </a>
          </div>

          <div class="nav-label">Business Management</div>
          <div class="nav-group">
            <a href="#accounts" class="nav-item" data-screen="accounts">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Account Provisioning</span>
            </a>
            <a href="#leads" class="nav-item" data-screen="leads">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 17H2a3 3 0 0 0 3-3V9a7 7 0 0 1 14 0v5a3 3 0 0 0 3 3zm-8.27 4a2 2 0 0 1-3.46 0"/></svg>
              <span>Registration Queue</span>
            </a>
            <a href="#industries" class="nav-item" data-screen="industries">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 10a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10z"/><path d="M6 4h12"/><path d="M10 2h4"/></svg>
              <span>Industry Verticals</span>
            </a>
          </div>

          <div class="nav-label">Billing & Revenue</div>
          <div class="nav-group">
            <a href="#plans" class="nav-item" data-screen="plans">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>
              <span>Subscription Plans</span>
            </a>
            <a href="#gateways" class="nav-item" data-screen="gateways">
               <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
               <span>Payment Gateways</span>
            </a>
            <a href="#revenue" class="nav-item" data-screen="revenue">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/></svg>
              <span>Revenue Tracking</span>
            </a>
          </div>

          <div class="nav-label">Modules</div>
          <div class="nav-group">
            <a href="#modules" class="nav-item" data-screen="modules">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
              <span>Modular Plugins</span>
            </a>
          </div>

          <div class="nav-label">System</div>
          <div class="nav-group">
            <a href="#themes" class="nav-item" data-screen="themes">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2v20"/><path d="M12 12 2.1 14.9"/><path d="M12 12 14.9 21.9"/><path d="M12 12 21.9 9.1"/><path d="M12 12 9.1 2.1"/></svg>
              <span>Experience Center</span>
            </a>
            <a href="#security" class="nav-item" data-screen="security">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>Security & Compliance</span>
            </a>
            <a href="#logs" class="nav-item" data-screen="logs">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span>System Audit Logs</span>
            </a>
          </div>
        </nav>
      </aside>

      <!-- 3. MAIN CONTENT AREA -->
      <main class="admin-main" id="mainContent">
        
        <!-- SCREEN: DASHBOARD OVERVIEW -->
        <div id="screen-dashboard" class="screen active">
          <div class="screen-header">
            <div>
              <h1>Platform Orchestration</h1>
              <p>Real-time telemetry and ecosystem distribution.</p>
            </div>
            <div class="header-actions">
              <button class="btn-primary" onclick="openProvisionWizard()">🚀 Multi-Step Onboarding</button>
            </div>
          </div>

          <!-- KPI WIDGETS -->
          <div class="stats-grid">
            <div class="stat-card live-border">
              <div class="card-icon green ripple"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              <div class="card-data">
                <span class="label">Live Accounts</span>
                <span class="value" id="statLive">0</span>
                <span class="trend up">Active Revenue</span>
              </div>
            </div>
            <div class="stat-card trial-border">
              <div class="card-icon orange"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
              <div class="card-data">
                <span class="label">Trial Window</span>
                <span class="value" id="statTrial">0</span>
                <span class="trend">Sales Pipeline</span>
              </div>
            </div>
            <div class="stat-card test-border">
              <div class="card-icon blue"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
              <div class="card-data">
                <span class="label">Total Businesses</span>
                <span class="value" id="statTotalBiz">0</span>
                <span class="trend">Global Footprint</span>
              </div>
            </div>
            <div class="stat-card">
              <div class="card-icon purple"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
              <div class="card-data">
                <span class="label">Monthly Revenue</span>
                <span class="value" id="totalMRR">₹0</span>
                <span class="trend up">+12% growth</span>
              </div>
            </div>
          </div>

          <div class="dashboard-grid-2">
            <!-- AI INSIGHTS PANEL -->
            <div class="ai-insights-panel">
                <div class="panel-header">
                    <h3>🧠 AI Platform Assistant</h3>
                    <span class="pulse-dot"></span>
                </div>
                <div class="insight-list" id="aiInsightsList">
                    <div class="insight-item">
                        <div class="insight-icon">📈</div>
                        <div class="insight-body">
                            <strong>Industry Growth Trend</strong>
                            <p>Fashion industry businesses increased 22% this quarter.</p>
                        </div>
                    </div>
                </div>
                <button class="btn-secondary full-width mt-20" onclick="generateAIReport()">Download Growth Forecast</button>
            </div>

            <!-- AUDIT & COMPLIANCE PREVIEW -->
            <div class="data-card">
                <div class="card-header">
                    <h3>Compliance Audit Trail</h3>
                </div>
                <div class="usage-list" id="miniAuditLog">
                    <!-- Logs go here -->
                </div>
            </div>
          </div>
        </div>

        <!-- SCREEN: ACCOUNT PROVISIONING -->
        <div id="screen-accounts" class="screen">
          <div class="screen-header">
            <div>
              <h1>Business Management</h1>
              <p>Monitor and manage all tenant environments.</p>
            </div>
            <button class="btn-primary" onclick="openProvisionWizard()">+ Provision New Tenant</button>
          </div>

          <div class="filter-bar">
              <div class="filter-group">
                  <label>Industry</label>
                  <select id="filterIndustry" onchange="filterAccounts()">
                      <option value="all">All Industries</option>
                      <option value="pharmacy">Pharmacy</option>
                      <option value="healthcare">Healthcare</option>
                      <option value="retail">Retail POS</option>
                      <option value="finance">Finance Suite</option>
                      <option value="grocery">Grocery OS</option>
                      <option value="fashion">Fashion OS</option>
                      <option value="bakers">Home Bakers OS</option>
                      <option value="tradeguard">TradeGuard AI</option>
                  </select>
              </div>
              <div class="filter-group">
                  <label>Environment</label>
                  <select id="filterEnv" onchange="filterAccounts()">
                      <option value="all">All Envs</option>
                      <option value="live">Live Production</option>
                      <option value="trial">Active Trial</option>
                      <option value="test">Sandbox/Test</option>
                  </select>
              </div>
              <div class="filter-group">
                  <label>Status</label>
                  <select id="filterStatus" onchange="filterAccounts()">
                      <option value="all">All Status</option>
                      <option value="Active">Active</option>
                      <option value="Suspended">Suspended</option>
                      <option value="Archived">Archived</option>
                  </select>
              </div>
          </div>

          <div class="data-card overflow-x">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Business / Owner</th>
                  <th>Industry</th>
                  <th>Subdomain</th>
                  <th>Environment</th>
                  <th>Plan</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="accountsTableBody"></tbody>
            </table>
          </div>
        </div>

        <!-- SCREEN: REGISTRATION QUEUE (LEADS) -->
        <div id="screen-leads" class="screen">
            <div class="screen-header">
                <h1>Registration Lead Hub</h1>
                <p>Public signups awaiting verification or contact.</p>
            </div>
            <div class="data-card overflow-x">
                <table class="data-table">
                    <thead><tr><th>Lead / Business</th><th>Contact</th><th>Interest</th><th>Source</th><th>Actions</th></tr></thead>
                    <tbody id="leadTableBody"></tbody>
                </table>
            </div>
        </div>

        <!-- SCREEN: INDUSTRIES -->
        <div id="screen-industries" class="screen">
          <div class="screen-header">
            <h1>Industry Verticals</h1>
            <button class="btn-primary" onclick="alert('Industry Engine Live')">+ Add New Vertical</button>
          </div>
          <div class="data-card overflow-x">
            <table class="data-table">
                <thead>
                    <tr><th>Vertical Name</th><th>Default Modules</th><th>Base Theme</th><th>Status</th><th>Action</th></tr>
                </thead>
                <tbody id="industryTableBody">
                    <tr><td>Pharmacy</td><td>POS, Inventory, CRM, GST</td><td>Emerald Green</td><td><span class="tag live">Active</span></td><td><button class="btn-secondary" onclick="editIndustry('pharmacy')">Edit Modules</button></td></tr>
                    <tr><td>Healthcare</td><td>Patient CRM, Billing</td><td>Ocean Blue</td><td><span class="tag live">Active</span></td><td><button class="btn-secondary" onclick="editIndustry('healthcare')">Edit Modules</button></td></tr>
                    <tr><td>Retail POS</td><td>Stock, Sales, Offers</td><td>Sunset Orange</td><td><span class="tag live">Active</span></td><td><button class="btn-secondary" onclick="editIndustry('retail')">Edit Modules</button></td></tr>
                    <tr><td>Grocery OS</td><td>Inventory, Billing, Suppliers</td><td>Midnight Black</td><td><span class="tag live">Active</span></td><td><button class="btn-secondary" onclick="editIndustry('grocery')">Edit Modules</button></td></tr>
                </tbody>
            </table>
          </div>
        </div>

        <!-- SCREEN: PLANS -->
        <div id="screen-plans" class="screen">
          <div class="screen-header">
            <h1>Subscription Plan Manager</h1>
            <button class="btn-primary" onclick="openPlanModal()">+ Create Plan</button>
          </div>
          <div class="plans-grid" id="plansGrid">
              <!-- Rendered by JS -->
          </div>
        </div>

        <!-- SCREEN: GATEWAYS -->
        <div id="screen-gateways" class="screen">
            <div class="screen-header">
                <h1>Global Payment Gateways</h1>
            </div>
            <div class="data-card">
                <div class="gateway-list">
                    <div class="gateway-item">
                        <div class="gateway-info">
                            <strong>Razorpay</strong>
                            <p>Primary gateway for India (INR)</p>
                            <div class="key-field mt-10">
                                <label>API Key:</label>
                                <input type="password" value="rzp_live_8Ambz8DneyktAE" id="razorKey" class="key-input" />
                                <button class="btn-sm" onclick="toggleKey('razorKey')">Show</button>
                            </div>
                        </div>
                        <div class="gateway-status"><span class="tag live">Enabled</span></div>
                        <button class="btn-secondary" onclick="saveGateway('Razorpay')">Save Changes</button>
                    </div>
                    <div class="gateway-item">
                        <div class="gateway-info">
                            <strong>Stripe</strong>
                            <p>Global card payments (USD/EURO)</p>
                            <div class="key-field mt-10">
                                <label>API Secret:</label>
                                <input type="password" value="sk_live_9pSJ...mSJ" id="stripeKey" class="key-input" />
                                <button class="btn-sm" onclick="toggleKey('stripeKey')">Show</button>
                            </div>
                        </div>
                        <div class="gateway-status"><span class="tag live">Enabled</span></div>
                        <button class="btn-secondary" onclick="saveGateway('Stripe')">Save Changes</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- SCREEN: REVENUE -->
        <div id="screen-revenue" class="screen">
            <div class="screen-header">
                <h1>Revenue Tracking & Forecast</h1>
            </div>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="card-data">
                        <span class="label">Total ARR</span>
                        <span class="value" id="revARR">₹0</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="card-data">
                        <span class="label">Subscription Growth</span>
                        <span class="value">+18%</span>
                    </div>
                </div>
            </div>
            <div class="data-card">
                <div class="card-header"><h3>Recent Revenue Streams</h3></div>
                <table class="data-table">
                    <thead><tr><th>Date</th><th>Business</th><th>Plan</th><th>Amount</th><th>Status</th></tr></thead>
                    <tbody id="revenueTableBody"></tbody>
                </table>
            </div>
        </div>

        <!-- SCREEN: PLUGINS -->
        <div id="screen-modules" class="screen">
            <div class="screen-header">
                <h1>Modular Plugins & Marketplace</h1>
            </div>
            <div class="plugins-grid" id="pluginsRegistry">
                <div class="plugin-card">
                    <div class="p-icon">📦</div>
                    <div class="p-info">
                        <strong>Inventory Core</strong>
                        <p>Real-time stock tracking engine.</p>
                        <span class="tag live">Standard</span>
                    </div>
                    <label class="switch"><input type="checkbox" checked /> <span class="slider"></span></label>
                </div>
                <div class="plugin-card">
                    <div class="p-icon">📊</div>
                    <div class="p-info">
                        <strong>AI Forecast</strong>
                        <p>Predictive sales and stock analysis.</p>
                        <span class="tag trial">Premium</span>
                    </div>
                    <label class="switch"><input type="checkbox" /> <span class="slider"></span></label>
                </div>
                <div class="plugin-card">
                    <div class="p-icon">💹</div>
                    <div class="p-info">
                        <strong>GST Assistant</strong>
                        <p>Automated tax filing for India.</p>
                        <span class="tag live">Standard</span>
                    </div>
                    <label class="switch"><input type="checkbox" checked /> <span class="slider"></span></label>
                </div>
            </div>
        </div>

        <!-- SCREEN: AUDIT LOGS -->
        <div id="screen-logs" class="screen">
          <div class="screen-header">
            <h1>Platform Audit Logs</h1>
          </div>
          <div class="log-console" id="systemLog">[BOOT] Platform Admin Core v11.3 initialized...</div>
        </div>

        <!-- SECURITY SCREEN -->
        <div id="screen-security" class="screen">
            <div class="screen-header">
                <h1>Security & Infrastructure</h1>
            </div>
            <div class="data-card p-30">
                <div class="form-group">
                    <label>Admin MFA Status</label>
                    <span class="tag live">Enabled (Google Authenticator)</span>
                </div>
                <div class="form-group mt-20">
                    <label>API Rate Limiting</label>
                    <select class="key-input"><option>1000 req/min</option><option>5000 req/min</option></select>
                </div>
                <hr class="mt-20 opacity-1" />
                <button class="btn-primary mt-20">Save Security Policy</button>
            </div>
        </div>

      </main>
    </div>

    <!-- SUCCESS MODAL (POST-PROVISIONING) -->
    <div id="successModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2>🚀 Provisioning Successful</h2>
            </div>
            <div class="success-body" id="credView">
                <!-- Creds go here -->
            </div>
            <div class="notification-actions mt-20">
                <button class="btn-primary full-width" onclick="simulateNotify('email')">📧 Send Login via Email</button>
                <button class="btn-secondary full-width mt-10" onclick="simulateNotify('whatsapp')">💬 Send via WhatsApp</button>
                <button class="btn-secondary full-width mt-10" onclick="closeSuccess()">Close</button>
            </div>
        </div>
    </div>

    <!-- ONBOARDING WIZARD MODAL -->
    <div id="onboardingWizard" class="modal-overlay">
        <div class="modal-content large">
            <div class="wizard-header">
                <div class="wizard-steps">
                    <div class="step active" data-id="1">1. Business</div>
                    <div class="step" data-id="2">2. Industry</div>
                    <div class="step" data-id="3">3. Plan</div>
                    <div class="step" data-id="4">4. Env</div>
                    <div class="step" data-id="5">5. Summary</div>
                </div>
                <button class="close-btn" onclick="closeWizard()">×</button>
            </div>

            <form id="wizardForm">
                <!-- STEP 1: Details -->
                <div class="wizard-screen active" data-id="1">
                    <h3>Step 1: Business Identification</h3>
                    <div class="form-grid-2">
                        <div class="form-group"><label>Business Name</label><input type="text" id="wBizName" required /></div>
                        <div class="form-group"><label>Owner Name</label><input type="text" id="wOwner" required /></div>
                        <div class="form-group"><label>Email</label><input type="email" id="wEmail" required /></div>
                        <div class="form-group"><label>Phone</label><input type="text" id="wPhone" required /></div>
                        <div class="form-group"><label>City</label><input type="text" id="wCity" required /></div>
                        <div class="form-group"><label>Country</label><input type="text" id="wCountry" value="India" required /></div>
                    </div>
                </div>

                <!-- STEP 2: Industry -->
                <div class="wizard-screen" data-id="2">
                    <h3>Step 2: Select Industry Vertical</h3>
                    <div class="industry-picker">
                        <label class="ind-option"><input type="radio" name="wInd" value="pharmacy" checked /> <span>💊 Pharmacy</span></label>
                        <label class="ind-option"><input type="radio" name="wInd" value="healthcare" /> <span>🏥 Healthcare</span></label>
                        <label class="ind-option"><input type="radio" name="wInd" value="retail" /> <span>🛒 Retail</span></label>
                        <label class="ind-option"><input type="radio" name="wInd" value="finance" /> <span>📈 Finance</span></label>
                        <label class="ind-option"><input type="radio" name="wInd" value="grocery" /> <span>🍎 Grocery</span></label>
                        <label class="ind-option"><input type="radio" name="wInd" value="fashion" /> <span>👗 Fashion</span></label>
                        <label class="ind-option"><input type="radio" name="wInd" value="bakers" /> <span>🧁 Home Bakers</span></label>
                        <label class="ind-option"><input type="radio" name="wInd" value="tradeguard" /> <span>🛡️ TradeGuard</span></label>
                    </div>
                </div>

                <!-- STEP 3: Plan -->
                <div class="wizard-screen" data-id="3">
                    <h3>Step 3: Access Level (Subscription)</h3>
                    <div class="plan-picker">
                        <label class="plan-card"><input type="radio" name="wPlan" value="starter" /> <div class="p-body"><strong>Starter</strong><p>₹4,999/mo</p></div></label>
                        <label class="plan-card"><input type="radio" name="wPlan" value="professional" checked /> <div class="p-body"><strong>Professional</strong><p>₹9,999/mo</p></div></label>
                        <label class="plan-card"><input type="radio" name="wPlan" value="enterprise" /> <div class="p-body"><strong>Enterprise</strong><p>₹19,999/mo</p></div></label>
                    </div>
                </div>

                <!-- STEP 4: Env -->
                <div class="wizard-screen" data-id="4">
                    <h3>Step 4: Target Environment</h3>
                    <div class="env-picker">
                        <label class="env-card blue"><input type="radio" name="wEnv" value="test" checked /> <strong>Sandbox (Test)</strong></label>
                        <label class="env-card orange"><input type="radio" name="wEnv" value="trial" /> <strong>Active Trial</strong></label>
                        <label class="env-card green"><input type="radio" name="wEnv" value="live" /> <strong>Production (Live)</strong></label>
                    </div>
                </div>

                <!-- STEP 5: Summary & Create -->
                <div class="wizard-screen" data-id="5">
                    <h3>Step 5: Review & Provision</h3>
                    <div id="provisionSummary" class="provision-summary-box"></div>
                    <div id="wizardStatus" style="display:none; text-align:center; padding:20px; color:var(--secondary); font-weight:800;">
                        Generating Tenant v11.3...
                    </div>
                </div>

                <div class="wizard-footer">
                    <button type="button" class="btn-secondary" id="wizPrev" style="display:none">Back</button>
                    <button type="button" class="btn-primary" id="wizNext">Next Step</button>
                    <button type="submit" class="btn-primary" id="wizSubmit" style="display:none">Deploy Workspace</button>
                </div>
            </form>
        </div>
    </div>
  </div>

  <style>
    :root {
      --primary: #6366f1;
      --secondary: #10b981;
      --test-color: #3b82f6;
      --trial-color: #f59e0b;
      --live-color: #10b981;
      --bg: #05081a;
      --sidebar-bg: #0f172a;
      --card-bg: #1e293b;
      --card-border: rgba(255,255,255,0.1);
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
    }

    body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text-main); height: 100vh; overflow: hidden; }
    .admin-crm-container { display: flex; flex-direction: column; height: 100%; }

    /* Nav */
    .admin-top-nav { height: 64px; background: rgba(15,23,42,0.8); backdrop-filter: blur(12px); display: flex; align-items: center; justify-content: space-between; padding: 0 24px; border-bottom: 1px solid var(--card-border); z-index: 100; }
    .crm-logo { display:flex; align-items:center; gap:12px; font-weight:800; font-size:1.3rem; }
    .crm-logo img { height: 42px; width: auto; filter: drop-shadow(0 0 10px var(--primary)); }
    .platform-badge { background: var(--primary); font-size: 0.6rem; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; }
    .nav-center .search-wrapper { background: rgba(255,255,255,0.05); border: 1px solid var(--card-border); border-radius: 8px; padding: 6px 16px; width: 450px; display: flex; gap: 8px; }
    .search-wrapper input { background: transparent; border: none; color: white; outline: none; width: 100%; font-size:0.9rem;}
    
    .ai-status-pill { background: rgba(99,102,241,0.15); border: 1px solid var(--primary); color: var(--primary); padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; display:flex; align-items:center; gap:8px;}
    .pulse-dot { width: 8px; height: 8px; border-radius: 50%; background: #10b981; animation: pulse 2s infinite; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(16,185,129,0.7); } 70% { box-shadow: 0 0 0 10px rgba(16,185,129,0); } 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); } }

    /* Sidebar */
    .admin-body { display: flex; flex: 1; overflow: hidden; }
    .admin-sidebar { width: 260px; background: var(--sidebar-bg); border-right: 1px solid var(--card-border); overflow-y: auto; padding: 20px 12px; }
    .nav-label { font-size: 0.65rem; color: #64748b; text-transform: uppercase; font-weight: 800; margin: 24px 0 10px 12px; letter-spacing: 0.5px; }
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 10px; color: #94a3b8; text-decoration: none; font-size: 0.95rem; transition: 0.2s; font-weight: 500;}
    .nav-item:hover, .nav-item.active { background: rgba(99,102,241,0.12); color: var(--primary); }
    .nav-item.active { box-shadow: inset 0 0 0 1px rgba(99,102,241,0.3); }

    /* Layout */
    .admin-main { flex: 1; overflow-y: auto; padding: 40px; }
    .screen { display: none; animation: slideIn 0.3s ease-out; }
    .screen.active { display: block; }
    @keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    
    .screen-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .screen-header h1 { font-size: 2rem; font-weight: 900; margin: 0; letter-spacing:-0.5px;}

    /* Stats Cards */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 32px; }
    .stat-card { background: var(--card-bg); border: 1px solid var(--card-border); padding: 24px; border-radius: 20px; display: flex; gap: 20px; position:relative; overflow:hidden;}
    .stat-card .card-icon { width: 56px; height: 56px; border-radius: 14px; background: rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:center; color: var(--primary);}
    .stat-card .value { font-size: 2rem; font-weight: 900; }
    .stat-card .label { color: var(--text-muted); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; }
    .live-border { border-top: 4px solid var(--live-color); }
    .trial-border { border-top: 4px solid var(--trial-color); }
    .test-border { border-top: 4px solid var(--test-color); }

    /* AI Insights */
    .dashboard-grid-2 { display: grid; grid-template-columns: 3fr 2fr; gap: 24px; }
    .ai-insights-panel { background: linear-gradient(135deg, #1e1b4b 0%, #0f172a 100%); border: 1px solid var(--primary); padding: 24px; border-radius: 20px; }
    .insight-item { display: flex; gap: 16px; padding: 16px; border-radius: 12px; background: rgba(255,255,255,0.03); margin-bottom: 12px; }
    .insight-icon { font-size: 1.5rem; }
    .insight-body strong { display: block; margin-bottom: 4px; }
    .insight-body p { margin: 0; color: var(--text-muted); font-size: 0.9rem; }

    /* Tables */
    .data-card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 20px; overflow: hidden; }
    .p-30 { padding: 30px; }
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th { padding: 16px 20px; text-align: left; background: rgba(0,0,0,0.2); font-size: 0.75rem; color: #64748b; font-weight: 800; text-transform: uppercase; }
    .data-table td { padding: 16px 20px; border-bottom: 1px solid var(--card-border); font-size: 0.9rem; }
    
    /* Wizards */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.9); backdrop-filter: blur(10px); display: none; align-items: center; justify-content: center; z-index: 1000; }
    .modal-content.large { width: 900px; padding: 0; border-radius: 24px; }
    .wizard-header { background: #1e293b; padding: 24px 40px; border-radius: 24px 24px 0 0; display:flex; justify-content:space-between; align-items:center;}
    .wizard-steps { display:flex; gap:24px; }
    .step { font-size: 0.85rem; font-weight: 700; color: #64748b; }
    .step.active { color: var(--primary); }
    .wizard-screen { padding: 40px; display: none; height: 400px; overflow-y:auto;}
    .wizard-screen.active { display: block; }
    .wizard-footer { padding: 24px 40px; border-top: 1px solid var(--card-border); display:flex; justify-content:flex-end; gap:16px;}
    
    .industry-picker, .plan-picker, .env-picker { display:grid; grid-template-columns: repeat(4, 1fr); gap:12px; }
    .ind-option, .plan-card, .env-card { background:#0f172a; border: 1px solid #334155; padding:20px; border-radius:16px; cursor:pointer; text-align:center; transition:0.2s;}
    .ind-option input, .plan-card input, .env-card input { display:none; }
    .ind-option:has(input:checked), .plan-card:has(input:checked), .env-card:has(input:checked) { border-color:var(--primary); background:rgba(99,102,241,0.1); }
    
    .btn-primary { background: var(--primary); color: white; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-secondary { background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--card-border); padding: 12px 24px; border-radius: 12px; font-weight: 600; cursor: pointer; }
    .btn-sm { background: rgba(255,255,255,0.1); border:none; color:white; padding:4px 8px; border-radius:4px; font-size:0.7rem; cursor:pointer;}
    .full-width { width: 100%; }

    .tag { padding: 4px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; }
    .tag.live { background: #064e3b; color: #10b981; }
    .tag.trial { background: #451a03; color: #f59e0b; }
    .tag.test { background: #172554; color: #60a5fa; }
    
    .key-input { background: rgba(0,0,0,0.3); border: 1px solid var(--card-border); color: white; padding: 6px 12px; border-radius: 4px; font-family: monospace; }
    .gateway-item { display:flex; justify-content:space-between; align-items:center; padding:24px; border-bottom:1px solid var(--card-border);}

    /* Plugin Grid */
    .plugins-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:20px;}
    .plugin-card { background: var(--card-bg); border: 1px solid var(--card-border); padding:20px; border-radius:16px; display:flex; align-items:center; gap:16px;}
    .p-icon { font-size:2rem; }
    .p-info { flex:1; }
    .p-info strong { display:block; }
    .p-info p { font-size:0.8rem; color:var(--text-muted); margin:4px 0;}

    /* Success Card */
    .success-body { background: rgba(16,185,129,0.05); padding:24px; border-radius:16px; border:1px solid var(--secondary); margin-top:16px;}
    .cred-item { display:flex; justify-content:space-between; margin-bottom:12px; font-family:monospace; font-size:1.1rem;}
    .cred-item label { color:var(--text-muted); font-size:0.8rem; text-transform:uppercase;}

    .mt-10 { margin-top: 10px; }
    .mt-20 { margin-top: 20px; }
    .mt-30 { margin-top: 30px; }

    .log-console { height: 500px; background: #000; color: #10b981; font-family: 'Fira Code', monospace; padding: 20px; border-radius: 16px; font-size: 0.8rem; overflow-y:auto;}
    .usage-list { padding: 20px; }
    .audit-entry { font-size:0.75rem; margin-bottom:8px; border-bottom:1px solid rgba(255,255,255,0.05); padding-bottom:4px;}

    /* Custom UI Elements */
    .switch { position: relative; display: inline-block; width: 44px; height: 24px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; inset: 0; background-color: #334155; transition: .4s; border-radius: 24px; }
    .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
    input:checked + .slider { background-color: var(--primary); }
    input:checked + .slider:before { transform: translateX(20px); }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
        // Screens Logic
        window.switchScreen = (id) => {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            document.getElementById('screen-' + id)?.classList.add('active');
            document.querySelector(`[data-screen="${id}"]`)?.classList.add('active');
            window.location.hash = id;
            logAudit(`Navigated to section: ${id.toUpperCase()}`);
        };

        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', (e) => {
                const screenId = item.getAttribute('data-screen');
                if(screenId) switchScreen(screenId);
            });
        });

        if(window.location.hash) switchScreen(window.location.hash.substring(1));

        // Wizard Logic
        let currentStep = 1;
        window.openProvisionWizard = () => {
            currentStep = 1;
            updateWizardUI();
            document.getElementById('onboardingWizard').style.display = 'flex';
        };
        window.closeWizard = () => document.getElementById('onboardingWizard').style.display = 'none';

        function updateWizardUI() {
            document.querySelectorAll('.wizard-screen').forEach(s => s.classList.remove('active'));
            document.querySelector(`.wizard-screen[data-id="${currentStep}"]`).classList.add('active');
            document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
            document.querySelector(`.step[data-id="${currentStep}"]`).classList.add('active');
            
            document.getElementById('wizPrev').style.display = currentStep === 1 ? 'none' : 'block';
            document.getElementById('wizNext').style.display = currentStep === 5 ? 'none' : 'block';
            document.getElementById('wizSubmit').style.display = currentStep === 5 ? 'block' : 'none';

            if(currentStep === 5) renderSummary();
        }

        document.getElementById('wizNext').addEventListener('click', () => { currentStep++; updateWizardUI(); });
        document.getElementById('wizPrev').addEventListener('click', () => { currentStep--; updateWizardUI(); });

        function renderSummary() {
            const biz = document.getElementById('wBizName').value;
            const ind = document.querySelector('input[name="wInd"]:checked').value;
            const plan = document.querySelector('input[name="wPlan"]:checked').value;
            const env = document.querySelector('input[name="wEnv"]:checked').value;
            
            document.getElementById('provisionSummary').innerHTML = `
                <div style="background:rgba(255,255,255,0.05); padding:24px; border-radius:16px;">
                    <p><strong>Business:</strong> ${biz}</p>
                    <p><strong>Industry:</strong> ${ind.toUpperCase()}</p>
                    <p><strong>Subscription:</strong> ${plan.toUpperCase()} Plan</p>
                    <p><strong>Environment:</strong> <span class="tag ${env}">${env.toUpperCase()}</span></p>
                    <hr style="opacity:0.1; margin:16px 0;">
                    <p style="font-size:0.8rem; color:var(--text-muted)">Workspace URL: <strong>${biz.toLowerCase().replace(/\s+/g, '')}.boboanalytics.com</strong></p>
                </div>
            `;
        }

        document.getElementById('wizardForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const statusBox = document.getElementById('wizardStatus');
            statusBox.style.display = 'block';
            
            const pass = 'BOBO_' + Math.random().toString(36).substr(2, 6).toUpperCase();
            const username = document.getElementById('wBizName').value.toLowerCase().replace(/\s+/g, '_') + '_admin';

            const newAcc = {
                id: 'T-' + Math.random().toString(36).substr(2, 9).toUpperCase(),
                businessName: document.getElementById('wBizName').value,
                ownerName: document.getElementById('wOwner').value,
                email: document.getElementById('wEmail').value,
                phone: document.getElementById('wPhone').value,
                city: document.getElementById('wCity').value,
                industry: document.querySelector('input[name="wInd"]:checked').value,
                plan: document.querySelector('input[name="wPlan"]:checked').value,
                environment: document.querySelector('input[name="wEnv"]:checked').value,
                username: username,
                password: pass,
                status: 'Active',
                created: new Date().toISOString()
            };

            await new Promise(r => setTimeout(r, 2000));
            
            let accounts = JSON.parse(localStorage.getItem('bobo_accounts') || '[]');
            accounts.push(newAcc);
            localStorage.setItem('bobo_accounts', JSON.stringify(accounts));
            
            logAudit(`COMPLIANCE: Admin provisioned new tenant ${newAcc.businessName} [Plan: ${newAcc.plan}]`);
            
            statusBox.style.display = 'none';
            closeWizard();
            showSuccess(newAcc);
            refreshState();
        });

        window.showSuccess = (acc) => {
            const isLive = acc.environment === 'live';
            document.getElementById('credView').innerHTML = `
                <div style="text-align:center; margin-bottom:15px;">
                    <span class="tag ${acc.environment}">${acc.environment.toUpperCase()} ENVIRONMENT</span>
                </div>
                <div class="cred-item"><label>Workspace</label> <span>${acc.businessName.toLowerCase().replace(/\s+/g,'')}.boboanalytics.com</span></div>
                <div class="cred-item"><label>Admin Username</label> <span>${acc.username}</span></div>
                <div class="cred-item"><label>Secret Key</label> <span>${acc.password}</span></div>
                <div class="cred-item"><label>Welcome Msg</label> <span>${isLive ? '🚀 Production Ready' : '⏳ 14-Day Sandbox'}</span></div>
                <p style="font-size:0.75rem; color:var(--text-muted); margin-top:10px; border:1px dashed var(--card-border); padding:10px; border-radius:8px;">
                    <strong>Note:</strong> ${isLive ? 'Live customers receive production server credentials.' : 'Trial users receive standard access with upgrade prompts.'}
                </p>
            `;
            document.getElementById('successModal').style.display = 'flex';
        };

        window.closeSuccess = () => document.getElementById('successModal').style.display = 'none';

        window.simulateNotify = (type) => {
            const accs = JSON.parse(localStorage.getItem('bobo_accounts') || '[]');
            const last = accs[accs.length - 1];
            alert(`NOTIFY: Sent welcome kit to ${last.ownerName} via ${type.toUpperCase()}.\nEmail: ${last.email}\nPhone: ${last.phone}`);
            logAudit(`NOTIFY: Credentials shared via ${type} to ${last.businessName}`);
        };

        window.toggleKey = (id) => {
            const input = document.getElementById(id);
            input.type = input.type === 'password' ? 'text' : 'password';
        };

        function logAudit(msg) {
            const auditLog = JSON.parse(localStorage.getItem('bobo_audit') || '[]');
            const entry = { time: new Date().toISOString(), msg: msg };
            auditLog.push(entry);
            localStorage.setItem('bobo_audit', JSON.stringify(auditLog.slice(-100)));
            renderAudit();
        }

        function renderAudit() {
            const logs = JSON.parse(localStorage.getItem('bobo_audit') || '[]');
            const logPanel = document.getElementById('miniAuditLog');
            const logGlobal = document.getElementById('systemLog');
            
            if(logPanel) {
                logPanel.innerHTML = logs.slice(-10).reverse().map(l => `
                    <div class="audit-entry">
                        <span style="color:var(--primary)">[${new Date(l.time).toLocaleTimeString()}]</span> ${l.msg}
                    </div>
                `).join('');
            }

            if(logGlobal) {
                logGlobal.innerHTML = logs.map(l => `<div>[${new Date(l.time).toLocaleString()}] ${l.msg}</div>`).join('');
            }
        }

        function refreshState() {
            const accounts = JSON.parse(localStorage.getItem('bobo_accounts') || '[]');
            document.getElementById('statTotalBiz').innerText = accounts.length;
            document.getElementById('statLive').innerText = accounts.filter(a => a.environment === 'live').length;
            document.getElementById('statTrial').innerText = accounts.filter(a => a.environment === 'trial').length;
            
            let mrr = 0;
            accounts.filter(a=>a.environment === 'live').forEach(a => {
                if(a.plan === 'starter') mrr += 4999;
                else if(a.plan === 'professional') mrr += 9999;
                else mrr += 19999;
            });
            document.getElementById('totalMRR').innerText = '₹' + mrr.toLocaleString();
            document.getElementById('revARR').innerText = '₹' + (mrr * 12).toLocaleString();

            renderAccounts(accounts);
            renderRevenue(accounts);
            renderLeads(accounts);
        }

        function renderLeads(accounts) {
            const tbody = document.getElementById('leadTableBody');
            if(!tbody) return;
            // Only show organic leads awaiting provisioning
            const leads = accounts.filter(a => a.type === 'Lead');
            tbody.innerHTML = leads.map(a => `
                <tr>
                    <td><strong>${a.businessName}</strong><br><small>${a.ownerName}</small></td>
                    <td>${a.email}<br>${a.phone}</td>
                    <td><span class="tag test">${a.industry.toUpperCase()}</span></td>
                    <td><span class="tag live">${a.source || 'Direct'}</span></td>
                    <td>
                        <button class="btn-sm" onclick="viewLeadInfo('${a.id}')">Review Hub</button>
                        <button class="btn-sm" style="background:var(--primary)" onclick="switchScreen('accounts')">Provision</button>
                    </td>
                </tr>
            `).join('') || '<tr><td colspan="5" style="text-align:center">No active leads in queue.</td></tr>';
        }

        window.viewLeadInfo = (id) => {
            const accs = JSON.parse(localStorage.getItem('bobo_accounts') || '[]');
            const a = accs.find(x => x.id === id);
            alert(`LEAD DATA:\n\nBusiness: ${a.businessName}\nOwner: ${a.ownerName}\nEmail: ${a.email}\nPhone: ${a.phone}\nPlan Interest: ${a.plan.toUpperCase()}\nStatus: ${a.status}`);
        };

        function renderRevenue(accounts) {
            const tbody = document.getElementById('revenueTableBody');
            if(!tbody) return;
            const liveOnly = accounts.filter(a => a.environment === 'live');
            tbody.innerHTML = liveOnly.map(a => `
                <tr>
                    <td>${new Date(a.created).toLocaleDateString()}</td>
                    <td>${a.businessName}</td>
                    <td>${a.plan.toUpperCase()}</td>
                    <td>₹${a.plan === 'starter' ? '4,999' : a.plan === 'professional' ? '9,999' : '19,999'}</td>
                    <td><span class="tag live">Paid</span></td>
                </tr>
            `).join('') || '<tr><td colspan="5" style="text-align:center">No revenue records.</td></tr>';
        }

        function renderAccounts(accounts) {
            const tbody = document.getElementById('accountsTableBody');
            if(!tbody) return;

            const fInd = document.getElementById('filterIndustry')?.value || 'all';
            const fEnv = document.getElementById('filterEnv')?.value || 'all';
            const fStat = document.getElementById('filterStatus')?.value || 'all';

            const filtered = accounts.filter(a => {
                if(fInd !== 'all' && a.industry !== fInd) return false;
                if(fEnv !== 'all' && a.environment !== fEnv) return false;
                if(fStat !== 'all' && a.status !== fStat) return false;
                return true;
            });

            tbody.innerHTML = filtered.map(a => `
                <tr>
                    <td><strong>${a.businessName}</strong><br><small>${a.ownerName}</small></td>
                    <td>${a.industry.toUpperCase()}</td>
                    <td><code>${a.businessName.toLowerCase().replace(/\s+/g,'')}.boboanalytics.com</code></td>
                    <td><span class="tag ${a.environment}">${a.environment}</span></td>
                    <td><strong>${a.plan.toUpperCase()}</strong></td>
                    <td><span class="tag live">🟢 ${a.status}</span></td>
                    <td>
                        <button class="btn-sm" onclick="viewProvisionInfo('${a.id}')">Details</button>
                        <button class="btn-sm" style="background:#ef4444" onclick="logAudit('Admin suspended ${a.businessName}')">Suspend</button>
                    </td>
                </tr>
            `).join('') || '<tr><td colspan="7" style="text-align:center; padding:40px; color:var(--text-muted)">No tenants found.</td></tr>';
        }

        window.viewProvisionInfo = (id) => {
            const accs = JSON.parse(localStorage.getItem('bobo_accounts') || '[]');
            const a = accs.find(x => x.id === id);
            alert(`Registration Info:\n\nBusiness: ${a.businessName}\nOwner: ${a.ownerName}\nEmail: ${a.email}\nPhone: ${a.phone}\nJoin Date: ${new Date(a.created).toLocaleString()}`);
        };

        window.saveGateway = (name) => {
            alert(`COMPLIANCE: Saved configuration for ${name} Gateway.`);
            logAudit(`Admin updated ${name} API configuration.`);
        };

        window.openPlanModal = () => alert('Plan Editor Active: Set Quotas, Limits & Pricing');
        window.editIndustry = (name) => alert(`Editing Modules for ${name.toUpperCase()}: Inventory, POS, Analytics enabled.`);

        renderAudit();
        refreshState();
    });
  </script>
</MainLayout>
