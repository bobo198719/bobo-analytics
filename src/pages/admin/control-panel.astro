---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Admin | SaaS Control Center" hideNav={true}>
  <style>
    :root {
      --bg-dark: #050810;
      --sidebar-bg: #0c111d;
      --card-bg: #141c2d;
      --neon-blue: #3b82f6;
      --neon-green: #10b981;
      --neon-red: #ef4444;
      --border-color: rgba(255,255,255,0.08);
      --text-muted: #94a3b8;
    }

    body {
      margin: 0;
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg-dark);
      color: #fff;
      display: flex;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* SIDEBAR */
    .sidebar {
      width: 260px;
      height: 100vh;
      background: var(--sidebar-bg);
      padding: 30px 15px;
      position: fixed;
      left: 0;
      top: 0;
      border-right: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      z-index: 1000;
      transition: transform 0.3s ease;
    }

    .sidebar h2 {
      margin-bottom: 30px;
      font-size: 1.2rem;
      font-weight: 800;
      letter-spacing: 1px;
      color: #fff;
      padding: 0 15px;
    }

    .nav-menu { flex: 1; }

    .menu-item {
      padding: 14px 18px;
      margin-bottom: 6px;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s ease;
      color: var(--text-muted);
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
      border: none;
      background: transparent;
      width: 100%;
      text-align: left;
      font-size: 0.95rem;
    }

    .menu-item:hover {
      background: rgba(255, 255, 255, 0.04);
      color: white;
    }

    .menu-item.active {
      background: var(--neon-blue);
      color: white;
      box-shadow: 0 8px 16px rgba(59, 130, 246, 0.25);
    }

    /* MAIN AREA */
    .main {
      margin-left: 260px;
      flex: 1;
      padding: 40px;
      width: calc(100% - 260px);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    /* SECTIONS */
    .section {
      display: none;
    }

    .section.active {
      display: block;
      animation: fadeIn 0.3s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* KPI GRID */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 32px;
    }

    .card {
      background: var(--card-bg);
      padding: 24px;
      border-radius: 16px;
      border: 1px solid var(--border-color);
    }

    .card-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 8px; }
    .value { font-size: 2rem; font-weight: 800; }

    /* TABLES */
    .table-box {
      background: var(--card-bg);
      padding: 24px;
      border-radius: 16px;
      border: 1px solid var(--border-color);
      overflow-x: auto;
    }

    h3 { margin-top: 0; font-size: 1.25rem; }

    table { width: 100%; border-collapse: collapse; min-width: 700px; }
    th { text-align: left; padding: 12px 16px; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; border-bottom: 1px solid var(--border-color); }
    td { padding: 16px; border-bottom: 1px solid var(--border-color); font-size: 0.9rem; }

    /* MOBILE */
    .mobile-header {
      display: none;
      height: 60px;
      background: var(--sidebar-bg);
      position: fixed;
      top: 0; left: 0; width: 100%;
      z-index: 1001;
      padding: 0 20px;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border-color);
    }

    .hamburger { font-size: 1.5rem; cursor: pointer; }

    @media (max-width: 900px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; width: 100%; padding: 80px 20px; }
      .mobile-header { display: flex; }
    }

    .status-active { color: var(--neon-green); font-weight: bold; }
    .status-inactive { color: var(--neon-red); font-weight: bold; }
  </style>

  <div class="mobile-header">
    <div class="hamburger" onclick="toggleSidebar()">☰</div>
    <div style="font-weight: 800;">BOBO ADMIN</div>
    <div style="color:var(--neon-blue);">v12.1</div>
  </div>

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-top">
      <h2>BOBO ADMIN</h2>
    </div>
    <nav class="nav-menu">
      <button class="menu-item active" data-id="dashboard" onclick="switchTab('dashboard', this)">
        <span class="icon">📊</span>
        <span class="label">Dashboard</span>
      </button>
      <button class="menu-item" data-id="tenants" onclick="switchTab('tenants', this)">
        <span class="icon">🏢</span>
        <span class="label">Tenants</span>
      </button>
      <button class="menu-item" data-id="billing" onclick="switchTab('billing', this)">
        <span class="icon">💸</span>
        <span class="label">Billing</span>
      </button>
      <button class="menu-item" data-id="security" onclick="switchTab('security', this)">
        <span class="icon">🛡️</span>
        <span class="label">Security Logs</span>
      </button>
      <button class="menu-item" data-id="leads" onclick="switchTab('leads', this)">
        <span class="icon">🎯</span>
        <span class="label">Leads Management</span>
      </button>
    </nav>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <div class="container">

      <!-- DASHBOARD -->
      <div id="dashboard" class="section active">
        <h1>Dashboard Overview</h1>
        <div class="kpi-grid">
          <div class="card"><div class="card-label">Total Users</div><div class="value" id="k-users">0</div></div>
          <div class="card"><div class="card-label">Active Nodes</div><div class="value" id="k-active" style="color:var(--neon-green)">0</div></div>
          <div class="card"><div class="card-label">Revenue</div><div class="value" id="k-revenue">₹0</div></div>
          <div class="card"><div class="card-label">Alerts</div><div class="value" id="k-alerts" style="color:var(--neon-red)">0</div></div>
        </div>
        <div class="table-box">
          <h3>Ecosystem Health</h3>
          <div style="height:300px; display:flex; align-items:center; justify-content:center; background:rgba(255,255,255,0.02); border-radius:12px;">
            <canvas id="industryChart"></canvas>
          </div>
        </div>
      </div>

      <!-- TENANTS -->
      <div id="tenants" class="section">
        <h1>Tenant Registry</h1>
        <div class="table-box">
          <table>
            <thead><tr><th>Business</th><th>Industry</th><th>Plan</th><th>Status</th></tr></thead>
            <tbody id="tenantBody"></tbody>
          </table>
        </div>
      </div>

      <!-- BILLING -->
      <div id="billing" class="section">
        <h1>Revenue Records</h1>
        <div class="table-box">
          <table>
            <thead><tr><th>Date</th><th>Client</th><th>Plan</th><th>Amount</th></tr></thead>
            <tbody id="billingBody"></tbody>
          </table>
        </div>
      </div>

      <!-- SECURITY -->
      <div id="security" class="section">
        <h1>Security Operations</h1>
        <div class="table-box">
          <table>
            <thead><tr><th>User</th><th>IP Address</th><th>Status</th><th>Time</th></tr></thead>
            <tbody id="logBody"></tbody>
          </table>
        </div>
      </div>

      <!-- LEADS -->
      <div id="leads" class="section">
        <h1>Leads Hub</h1>
        <div class="card"><p>Global lead queue is empty.</p></div>
      </div>

    </div>
  </main>

  <script is:inline>
    // DEFINE TABS GLOBALLY BEFORE DATA LOADS
    window.switchTab = function(id, el) {
      console.log("[ADMIN] Switching Tab to:", id);
      const sections = document.querySelectorAll('.section');
      sections.forEach(s => s.classList.remove('active'));
      const target = document.getElementById(id);
      if(target) target.classList.add('active');
      const items = document.querySelectorAll('.menu-item');
      items.forEach(i => i.classList.remove('active'));
      if(el) el.classList.add('active');
      else {
        const matchingBtn = document.querySelector(`.menu-item[data-id="${id}"]`);
        if(matchingBtn) matchingBtn.classList.add('active');
      }
      const sidebar = document.getElementById('sidebar');
      if(sidebar) sidebar.classList.remove('open');
      return false;
    };
    window.toggleSidebar = function() {
      const sidebar = document.getElementById('sidebar');
      if(sidebar) sidebar.classList.toggle('open');
    };
  </script>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    let myChart = null;
    async function loadDashboardData() {
      try {
        const [usersR, logsR, revR, dashR] = await Promise.all([
          fetch('/api/v2/admin-ops?action=users'),
          fetch('/api/v2/admin-ops?action=login-logs'),
          fetch('/api/v2/admin-ops?action=revenue'),
          fetch('/api/v2/admin-ops?action=dashboard')
        ]);
        const users = await usersR.json();
        const logs = await logsR.json();
        const rev = await revR.json();
        const dash = await dashR.json();

        if(document.getElementById('k-users')) document.getElementById('k-users').innerText = users.length;
        if(document.getElementById('k-active')) document.getElementById('k-active').innerText = users.filter(u=>u.status==='active').length;
        if(document.getElementById('k-revenue')) document.getElementById('k-revenue').innerText = '₹' + dash.revenue.toLocaleString();
        
        const tBody = document.getElementById('tenantBody');
        if(tBody) tBody.innerHTML = users.map(u => `<tr><td><strong>${u.business_name}</strong></td><td>${u.industry}</td><td>${u.plan_type}</td><td><span class="${u.status==='active'?'status-active':'status-inactive'}">${u.status}</span></td></tr>`).join('');
        const revBody = document.getElementById('billingBody');
        if(revBody) revBody.innerHTML = (rev.records || []).map(r => `<tr><td>${new Date(r.created_at).toLocaleDateString()}</td><td>${r.business_name}</td><td>${r.plan_type}</td><td>₹${r.amount}</td></tr>`).join('');
        const logBody = document.getElementById('logBody');
        if(logBody) logBody.innerHTML = logs.map(l => `<tr><td>${l.username}</td><td><code>${l.ip_address}</code></td><td><span class="${l.status==='success'?'status-active':'status-inactive'}">${l.status}</span></td><td>${new Date(l.created_at).toLocaleTimeString()}</td></tr>`).join('');

        const counts = { Restaurant:0, Pharmacy:0, Retail:0, Bakery:0 };
        users.forEach(u => { if(counts[u.industry]!==undefined) counts[u.industry]++; });
        const chartData = [counts.Restaurant, counts.Pharmacy, counts.Retail, counts.Bakery];
        const hasData = chartData.some(v => v > 0);
        const finalData = hasData ? chartData : [25, 25, 25, 25]; 

        const ctx = document.getElementById('industryChart');
        if(ctx && window.Chart) {
           if(myChart) myChart.destroy();
           myChart = new Chart(ctx, {
             type: 'doughnut',
             data: { labels: ['Restaurant', 'Pharmacy', 'Retail', 'Bakery'], datasets: [{ data: finalData, backgroundColor: ['#ef4444', '#10b981', '#3b82f6', '#f59e0b'], borderWidth: 0 }] },
             options: { responsive:true, maintainAspectRatio:false, cutout: '75%', plugins: { legend: { position: 'bottom', labels: { color: '#fff', padding: 20 } } } }
           });
        }
        const secR = await fetch('/api/v2/admin-ops?action=security-alerts');
        const alerts = await secR.json();
        if(document.getElementById('k-alerts')) document.getElementById('k-alerts').innerText = alerts.length;
      } catch (e) { console.error(e); }
    }
    document.addEventListener('DOMContentLoaded', loadDashboardData);
  </script>
</MainLayout>
