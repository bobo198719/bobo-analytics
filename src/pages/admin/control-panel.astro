        { id: "starter", title: "Starter Node", features: "1 Restaurant, 1 Location, Table Management, Manual Menu Sync, GST Billing", price: "", emi: "" },
        { id: "growth", title: "Growth Protocol", features: "5 Restaurant Locations, KDS, QR Table Ordering, Smart AI Menu Uploads, Advanced Revenue Dashboards, GST Taxation Intel, 30 Table Support", price: "", emi: "" },
        { id: "best_value", title: "Best Value", features: "Unlimited Branches, Global Staff Governance Matrix, Advanced Yield & Profit Projections, Custom Branding, Full API Infrastructure Access", price: "", emi: "" }
      ],
      bakery: [
