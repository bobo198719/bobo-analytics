---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Admin | Production Control Panel" hideNav={true}>
  <style>
    :root {
      --bg-dark: #050810;
      --sidebar-bg: #0c111d;
      --card-bg: #141c2d;
      --neon-blue: #3b82f6;
      --neon-green: #10b981;
      --neon-red: #ef4444;
      --border-color: rgba(255,255,255,0.08);
      --text-muted: #94a3b8;
    }

    body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg-dark); color: #fff; display: flex; min-height: 100vh; overflow-x: hidden; }

    /* AUTH OVERLAY */
    #authOverlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--bg-dark); z-index: 2000; display: flex; align-items: center; justify-content: center; }
    .auth-card { background: var(--card-bg); padding: 40px; border-radius: 24px; border: 1px solid var(--border-color); width: 400px; text-align: center; }
    .auth-input { width: 100%; padding: 14px; margin-bottom: 20px; border-radius: 12px; border: 1px solid var(--border-color); background: rgba(255,255,255,0.05); color: white; outline: none; }
    .btn-primary { width: 100%; background: var(--neon-blue); color: white; border: none; padding: 14px; border-radius: 12px; font-weight: 800; cursor: pointer; }

    /* CONTENT */
    #dashboardContent { display: none; width: 100%; }
    .sidebar { width: 260px; height: 100vh; background: var(--sidebar-bg); padding: 30px 15px; position: fixed; left: 0; top: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; }
    .menu-item { padding: 14px 18px; margin-bottom: 6px; border-radius: 12px; cursor: pointer; transition: 0.2s; color: var(--text-muted); font-weight: 600; display: flex; align-items: center; gap: 12px; border: none; background: transparent; width: 100%; font-size: 0.95rem; }
    .menu-item.active { background: var(--neon-blue); color: white; }

    .main { margin-left: 260px; flex: 1; padding: 40px; width: calc(100% - 260px); }
    .container { max-width: 1200px; margin: 0 auto; }
    .section { display: none; }
    .section.active { display: block; animation: fadeIn 0.3s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 32px; }
    .card { background: var(--card-bg); padding: 24px; border-radius: 16px; border: 1px solid var(--border-color); }
    .card-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; margin-bottom: 8px; }
    .value { font-size: 2.2rem; font-weight: 800; }

    .table-box { background: var(--card-bg); padding: 24px; border-radius: 16px; border: 1px solid var(--border-color); overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 700px; }
    th { text-align: left; padding: 12px 16px; color: var(--text-muted); font-size: 0.75rem; border-bottom: 1px solid var(--border-color); }
    td { padding: 16px; border-bottom: 1px solid var(--border-color); font-size: 0.95rem; }

    .status-active { color: var(--neon-green); font-weight: bold; }
  </style>

  <div id="authOverlay">
    <div class="auth-card">
      <h2 style="margin-bottom: 10px;">🛡️ Enterprise Secure OS</h2>
      <p style="color:var(--text-muted); margin-bottom: 30px;">Production Gateway v15.1</p>
      <input id="email" class="auth-input" type="email" placeholder="Master Email">
      <input id="password" class="auth-input" type="password" placeholder="Key Fragment">
      <button class="btn-primary" onclick="login()">Enter Console</button>
      <p id="authError" style="color:var(--neon-red); margin-top:20px; font-size:0.85rem; font-weight:bold;"></p>
    </div>
  </div>

  <div id="dashboardContent">
    <aside class="sidebar">
      <h2>BOBO OS</h2>
      <nav class="nav-menu">
        <button class="menu-item active" onclick="switchTab('dashboard', this)"><span>📊</span> Dashboard</button>
        <button class="menu-item" onclick="switchTab('tenants', this)"><span>🏢</span> Tenants</button>
        <button class="menu-item" onclick="switchTab('onboarding', this)"><span>📩</span> Incoming Leads</button>
        <button class="menu-item" onclick="switchTab('audit', this)"><span>📜</span> Audit Logs</button>
        <button class="menu-item" onclick="switchTab('billing', this)"><span>💸</span> Billing</button>
      </nav>
      <button class="menu-item" onclick="logout()" style="margin-top:auto; color:var(--neon-red)"><span>🚪</span> Sign Out</button>
    </aside>

    <main class="main">
      <div class="container">
        <div id="dashboard" class="section active">
          <h1>Production Control Tower</h1>
          <div class="kpi-grid">
            <div class="card"><div class="card-label">Overall Users</div><div id="users" class="value">0</div></div>
            <div class="card"><div class="card-label">Active Deployments</div><div id="active" class="value" style="color:var(--neon-green)">0</div></div>
            <div class="card"><div class="card-label">Projected Yield</div><div id="revenue" class="value">₹0</div></div>
            <div class="card"><div class="card-label">Security Health</div><div class="value" style="color:var(--neon-green)">100%</div></div>
          </div>
          <div class="card"><canvas id="industryChart" style="height:350px;"></canvas></div>
        </div>

        <div id="tenants" class="section">
          <h1>Tenant Registry</h1>
          <div class="table-box">
            <table>
              <thead><tr><th>Name</th><th>Industry</th><th>Status</th><th>Yield</th></tr></thead>
              <tbody id="tenantTable"></tbody>
            </table>
          </div>
        </div>

        <!-- LEADS ONBOARDING PIPELINE -->
        <div id="onboarding" class="section">
          <h1>Incoming Leads & Onboarding</h1>
          <p style="color:var(--text-muted); margin-top:-10px; margin-bottom:20px;">Review and provision infrastructure for incoming clients.</p>
          <div class="table-box">
            <table>
              <thead><tr><th>Date</th><th>Business</th><th>Owner</th><th>Phone</th><th>Email</th><th>Industry</th><th>City</th><th>Action</th></tr></thead>
              <tbody id="leadsTable"></tbody>
            </table>
          </div>
        </div>

        <div id="audit" class="section">
          <h1>Security & Auth Logs</h1>
          <div class="table-box">
            <table>
              <thead><tr><th>Time</th><th>User / Email</th><th>Status</th><th>Diagnostics</th></tr></thead>
              <tbody id="auditTable"></tbody>
            </table>
          </div>
        </div>

        <div id="billing" class="section">
          <h1>Enterprise Subscriptions</h1>
          <div class="card" style="text-align: center;">
            <button class="btn-primary" onclick="payNow()" style="width: auto; padding: 15px 30px;">Subscribe Now ₹4,999</button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    const API = "/api";
    let myChart = null;

    window.login = async function() {
      const email = document.getElementById("email").value;
      const password = document.getElementById("password").value;
      const errorEl = document.getElementById("authError");
      try {
        const res = await fetch(API + "/auth/login", { 
          method:"POST", 
          headers:{"Content-Type":"application/json"}, 
          body:JSON.stringify({email, password, industry: "admin"}) 
        });
        const data = await res.json();
        if(data.token) { localStorage.setItem("token", data.token); location.reload(); }
        else { errorEl.innerText = data.error || "Denied."; }
      } catch(e) { errorEl.innerText = "Offline."; }
    }

    window.logout = function() { localStorage.removeItem("token"); location.reload(); }

    function checkAuth() {
      const token = localStorage.getItem("token");
      if(token) {
        document.getElementById("authOverlay").style.display = "none";
        document.getElementById("dashboardContent").style.display = "flex";
        initSync();
      }
    }

    window.switchTab = function(id, el) {
      document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
      document.getElementById(id).classList.add('active');
      document.querySelectorAll('.menu-item').forEach(m => m.classList.remove('active'));
      if(el) el.classList.add('active');
    }

    async function initSync() {
      const token = localStorage.getItem("token");
      const [statsR, tenantR, auditR, leadsR] = await Promise.all([
        fetch(API + "/stats", { headers: { "Authorization": token } }),
        fetch(API + "/tenants", { headers: { "Authorization": token } }),
        fetch(API + "/admin/audit-logs", { headers: { "Authorization": token } }),
        fetch(API + "/admin/leads", { headers: { "Authorization": token } })
      ]);
      if(statsR.status === 401) return logout();
      const stats = await statsR.json();
      const tenants = await tenantR.json();
      const audits = auditR.ok ? await auditR.json() : [];
      const leads = leadsR.ok ? await leadsR.json() : [];

      document.getElementById("users").innerText = stats.users;
      document.getElementById("active").innerText = stats.active;
      document.getElementById("revenue").innerText = "₹" + stats.revenue.toLocaleString();
      
      let html = "";
      tenants.forEach(t => { html += `<tr><td><strong>${t.name}</strong></td><td>${t.industry}</td><td class="status-active">${t.status}</td><td>₹${t.revenue.toLocaleString()}</td></tr>`; });
      document.getElementById("tenantTable").innerHTML = html || '<tr><td colspan="4">No Records.</td></tr>';
      
      let leadsHtml = "";
      leads.forEach(l => {
         leadsHtml += `<tr>
           <td style="color:var(--text-muted); font-size:0.8rem;">${new Date(l.created_at).toLocaleString()}</td>
           <td><strong>${l.businessName}</strong></td>
           <td>${l.ownerName}</td>
           <td>${l.phone}</td>
           <td>${l.email}</td>
           <td><span style="background:var(--neon-blue); padding:4px 8px; border-radius:6px; font-size:0.75rem;">${l.industry}</span></td>
           <td>${l.city}</td>
           <td>
              ${l.status === 'pending' 
                ? `<button onclick="approveLead('${l.id}')" style="background:var(--neon-green); color:white; border:none; padding:8px 12px; border-radius:6px; cursor:pointer; font-weight:bold;">✅ Approve & Dispatch</button>` 
                : `<span style="color:var(--neon-green); font-weight:bold;">Provisioned</span>`}
           </td>
         </tr>`;
      });
      document.getElementById("leadsTable").innerHTML = leadsHtml || '<tr><td colspan="8">No incoming leads.</td></tr>';
      
      let auditHtml = "";
      audits.forEach(a => { 
        const isFail = a.status === 'Failed';
        const color = isFail ? 'var(--neon-red)' : 'var(--neon-green)';
        auditHtml += `<tr>
            <td style="color:var(--text-muted);font-size:0.8rem;">${new Date(a.time).toLocaleString()}</td>
            <td><strong>${a.user}</strong></td>
            <td style="color:${color};font-weight:bold;">${a.status}</td>
            <td style="color:var(--text-muted);">${a.error || 'Authed OK'}</td>
        </tr>`; 
      });
      document.getElementById("auditTable").innerHTML = auditHtml || '<tr><td colspan="4">No Logs Captured Yet.</td></tr>';

      updateChart(tenants);
    }

    window.payNow = async function() {
      const token = localStorage.getItem("token");
      const res = await fetch(API + "/create-order", { method:"POST", headers:{"Content-Type":"application/json", "Authorization":token}, body:JSON.stringify({amount: 4999}) });
      const order = await res.json();
      const options = { key: "rzp_test_placeholder", amount: order.amount, currency: "INR", name: "Bobo OS", order_id: order.id, handler: async function (response) {
         const vr = await fetch(API + "/verify-payment", { method:"POST", headers:{"Content-Type":"application/json", "Authorization":token}, body:JSON.stringify({ razorpay_order_id: response.razorpay_order_id, razorpay_payment_id: response.razorpay_payment_id, razorpay_signature: response.razorpay_signature }) });
         const vData = await vr.json();
         if(vData.status === "success") alert("Verified Payment!");
      }, theme: { color: "#3b82f6" } };
      new window.Razorpay(options).open();
    }

    window.approveLead = async function(id) {
      if(!confirm("Create infrastructure and dispatch welcome credentials?")) return;
      const btn = event.currentTarget;
      btn.innerText = "Dispatching...";
      btn.disabled = true;
      try {
        const res = await fetch(API + "/admin/approve-lead", {
          method: "POST",
          headers: {"Content-Type": "application/json", "Authorization": localStorage.getItem("token")},
          body: JSON.stringify({ leadId: id })
        });
        const data = await res.json();
        if(data.success) {
          alert("✅ Infrastructure provisioned! Credentials sent successfully.");
          initSync();
        } else {
          alert("Error: " + data.error);
          btn.innerText = "Error";
        }
      } catch(e) { alert("Network error"); btn.innerText = "✅ Approve & Dispatch"; btn.disabled = false;}
    }

    function updateChart(data) {
      const ctx = document.getElementById('industryChart'); if(!ctx) return;
      const sectors = { Restaurant:0, Bakery:0, Retail:0, Pharmacy:0 };
      data.forEach(t => { if(sectors[t.industry]!==undefined) sectors[t.industry]++; });
      if(myChart) myChart.destroy();
      myChart = new Chart(ctx, { type:'doughnut', data:{ labels:Object.keys(sectors), datasets:[{ data:Object.values(sectors).some(v=>v>0)?Object.values(sectors):[1,1,1,1], backgroundColor:['#ef4444', '#f59e0b', '#3b82f6', '#10b981'], borderWidth:0 }] }, options:{ responsive:true, maintainAspectRatio:false, cutout:'75%', plugins: { legend: { position:'bottom', labels:{color:'#fff', padding:20} } } } });
    }

    document.addEventListener('DOMContentLoaded', checkAuth);
  </script>
</MainLayout>
