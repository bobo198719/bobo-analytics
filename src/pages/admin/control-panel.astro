---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Admin | Enterprise Control Panel" hideNav={true}>
  <style>
    :root {
      --bg-dark: #050810;
      --sidebar-bg: #0c111d;
      --card-bg: #141c2d;
      --neon-blue: #3b82f6;
      --neon-green: #10b981;
      --neon-red: #ef4444;
      --border-color: rgba(255,255,255,0.08);
      --text-muted: #94a3b8;
    }

    body {
      margin: 0;
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg-dark);
      color: #fff;
      display: flex;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* SIDEBAR */
    .sidebar { width: 260px; height: 100vh; background: var(--sidebar-bg); padding: 30px 15px; position: fixed; left: 0; top: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; z-index: 1000; }
    .sidebar h2 { margin-bottom: 30px; font-size: 1.2rem; font-weight: 800; padding: 0 15px; }

    .menu-item { padding: 14px 18px; margin-bottom: 6px; border-radius: 12px; cursor: pointer; transition: all 0.2s ease; color: var(--text-muted); font-weight: 600; display: flex; align-items: center; gap: 12px; border: none; background: transparent; width: 100%; text-align: left; font-size: 0.95rem; }
    .menu-item:hover { background: rgba(255, 255, 255, 0.04); color: white; }
    .menu-item.active { background: var(--neon-blue); color: white; box-shadow: 0 8px 16px rgba(59, 130, 246, 0.25); }

    /* MAIN AREA */
    .main { margin-left: 260px; flex: 1; padding: 40px; width: calc(100% - 260px); }
    .container { max-width: 1200px; margin: 0 auto; }

    /* SECTIONS */
    .section { display: none; }
    .section.active { display: block; animation: fadeIn 0.3s ease-out; }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }

    /* KPI GRID */
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 32px; }
    .card { background: var(--card-bg); padding: 24px; border-radius: 16px; border: 1px solid var(--border-color); }
    .card-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 8px; }
    .value { font-size: 2.2rem; font-weight: 800; }

    /* TABLES */
    .table-box { background: var(--card-bg); padding: 24px; border-radius: 16px; border: 1px solid var(--border-color); overflow-x: auto; }
    h1 { font-size: 1.8rem; margin-bottom: 24px; }
    table { width: 100%; border-collapse: collapse; min-width: 700px; }
    th { text-align: left; padding: 12px 16px; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; border-bottom: 1px solid var(--border-color); }
    td { padding: 16px; border-bottom: 1px solid var(--border-color); font-size: 0.95rem; }

    .btn-add { background: var(--neon-blue); color: white; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: 0.2s; margin-bottom: 20px; }
    .btn-add:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3); }
    .status-active { color: var(--neon-green); font-weight: bold; }
  </style>

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-top">
      <h2>BOBO OS</h2>
      <div style="color:var(--neon-blue); font-size:0.75rem; padding-left:15px; margin-top:-20px; margin-bottom:30px;">MASTER CONSOLE v2.0</div>
    </div>
    <nav class="nav-menu">
      <button class="menu-item active" onclick="switchTab('dashboard', this)"><span>📊</span> Dashboard</button>
      <button class="menu-item" onclick="switchTab('tenants', this)"><span>🏢</span> Tenants</button>
      <button class="menu-item" onclick="switchTab('billing', this)"><span>💸</span> Billing</button>
    </nav>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <div class="container">
      <div id="dashboard" class="section active">
        <h1>Dashboard Control Tower</h1>
        <div class="kpi-grid">
          <div class="card"><div class="card-label">Total Users</div><div class="value" id="users">0</div></div>
          <div class="card"><div class="card-label">Active Nodes</div><div class="value" id="active" style="color:var(--neon-green)">0</div></div>
          <div class="card"><div class="card-label">Overall Revenue</div><div class="value" id="revenue">₹0</div></div>
          <div class="card"><div class="card-label">Security Alerts</div><div class="value" id="alerts" style="color:var(--neon-red)">0</div></div>
        </div>
        <div class="table-box">
          <h3>Ecosystem Health</h3>
          <div style="height:350px;"><canvas id="industryChart"></canvas></div>
        </div>
      </div>

      <div id="tenants" class="section">
        <h1>Tenant Registry</h1>
        <button class="btn-add" onclick="addTenant()">+ Add Tenant</button>
        <div class="table-box">
          <table>
            <thead><tr><th>Establishment Name</th><th>Industry</th><th>Status</th><th>Revenue</th></tr></thead>
            <tbody id="tenantTable"></tbody>
          </table>
        </div>
      </div>

      <div id="billing" class="section">
        <h1>Billing Management</h1>
        <div class="card"><h2>Awaiting Financial Sync...</h2></div>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    const API = "http://localhost:5000/api";
    let myChart = null;

    window.switchTab = function(id, el) {
      document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
      const target = document.getElementById(id);
      if(target) target.classList.add('active');
      document.querySelectorAll('.menu-item').forEach(i => i.classList.remove('active'));
      if(el) el.classList.add('active');
    };

    async function fetchData() {
      try {
        const [statsR, tenantR] = await Promise.all([ fetch(API + "/stats"), fetch(API + "/tenants") ]);
        const stats = await statsR.json();
        const tenants = await tenantR.json();

        document.getElementById("users").innerText = stats.users;
        document.getElementById("active").innerText = stats.active;
        document.getElementById("revenue").innerText = "₹" + stats.revenue.toLocaleString();
        document.getElementById("alerts").innerText = stats.alerts;

        let html = "";
        tenants.forEach(t => {
          html += `<tr><td><strong>${t.name}</strong></td><td>${t.industry}</td><td class="status-active">${t.status}</td><td>₹${t.revenue.toLocaleString()}</td></tr>`;
        });
        document.getElementById("tenantTable").innerHTML = html || '<tr><td colspan="4">No Records Found.</td></tr>';
        
        updateChart(tenants);
      } catch (err) { console.error(err); }
    }

    window.addTenant = async function() {
      const name = prompt("Establishment Name:");
      const industry = prompt("Industry (e.g. Retail):", "Retail");
      const revenue = prompt("Revenue:", "1000");
      if(!name) return;
      await fetch(API + "/tenants", {
        method: "POST", headers: {"Content-Type": "application/json"},
        body: JSON.stringify({ name, industry, status: "active", revenue: Number(revenue) })
      });
      fetchData();
    }

    function updateChart(data) {
      const ctx = document.getElementById('industryChart');
      if(!ctx || !window.Chart) return;
      const sectors = { Restaurant:0, Bakery:0, Retail:0, Pharmacy:0 };
      data.forEach(t => { if(sectors[t.industry] !== undefined) sectors[t.industry]++; });
      const finalData = Object.values(sectors).some(v=>v>0) ? Object.values(sectors) : [1,1,1,1];
      if(myChart) myChart.destroy();
      myChart = new Chart(ctx, { type: 'doughnut', data: { labels: Object.keys(sectors), datasets: [{ data: finalData, backgroundColor: ['#ef4444', '#f59e0b', '#3b82f6', '#10b981'], borderWidth: 0 }] }, options: { responsive:true, maintainAspectRatio:false, plugins: { legend: { position: 'bottom', labels: { color: '#fff' } } } } });
    }

    document.addEventListener('DOMContentLoaded', fetchData);
  </script>
</MainLayout>
