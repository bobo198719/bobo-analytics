---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Admin Master | SaaS Control Center">
  <div class="admin-wrapper">
    <header class="admin-header">
      <div class="flex-row">
        <div>
          <h1>🛸 SaaS Master Engine</h1>
          <p>Complete Provisioning, Billing & Security Intelligence</p>
        </div>
        <div class="ai-insight-box">
          <span class="pulse silver"></span> Security Guard: <span id="security-status-text">Scanning for threats...</span>
        </div>
      </div>
    </header>

    <!-- Core Metrics -->
    <section class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div class="stat-info">
          <h3>Total Users</h3>
          <p id="stat-total" class="loading-shimmer">...</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">📈</div>
        <div class="stat-info">
          <h3>Active Clients</h3>
          <p id="stat-active" class="loading-shimmer">...</p>
        </div>
      </div>
      <div class="stat-card revenue">
        <div class="stat-icon">🛡️</div>
        <div class="stat-info">
          <h3>Security Alerts</h3>
          <p id="stat-alerts" class="loading-shimmer">0</p>
        </div>
      </div>
    </section>

    <div class="tabs-container">
      <div class="tabs-nav">
        <button class="tab-btn active" data-tab="provisioning">Provisioning</button>
        <button class="tab-btn" data-tab="plans">Pricing Plans</button>
        <button class="tab-btn" data-tab="revenue">Revenue Ledger</button>
        <button class="tab-btn" data-tab="security">Security Radar</button>
        <button class="tab-btn" data-tab="leads">Leads Queue</button>
      </div>

      <div class="tab-content active" id="provisioning">
        <section class="table-container">
           <div class="table-header">
             <h2>Account Provisioning</h2>
             <button class="btn-primary" onclick="openProvisionModal()">+ Provision Tenant</button>
           </div>
           <div class="table-scroll">
             <table>
               <thead>
                 <tr><th>Business</th><th>Industry</th><th>Plan</th><th>Status</th><th>Actions</th></tr>
               </thead>
               <tbody id="provisionTableBody"></tbody>
             </table>
           </div>
        </section>
      </div>

      <div class="tab-content" id="plans">
        <section class="table-container">
           <div class="table-header">
             <h2>Subscription Plans</h2>
             <button class="btn-primary" onclick="openPlanModal()">+ Create Plan</button>
           </div>
           <div class="table-scroll">
             <table>
               <thead>
                 <tr><th>Plan Name</th><th>Price</th><th>Duration</th><th>Features</th></tr>
               </thead>
               <tbody id="plansTableBody"></tbody>
             </table>
           </div>
        </section>
      </div>

      <div class="tab-content" id="revenue">
        <section class="table-container">
           <div class="table-header">
             <h2>Revenue Ledger</h2>
             <button class="btn-primary" onclick="openPaymentModal()">+ Record Manual Payment</button>
           </div>
           <div class="table-scroll">
             <table>
               <thead>
                 <tr><th>Date</th><th>Client</th><th>Plan</th><th>Amount</th><th>Method</th></tr>
               </thead>
               <tbody id="revenueTableBody"></tbody>
             </table>
           </div>
        </section>
      </div>

   <!-- Manual Payment Modal -->
  <div id="paymentModal" class="modal">
    <div class="modal-content">
      <h2>💸 Record Manual Payment</h2>
      <div class="form-group">
        <label>Select Tenant</label>
        <select id="payUserId"></select>
      </div>
      <div class="form-group">
        <label>Amount (₹)</label>
        <input type="number" id="payAmount" placeholder="e.g. 5000" />
      </div>
      <div class="form-group">
        <label>Payment Method</label>
        <select id="payMethod">
          <option value="Manual / UPI">Manual / UPI</option>
          <option value="Bank Transfer">Bank Transfer</option>
          <option value="Cash">Cash</option>
        </select>
      </div>
      <div class="modal-actions">
        <button onclick="document.getElementById('paymentModal').style.display='none'" class="btn btn-secondary">Cancel</button>
        <button id="confirmPayment" class="btn btn-primary">Lock Payment</button>
      </div>
    </div>
  </div>

      <div class="tab-content" id="security">
        <section class="table-container">
           <div class="table-header">
             <h2>Security & Login Logs</h2>
             <div class="alert-pills" id="security-alerts-container">
                <!-- Alerts will appear here -->
             </div>
           </div>
           
           <div class="table-scroll">
             <table class="small-table">
               <thead>
                 <tr><th>User</th><th>IP Address</th><th>Device</th><th>Status</th><th>Time</th><th>Action</th></tr>
               </thead>
               <tbody id="loginLogsBody"></tbody>
             </table>
           </div>
        </section>
      </div>

      <div class="tab-content" id="leads">
        <section class="table-container">
           <div class="table-header">
             <h2>Registration Queue (Leads)</h2>
           </div>
           <div class="table-scroll">
             <table>
               <thead>
                 <tr><th>Date</th><th>Name</th><th>Phone</th><th>Industry</th><th>Status</th></tr>
               </thead>
               <tbody id="leadsTableBody"></tbody>
             </table>
           </div>
        </section>
      </div>
    </div>
  </div>

  <!-- Provision Modal -->
  <div id="provisionModal" class="modal">
    <div class="modal-content">
      <h2>🆕 Provision New Tenant</h2>
      <div class="form-group">
        <label>Business Name</label>
        <input type="text" id="provBusiness" placeholder="E.g. Bobo Bakery" />
      </div>
      <div class="form-group">
        <label>Username</label>
        <input type="text" id="provUser" placeholder="admin_name" />
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" id="provPass" placeholder="••••••••" />
      </div>
      <div class="form-group">
        <label>Industry</label>
        <select id="provIndustry">
          <option value="Bakery">Bakery</option>
          <option value="Pharmacy">Pharmacy</option>
          <option value="Retail">Retail</option>
          <option value="Groceries">Groceries</option>
        </select>
      </div>
      <div class="form-group">
        <label>Initial Plan</label>
        <select id="provPlan">
          <option value="trial">Trial</option>
          <option value="Starter">Starter</option>
          <option value="Pro">Pro</option>
        </select>
      </div>
      <div class="modal-actions">
        <button onclick="document.getElementById('provisionModal').style.display='none'" class="btn btn-secondary">Cancel</button>
        <button id="confirmProvision" class="btn btn-primary">Create Tenant</button>
      </div>
    </div>
  </div>

  <!-- Plan Modal -->
  <div id="planModal" class="modal">
    <div class="modal-content">
      <h2>💎 Create New Plan</h2>
      <div class="form-group">
        <label>Plan Name</label>
        <input type="text" id="planName" placeholder="Pro Gold" />
      </div>
      <div class="form-group">
        <label>Price (₹)</label>
        <input type="number" id="planPrice" value="999" />
      </div>
      <div class="form-group">
        <label>Duration (Days)</label>
        <input type="number" id="planDuration" value="30" />
      </div>
      <div class="modal-actions">
        <button onclick="document.getElementById('planModal').style.display='none'" class="btn btn-secondary">Cancel</button>
        <button id="confirmPlan" class="btn btn-primary">Create Plan</button>
      </div>
    </div>
  </div>

  <style>
    .admin-wrapper { padding: 80px 40px; max-width: 1400px; margin: 0 auto; color: white; }
    .admin-header { margin-bottom: 40px; }
    .flex-row { display: flex; justify-content: space-between; align-items: center; }
    .admin-header h1 { font-size: 2.8rem; font-weight: 900; background: linear-gradient(135deg, #fff 0%, #6366f1 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    
    .ai-insight-box { background: rgba(99, 102, 241, 0.1); padding: 12px 24px; border-radius: 40px; border: 1px solid rgba(99,102,241,0.2); font-size: 0.9rem; color: #a5b4fc; }
    .pulse.silver { background: #cbd5e1; box-shadow: 0 0 10px #cbd5e1; width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 10px; animation: pulse 2s infinite; }
    @keyframes pulse { 0% { opacity: 0.4; } 50% { opacity: 1; } 100% { opacity: 0.4; } }

    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px; }
    .stat-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 30px; display: flex; align-items: center; gap: 20px; }
    .stat-icon { font-size: 2rem; width: 60px; height: 60px; background: rgba(99, 102, 241, 0.1); border-radius: 16px; display: flex; justify-content: center; align-items: center; }
    .stat-info h3 { font-size: 0.85rem; opacity: 0.5; text-transform: uppercase; margin: 0 0 4px 0; }
    .stat-info p { font-size: 2.2rem; font-weight: 900; margin: 0; }
    .revenue p { color: #f87171; }

    .tabs-nav { display: flex; gap: 10px; margin-bottom: 30px; background: rgba(255,255,255,0.03); padding: 5px; border-radius: 14px; width: fit-content; }
    .tab-btn { background: transparent; border: none; color: rgba(255,255,255,0.5); padding: 12px 24px; border-radius: 10px; cursor: pointer; font-weight: 700; transition: 0.3s; }
    .tab-btn.active { background: #6366f1; color: white; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    .table-container { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 30px; }
    .table-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
    .table-scroll { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); font-size: 0.8rem; opacity: 0.4; text-transform: uppercase; }
    td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.95rem; }
    
    .small-table td { padding: 10px; font-size: 0.85rem; }

    .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); z-index: 1000; justify-content: center; align-items: center; }
    .modal-content { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.15); padding: 40px; border-radius: 24px; width: 90%; max-width: 480px; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 10px; font-size: 0.9rem; opacity: 0.7; }
    .form-group input, .form-group select { width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 12px; border-radius: 12px; color: #fff; }
    
    .btn { padding: 10px 20px; border-radius: 10px; border: none; cursor: pointer; font-weight: 700; transition: 0.3s; font-size: 0.85rem; }
    .btn-primary { background: #6366f1; color: white; }
    .btn-secondary { background: rgba(255,255,255,0.1); color: white; }
    .btn-danger { background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }
    .btn-danger:hover { background: #ef4444; color: white; }

    .status-tag { padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; }
    .status-success { background: rgba(34,197,94,0.15); color: #22c55e; }
    .status-failed { background: rgba(239,68,68,0.15); color: #ef4444; }

    .loading-shimmer { background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 4px; display: inline-block; min-width: 60px; }
    @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
    @media (max-width: 768px) { .stats-grid { grid-template-columns: 1fr; } .tabs-nav { width: 100%; overflow-x: auto; } }
  </style>

  <script>
    async function init() {
      await loadStats();
      await loadProvisioning();
      await loadSecurity();
      await loadPlans();
      await loadRevenue();
      await loadLeads();
      setupTabs();
    }

    async function loadStats() {
      const res = await fetch('/api/admin/dashboard');
      const data = await res.json();
      document.getElementById('stat-total').innerText = data.total;
      document.getElementById('stat-active').innerText = data.active;
      
      // Load security alerts count
      const secRes = await fetch('/api/security/security-alerts');
      const alerts = await secRes.json();
      document.getElementById('stat-alerts').innerText = alerts.length;
      document.getElementById('security-status-text').innerText = alerts.length > 0 ? `Detected ${alerts.length} threats` : "System Secure";
      
      document.querySelectorAll('.loading-shimmer').forEach(el => el.classList.remove('loading-shimmer'));
    }

    async function loadSecurity() {
      // Load Logs
      const res = await fetch('/api/security/login-logs');
      const data = await res.json();
      const tbody = document.getElementById('loginLogsBody');
      tbody.innerHTML = data.map(l => `
        <tr>
          <td><b>${l.username}</b></td>
          <td><small>${l.ip_address}</small></td>
          <td title="${l.device}"><div style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">${l.device}</div></td>
          <td><span class="status-tag ${l.status==='success'?'status-success':'status-failed'}">${l.status}</span></td>
          <td>${new Date(l.created_at).toLocaleString()}</td>
          <td>
             <button class="btn btn-danger" onclick="blockUser('${l.username}')">Block</button>
          </td>
        </tr>
      `).join('');

      // Load Alerts
      const alertRes = await fetch('/api/security/security-alerts');
      const alerts = await alertRes.json();
      const alertBox = document.getElementById('security-alerts-container');
      alertBox.innerHTML = alerts.map(a => `
        <div style="background:rgba(239,68,68,0.2); border:1px solid #ef4444; color:#ef4444; padding:5px 15px; border-radius:20px; font-size:0.8rem; font-weight:700">
           ⚠️ ${a.username}: ${a.attempts} Failed Attempts
        </div>
      `).join('');
    }

    async function loadProvisioning() {
      const res = await fetch('/api/admin/users');
      const data = await res.json();
      const tbody = document.getElementById('provisionTableBody');
      const payUserSelect = document.getElementById('payUserId');
      
      tbody.innerHTML = data.map(u => `
        <tr>
          <td><b>${u.business_name}</b><br/><small style="opacity:0.5">${u.username}</small></td>
          <td>${u.industry}</td>
          <td><span style="background:rgba(99,102,241,0.2); padding:4px 8px; border-radius:6px; font-size:0.8rem">${u.plan_type}</span></td>
          <td style="color:${u.status==='active'?'#22c55e':'#ef4444'}">
            <span class="status-tag ${u.status==='active'?'status-success':'status-failed'}">${u.status}</span>
          </td>
          <td class="action-cell">
            <button class="btn btn-secondary btn-sm" onclick="toggleStatus(${u.id}, '${u.status}')">Toggle</button>
            <button class="btn btn-danger btn-sm" onclick="deleteUser(${u.id})">Terminate</button>
          </td>
        </tr>
      `).join('');

      // Populate payment modal select
      payUserSelect.innerHTML = data.map(u => `<option value="${u.id}">${u.business_name} (${u.industry})</option>`).join('');
    }

    async function toggleStatus(id, current) {
      const status = current === 'active' ? 'inactive' : 'active';
      await fetch('/api/admin/update-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: id, status })
      });
      init();
    }

    window.openPaymentModal = () => document.getElementById('paymentModal').style.display = 'flex';

    document.getElementById('confirmPayment').onclick = async () => {
      const body = {
        userId: document.getElementById('payUserId').value,
        amount: document.getElementById('payAmount').value,
        method: document.getElementById('payMethod').value
      };
      const res = await fetch('/api/payment/manual', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      if (res.ok) {
        document.getElementById('paymentModal').style.display='none';
        init();
      }
    };

    async function loadPlans() {
      const res = await fetch('/api/admin/plans');
      const data = await res.json();
      const tbody = document.getElementById('plansTableBody');
      tbody.innerHTML = data.map(p => `
        <tr>
          <td><b>${p.name}</b></td>
          <td>₹${p.price}</td>
          <td>${p.duration} Days</td>
          <td><small>${p.features || 'Standard Features'}</small></td>
        </tr>
      `).join('');
    }

    async function loadRevenue() {
      const res = await fetch('/api/admin/revenue');
      const data = await res.json();
      const tbody = document.getElementById('revenueTableBody');
      tbody.innerHTML = data.records.map(r => `
        <tr>
          <td>${new Date(r.created_at).toLocaleDateString()}</td>
          <td><b>${r.business_name}</b></td>
          <td>${r.plan_type}</td>
          <td style="color:#22c55e; font-weight:700">₹${r.amount}</td>
          <td>${r.method}</td>
        </tr>
      `).join('');
    }

    async function loadLeads() {
      const res = await fetch('/api/admin/leads');
      const data = await res.json();
      const tbody = document.getElementById('leadsTableBody');
      tbody.innerHTML = data.map(l => `
        <tr>
          <td>${new Date(l.created_at).toLocaleDateString()}</td>
          <td><b>${l.name}</b></td>
          <td>${l.phone}</td>
          <td>${l.industry}</td>
          <td><span style="opacity:0.6">${l.status}</span></td>
        </tr>
      `).join('');
    }

    function setupTabs() {
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.onclick = () => {
          document.querySelectorAll('.tab-btn, .tab-content').forEach(el => el.classList.remove('active'));
          btn.classList.add('active');
          document.getElementById(btn.dataset.tab).classList.add('active');
          if(btn.dataset.tab === 'security') loadSecurity();
        };
      });
    }

    window.blockUser = async (username) => {
      if(!confirm(`Block user ${username} permanently?`)) return;
      await fetch('/api/security/block-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username })
      });
      init();
    };

    // Modal Triggers
    window.openProvisionModal = () => document.getElementById('provisionModal').style.display='flex';
    window.openPlanModal = () => document.getElementById('planModal').style.display='flex';

    document.getElementById('confirmProvision').onclick = async () => {
      const body = {
        businessName: document.getElementById('provBusiness').value,
        username: document.getElementById('provUser').value,
        password: document.getElementById('provPass').value,
        industry: document.getElementById('provIndustry').value,
        planType: document.getElementById('provPlan').value
      };
      const res = await fetch('/api/admin/create-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      if (res.ok) {
        document.getElementById('provisionModal').style.display='none';
        init();
      }
    };

    window.deleteUser = async (id) => {
      if(!confirm("Are you sure? This will terminate the tenant registry.")) return;
      await fetch('/api/admin/delete-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: id })
      });
      init();
    };

    document.addEventListener('DOMContentLoaded', init);
  </script>
</MainLayout>
