---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Admin Dashboard | SaaS Registry">
  <div class="admin-wrapper">
    <header class="admin-header">
      <div class="flex-row">
        <h1>🛡️ Admin Control</h1>
        <div class="status-indicator">Live System Status: <span class="pulse green"></span> Active</div>
      </div>
      <p>SaaS Central Registry & Subscription Management</p>
    </header>

    <!-- Stats Section -->
    <section class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div class="stat-info">
          <h3>Total Users</h3>
          <p id="stat-total" class="loading-shimmer">...</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">✅</div>
        <div class="stat-info">
          <h3>Active Users</h3>
          <p id="stat-active" class="loading-shimmer">...</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">⏰</div>
        <div class="stat-info">
          <h3>Expired Users</h3>
          <p id="stat-expired" class="loading-shimmer">...</p>
        </div>
      </div>
      <div class="stat-card revenue">
        <div class="stat-icon">💰</div>
        <div class="stat-info">
          <h3>Total Revenue</h3>
          <p id="stat-revenue" class="loading-shimmer">...</p>
        </div>
      </div>
    </section>

    <!-- Table Section -->
    <section class="table-container">
      <div class="table-header">
        <h2>Central User Registry</h2>
        <div class="search-bar">
          <input type="text" id="userSearch" placeholder="Search by name, email or business..." />
        </div>
      </div>
      
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Industry</th>
              <th>Business Name</th>
              <th>Owner</th>
              <th class="hide-mobile">Phone</th>
              <th>Plan</th>
              <th>Status</th>
              <th>Expiry</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="userTableBody">
            <!-- Rows will be injected here -->
          </tbody>
        </table>
      </div>
    </section>

    <!-- History Section -->
    <section class="table-container history-section">
      <div class="table-header">
        <h2>📜 User History & Audit Log</h2>
        <button class="btn-action" onclick="loadHistory()">Refresh Logs</button>
      </div>
      
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Date</th>
              <th>User ID</th>
              <th>Business</th>
              <th>Plan</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="historyTableBody">
            <!-- History rows will be injected here -->
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <!-- Password Reset Modal -->
  <div id="resetModal" class="modal">
    <div class="modal-content">
      <h2>🔑 Reset User Password</h2>
      <p id="resetUserText"></p>
      <input type="password" id="newPassword" placeholder="New Password" />
      <div class="modal-actions">
        <button id="cancelReset" class="btn btn-secondary">Cancel</button>
        <button id="confirmReset" class="btn btn-primary">Update Password</button>
      </div>
    </div>
  </div>

  <style>
    .admin-wrapper {
      padding: 100px 40px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .admin-header { margin-bottom: 48px; }
    .flex-row { display: flex; justify-content: space-between; align-items: center; }
    .admin-header h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 8px; }
    .status-indicator {
      background: rgba(255, 255, 255, 0.05);
      padding: 12px 24px;
      border-radius: 40px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .pulse {
      width: 10px; height: 10px; border-radius: 50%;
      background: #22c55e;
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
      70% { box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
      100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      margin-bottom: 60px;
    }

    .stat-card {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 32px;
      border-radius: 24px;
      display: flex;
      align-items: center;
      gap: 24px;
      transition: all 0.3s ease;
    }

    .stat-card:hover { background: rgba(255, 255, 255, 0.06); transform: translateY(-5px); }
    .stat-icon {
      width: 64px; height: 64px;
      background: rgba(99, 102, 241, 0.1);
      border-radius: 16px;
      display: flex; justify-content: center; align-items: center;
      font-size: 1.8rem;
    }

    .stat-info h3 { font-size: 0.9rem; color: rgba(255, 255, 255, 0.5); font-weight: 600; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 1px; }
    .stat-info p { font-size: 2.2rem; font-weight: 800; margin: 0; }
    .revenue .stat-icon { background: rgba(34, 197, 94, 0.1); }
    .revenue p { color: #22c55e; }

    .table-container {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 32px;
      padding: 40px;
      overflow: hidden;
      margin-bottom: 40px;
    }

    .table-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; flex-wrap: wrap; gap: 20px; }
    .search-bar input {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 14px 24px;
      border-radius: 16px;
      color: white;
      width: 320px;
      font-size: 0.95rem;
    }

    .table-scroll { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th {
      padding: 16px;
      color: rgba(255, 255, 255, 0.5);
      font-weight: 600;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    td { padding: 20px 16px; border-bottom: 1px solid rgba(255, 255, 255, 0.05); vertical-align: middle; }
    .status-badge {
      display: inline-block;
      padding: 6px 14px;
      border-radius: 12px;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .active-badge { background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.2); }
    .expired-badge { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }
    .deleted-badge { background: rgba(255, 255, 255, 0.1); color: #999; border: 1px solid rgba(255, 255, 255, 0.1); }

    .action-group { display: flex; gap: 8px; }
    .btn-action {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 8px 12px;
      border-radius: 8px;
      color: white;
      cursor: pointer;
      font-size: 0.8rem;
      transition: all 0.2s;
    }

    .btn-action:hover { background: rgba(255, 255, 255, 0.1); border-color: #6366f1; }
    .btn-danger { color: #ef4444; }
    .btn-danger:hover { border-color: #ef4444; background: rgba(239, 68, 68, 0.1); }

    .modal {
      display: none;
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(5px);
      z-index: 1000;
      justify-content: center;
      align-items: center;
    }

    .modal-content {
      background: #111;
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 40px;
      border-radius: 24px;
      max-width: 400px;
      width: 90%;
    }

    .modal-content input {
      width: 100%;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 14px;
      border-radius: 12px;
      color: white;
      margin: 20px 0;
    }

    .modal-actions { display: flex; gap: 12px; }
    .btn { flex: 1; padding: 12px; border-radius: 10px; border: none; cursor: pointer; font-weight: 700; }
    .btn-primary { background: #6366f1; color: white; }
    .btn-secondary { background: rgba(255, 255, 255, 0.1); color: white; }

    .loading-shimmer {
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
      border-radius: 4px;
      display: inline-block;
      min-width: 60px;
    }

    @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
    
    .history-section h2 { margin: 0; }
    .action-label { font-weight: 700; color: #6366f1; text-transform: capitalize; }
    
    @media (max-width: 768px) {
      .hide-mobile { display: none; }
      .admin-wrapper { padding: 40px 16px; }
      .table-container { padding: 20px; }
    }
  </style>

  <script>
    let allUsers = [];
    let selectedUserId = null;

    async function fetchData() {
      await loadDashboard();
      await loadUsers();
      await loadHistory();
    }

    async function loadDashboard() {
      try {
        const res = await fetch('/api/admin/dashboard');
        const stats = await res.json();
        
        document.getElementById('stat-total').textContent = stats.totalUsers || 0;
        document.getElementById('stat-total').classList.remove('loading-shimmer');
        document.getElementById('stat-active').textContent = stats.activeUsers || 0;
        document.getElementById('stat-active').classList.remove('loading-shimmer');
        document.getElementById('stat-expired').textContent = stats.expiredUsers || 0;
        document.getElementById('stat-expired').classList.remove('loading-shimmer');
        document.getElementById('stat-revenue').textContent = '₹' + (stats.revenue || 0).toLocaleString();
        document.getElementById('stat-revenue').classList.remove('loading-shimmer');
      } catch (e) {
        console.error("Dashboard error:", e);
      }
    }

    async function loadUsers() {
      try {
        const res = await fetch('/api/admin/users');
        allUsers = await res.json();
        renderUsers(allUsers);
      } catch (e) {
        console.error("Users error:", e);
      }
    }

    async function loadHistory() {
      try {
        const res = await fetch('/api/admin/user-history');
        const history = await res.json();
        const tbody = document.getElementById('historyTableBody');
        tbody.innerHTML = history.map(h => `
          <tr>
            <td style="font-size:0.8rem; color:rgba(255,255,255,0.5)">
              ${new Date(h.timestamp).toLocaleString()}
            </td>
            <td>#${h.user_id}</td>
            <td><b>${h.business_name}</b></td>
            <td><span style="opacity:0.7">${h.plan_type}</span></td>
            <td>
               <span class="status-badge ${h.status === 'active' ? 'active-badge' : h.status === 'deleted' ? 'deleted-badge' : 'expired-badge'}">
                ${h.status}
              </span>
            </td>
            <td class="action-label">${h.action.replace('_', ' ')}</td>
          </tr>
        `).join('');
      } catch (e) {
        console.error("History error:", e);
      }
    }

    function renderUsers(users) {
      const tbody = document.getElementById('userTableBody');
      tbody.innerHTML = users.map(u => `
        <tr>
          <td><span style="color:rgba(255,255,255,0.3)">#${u.id}</span></td>
          <td><b>${u.industry}</b></td>
          <td>
            <div style="font-weight:700">${u.business_name}</div>
            <div style="font-size:0.8rem; color:rgba(255,255,255,0.5)">${u.email}</div>
          </td>
          <td>${u.owner_name}</td>
          <td class="hide-mobile">${u.phone}</td>
          <td><span style="opacity:0.7">${u.plan}</span></td>
          <td>
            <span class="status-badge ${u.status === 'active' ? 'active-badge' : 'expired-badge'}">
              ${u.status}
            </span>
          </td>
          <td>
            <div style="font-size:0.9rem">${new Date(u.expiry_date).toLocaleDateString()}</div>
          </td>
          <td>
            <div class="action-group">
              <button class="btn-action" title="Toggle Status" onclick="toggleStatus(${u.id}, '${u.status}')">🔄</button>
              <button class="btn-action" title="Reset Pass" onclick="openResetModal('${u.id}', '${u.business_name}')">🔑</button>
              <button class="btn-action btn-danger" title="Delete User" onclick="deleteUser(${u.id}, '${u.business_name}')">🗑️</button>
            </div>
          </td>
        </tr>
      `).join('');
    }

    window.toggleStatus = async (id, currentStatus) => {
      const newStatus = currentStatus === 'active' ? 'expired' : 'active';
      if (!confirm(`Switch user to ${newStatus}?`)) return;

      try {
        const res = await fetch('/api/admin/update-status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: id, status: newStatus })
        });
        if (res.ok) {
          fetchData();
        }
      } catch (e) {
        alert("Update failed");
      }
    };

    window.deleteUser = async (id, name) => {
      if (!confirm(`🚨 DANGER: Delete ${name} forever? This will be logged in history but account data will be removed.`)) return;

      try {
        const res = await fetch('/api/admin/delete-user', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: id })
        });
        if (res.ok) {
          fetchData();
        }
      } catch (e) {
        alert("Deletion failed");
      }
    };

    // Modal & Reset Logic
    window.openResetModal = (id, name) => {
      selectedUserId = id;
      document.getElementById('resetUserText').textContent = `Set new password for ${name}`;
      document.getElementById('resetModal').style.display = 'flex';
    };

    document.getElementById('cancelReset').onclick = () => {
      document.getElementById('resetModal').style.display = 'none';
      selectedUserId = null;
    };

    document.getElementById('confirmReset').onclick = async () => {
      const password = document.getElementById('newPassword').value;
      if (!password) return alert("Please enter a new password");

      try {
        const res = await fetch('/api/admin/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: selectedUserId, newPassword: password })
        });
        const result = await res.json();
        if (result.success) {
          alert("Password updated!");
          document.getElementById('resetModal').style.display = 'none';
          document.getElementById('newPassword').value = '';
        }
      } catch (e) {
        alert("Update failed");
      }
    };

    // Search Logic
    document.getElementById('userSearch').addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      const filtered = allUsers.filter(u => 
        u.business_name.toLowerCase().includes(term) ||
        u.owner_name.toLowerCase().includes(term) ||
        u.email.toLowerCase().includes(term) ||
        u.username.toLowerCase().includes(term)
      );
      renderUsers(filtered);
    });

    // Initial Load
    document.addEventListener('DOMContentLoaded', fetchData);
    window.loadHistory = loadHistory; // Expose to global for button
  </script>
</MainLayout>
