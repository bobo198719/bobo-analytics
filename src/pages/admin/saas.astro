    window.handlePromoTarget = function() {
      const tg = document.getElementById("promoTarget").value;
      const sel = document.getElementById("promoSpecificUserSel");
      const multi = document.getElementById("promoTargetClients");
      
      sel.style.display = tg === "select" ? "block" : "none";
      
      if (tg !== "select" && tg !== "specific" && tg !== "all") {
          multi.style.display = "flex";
          const filtered = allUsers.filter(u => u.industry === tg);
          if (filtered.length === 0) {
             multi.innerHTML = `<span style="color:var(--muted);font-size:0.8rem;">No clients found in this industry.</span>`;
          } else {
             multi.innerHTML = `<label style="font-size:0.8rem; font-weight:bold; color:#a78bfa; margin-bottom:4px; padding-bottom:4px; border-bottom:1px solid var(--border); cursor:pointer"><input type="checkbox" id="promoToggleAll" checked onchange="document.querySelectorAll('.promo-user-cb').forEach(c=>c.checked=this.checked)"> Select / Deselect All</label>` 
             + filtered.map(u => `<label style="font-size:0.8rem; display:flex; align-items:center; gap:6px; cursor:pointer"><input type="checkbox" class="promo-user-cb" value="${u.id}" checked> ${u.business_name || u.username} (#${u.id})</label>`).join("");
          }
      } else if (tg === "all") {
          multi.style.display = "flex";
          multi.innerHTML = `<label style="font-size:0.8rem; font-weight:bold; color:#a78bfa; margin-bottom:4px; padding-bottom:4px; border-bottom:1px solid var(--border); cursor:pointer"><input type="checkbox" id="promoToggleAll" checked onchange="document.querySelectorAll('.promo-user-cb').forEach(c=>c.checked=this.checked)"> Select / Deselect All</label>` 
          + allUsers.map(u => `<label style="font-size:0.8rem; display:flex; align-items:center; gap:6px; cursor:pointer"><input type="checkbox" class="promo-user-cb" value="${u.id}" checked> ${u.business_name || u.username} (#${u.id})</label>`).join("");
      } else {
          multi.style.display = "none";
          multi.innerHTML = "";
      }
