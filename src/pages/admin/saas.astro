---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Admin | Master Dashboard" hideNav={true}>
  <style>
    :root {
      --bg-dark: #050810;
      --sidebar-bg: #0c111d;
      --card-bg: #141c2d;
      --neon-blue: #3b82f6;
      --neon-green: #10b981;
      --neon-red: #ef4444;
      --border-color: rgba(255,255,255,0.08);
      --text-muted: #94a3b8;
    }

    body {
      margin: 0;
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg-dark);
      color: #fff;
      display: flex;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* SIDEBAR */
    .sidebar {
      width: 260px;
      height: 100vh;
      background: var(--sidebar-bg);
      padding: 30px 15px;
      position: fixed;
      left: 0;
      top: 0;
      border-right: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      z-index: 1000;
    }

    .sidebar h2 {
      margin-bottom: 30px;
      font-size: 1.2rem;
      font-weight: 800;
      letter-spacing: 1px;
      padding: 0 15px;
    }

    .nav-menu { flex: 1; }

    .menu-item {
      padding: 14px 18px;
      margin-bottom: 6px;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s ease;
      color: var(--text-muted);
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
      border: none;
      background: transparent;
      width: 100%;
      text-align: left;
      font-size: 0.95rem;
    }

    .menu-item:hover { background: rgba(255, 255, 255, 0.04); color: white; }
    .menu-item.active { background: var(--neon-blue); color: white; box-shadow: 0 8px 16px rgba(59, 130, 246, 0.25); }

    /* MAIN AREA */
    .main {
      margin-left: 260px;
      flex: 1;
      padding: 40px;
      width: calc(100% - 260px);
    }

    .container { max-width: 1200px; margin: 0 auto; }

    /* SECTIONS */
    .section { display: none; }
    .section.active { display: block; animation: fadeIn 0.3s ease-out; }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* KPI GRID */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 32px;
    }

    .card {
      background: var(--card-bg);
      padding: 24px;
      border-radius: 16px;
      border: 1px solid var(--border-color);
    }

    .card-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 8px; }
    .value { font-size: 2.2rem; font-weight: 800; }

    /* TABLES */
    .table-box {
      background: var(--card-bg);
      padding: 24px;
      border-radius: 16px;
      border: 1px solid var(--border-color);
      overflow-x: auto;
    }

    h1, h3 { margin-top: 0; }
    h1 { font-size: 1.8rem; margin-bottom: 24px; }

    table { width: 100%; border-collapse: collapse; min-width: 700px; }
    th { text-align: left; padding: 12px 16px; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; border-bottom: 1px solid var(--border-color); }
    td { padding: 16px; border-bottom: 1px solid var(--border-color); font-size: 0.95rem; }

    /* ACTION BUTTON */
    .btn-add {
      background: var(--neon-blue);
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: 0.2s;
      margin-bottom: 20px;
    }

    .btn-add:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3); }

    .status-active { color: var(--neon-green); font-weight: bold; }
  </style>

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-top">
      <h2>BOBO OS</h2>
      <div style="color:var(--neon-blue); font-size:0.7rem; font-weight:bold; padding-left:15px; margin-top:-20px; margin-bottom:20px;">DYNAMIC BACKEND ENABLED</div>
    </div>
    <nav class="nav-menu">
      <button class="menu-item active" onclick="switchTab('dashboard', this)"><span>📊</span> Dashboard</button>
      <button class="menu-item" onclick="switchTab('tenants', this)"><span>🏢</span> Tenants Register</button>
      <button class="menu-item" onclick="switchTab('billing', this)"><span>💸</span> Revenue Trace</button>
    </nav>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <div class="container">

      <!-- DASHBOARD -->
      <div id="dashboard" class="section active">
        <h1>Dashboard Control Tower</h1>
        <div class="kpi-grid">
          <div class="card"><div class="card-label">Total Users</div><div class="value" id="users">0</div></div>
          <div class="card"><div class="card-label">Active Nodes</div><div class="value" id="active" style="color:var(--neon-green)">0</div></div>
          <div class="card"><div class="card-label">Overall Revenue</div><div class="value" id="revenue">₹0</div></div>
          <div class="card"><div class="card-label">Security Alerts</div><div class="value" id="alerts" style="color:var(--neon-red)">0</div></div>
        </div>

        <div class="table-box">
          <h3>Ecosystem Health</h3>
          <div style="height:350px;">
            <canvas id="industryChart"></canvas>
          </div>
        </div>
      </div>

      <!-- TENANTS -->
      <div id="tenants" class="section">
        <h1>Tenant Registry</h1>
        <button class="btn-add" onclick="addTenant()">+ Provision New Tenant</button>
        <div class="table-box">
          <table>
            <thead><tr><th>Establishment Name</th><th>Industry Hub</th><th>Operational Status</th><th>Monthly Yield</th></tr></thead>
            <tbody id="tenantTable"></tbody>
          </table>
        </div>
      </div>

      <!-- BILLING -->
      <div id="billing" class="section">
        <h1>Financial Ledger</h1>
        <div class="card">
           <p style="color:var(--text-muted)">Live Transaction Streaming is active.</p>
           <h2 id="billingStatus">Awaiting Data Pool...</h2>
        </div>
      </div>

    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    const API = "http://localhost:5000/api";
    let myChart = null;

    // TAB SWITCHER
    window.switchTab = function(id, el) {
      document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
      const target = document.getElementById(id);
      if(target) target.classList.add('active');
      document.querySelectorAll('.menu-item').forEach(i => i.classList.remove('active'));
      if(el) el.classList.add('active');
    };

    // LOAD DASHBOARD STATS
    async function loadStats() {
      try {
        const res = await fetch(API + "/stats");
        const data = await res.json();

        document.getElementById("users").innerText = data.users;
        document.getElementById("active").innerText = data.active;
        document.getElementById("revenue").innerText = "₹" + data.revenue.toLocaleString();
        document.getElementById("alerts").innerText = data.alerts;
      } catch (err) { console.error('Stats Sync Error:', err); }
    }

    // LOAD TENANTS
    async function loadTenants() {
      try {
        const res = await fetch(API + "/tenants");
        const data = await res.json();

        let html = "";
        data.forEach(t => {
          html += `
            <tr>
              <td><strong>${t.name}</strong></td>
              <td>${t.industry}</td>
              <td class="status-active">${t.status}</td>
              <td>₹${t.revenue.toLocaleString()}</td>
            </tr>
          `;
        });

        document.getElementById("tenantTable").innerHTML = html || '<tr><td colspan="4">No Records in MongolDB.</td></tr>';
        updateChart(data);
      } catch (err) { console.error('Tenant Sync Error:', err); }
    }

    // ADD TENANT
    window.addTenant = async function() {
      const name = prompt("Enter Establishment Name:");
      if(!name) return;
      const industry = prompt("Enter Industry (e.g. Restaurant, Bakery, Retail, Pharmacy):", "Restaurant");
      const revenue = prompt("Enter Monthly Revenue (INR):", "5000");

      try {
        await fetch(API + "/tenants", {
          method: "POST",
          headers: {"Content-Type": "application/json"},
          body: JSON.stringify({
            name,
            industry,
            status: "active",
            revenue: Number(revenue)
          })
        });
        loadTenants();
        loadStats();
      } catch (err) { alert('Failed to provision tenant. Is Backend running?'); }
    }

    // UI CHART
    function updateChart(data) {
      const ctx = document.getElementById('industryChart');
      if(!ctx || !window.Chart) return;

      const sectors = { Restaurant:0, Bakery:0, Retail:0, Pharmacy:0 };
      data.forEach(t => { if(sectors[t.industry] !== undefined) sectors[t.industry]++; });

      const finalData = Object.values(sectors).some(v=>v>0) ? Object.values(sectors) : [1,1,1,1];

      if(myChart) myChart.destroy();
      myChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: ['Restaurant', 'Bakery', 'Retail', 'Pharmacy'],
          datasets: [{
            data: finalData,
            backgroundColor: ['#ef4444', '#f59e0b', '#3b82f6', '#10b981'],
            borderWidth: 0,
            hoverOffset: 20
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '75%',
          plugins: { legend: { position: 'bottom', labels: { color: '#fff', padding: 25 } } }
        }
      });
    }

    // INIT
    document.addEventListener('DOMContentLoaded', () => {
      loadStats();
      loadTenants();
    });
  </script>
</MainLayout>
