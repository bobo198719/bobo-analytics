    // ── PASSWORD TOGGLE ───────────────────────────────────────────
    window.togPass = function(id,pass) {
      const el=document.getElementById("pt-"+id), btn=document.getElementById("pb-"+id);
      if(el.dataset.r==="1") {
        el.innerText="••••••••"; el.style.color="var(--muted)"; el.style.letterSpacing="2px"; el.dataset.r="0"; btn.innerText="👁 Show";
      } else {
        el.innerText=pass; el.style.color="#fff"; el.style.letterSpacing="normal"; el.dataset.r="1"; btn.innerText="🔒 Hide";
        navigator.clipboard.writeText(pass).catch(()=>{});
      }
    };

    // ── RESET MODAL ───────────────────────────────────────────────
    window.openReset = function(id,username) {
      document.getElementById("resetId").value=id;
      document.getElementById("resetSub").innerText="New password for: "+username;
      document.getElementById("newPass").value="";
      document.getElementById("confPass").value="";
      document.getElementById("resetErr").innerText="";
      document.getElementById("resetModal").classList.add("open");
    };
    window.closeReset = ()=>document.getElementById("resetModal").classList.remove("open");

    window.submitReset = async function() {
      const id=document.getElementById("resetId").value;
      const np=document.getElementById("newPass").value;
      const cp=document.getElementById("confPass").value;
      const er=document.getElementById("resetErr");
      if(!np||np.length<6){er.innerText="Min 6 characters.";return;}
      if(np!==cp){er.innerText="Passwords don't match.";return;}
      er.innerText="Updating…";
      try {
        const r=await fetch(API+"/admin/reset-password",{method:"POST",headers:{"Content-Type":"application/json","Authorization":localStorage.getItem("token")},body:JSON.stringify({userId:id,newPassword:np})});
        const d=await r.json();
        if(d.success){closeReset();loadUsers();toast("✅ Password reset for #"+id,"success");}
        else er.innerText=d.error||"Failed.";
      } catch(e){er.innerText="Offline.";}
    };

