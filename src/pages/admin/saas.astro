---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Admin Pro Dashboard | SaaS Control">
  <div class="admin-wrapper">
    <header class="admin-header">
      <div class="flex-row">
        <div>
          <h1>💎 Pro SaaS Control</h1>
          <p>Revenue, Industry Analytics & Growth Tracking</p>
        </div>
        <div class="status-indicator">Revenue Tracking Active: <span class="pulse green"></span> System Live</div>
      </div>
    </header>

    <!-- Core Metrics -->
    <section class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div class="stat-info">
          <h3>Total Users</h3>
          <p id="stat-total" class="loading-shimmer">...</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">✅</div>
        <div class="stat-info">
          <h3>Active Users</h3>
          <p id="stat-active" class="loading-shimmer">...</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🎁</div>
        <div class="stat-info">
          <h3>Trial Users</h3>
          <p id="stat-trial" class="loading-shimmer">...</p>
        </div>
      </div>
      <div class="stat-card revenue">
        <div class="stat-icon">💰</div>
        <div class="stat-info">
          <h3>Total Revenue</h3>
          <p id="stat-revenue" class="loading-shimmer">...</p>
        </div>
      </div>
    </section>

    <!-- Analytics Section -->
    <div class="analytics-grid">
      <section class="analytics-card">
        <h3>📈 Conversion Health</h3>
        <div class="conversion-val" id="conv-rate">--%</div>
        <p>Trial to Paid Conversion</p>
        <div class="conv-bar-bg"><div class="conv-bar-fill" id="conv-fill" style="width: 0%"></div></div>
      </section>

      <section class="analytics-card">
        <h3>🌱 Daily Growth</h3>
        <p>Recent Signups</p>
        <div id="daily-signup-list" class="growth-list">
           <!-- Signups injected here -->
        </div>
      </section>
    </div>

    <!-- User Management -->
    <section class="table-container">
      <div class="table-header">
        <h2>Users Registry</h2>
        <div class="search-bar">
          <input type="text" id="userSearch" placeholder="Filter by name, business, email..." />
        </div>
      </div>
      
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>User</th>
              <th>Industry</th>
              <th>Plan</th>
              <th>Status</th>
              <th>Revenue</th>
              <th class="hide-mobile">Next Expiry</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="userTableBody">
            <!-- Table rows injected -->
          </tbody>
        </table>
      </div>
    </section>

    <!-- History Log -->
    <section class="table-container history-section">
      <div class="table-header">
        <h2>📜 Live Audit Log</h2>
        <button class="btn-action" onclick="loadHistory()">Refresh Logs</button>
      </div>
      <div class="table-scroll">
        <table class="small-table">
          <thead>
             <tr><th>Date</th><th>User</th><th>Business</th><th>Action</th><th>Plan</th></tr>
          </thead>
          <tbody id="historyBody"></tbody>
        </table>
      </div>
    </section>
  </div>

  <!-- Upgrade/Activate Modal -->
  <div id="activateModal" class="modal">
    <div class="modal-content">
      <h2>🚀 System Activation</h2>
      <p id="activateUserText"></p>
      <div class="form-group">
        <label>Select Plan</label>
        <select id="upgradePlan">
          <option value="Starter">Starter (₹499)</option>
          <option value="Pro">Pro (₹999)</option>
          <option value="Enterprise">Enterprise (₹4999)</option>
          <option value="trial">Reset to Trial (₹0)</option>
        </select>
      </div>
      <div class="form-group">
        <label>Payment Amount Received</label>
        <input type="number" id="payAmount" value="499" />
      </div>
      <div class="modal-actions">
        <button id="cancelActivate" class="btn btn-secondary">Cancel</button>
        <button id="confirmActivate" class="btn btn-primary">Process Payment</button>
      </div>
    </div>
  </div>

  <!-- Password Reset Modal -->
  <div id="resetModal" class="modal">
    <div class="modal-content">
      <h2>🔑 Admin Override: Password</h2>
      <p id="resetUserText"></p>
      <input type="password" id="newPassword" placeholder="New Password" />
      <div class="modal-actions">
        <button onclick="document.getElementById('resetModal').style.display='none'" class="btn btn-secondary">Cancel</button>
        <button id="confirmReset" class="btn btn-primary">Update Credential</button>
      </div>
    </div>
  </div>

  <style>
    .admin-wrapper { padding: 80px 40px; max-width: 1400px; margin: 0 auto; color: white; }
    .admin-header { margin-bottom: 40px; }
    .flex-row { display: flex; justify-content: space-between; align-items: center; }
    .admin-header h1 { font-size: 2.8rem; font-weight: 900; background: linear-gradient(135deg, #fff 0%, #6366f1 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    
    .status-indicator { background: rgba(255, 255, 255, 0.05); padding: 10px 20px; border-radius: 30px; border: 1px solid rgba(255,255,255,0.1); font-size: 0.9rem; display: flex; align-items: center; gap: 10px; }
    .pulse { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 10px #22c55e; animation: pulse 2s infinite; }
    @keyframes pulse { 0% { opacity: 0.4; } 50% { opacity: 1; } 100% { opacity: 0.4; } }

    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .stat-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 30px; display: flex; align-items: center; gap: 20px; }
    .stat-icon { font-size: 2rem; width: 60px; height: 60px; background: rgba(99, 102, 241, 0.1); border-radius: 16px; display: flex; justify-content: center; align-items: center; }
    .stat-info h3 { font-size: 0.85rem; opacity: 0.5; text-transform: uppercase; margin: 0 0 4px 0; }
    .stat-info p { font-size: 2rem; font-weight: 800; margin: 0; }
    .revenue .stat-icon { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
    .revenue p { color: #22c55e; }

    .analytics-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 20px; margin-bottom: 40px; }
    .analytics-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); padding: 30px; border-radius: 24px; }
    .conversion-val { font-size: 3.5rem; font-weight: 900; color: #6366f1; margin: 10px 0; }
    .conv-bar-bg { height: 8px; background: rgba(255,255,255,0.1); border-radius: 10px; overflow: hidden; margin-top: 15px; }
    .conv-bar-fill { height: 100%; background: #6366f1; transition: width 1s ease; }

    .growth-list { display: flex; gap: 10px; overflow-x: auto; padding-bottom: 10px; }
    .growth-item { background: rgba(255,255,255,0.05); padding: 15px; border-radius: 12px; min-width: 120px; text-align: center; border: 1px solid rgba(255,255,255,0.05); }
    .growth-date { font-size: 0.75rem; opacity: 0.5; margin-bottom: 5px; }
    .growth-count { font-size: 1.5rem; font-weight: 800; color: #22c55e; }

    .table-container { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 30px; margin-bottom: 40px; }
    .table-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 20px; flex-wrap: wrap; }
    .search-bar input { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 12px 20px; border-radius: 12px; color: #fff; width: 300px; }
    
    .table-scroll { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); font-size: 0.8rem; opacity: 0.4; text-transform: uppercase; }
    td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.95rem; }

    .status-pill { padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; }
    .pill-active { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
    .pill-expired { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
    .plan-pill { background: rgba(99, 102, 241, 0.1); border: 1px solid rgba(99,102,241,0.2); padding: 2px 8px; border-radius: 4px; font-size: 0.8rem; }

    .action-group { display: flex; gap: 5px; }
    .btn-action { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 6px 10px; border-radius: 8px; color: #fff; cursor: pointer; transition: 0.2s; }
    .btn-action:hover { background: #6366f1; border-color: #6366f1; }
    .btn-danger:hover { background: #ef4444; border-color: #ef4444; }

    .small-table td, .small-table th { padding: 10px; font-size: 0.85rem; }
    
    .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); z-index: 1000; justify-content: center; align-items: center; }
    .modal-content { background: #111; border: 1px solid rgba(255,255,255,0.1); padding: 40px; border-radius: 20px; width: 90%; max-width: 450px; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 10px; font-size: 0.9rem; opacity: 0.7; }
    .form-group input, .form-group select { width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 12px; border-radius: 10px; color: #fff; }
    .modal-actions { display: flex; gap: 10px; margin-top: 30px; }
    .btn { flex: 1; padding: 12px; border: none; border-radius: 10px; cursor: pointer; font-weight: 700; color: #fff; }
    .btn-primary { background: #6366f1; }
    .btn-secondary { background: rgba(255,255,255,0.1); }

    .loading-shimmer { background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 4px; display: inline-block; min-width: 50px; }
    @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
    @media (max-width: 768px) { .analytics-grid { grid-template-columns: 1fr; } .hide-mobile { display: none; } }
  </style>

  <script>
    let usersData = [];
    let selectedId = null;

    async function loadAll() {
      await getStats();
      await getUsers();
      await getHistory();
      await getAnalytics();
    }

    async function getStats() {
      const res = await fetch('/api/admin/dashboard');
      const stats = await res.json();
      document.getElementById('stat-total').innerText = stats.total;
      document.getElementById('stat-total').classList.remove('loading-shimmer');
      document.getElementById('stat-active').innerText = stats.active;
      document.getElementById('stat-active').classList.remove('loading-shimmer');
      document.getElementById('stat-trial').innerText = stats.trial;
      document.getElementById('stat-trial').classList.remove('loading-shimmer');
      document.getElementById('stat-revenue').innerText = '₹' + stats.revenue.toLocaleString();
      document.getElementById('stat-revenue').classList.remove('loading-shimmer');
    }

    async function getUsers() {
      const res = await fetch('/api/admin/users');
      usersData = await res.json();
      renderUsers(usersData);
    }

    async function getAnalytics() {
      const convRes = await fetch('/api/admin/conversion');
      const conv = await convRes.json();
      document.getElementById('conv-rate').innerText = conv.conversion + '%';
      document.getElementById('conv-fill').style.width = conv.conversion + '%';

      const growthRes = await fetch('/api/admin/daily-signups');
      const growth = await growthRes.json();
      const gl = document.getElementById('daily-signup-list');
      gl.innerHTML = growth.map(g => `
        <div class="growth-item">
          <div class="growth-date">${new Date(g.date).toLocaleDateString(undefined, {month:'short', day:'numeric'})}</div>
          <div class="growth-count">+${g.count}</div>
        </div>
      `).join('');
    }

    async function getHistory() {
      const res = await fetch('/api/admin/user-history');
      const history = await res.json();
      const body = document.getElementById('historyBody');
      body.innerHTML = history.slice(0, 15).map(h => `
        <tr>
          <td>${new Date(h.timestamp).toLocaleString(undefined, {month:'short', day:'numeric', hour:'2-digit', minute:'2-digit'})}</td>
          <td>#${h.user_id}</td>
          <td><b>${h.business_name}</b></td>
          <td style="color:#6366f1; font-weight:700">${h.action.replace('_',' ')}</td>
          <td><span class="plan-pill">${h.plan_type}</span></td>
        </tr>
      `).join('');
    }

    function renderUsers(users) {
      const tbody = document.getElementById('userTableBody');
      tbody.innerHTML = users.map(u => `
        <tr>
          <td>
            <div style="font-weight:700">${u.business_name}</div>
            <div style="font-size:0.75rem; opacity:0.5">${u.email}</div>
          </td>
          <td><b>${u.industry}</b></td>
          <td><span class="plan-pill">${u.plan_type}</span></td>
          <td><span class="status-pill pill-${u.status}">${u.status}</span></td>
          <td style="color:#22c55e; font-weight:700">₹${u.amount_paid}</td>
          <td class="hide-mobile">${new Date(u.expiry_date).toLocaleDateString()}</td>
          <td>
            <div class="action-group">
              <button class="btn-action" title="Activate/Upgrade" onclick="openActivate(${u.id}, '${u.business_name}')">🚀</button>
              <button class="btn-action" title="Reset Pass" onclick="openReset(${u.id}, '${u.owner_name}')">🔑</button>
              <button class="btn-action btn-danger" onclick="deleteUser(${u.id}, '${u.business_name}')">🗑️</button>
            </div>
          </td>
        </tr>
      `).join('');
    }

    // Modal Handlers
    window.openActivate = (id, business) => {
      selectedId = id;
      document.getElementById('activateUserText').innerText = `Confirm Payment for ${business}`;
      document.getElementById('activateModal').style.display = 'flex';
    };

    document.getElementById('cancelActivate').onclick = () => document.getElementById('activateModal').style.display = 'none';

    document.getElementById('confirmActivate').onclick = async () => {
      const plan = document.getElementById('upgradePlan').value;
      const amount = document.getElementById('payAmount').value;
      const res = await fetch('/api/admin/activate-plan', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: selectedId, plan, amount: parseInt(amount) })
      });
      if (res.ok) {
        document.getElementById('activateModal').style.display = 'none';
        loadAll();
      }
    };

    window.openReset = (id, name) => {
      selectedId = id;
      document.getElementById('resetUserText').innerText = `Override password for ${name}`;
      document.getElementById('resetModal').style.display = 'flex';
    };

    document.getElementById('confirmReset').onclick = async () => {
      const pass = document.getElementById('newPassword').value;
      if (!pass) return alert("Password required");
      const res = await fetch('/api/admin/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: selectedId, newPassword: pass })
      });
      if (res.ok) {
        alert("Success");
        document.getElementById('resetModal').style.display = 'none';
      }
    };

    window.deleteUser = async (id, name) => {
      if (!confirm(`Permanently delete ${name}? History will be kept.`)) return;
      const res = await fetch('/api/admin/delete-user', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: id })
      });
      if (res.ok) loadAll();
    };

    // Filters
    document.getElementById('userSearch').oninput = (e) => {
      const q = e.target.value.toLowerCase();
      const filtered = usersData.filter(u => u.business_name.toLowerCase().includes(q) || u.owner_name.toLowerCase().includes(q) || u.email.toLowerCase().includes(q));
      renderUsers(filtered);
    };

    document.addEventListener('DOMContentLoaded', loadAll);
    window.loadHistory = getHistory;
  </script>
</MainLayout>
