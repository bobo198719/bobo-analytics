  <script is:inline>
    const API = "/api";
    let myChart = null;
    let allUsers = [];
    const PLANS = ["trial","pro","enterprise"];
    window.logout = ()=>{ localStorage.removeItem("token"); location.replace("/admin-login"); };

    function checkAuth() {
      if (localStorage.getItem("token")) {
        document.getElementById("dashboardContent").style.display="flex";
        initSync();
        // Secondary pulse for any lazy-loaded components
        setTimeout(initSync, 1500); 
      } else {
        window.location.replace("/admin-login");
      }
    }

    // ── TABS ──────────────────────────────────────────────────────
    window.switchTab = function(id,el) {
      if(id === 'settings' && localStorage.getItem("sysLocked") !== "0") {
        toast("🛡️ ACCESS DENIED: System Setup is Locked.","error");
        return;
      }
      document.querySelectorAll(".section").forEach(s=>s.classList.remove("active"));
      document.getElementById(id).classList.add("active");
      document.querySelectorAll(".menu-item").forEach(m=>m.classList.remove("active"));
      if(el) el.classList.add("active");
      document.querySelector('.sidebar').classList.remove('open');
      if(id==="users") loadUsers();
      if(id==="subscriptions") {
        const sector = document.getElementById("pricingSector")?.value || "restaurant";
        loadSectorPlans(sector);
      }
    };

    // ── MASTER CONTROL SYNC ───────────────────────────────────────
    async function initSync() {
      const tok = localStorage.getItem("token");
      const range = document.getElementById("dateFilter")?.value || "30";
      
      try {
        const [sR,tR,aR,lR,cR,actR,alR] = await Promise.all([
          fetch(API+"/stats?range="+range,{headers:{"Authorization":tok}}),
          fetch(API+"/tenants",{headers:{"Authorization":tok}}),
          fetch(API+"/admin/audit-logs",{headers:{"Authorization":tok}}),
          fetch(API+"/admin/leads",{headers:{"Authorization":tok}}),
          fetch(API+"/admin/campaigns",{headers:{"Authorization":tok}}),
          fetch(API+"/activity",{headers:{"Authorization":tok}}),
          fetch(API+"/alerts",{headers:{"Authorization":tok}})
        ]);
        if(sR.status===401) return logout();
        
        loadUsers(); 
        
        const stats=await sR.json(), tenants=await tR.json();
        const audits = aR.ok ? await aR.json() : [];
        const leads = lR.ok ? await lR.json() : [];
        const campaigns = cR.ok ? await cR.json() : [];
        const activities = actR.ok ? await actR.json() : [];
        const alerts = alR.ok ? await alR.json() : [];

        // KPI REFRESH
        const setVal = (id, val, suffix="") => {
          const el = document.getElementById(id);
          if(el) el.innerText = val + suffix;
        };

        setVal("kpi-visits", Math.floor(stats.visits||0).toLocaleString());
        setVal("kpi-users", Math.floor(stats.users||0).toLocaleString());
        setVal("kpi-views", Math.floor(stats.views||0).toLocaleString());
        setVal("kpi-duration", stats.duration || "0s");
        
        // BARS
        if(stats.devices) {
          const mobile = stats.devices.mobile || 0;
          const desktop = stats.devices.desktop || 0;
          const tablet = stats.devices.tablet || 0;

          const mEl = document.getElementById("dev-mobile");
          if(mEl) mEl.innerText = mobile + "%";
          const mBar = document.getElementById("bar-mobile");
          if(mBar) mBar.style.width = mobile + "%";

          const dEl = document.getElementById("dev-desktop");
          if(dEl) dEl.innerText = desktop + "%";
          const dBar = document.getElementById("bar-desktop");
          if(dBar) dBar.style.width = desktop + "%";

          const tEl = document.getElementById("dev-tablet");
          if(tEl) tEl.innerText = tablet + "%";
          const tBar = document.getElementById("bar-tablet");
          if(tBar) tBar.style.width = tablet + "%";
        }

        renderGeoTable(stats.geo);
        updateCharts(stats);
        renderAudit(audits);
        renderPipeline(leads);
        renderLeads(leads);
        renderActivity(activities);
        renderAlerts(alerts);
        generateInsight();

        // Organizations
