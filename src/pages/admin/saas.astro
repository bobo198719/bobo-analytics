---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Admin | SaaS Control Center" hideNav={true}>
  <style>
    :root {
      --bg-dark: #0b0f1a;
      --sidebar-bg: #0f172a;
      --card-bg: #111827;
      --neon-blue: #38bdf8;
      --neon-green: #34d399;
      --neon-red: #fb7185;
      --border-color: #1f2937;
      --text-muted: #94a3b8;
    }

    body {
      margin: 0;
      font-family: 'Outfit', 'Inter', sans-serif;
      background: var(--bg-dark);
      color: #fff;
      display: flex;
    }

    /* SIDEBAR - Fixed Pillar */
    .sidebar {
      width: 240px;
      height: 100vh;
      background: var(--sidebar-bg);
      padding: 30px 20px;
      position: fixed;
      left: 0;
      top: 0;
      border-right: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      z-index: 1000;
    }

    .sidebar h2 {
      margin-bottom: 40px;
      font-size: 1.4rem;
      font-weight: 900;
      letter-spacing: 1px;
      color: var(--neon-blue);
      text-align: center;
    }

    .nav-menu {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .nav-item {
      padding: 12px 18px;
      border-radius: 10px;
      cursor: pointer;
      transition: 0.3s;
      color: var(--text-muted);
      border: none;
      background: transparent;
      text-align: left;
      font-size: 1rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
      width: 100%;
    }

    .nav-item:hover {
      background: rgba(255,255,255,0.05);
      color: white;
    }

    .nav-item.active {
      background: linear-gradient(90deg, #2563eb, #1e40af);
      color: white;
      box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
    }

    .sidebar-footer {
      margin-top: auto;
      padding-top: 20px;
      border-top: 1px solid var(--border-color);
    }

    .btn-quick {
      width: 100%;
      padding: 10px;
      background: rgba(14, 165, 233, 0.1);
      border: 1px solid var(--neon-blue);
      color: var(--neon-blue);
      border-radius: 8px;
      cursor: pointer;
      margin-bottom: 10px;
      font-weight: 700;
      transition: 0.3s;
    }
    .btn-quick:hover {
      background: var(--neon-blue);
      color: white;
    }

    /* MAIN CONTENT AREA */
    .main {
      margin-left: 240px;
      flex: 1;
      min-height: 100vh;
      width: calc(100% - 240px);
      padding: 40px 20px;
    }

    .container {
      max-width: 1300px;
      margin: 0 auto;
    }

    header.dashboard-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 40px;
    }

    .header-info h1 {
      margin: 0;
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -1px;
    }

    .top-stats {
      display: flex;
      gap: 20px;
    }
    .top-stat-item {
      background: var(--card-bg);
      padding: 10px 20px;
      border-radius: 30px;
      border: 1px solid var(--border-color);
      font-size: 0.9rem;
      font-weight: 700;
    }

    /* KPI GRID */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      margin-bottom: 40px;
    }

    .card {
      background: var(--card-bg);
      padding: 25px;
      border-radius: 16px;
      border: 1px solid var(--border-color);
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
      border-color: rgba(56, 189, 248, 0.3);
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .card-label {
      font-size: 0.85rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }

    .value {
      font-size: 32px;
      font-weight: 900;
      margin-top: 10px;
      letter-spacing: -1px;
    }

    /* SECTION GRIDS */
    .section-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 24px;
      margin-bottom: 40px;
    }

    .section {
      background: var(--card-bg);
      padding: 25px;
      border-radius: 16px;
      border: 1px solid var(--border-color);
    }

    .section h3 {
      margin: 0 0 20px 0;
      font-size: 1.1rem;
      font-weight: 800;
      color: var(--neon-blue);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    /* CHARTS */
    .chart-box { height: 300px; position: relative; }

    /* TABLES */
    .table-container { 
      width: 100%; 
      overflow-x: auto; 
    }
    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 8px;
      min-width: 800px;
    }
    th {
      text-align: left;
      padding: 15px 20px;
      font-size: 0.75rem;
      text-transform: uppercase;
      color: var(--text-muted);
      letter-spacing: 1px;
    }
    td {
      padding: 18px 20px;
      background: rgba(255,255,255,0.02);
      font-size: 0.95rem;
    }
    tr td:first-child { border-radius: 12px 0 0 12px; }
    tr td:last-child { border-radius: 0 12px 12px 0; }
    
    /* TAB CONTENT */
    .tab-content { display: none; }
    .tab-content.active { display: block; animation: fadeIn 0.4s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* RESPONSIVE */
    @media (max-width: 1100px) {
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
      .section-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .sidebar { width: 80px; padding: 20px 10px; }
      .sidebar h2, .nav-item span:not(.icon) { display: none; }
      .main { margin-left: 80px; width: calc(100% - 80px); }
      .kpi-grid { grid-template-columns: 1fr; }
    }

    /* HELPER CLASSES */
    .status-tag { padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; }
    .status-active { background: rgba(52, 211, 153, 0.1); color: var(--neon-green); border: 1px solid rgba(52, 211, 153, 0.2); }
    .status-inactive { background: rgba(251, 113, 133, 0.1); color: var(--neon-red); border: 1px solid rgba(251, 113, 133, 0.2); }
    
    .btn-action { padding: 8px 15px; border-radius: 8px; border: 1px solid var(--border-color); background: rgba(255,255,255,0.05); color: white; cursor: pointer; font-size: 0.85rem; font-weight: 600; transition: 0.2s; }
    .btn-action:hover { background: rgba(255,255,255,0.1); border-color: var(--neon-blue); }
    .btn-danger { color: var(--neon-red); border-color: rgba(251, 113, 133, 0.3); }

    .modal {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.8); backdrop-filter: blur(10px);
      display: none; justify-content: center; align-items: center; z-index: 2000;
    }
    .modal.active { display: flex; }
    .modal-content { background: var(--card-bg); padding: 40px; border-radius: 24px; width: 500px; border: 1px solid var(--border-color); }
    .modal-content h2 { margin-bottom: 25px; color: var(--neon-blue); }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; color: var(--text-muted); font-size: 0.85rem; }
    .form-group input, .form-group select { width: 100%; padding: 12px; background: rgba(0,0,0,0.3); border: 1px solid var(--border-color); border-radius: 10px; color: white; }
  </style>

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <h2>BOBO ADMIN</h2>
    <nav class="nav-menu">
      <button class="nav-item active" data-tab="overview">📊 Dashboard</button>
      <button class="nav-item" data-tab="provisioning">🏢 Tenants</button>
      <button class="nav-item" data-tab="billing">💸 Billing</button>
      <button class="nav-item" data-tab="security">🛡️ Security</button>
      <button class="nav-item" data-tab="leads">🎯 Leads</button>
    </nav>

    <div class="sidebar-footer">
      <button class="btn-quick" onclick="openProvisionModal()">+ New Tenant</button>
      <button class="btn-quick" onclick="openPaymentModal()">+ Record Payment</button>
    </div>
  </aside>

  <!-- MAIN AREA -->
  <main class="main">
    <div class="container">
      
      <header class="dashboard-header">
        <div class="header-info">
          <h1>Control Tower <span style="color:var(--neon-blue);">v11.7</span></h1>
          <p style="color:var(--text-muted); margin-top:5px;">Real-time SaaS Monitoring & Orchestration</p>
        </div>
        <div class="top-stats">
          <div class="top-stat-item">Access: <span id="g-total" style="color:var(--neon-blue);">0</span></div>
          <div class="top-stat-item">Active: <span id="g-active" style="color:var(--neon-green);">0</span></div>
        </div>
      </header>

      <!-- DASHBOARD TAB -->
      <div class="tab-content active" id="overview">
        <!-- KPI GRID -->
        <div class="kpi-grid">
          <div class="card">
            <div class="card-label">Total Users</div>
            <div class="value" id="k-users">0</div>
          </div>
          <div class="card">
            <div class="card-label">Active Tenants</div>
            <div class="value" id="k-active" style="color:var(--neon-green);">0</div>
          </div>
          <div class="card">
            <div class="card-label">Monthly Revenue</div>
            <div class="value" id="k-revenue">₹0</div>
          </div>
          <div class="card">
            <div class="card-label">Security Alerts</div>
            <div class="value" id="k-alerts" style="color:var(--neon-red);">0</div>
          </div>
        </div>

        <!-- MIDDLE GRID: Chart + AI -->
        <div class="section-grid">
          <div class="section">
            <h3>📈 Revenue Growth</h3>
            <div class="chart-box">
              <canvas id="revenueChart"></canvas>
            </div>
          </div>
          <div class="section">
            <h3>🧠 AI Insights</h3>
            <ul id="ai-insights-list" style="list-style:none; padding:0; margin:0; line-height:1.6;">
              <li style="padding:15px; background:rgba(255,255,255,0.03); border-radius:10px; margin-bottom:10px; border-left:3px solid var(--neon-blue);">Analyzing systems...</li>
            </ul>
          </div>
        </div>

        <!-- Industry Dist -->
        <div class="section">
          <h3>🏢 Industry Distribution</h3>
          <div class="chart-box" style="height:200px;">
            <canvas id="industryChart"></canvas>
          </div>
        </div>
      </div>

      <!-- TENANTS TAB -->
      <div class="tab-content" id="provisioning">
        <div class="section">
          <h3>Tenant Provisioning Table</h3>
          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>Business</th>
                  <th>Industry</th>
                  <th>Plan</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="provisionTableBody"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- BILLING TAB -->
      <div class="tab-content" id="billing">
        <div class="section">
          <h3>Revenue Ledger</h3>
          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Client</th>
                  <th>Plan</th>
                  <th>Amount</th>
                  <th>Method</th>
                </tr>
              </thead>
              <tbody id="revenueTableBody"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- SECURITY TAB -->
      <div class="tab-content" id="security">
        <div class="section">
          <h3>Advanced Security Logs</h3>
          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>User</th>
                  <th>IP Address</th>
                  <th>Device</th>
                  <th>Status</th>
                  <th>Time</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="loginLogsBody"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- LEADS TAB -->
      <div class="tab-content" id="leads">
        <div class="section">
          <h3>Lead Generation Queue</h3>
          <p style="color:var(--text-muted);">CRM lead data will populate here based on marketing campaigns.</p>
        </div>
      </div>

    </div>
  </main>

  <!-- MODALS -->
  <div id="provisionModal" class="modal">
    <div class="modal-content">
      <h2>Deploy New Tenant</h2>
      <div class="form-group">
        <label>Business Name</label>
        <input type="text" id="provBusiness" placeholder="e.g. Skyline Cafe">
      </div>
      <div class="form-group">
        <label>Username (Subdomain)</label>
        <input type="text" id="provUser" placeholder="e.g. skyline">
      </div>
      <div class="form-group">
        <label>Industry</label>
        <select id="provIndustry">
          <option value="Restaurant">Restaurant</option>
          <option value="Bakery">Bakery</option>
          <option value="Pharmacy">Pharmacy</option>
          <option value="Retail">Retail</option>
        </select>
      </div>
      <div class="form-group">
        <label>initial Plan</label>
        <select id="provPlan">
          <option value="Basic">Basic</option>
          <option value="Pro">Pro</option>
          <option value="Premium">Premium</option>
        </select>
      </div>
      <div style="display:flex; gap:10px; margin-top:20px;">
        <button class="btn-quick" id="confirmProvision">Deploy Instance</button>
        <button class="btn-action" onclick="document.getElementById('provisionModal').classList.remove('active')">Cancel</button>
      </div>
    </div>
  </div>

  <div id="paymentModal" class="modal">
    <div class="modal-content">
      <h2>Manual Payment Entry</h2>
      <div class="form-group">
        <label>Select Tenant</label>
        <select id="payUserId"></select>
      </div>
      <div class="form-group">
        <label>Amount (INR)</label>
        <input type="number" id="payAmount" value="5000">
      </div>
      <div class="form-group">
        <label>Method</label>
        <select id="payMethod">
          <option value="UPI">UPI</option>
          <option value="Bank Transfer">Bank Transfer</option>
          <option value="Cash">Cash</option>
        </select>
      </div>
      <div style="display:flex; gap:10px; margin-top:20px;">
        <button class="btn-quick" id="confirmPayment">Record Entry</button>
        <button class="btn-action" onclick="document.getElementById('paymentModal').classList.remove('active')">Cancel</button>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    // DASHBOARD LOGIC v11.7
    let globalData = {};
    let charts = {};

    function animateValue(obj, start, end, duration, prefix = '', suffix = '') {
      if (!obj) return;
      let startTimestamp = null;
      const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        obj.innerHTML = prefix + Math.floor(progress * (end - start) + start).toLocaleString() + suffix;
        if (progress < 1) window.requestAnimationFrame(step);
      };
      window.requestAnimationFrame(step);
    }

    function initCharts() {
      // Revenue
      const ctxRev = document.getElementById('revenueChart').getContext('2d');
      charts.revenue = new Chart(ctxRev, {
        type: 'line',
        data: {
          labels: ['Jan', 'Feb', 'Mar', 'Apr'],
          datasets: [{
            label: 'Revenue',
            data: [15000, 28000, 42000, 45000],
            borderColor: '#38bdf8',
            backgroundColor: 'rgba(56, 189, 248, 0.1)',
            fill: true,
            tension: 0.4
          }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display:false } } }
      });

      // Industry
      const ctxInd = document.getElementById('industryChart').getContext('2d');
      charts.industry = new Chart(ctxInd, {
        type: 'bar',
        data: {
          labels: ['Restaurant', 'Pharmacy', 'Retail', 'Bakery'],
          datasets: [{
            data: [0, 0, 0, 0],
            backgroundColor: ['#e11d48', '#10b981', '#38bdf8', '#fbbf24']
          }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display:false } } }
      });
    }

    async function loadAllData() {
      try {
        const dashRes = await fetch('/api/v2/admin-ops?action=dashboard');
        const dashData = await dashRes.json();
        
        const userRes = await fetch('/api/v2/admin-ops?action=users');
        const users = await userRes.json();
        globalData.users = users;

        // Update KPIs
        animateValue(document.getElementById('k-users'), 0, users.length, 1000);
        animateValue(document.getElementById('k-active'), 0, users.filter(u=>u.status==='active').length, 1000);
        animateValue(document.getElementById('k-revenue'), 0, dashData.revenue, 1000, '₹');
        
        document.getElementById('g-total').innerText = users.length;
        document.getElementById('g-active').innerText = users.filter(u=>u.status==='active').length;

        // Render Tenants
        document.getElementById('provisionTableBody').innerHTML = users.map(u => `
          <tr>
            <td><div style="font-weight:700;">${u.business_name}</div><div style="font-size:0.7rem; color:var(--text-muted);">@${u.username}</div></td>
            <td>${u.industry}</td>
            <td>${u.plan_type}</td>
            <td><span class="status-tag ${u.status==='active'?'status-active':'status-inactive'}">${u.status}</span></td>
            <td>
              <button class="btn-action" onclick="toggleStatus(${u.id}, '${u.status}')">Toggle</button>
              <button class="btn-action btn-danger" onclick="deleteUser(${u.id})">Delete</button>
            </td>
          </tr>
        `).join('');

        // Update Charts
        const counts = { Restaurant:0, Pharmacy:0, Retail:0, Bakery:0 };
        users.forEach(u => { if(counts[u.industry]!==undefined) counts[u.industry]++; });
        charts.industry.data.datasets[0].data = [counts.Restaurant, counts.Pharmacy, counts.Retail, counts.Bakery];
        charts.industry.update();

        // AI Insights
        document.getElementById('ai-insights-list').innerHTML = `
          <li style="padding:10px; background:rgba(255,255,255,0.03); border-radius:8px; margin-bottom:10px; border-left:3px solid var(--neon-green);">System Health: Optimal. ${users.filter(u=>u.status==='active').length} nodes responding.</li>
          <li style="padding:10px; background:rgba(255,255,255,0.03); border-radius:8px; margin-bottom:10px; border-left:3px solid var(--neon-blue);">Revenue Trend: Upward trajectory +12%.</li>
        `;

        loadSecurityLogs();
        loadRevenue();
        document.getElementById('payUserId').innerHTML = users.map(u => `<option value="${u.id}">${u.business_name}</option>`).join('');

      } catch (e) { console.error(e); }
    }

    async function loadSecurityLogs() {
      const res = await fetch('/api/v2/admin-ops?action=login-logs');
      const logs = await res.json();
      document.getElementById('loginLogsBody').innerHTML = logs.map(l => `
        <tr>
          <td>${l.username}</td>
          <td><code>${l.ip_address}</code></td>
          <td style="max-width:150px; overflow:hidden;">${l.device}</td>
          <td><span class="status-tag ${l.status==='success'?'status-active':'status-inactive'}">${l.status}</span></td>
          <td style="font-size:0.75rem;">${new Date(l.created_at).toLocaleTimeString()}</td>
          <td><button class="btn-action btn-danger" onclick="alert('Blocked')">Block IP</button></td>
        </tr>
      `).join('');
      
      const alerts = await (await fetch('/api/v2/admin-ops?action=security-alerts')).json();
      document.getElementById('k-alerts').innerText = alerts.length;
    }

    async function loadRevenue() {
      const res = await fetch('/api/v2/admin-ops?action=revenue');
      const data = await res.json();
      document.getElementById('revenueTableBody').innerHTML = (data.records || []).map(r => `
        <tr>
          <td>${new Date(r.created_at).toLocaleDateString()}</td>
          <td>${r.business_name}</td>
          <td>${r.plan_type}</td>
          <td style="font-weight:700;">₹${r.amount}</td>
          <td style="color:var(--text-muted);">${r.method}</td>
        </tr>
      `).join('');
    }

    // INTERACTION
    document.querySelectorAll('.nav-item').forEach(btn => {
      btn.onclick = () => {
        document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById(btn.dataset.tab).classList.add('active');
      };
    });

    window.openProvisionModal = () => document.getElementById('provisionModal').classList.add('active');
    window.openPaymentModal = () => document.getElementById('paymentModal').classList.add('active');

    window.toggleStatus = async (id, current) => {
        const status = current === 'active' ? 'inactive' : 'active';
        await fetch('/api/v2/admin-ops?action=update-status', { method: 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({userId: id, status}) });
        loadAllData();
    };

    window.deleteUser = async (id) => {
        if(!confirm("Terminate Tenant?")) return;
        await fetch('/api/v2/admin-ops?action=delete-user', { method: 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({userId: id}) });
        loadAllData();
    };

    document.getElementById('confirmProvision').onclick = async () => {
      const body = {
        businessName: document.getElementById('provBusiness').value,
        username: document.getElementById('provUser').value,
        industry: document.getElementById('provIndustry').value,
        planType: document.getElementById('provPlan').value
      };
      await fetch('/api/v2/admin-ops?action=create-user', { method: 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      document.getElementById('provisionModal').classList.remove('active');
      loadAllData();
    };

    document.getElementById('confirmPayment').onclick = async () => {
      const body = {
        userId: document.getElementById('payUserId').value,
        amount: document.getElementById('payAmount').value,
        method: document.getElementById('payMethod').value
      };
      await fetch('/api/v2/admin-ops?action=manual-payment', { method: 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      document.getElementById('paymentModal').classList.remove('active');
      loadAllData();
    };

    document.addEventListener('DOMContentLoaded', () => {
      initCharts();
      loadAllData();
    });
  </script>
</MainLayout>
