---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Admin Master | SaaS Control Center">
  <div class="dashboard-wrapper">
    <!-- Navbar / Header -->
    <header class="top-nav glass-panel">
      <div class="nav-left">
        <div class="logo-glow"></div>
        <h1>Bobo Analytics <span class="badge neon-blue">Enterprise V11.2</span></h1>
      </div>
      
      <div class="nav-right">
        <div class="system-status">
          <span class="indicator pulse-green"></span>
          <span class="status-text text-green">All Systems Operational</span>
          <span class="uptime">99.9% Uptime</span>
        </div>
        
        <div class="notification-bell">
          🔔 <span class="badge neon-red" id="alertBadge">0</span>
        </div>
        
        <div class="user-profile">
          <div class="avatar">SA</div>
          <div class="user-info">
            <span class="name">Super Admin</span>
            <span class="role">Master Core</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <div class="main-layout">
      <!-- Sidebar -->
      <aside class="sidebar glass-panel">
        <nav class="nav-menu">
           <button class="nav-item active" data-tab="overview">
             <span class="icon">📊</span> Dashboard
           </button>
           <button class="nav-item" data-tab="provisioning">
             <span class="icon">🏢</span> Tenants
           </button>
           <button class="nav-item" data-tab="billing">
             <span class="icon">💳</span> Billing & Plans
           </button>
           <button class="nav-item" data-tab="security">
             <span class="icon">🛡️</span> Security Center
           </button>
           <button class="nav-item" data-tab="leads">
             <span class="icon">🎯</span> Leads & Queue
           </button>
        </nav>
        
        <div class="sidebar-bottom">
           <div class="quick-actions-panel">
             <h3>Quick Actions</h3>
             <button class="btn-action neon-border" onclick="openProvisionModal()">+ New Tenant</button>
             <button class="btn-action neon-border" onclick="openPaymentModal()">+ Record Payment</button>
           </div>
        </div>
      </aside>

      <!-- Dashboard Content -->
      <main class="content-area">
        <!-- GLOBAL FILTER BAR -->
        <div class="filter-bar glass-panel">
          <span class="filter-label">Industry Filter:</span>
          <button class="filter-btn active" data-filter="all">All Industries</button>
          <button class="filter-btn" data-filter="Bakery">Bakery</button>
          <button class="filter-btn" data-filter="Pharmacy">Pharmacy</button>
          <button class="filter-btn" data-filter="Restaurant">Restaurant</button>
          <button class="filter-btn" data-filter="Retail">Retail</button>
        </div>

        <!-- OVERVIEW TAB -->
        <div class="tab-content active" id="overview">
          
          <!-- KPI Cards -->
          <div class="kpi-grid">
            <div class="kpi-card glass-panel hover-glow">
              <div class="kpi-header">Total Users</div>
              <div class="kpi-value text-gradient-blue" id="kpi-users" data-target="0">0</div>
              <div class="kpi-trend positive">↑ 12% this month</div>
            </div>
            
            <div class="kpi-card glass-panel hover-glow">
              <div class="kpi-header">Active Clients</div>
              <div class="kpi-value text-gradient-green" id="kpi-active" data-target="0">0</div>
              <div class="kpi-trend positive">↑ 5% this month</div>
            </div>

            <div class="kpi-card glass-panel hover-glow">
              <div class="kpi-header">Total Revenue</div>
              <div class="kpi-value text-gradient-gold">₹<span id="kpi-revenue" data-target="0">0</span></div>
              <div class="kpi-trend positive">📈 Steady growth</div>
            </div>

            <div class="kpi-card glass-panel hover-glow alert-card">
              <div class="kpi-header">Security Alerts</div>
              <div class="kpi-value text-gradient-red" id="kpi-alerts" data-target="0">0</div>
              <div class="kpi-trend negative" id="kpi-alerts-trend">Requires Attention</div>
            </div>
          </div>

          <!-- Middle Section: Charts & Insights -->
          <div class="dashboard-middle-grid">
            
            <div class="chart-container glass-panel hover-glow">
               <h3>Revenue Growth (30 Days)</h3>
               <div style="position: relative; height: 250px; width: 100%;">
                 <canvas id="revenueChart"></canvas>
               </div>
            </div>

            <div class="chart-container glass-panel hover-glow">
               <h3>Industry Distribution</h3>
               <div style="position: relative; height: 250px; width: 100%; display: flex; justify-content: center;">
                 <canvas id="industryChart"></canvas>
               </div>
            </div>

            <div class="ai-insights glass-panel hover-glow">
               <div class="ai-header">
                 <span class="icon spin-slow">🧠</span> 
                 <h3>AI Control Insights</h3>
               </div>
               <ul class="insight-list" id="ai-insights-list">
                 <li class="loading-pulse">Analyzing network activity...</li>
               </ul>
            </div>
          </div>

          <!-- Bottom Section: Live Timeline & Recent -->
          <div class="dashboard-bottom-grid">
            <div class="glass-panel table-panel hover-glow">
               <h3>Live Activity Timeline</h3>
               <div class="timeline" id="activity-timeline">
                  <div class="timeline-item"><div class="dot pulse-blue"></div><div class="content"><p>System Initializing...</p><span class="time">Just now</span></div></div>
               </div>
            </div>
          </div>
        </div>

        <!-- PROVISIONING TAB -->
        <div class="tab-content" id="provisioning">
          
          <div class="kpi-grid" style="margin-bottom: 20px; grid-template-columns: repeat(2, 1fr);">
            <div class="kpi-card glass-panel hover-glow" style="padding: 20px;">
              <div class="kpi-header" style="margin-bottom: 5px;">Total Access Given</div>
              <div class="kpi-value text-gradient-blue" id="prov-total">0</div>
            </div>
            <div class="kpi-card glass-panel hover-glow" style="padding: 20px;">
              <div class="kpi-header" style="margin-bottom: 5px;">Active Tenants</div>
              <div class="kpi-value text-gradient-green" id="prov-active">0</div>
            </div>
          </div>

          <div class="glass-panel table-panel">
            <div class="panel-header">
              <h2>Tenant Database (Account Provisioning)</h2>
            </div>
            <div class="table-responsive">
              <table id="provisionTable">
                <thead>
                  <tr><th>Business</th><th>Industry</th><th>Plan</th><th>Status</th><th>Actions</th></tr>
                </thead>
                <tbody id="provisionTableBody"></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- BILLING TAB -->
        <div class="tab-content" id="billing">
          <div class="dashboard-middle-grid">
             <div class="glass-panel table-panel">
                <div class="panel-header">
                  <h2>Pricing Plans</h2>
                  <button class="btn-primary neon-border" onclick="openPlanModal()">+ Add Plan</button>
                </div>
                <div class="table-responsive">
                  <table>
                    <thead><tr><th>Name</th><th>Price</th><th>Duration</th><th>Features</th></tr></thead>
                    <tbody id="plansTableBody"></tbody>
                  </table>
                </div>
             </div>

             <div class="glass-panel table-panel">
                <div class="panel-header">
                  <h2>Revenue Ledger</h2>
                </div>
                <div class="table-responsive">
                  <table>
                    <thead><tr><th>Date</th><th>Client</th><th>Plan</th><th>Amount</th><th>Method</th></tr></thead>
                    <tbody id="revenueTableBody"></tbody>
                  </table>
                </div>
             </div>
          </div>
        </div>

        <!-- SECURITY TAB -->
        <div class="tab-content" id="security">
          <div class="glass-panel table-panel critical-border">
             <div class="panel-header">
               <h2 class="text-red">Security Control Center</h2>
               <div id="security-alerts-container"></div>
             </div>
             <div class="table-responsive">
               <table>
                 <thead><tr><th>User</th><th>IP Address</th><th>Device</th><th>Status</th><th>Time</th><th>Action</th></tr></thead>
                 <tbody id="loginLogsBody"></tbody>
               </table>
             </div>
          </div>
        </div>

        <!-- LEADS TAB -->
        <div class="tab-content" id="leads">
          <div class="glass-panel table-panel">
            <div class="panel-header">
               <h2>Registration Queue (Leads)</h2>
            </div>
            <div class="table-responsive">
               <table>
                 <thead><tr><th>Date</th><th>Name</th><th>Phone</th><th>Industry</th><th>Status</th></tr></thead>
                 <tbody id="leadsTableBody"></tbody>
               </table>
            </div>
          </div>
        </div>

      </main>
    </div>
  </div>

  <!-- MODALS -->
  <div id="provisionModal" class="modal glass-modal">
    <div class="modal-content glass-panel">
      <h2>🆕 Provision New SaaS Tenant</h2>
      <div class="form-grid">
        <div class="form-group"><label>Business Name</label><input type="text" id="provBusiness" class="glass-input" placeholder="E.g. Apollo Pharmacy" /></div>
        <div class="form-group"><label>Username</label><input type="text" id="provUser" class="glass-input" placeholder="admin_name" /></div>
        <div class="form-group"><label>Password</label><input type="password" id="provPass" class="glass-input" placeholder="••••••••" /></div>
        <div class="form-group">
          <label>Industry</label>
          <select id="provIndustry" class="glass-input">
            <option value="Bakery">Bakery</option>
            <option value="Pharmacy">Pharmacy</option>
            <option value="Retail">Retail</option>
            <option value="Restaurant">Restaurant</option>
            <option value="Salon">Salon</option>
          </select>
        </div>
        <div class="form-group">
          <label>Plan Tier</label>
          <select id="provPlan" class="glass-input">
            <option value="Trial">14-Day Trial</option>
            <option value="Starter">Starter</option>
            <option value="Pro">Pro Enterprise</option>
          </select>
        </div>
      </div>
      <div class="modal-actions">
        <button onclick="document.getElementById('provisionModal').classList.remove('active')" class="btn-secondary glass-btn">Cancel</button>
        <button id="confirmProvision" class="btn-primary neon-btn">Deploy Tenant</button>
      </div>
    </div>
  </div>

  <div id="paymentModal" class="modal glass-modal">
    <div class="modal-content glass-panel">
      <h2>💸 Record Manual Payment</h2>
      <div class="form-group">
        <label>Select Tenant</label>
        <select id="payUserId" class="glass-input"></select>
      </div>
      <div class="form-group">
        <label>Amount (₹)</label>
        <input type="number" id="payAmount" class="glass-input" placeholder="e.g. 5000" />
      </div>
      <div class="form-group">
        <label>Payment Method</label>
        <select id="payMethod" class="glass-input">
          <option value="Manual / UPI">Manual / UPI</option>
          <option value="Bank Transfer">Bank Transfer</option>
          <option value="Cash">Cash</option>
        </select>
      </div>
      <div class="modal-actions">
        <button onclick="document.getElementById('paymentModal').classList.remove('active')" class="btn-secondary glass-btn">Cancel</button>
        <button id="confirmPayment" class="btn-primary neon-btn">Lock Payment</button>
      </div>
    </div>
  </div>

  <div id="planModal" class="modal glass-modal">
    <div class="modal-content glass-panel">
      <h2>💎 Create New Plan Tier</h2>
      <div class="form-group"><label>Plan Name</label><input type="text" id="planName" class="glass-input" placeholder="Pro Gold" /></div>
      <div class="form-group"><label>Price (₹)</label><input type="number" id="planPrice" class="glass-input" value="999" /></div>
      <div class="form-group"><label>Duration (Days)</label><input type="number" id="planDuration" class="glass-input" value="30" /></div>
      <div class="modal-actions">
        <button onclick="document.getElementById('planModal').classList.remove('active')" class="btn-secondary glass-btn">Cancel</button>
        <button id="confirmPlan" class="btn-primary neon-btn">Create Plan</button>
      </div>
    </div>
  </div>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800;900&display=swap');
    
    :root {
      --bg-dark: #05050f;
      --glass-bg: rgba(15, 15, 30, 0.6);
      --glass-border: rgba(255, 255, 255, 0.08);
      --neon-blue: #0ea5e9;
      --neon-green: #10b981;
      --neon-red: #f43f5e;
      --neon-gold: #fbbf24;
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
    }

    body {
      margin: 0; padding: 0;
      background: var(--bg-dark);
      background-image: 
        radial-gradient(circle at 15% 50%, rgba(14, 165, 233, 0.15), transparent 25%),
        radial-gradient(circle at 85% 30%, rgba(244, 63, 94, 0.15), transparent 25%);
      color: var(--text-main);
      font-family: 'Outfit', -apple-system, sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    * { box-sizing: border-box; }

    /* Glassmorphism Classes */
    .glass-panel {
      background: var(--glass-bg);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
      transition: all 0.3s ease;
    }

    .hover-glow:hover {
      box-shadow: 0 0 20px rgba(14, 165, 233, 0.2);
      border-color: rgba(14, 165, 233, 0.3);
      transform: translateY(-2px);
    }

    /* Gradients & Text */
    .text-gradient-blue { background: linear-gradient(to right, #38bdf8, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .text-gradient-green { background: linear-gradient(to right, #34d399, #10b981); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .text-gradient-gold { background: linear-gradient(to right, #fcd34d, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .text-gradient-red { background: linear-gradient(to right, #fb7185, #e11d48); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .text-green { color: var(--neon-green); }
    .text-red { color: var(--neon-red); }

    /* Layout */
    .dashboard-wrapper { display: flex; flex-direction: column; height: 100vh; }
    .main-layout { display: flex; flex: 1; overflow: hidden; padding: 20px; gap: 20px; }
    
    /* Header */
    .top-nav { display: flex; justify-content: space-between; align-items: center; padding: 15px 30px; margin: 20px 20px 0 20px; border-radius: 24px; z-index: 10; }
    .nav-left { display: flex; align-items: center; gap: 15px; }
    .nav-left h1 { margin: 0; font-size: 1.5rem; font-weight: 800; }
    .badge { padding: 4px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; }
    .neon-blue { background: rgba(14, 165, 233, 0.2); color: #38bdf8; border: 1px solid rgba(14, 165, 233, 0.5); }
    .neon-red { background: rgba(244, 63, 94, 0.2); color: #fb7185; border: 1px solid rgba(244, 63, 94, 0.5); }
    
    .nav-right { display: flex; align-items: center; gap: 30px; }
    .system-status { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; font-weight: 600; background: rgba(255,255,255,0.03); padding: 8px 16px; border-radius: 20px; }
    .indicator { width: 10px; height: 10px; border-radius: 50%; }
    .pulse-green { background: #10b981; box-shadow: 0 0 10px #10b981; animation: pulse 2s infinite; }
    .pulse-red { background: #ef4444; box-shadow: 0 0 10px #ef4444; animation: pulse 1s infinite; }
    .uptime { color: var(--text-muted); font-size: 0.75rem; margin-left: 10px; border-left: 1px solid var(--glass-border); padding-left: 10px; }
    
    .notification-bell { font-size: 1.2rem; position: relative; cursor: pointer; }
    .notification-bell .badge { position: absolute; top: -8px; right: -12px; font-size: 0.6rem; padding: 2px 6px; }
    
    .user-profile { display: flex; align-items: center; gap: 10px; }
    .avatar { width: 40px; height: 40px; border-radius: 12px; background: linear-gradient(135deg, #6366f1, #8b5cf6); display: flex; justify-content: center; align-items: center; font-weight: 800; font-size: 1.1rem; }
    .user-info { display: flex; flex-direction: column; }
    .name { font-weight: 700; font-size: 0.9rem; }
    .role { font-size: 0.75rem; color: var(--neon-gold); text-transform: uppercase; letter-spacing: 1px; }

    /* Sidebar */
    .sidebar { width: 280px; display: flex; flex-direction: column; justify-content: space-between; padding: 20px; border-radius: 24px; }
    .nav-menu { display: flex; flex-direction: column; gap: 10px; }
    .nav-item { background: transparent; border: none; color: var(--text-muted); text-align: left; padding: 15px 20px; border-radius: 16px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: 0.3s; display: flex; align-items: center; gap: 15px; font-family: 'Outfit'; }
    .nav-item:hover { background: rgba(255,255,255,0.05); color: white; transform: translateX(5px); }
    .nav-item.active { background: linear-gradient(90deg, rgba(14, 165, 233, 0.2) 0%, transparent 100%); color: var(--neon-blue); border-left: 3px solid var(--neon-blue); }
    
    .quick-actions-panel { background: rgba(0,0,0,0.2); padding: 20px; border-radius: 16px; border: 1px solid var(--glass-border); }
    .quick-actions-panel h3 { margin: 0 0 15px 0; font-size: 0.85rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 1px; }
    .btn-action { width: 100%; text-align: left; background: rgba(255,255,255,0.03); color: white; border: 1px solid var(--glass-border); padding: 12px; border-radius: 10px; margin-bottom: 10px; cursor: pointer; transition: 0.3s; font-weight: 600; }
    .btn-action:hover { background: rgba(14, 165, 233, 0.1); border-color: var(--neon-blue); color: var(--neon-blue); }

    /* Content Area */
    .content-area { flex: 1; min-width: 0; overflow-y: auto; padding-right: 10px; }
    .content-area::-webkit-scrollbar { width: 8px; }
    .content-area::-webkit-scrollbar-track { background: transparent; }
    .content-area::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }

    .filter-bar { padding: 15px 25px; border-radius: 20px; margin-bottom: 25px; display: flex; align-items: center; gap: 15px; flex-wrap: wrap; }
    .filter-label { font-size: 0.9rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
    .filter-btn { background: rgba(255,255,255,0.05); border: 1px solid transparent; color: var(--text-muted); padding: 8px 16px; border-radius: 20px; cursor: pointer; font-weight: 600; transition: 0.3s; }
    .filter-btn:hover { color: white; background: rgba(255,255,255,0.1); }
    .filter-btn.active { background: rgba(14, 165, 233, 0.2); color: var(--neon-blue); border-color: rgba(14, 165, 233, 0.5); }

    .tab-content { display: none; animation: fadeIn 0.4s ease-out forwards; }
    .tab-content.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* KPI Grid */
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 25px; }
    .kpi-card { padding: 25px; display: flex; flex-direction: column; position: relative; overflow: hidden; }
    .kpi-header { font-size: 0.9rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; }
    .kpi-value { font-size: 3.5rem; font-weight: 900; line-height: 1; margin-bottom: 10px; }
    .kpi-trend { font-size: 0.85rem; font-weight: 600; padding: 4px 10px; border-radius: 20px; display: inline-block; width: fit-content; }
    .kpi-trend.positive { background: rgba(16, 185, 129, 0.1); color: #34d399; }
    .kpi-trend.negative { background: rgba(244, 63, 94, 0.1); color: #fb7185; }
    .alert-card { border-color: rgba(244, 63, 94, 0.3); }

    /* Dashboard Middle Grid */
    .dashboard-middle-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 20px; margin-bottom: 25px; }
    .chart-container { padding: 25px; }
    .chart-container h3 { margin: 0 0 20px 0; font-size: 1.1rem; }
    
    .ai-insights { padding: 25px; background: linear-gradient(180deg, rgba(139, 92, 246, 0.1) 0%, transparent 100%); border-top: 2px solid #8b5cf6; }
    .ai-header { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
    .ai-header h3 { margin: 0; font-size: 1.1rem; color: #a78bfa; }
    .insight-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 15px; }
    .insight-list li { background: rgba(0,0,0,0.3); padding: 15px; border-radius: 12px; font-size: 0.85rem; border-left: 3px solid #8b5cf6; }

    /* Timeline Section */
    .dashboard-bottom-grid { margin-bottom: 25px; }
    .timeline { padding: 10px; max-height: 300px; overflow-y: auto; }
    .timeline-item { display: flex; gap: 15px; margin-bottom: 20px; position: relative; }
    .timeline-item::before { content: ''; position: absolute; left: 4px; top: 15px; bottom: -20px; width: 2px; background: var(--glass-border); }
    .timeline-item:last-child::before { display: none; }
    .dot { width: 10px; height: 10px; border-radius: 50%; background: #38bdf8; margin-top: 5px; position: relative; z-index: 2; box-shadow: 0 0 10px #38bdf8; }
    .timeline-item .content p { margin: 0 0 5px 0; font-size: 0.95rem; }
    .timeline-item .content .time { font-size: 0.75rem; color: var(--text-muted); }

    /* Tables */
    .table-panel { padding: 25px; }
    .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
    .panel-header h2 { margin: 0; font-size: 1.5rem; }
    .table-responsive { overflow-x: auto; }
    table { width: 100%; border-collapse: separate; border-spacing: 0 8px; }
    th { text-align: left; padding: 10px 15px; font-size: 0.8rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 1px; white-space: nowrap; }
    td { padding: 15px; background: rgba(255,255,255,0.02); white-space: nowrap; }
    tr td:first-child { border-top-left-radius: 12px; border-bottom-left-radius: 12px; }
    tr td:last-child { border-top-right-radius: 12px; border-bottom-right-radius: 12px; }
    tr { transition: 0.2s; }
    tr:hover td { background: rgba(255,255,255,0.05); }

    /* Badges & Buttons */
    .status-tag { padding: 6px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
    .status-active { background: rgba(16, 185, 129, 0.15); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.3); }
    .status-inactive { background: rgba(244, 63, 94, 0.15); color: #fb7185; border: 1px solid rgba(244, 63, 94, 0.3); }
    .status-pending { background: rgba(251, 191, 36, 0.15); color: #fbbf24; border: 1px solid rgba(251, 191, 36, 0.3); }

    .btn-sm { padding: 6px 12px; font-size: 0.75rem; border-radius: 8px; }
    .btn-primary { background: linear-gradient(135deg, #0ea5e9, #2563eb); color: white; border: none; cursor: pointer; transition: 0.3s; padding: 10px 20px; border-radius: 12px; font-weight: 700; }
    .btn-primary:hover { box-shadow: 0 0 20px rgba(14, 165, 233, 0.4); transform: translateY(-2px); }
    .btn-secondary { background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--glass-border); cursor: pointer; transition: 0.3s; padding: 10px 20px; border-radius: 12px; font-weight: 700; }
    .btn-secondary:hover { background: rgba(255,255,255,0.1); }
    .btn-danger { background: rgba(244, 63, 94, 0.1); color: #fb7185; border: 1px solid rgba(244, 63, 94, 0.3); border-radius: 8px; cursor: pointer; font-weight: 700; padding: 6px 12px; }
    .btn-danger:hover { background: #e11d48; color: white; }

    /* Modals */
    .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); backdrop-filter: blur(10px); z-index: 100; justify-content: center; align-items: center; opacity: 0; transition: 0.3s; }
    .modal.active { display: flex; opacity: 1; animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    @keyframes popIn { 0% { transform: scale(0.8); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
    .modal-content { width: 90%; max-width: 500px; padding: 40px; border-radius: 24px; }
    .form-grid { display: flex; flex-direction: column; gap: 20px; margin: 30px 0; }
    .form-group label { display: block; margin-bottom: 8px; font-size: 0.85rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
    .glass-input { width: 100%; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); padding: 15px; border-radius: 12px; color: white; font-family: 'Outfit'; font-size: 1rem; transition: 0.3s; }
    .glass-input:focus { border-color: var(--neon-blue); outline: none; box-shadow: 0 0 10px rgba(14, 165, 233, 0.2); }
    .modal-actions { display: flex; gap: 15px; justify-content: flex-end; }
    .modal-actions button { flex: 1; }

    /* Animations */
    @keyframes pulse { 0% { opacity: 0.4; transform: scale(1); } 50% { opacity: 1; transform: scale(1.2); } 100% { opacity: 0.4; transform: scale(1); } }
    .spin-slow { display: inline-block; animation: spin 4s linear infinite; }
    @keyframes spin { 100% { transform: rotate(360deg); } }
    .loading-pulse { animation: loadPulse 1.5s infinite; opacity: 0.5; }
    @keyframes loadPulse { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }

    /* Responsive */
    @media (max-width: 1024px) {
      .dashboard-middle-grid { grid-template-columns: 1fr; }
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .main-layout { flex-direction: column; }
      .sidebar { width: 100%; flex-direction: row; flex-wrap: wrap; padding: 15px; }
      .nav-menu { flex-direction: row; width: 100%; overflow-x: auto; }
      .kpi-grid { grid-template-columns: 1fr; }
      .top-nav { flex-direction: column; gap: 15px; text-align: center; }
    }
  </style>

  <script is:inline>
    // --- STATE MANAGEMENT ---
    let globalData = {};
    let currentFilter = 'all';
    let charts = {};

    // --- ANIMATION ENGINE ---
    function animateValue(obj, start, end, duration, prefix = '', suffix = '') {
        if (!obj) return;
        let startTimestamp = null;
        const step = (timestamp) => {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.min((timestamp - startTimestamp) / duration, 1);
            obj.innerHTML = prefix + Math.floor(progress * (end - start) + start).toLocaleString() + suffix;
            if (progress < 1) window.requestAnimationFrame(step);
        };
        window.requestAnimationFrame(step);
    }

    function addTimelineEvent(text, timeStr, colorClass="pulse-blue") {
        const tl = document.getElementById('activity-timeline');
        const item = document.createElement('div');
        item.className = 'timeline-item';
        item.innerHTML = `<div class="dot ${colorClass}"></div><div class="content"><p>${text}</p><span class="time">${timeStr}</span></div>`;
        tl.prepend(item);
    }

    // --- CHART ENGINE ---
    function initCharts() {
        // Line Chart (Revenue)
        const ctxRev = document.getElementById('revenueChart').getContext('2d');
        
        let gradientRev = ctxRev.createLinearGradient(0, 0, 0, 400);
        gradientRev.addColorStop(0, 'rgba(14, 165, 233, 0.5)');
        gradientRev.addColorStop(1, 'rgba(14, 165, 233, 0.0)');

        charts.revenue = new Chart(ctxRev, {
            type: 'line',
            data: {
                labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4'],
                datasets: [{
                    label: 'Revenue Growth',
                    data: [12000, 19000, 25000, 32000], // Mock Data until timeline API matches
                    borderColor: '#0ea5e9',
                    backgroundColor: gradientRev,
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#0ea5e9',
                    pointBorderColor: '#fff',
                    pointHoverBackgroundColor: '#fff',
                    pointHoverBorderColor: '#0ea5e9'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } },
                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' }, beginAtZero: true }
                }
            }
        });

        // Pie Chart (Industry)
        const ctxInd = document.getElementById('industryChart').getContext('2d');
        charts.industry = new Chart(ctxInd, {
            type: 'doughnut',
            data: {
                labels: ['Restaurant', 'Pharmacy', 'Retail', 'Bakery'],
                datasets: [{
                    data: [40, 20, 15, 25],
                    backgroundColor: ['#e11d48', '#10b981', '#38bdf8', '#fbbf24'],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'right', labels: { color: '#f8fafc', padding: 20, font: { family: 'Outfit', size: 12 } } }
                },
                cutout: '70%'
            }
        });
    }

    function updateIndustryChart(users) {
        if(!charts.industry) return;
        const counts = {};
        users.forEach(u => {
           if(u.industry === 'admin' || u.industry === 'Admin') return; // Hide admin accounts from charts
           if(counts[u.industry] !== undefined) counts[u.industry]++;
           else counts[u.industry] = 1;
        });
        
        const labels = [];
        const data = [];
        const colors = [];
        const colorPalette = { 'Restaurant': '#e11d48', 'Pharmacy': '#10b981', 'Retail': '#38bdf8', 'Bakery': '#fbbf24', 'Salon': '#a855f7' };
        
        for (const [key, val] of Object.entries(counts)) {
            if (val > 0) {
                 labels.push(key);
                 data.push(val);
                 colors.push(colorPalette[key] || '#94a3b8');
            }
        }
        
        charts.industry.data.labels = labels;
        charts.industry.data.datasets[0].data = data;
        charts.industry.data.datasets[0].backgroundColor = colors;
        charts.industry.update();
    }

    // --- DATA LOADING ---
    async function loadAllData() {
        try {
            // Dashboard KPIs
            const dashRes = await fetch('/api/v2/admin-ops?action=dashboard');
            const dashData = await dashRes.json();
            
            // Users
            const userRes = await fetch('/api/v2/admin-ops?action=users');
            const userData = await userRes.json();
            globalData.users = userData;

            // Update KPIs with filters
            updateDashboardKPIs(dashData, userData);

            // Populate Tables
            renderUserTable(userData);
            
            // Generate AI Insights
            generateAIInsights(dashData, userData);
            
            // Update Charts
            if(charts.industry) updateIndustryChart(userData);

            // Fetch other tabs silently
            loadLogins();
            loadPlans();
            loadRevenue();
            loadSecurityLogs();
            loadLeads();

        } catch (e) {
            console.error("Dashboard Load Error:", e);
        }
    }

    function updateDashboardKPIs(dashData, userData) {
        const filteredUsers = currentFilter === 'all' ? userData : userData.filter(u => u.industry === currentFilter);
        const total = filteredUsers.length;
        const active = filteredUsers.filter(u => u.status === 'active').length;
        
        let revenue = dashData.revenue;
        // In real system, revenue would be filtered by user IDs. We mock filter proportion here for UX demo.
        if (currentFilter !== 'all') revenue = Math.floor(revenue * (total / Math.max(userData.length, 1)));

        animateValue(document.getElementById('kpi-users'), 0, total, 1000);
        animateValue(document.getElementById('kpi-active'), 0, active, 1000);
        animateValue(document.getElementById('kpi-revenue'), 0, revenue, 1000);
        
        const provTotalEl = document.getElementById('prov-total');
        const provActiveEl = document.getElementById('prov-active');
        if (provTotalEl) animateValue(provTotalEl, 0, total, 1000);
        if (provActiveEl) animateValue(provActiveEl, 0, active, 1000);
    }

    function generateAIInsights(dashData, users) {
        const list = document.getElementById('ai-insights-list');
        list.innerHTML = '';
        
        const activeCount = users.filter(u => u.status === 'active').length;
        const inactiveCount = users.length - activeCount;
        
        const insights = [
            `📈 <strong>Growth Trend:</strong> ${activeCount} active tenants running. Server load is stable.`,
            `💡 <strong>Optimization:</strong> ${inactiveCount} tenants are inactive. Consider sending an automated re-engagement email.`
        ];
        
        if (dashData.revenue > 100000) {
            insights.push(`🏆 <strong>Milestone Achieved:</strong> System crossed ₹1L in total processed revenue!`);
        }

        insights.forEach(ins => {
            const li = document.createElement('li');
            li.innerHTML = ins;
            list.appendChild(li);
        });
    }

    // --- TAB RENDERING ---
    function renderUserTable(users) {
        const tbody = document.getElementById('provisionTableBody');
        const filtered = currentFilter === 'all' ? users : users.filter(u => u.industry === currentFilter);
        
        tbody.innerHTML = filtered.map(u => `
            <tr>
              <td><div style="font-weight:700; color:white;">${u.business_name}</div><div style="font-size:0.75rem; color:#94a3b8">@${u.username}</div></td>
              <td><span class="badge neon-blue">${u.industry}</span></td>
              <td>${u.plan_type}</td>
              <td><span class="status-tag ${u.status === 'active' ? 'status-active' : 'status-inactive'}">${u.status}</span></td>
              <td>
                <button class="btn-secondary btn-sm" onclick="toggleStatus(${u.id}, '${u.status}')">Toggle Status</button>
                <button class="btn-danger" onclick="deleteUser(${u.id})">Delete</button>
              </td>
            </tr>
        `).join('');

        // Populate manual payment dropdown
        document.getElementById('payUserId').innerHTML = users.map(u => `<option value="${u.id}">${u.business_name}</option>`).join('');
    }

    async function loadSecurityLogs() {
        // Alerts
        const alertRes = await fetch('/api/v2/admin-ops?action=security-alerts');
        const alerts = await alertRes.json();
        const badge = document.getElementById('alertBadge');
        const kpiAlerts = document.getElementById('kpi-alerts');
        
        badge.innerText = alerts.length;
        animateValue(kpiAlerts, 0, alerts.length, 500);
        
        const alertBox = document.getElementById('security-alerts-container');
        alertBox.innerHTML = alerts.map(a => `<div style="background:rgba(244,63,94,0.1); color:#fb7185; padding:8px 15px; border-radius:10px; margin-bottom:10px; border:1px solid #fb7185; font-size:0.85rem">⚠️ Security Alert: User <b>${a.username}</b> had ${a.attempts} failed logins.</div>`).join('');
        
        if(alerts.length > 0) {
            document.querySelector('.indicator').className = 'indicator pulse-red';
            document.querySelector('.status-text').className = 'status-text text-red';
            document.querySelector('.status-text').innerText = 'Security Threats Detected';
            addTimelineEvent(`${alerts.length} brute force attempts detected`, 'Just now', 'pulse-red');
        }

        // Logs
        const res = await fetch('/api/v2/admin-ops?action=login-logs');
        const logs = await res.json();
        document.getElementById('loginLogsBody').innerHTML = logs.map(l => `
            <tr>
              <td><b>${l.username}</b></td>
              <td><code style="color:#94a3b8; font-size:0.8rem">${l.ip_address}</code></td>
              <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis" title="${l.device}">${l.device}</td>
              <td><span class="status-tag ${l.status==='success'?'status-active':'status-inactive'}">${l.status}</span></td>
              <td><span style="font-size:0.8rem; color:#94a3b8">${new Date(l.created_at).toLocaleString()}</span></td>
              <td><button class="btn-danger" onclick="blockUser('${l.username}')">Block IP</button></td>
            </tr>
        `).join('');
    }

    async function loadPlans() {
        const res = await fetch('/api/v2/admin-ops?action=plans');
        const plans = await res.json();
        document.getElementById('plansTableBody').innerHTML = plans.map(p => `
            <tr>
              <td><b>${p.name}</b></td>
              <td><span class="text-gradient-gold">₹${p.price}</span></td>
              <td>${p.duration} Days</td>
              <td><span style="color:#94a3b8">${p.features || 'Standard Features'}</span></td>
            </tr>
        `).join('');
    }

    async function loadRevenue() {
        const res = await fetch('/api/v2/admin-ops?action=revenue');
        const data = await res.json();
        document.getElementById('revenueTableBody').innerHTML = data.records.map(r => `
            <tr>
              <td><span style="font-size:0.85rem; color:#94a3b8">${new Date(r.created_at).toLocaleDateString()}</span></td>
              <td><b>${r.business_name}</b></td>
              <td><span class="badge neon-blue">${r.plan_type}</span></td>
              <td><strong class="text-gradient-green">₹${r.amount}</strong></td>
              <td>${r.method}</td>
            </tr>
        `).join('');
    }

    async function loadLeads() {}
    async function loadLogins() {} // Keeping footprints for older routes if needed

    // --- INTERACTION HOOKS ---
    function setupTabs() {
        document.querySelectorAll('.nav-item').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                btn.classList.add('active');
                document.getElementById(btn.dataset.tab).classList.add('active');
            };
        });
    }

    function setupFilters() {
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentFilter = btn.dataset.filter;
                updateDashboardKPIs(globalData.dashboardMockData, globalData.users);
                renderUserTable(globalData.users);
            };
        });
    }

    // --- ACTIONS ---
    window.openProvisionModal = () => document.getElementById('provisionModal').classList.add('active');
    window.openPaymentModal = () => document.getElementById('paymentModal').classList.add('active');
    window.openPlanModal = () => document.getElementById('planModal').classList.add('active');

    window.toggleStatus = async (id, current) => {
        const status = current === 'active' ? 'inactive' : 'active';
        await fetch('/api/v2/admin-ops?action=update-status', { method: 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({userId: id, status}) });
        addTimelineEvent(`Toggled status for tenant ID ${id} to ${status}`, 'Just now');
        loadAllData();
    };

    window.deleteUser = async (id) => {
        if(!confirm("Warning! This permanently terminates the tenant. Continue?")) return;
        await fetch('/api/v2/admin-ops?action=delete-user', { method: 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({userId: id}) });
        addTimelineEvent(`Deleted tenant ID ${id}`, 'Just now', 'pulse-red');
        loadAllData();
    };

    window.blockUser = async (user) => {
        if(!confirm(`Block ${user}?`)) return;
        await fetch('/api/v2/admin-ops?action=block-user', { method: 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({username: user}) });
        loadAllData();
    };

    // Form Submissions
    document.getElementById('confirmProvision').onclick = async () => {
      const body = {
        businessName: document.getElementById('provBusiness').value,
        username: document.getElementById('provUser').value,
        industry: document.getElementById('provIndustry').value,
        planType: document.getElementById('provPlan').value
      };
      await fetch('/api/v2/admin-ops?action=create-user', { method: 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      document.getElementById('provisionModal').classList.remove('active');
      addTimelineEvent(`Deployed new tenant: ${body.businessName}`, 'Just now');
      loadAllData();
    };

    document.getElementById('confirmPayment').onclick = async () => {
      const body = {
        userId: document.getElementById('payUserId').value,
        amount: document.getElementById('payAmount').value,
        method: document.getElementById('payMethod').value
      };
      await fetch('/api/v2/admin-ops?action=manual-payment', { method: 'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      document.getElementById('paymentModal').classList.remove('active');
      addTimelineEvent(`Recorded payment of ₹${body.amount}`, 'Just now', 'pulse-green');
      loadAllData();
    };

    // --- BOOT PROCESS ---
    document.addEventListener('DOMContentLoaded', () => {
        // Mock global data object temporarily for stats calculation
        globalData.dashboardMockData = { revenue: 0 }; 
        
        initCharts();
        setupTabs();
        setupFilters();
        
        // Initial timeline event
        setTimeout(() => addTimelineEvent('Core Services Connected', '1 min ago', 'pulse-green'), 500);

        loadAllData();
    });
  </script>
</MainLayout>
