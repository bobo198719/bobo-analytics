---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Admin | SaaS Control Center" hideNav={true}>
  <style>
    :root {
      --bg-dark: #0b0f1a;
      --sidebar-bg: #0f172a;
      --card-bg: #111827;
      --neon-blue: #2563eb;
      --neon-green: #10b981;
      --neon-red: #ef4444;
      --border-color: #1f2937;
      --text-muted: #94a3b8;
    }

    body {
      margin: 0;
      font-family: 'Outfit', 'Inter', sans-serif;
      background: var(--bg-dark);
      color: #fff;
      display: flex;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* SIDEBAR */
    .sidebar {
      width: 240px;
      height: 100vh;
      background: var(--sidebar-bg);
      padding: 30px 15px;
      position: fixed;
      left: 0;
      top: 0;
      border-right: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      z-index: 1000;
      transition: transform 0.3s ease;
    }

    .sidebar h2 {
      margin-bottom: 40px;
      font-size: 1.4rem;
      font-weight: 900;
      letter-spacing: 1px;
      color: #fff;
      text-align: center;
    }

    .menu-item {
      padding: 12px 18px;
      margin-bottom: 8px;
      border-radius: 10px;
      cursor: pointer;
      transition: 0.3s;
      color: var(--text-muted);
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
      border: none;
      background: transparent;
      width: 100%;
      text-align: left;
    }

    .menu-item:hover {
      background: rgba(255, 255, 255, 0.05);
      color: white;
    }

    .menu-item.active {
      background: var(--neon-blue);
      color: white;
      box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
    }

    /* MAIN AREA */
    .main {
      margin-left: 240px;
      flex: 1;
      padding: 40px;
      width: calc(100% - 240px);
      transition: margin 0.3s ease;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    /* SECTIONS */
    .section {
      display: none;
      animation: fadeIn 0.4s ease;
    }

    .section.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* KPI GRID */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .card {
      background: var(--card-bg);
      padding: 24px;
      border-radius: 12px;
      border: 1px solid var(--border-color);
    }

    .card-label { font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; font-weight: bold; }
    .value { font-size: 28px; font-weight: 900; margin-top: 10px; }

    /* DATA TABLES */
    .table-box {
      background: var(--card-bg);
      padding: 20px;
      border-radius: 12px;
      border: 1px solid var(--border-color);
      overflow-x: auto;
    }

    table { width: 100%; border-collapse: collapse; min-width: 800px; }
    th { text-align: left; padding: 15px; color: var(--text-muted); font-size: 0.8rem; border-bottom: 1px solid var(--border-color); }
    td { padding: 15px; border-bottom: 1px solid var(--border-color); font-size: 0.9rem; }

    /* MOBILE TOGGLE */
    .mobile-nav {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 60px;
      background: var(--sidebar-bg);
      z-index: 1001;
      padding: 0 20px;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border-color);
    }

    .hamburger {
      font-size: 1.5rem;
      cursor: pointer;
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .sidebar {
        transform: translateX(-100%);
      }
      .sidebar.open {
        transform: translateX(0);
      }
      .main {
        margin-left: 0;
        width: 100%;
        padding: 80px 20px 20px 20px;
      }
      .mobile-nav {
        display: flex;
      }
    }

    .status-tag { padding: 4px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: bold; }
    .status-active { background: rgba(16, 185, 129, 0.1); color: var(--neon-green); }
    .status-inactive { background: rgba(239, 68, 68, 0.1); color: var(--neon-red); }
  </style>

  <!-- MOBILE HEADER -->
  <div class="mobile-nav">
    <div class="hamburger" onclick="toggleSidebar()">☰</div>
    <div style="font-weight: 800; font-size: 1.2rem;">BOBO ADMIN</div>
    <div style="font-size: 0.8rem; color: var(--neon-blue);">v11.9 Stable</div>
  </div>

  <!-- SIDEBAR -->
  <div class="sidebar" id="sidebar">
    <h2 style="margin-top:0; border-bottom: 1px solid var(--border-color); padding-bottom: 20px;">BOBO ADMIN</h2>
    <div class="menu-item active" onclick="showSection('dashboard', this)"><span>📊</span> Dashboard</div>
    <div class="menu-item" onclick="showSection('tenants', this)"><span>🏢</span> Tenants</div>
    <div class="menu-item" onclick="showSection('billing', this)"><span>💸</span> Billing</div>
    <div class="menu-item" onclick="showSection('security', this)"><span>🛡️</span> Security Logs</div>
    <div class="menu-item" onclick="showSection('leads', this)"><span>🎯</span> Leads Management</div>
  </div>

  <!-- MAIN AREA -->
  <div class="main">
    <div class="container">

      <!-- DASHBOARD -->
      <div id="dashboard" class="section active">
        <h1>Dashboard Overview</h1>
        <div class="kpi-grid">
          <div class="card"><div class="card-label">Total Users</div><div class="value" id="k-users">0</div></div>
          <div class="card"><div class="card-label">Active Nodes</div><div class="value" id="k-active" style="color:var(--neon-green)">0</div></div>
          <div class="card"><div class="card-label">Gross Revenue</div><div class="value" id="k-revenue">₹0</div></div>
          <div class="card"><div class="card-label">Security Alerts</div><div class="value" id="k-alerts" style="color:var(--neon-red)">0</div></div>
        </div>
        <div class="table-box">
          <h3>Recent System Activity</h3>
          <p>Live industry distribution and deployment logs.</p>
          <div style="height:300px;"><canvas id="industryChart"></canvas></div>
        </div>
      </div>

      <!-- TENANTS -->
      <div id="tenants" class="section">
        <h1>Tenant Management</h1>
        <div class="table-box">
          <table>
            <thead><tr><th>Business</th><th>Industry</th><th>Plan</th><th>Status</th><th>Action</th></tr></thead>
            <tbody id="provisionTableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- BILLING -->
      <div id="billing" class="section">
        <h1>Revenue Ledger</h1>
        <div class="table-box">
          <table>
            <thead><tr><th>Date</th><th>Client</th><th>Plan</th><th>Amount</th></tr></thead>
            <tbody id="revenueTableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- SECURITY -->
      <div id="security" class="section">
        <h1>Security Control Center</h1>
        <div class="table-box">
          <table>
            <thead><tr><th>User</th><th>IP Address</th><th>Status</th><th>Time</th></tr></thead>
            <tbody id="loginLogsBody"></tbody>
          </table>
        </div>
      </div>

      <!-- LEADS -->
      <div id="leads" class="section">
        <h1>Leads Hub</h1>
        <p>No new lead registrations at the moment.</p>
      </div>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    // NAVIGATION
    function showSection(id, element) {
      document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
      document.getElementById(id).classList.add('active');
      document.querySelectorAll('.menu-item').forEach(m => m.classList.remove('active'));
      element.classList.add('active');
      if(window.innerWidth <= 900) document.getElementById('sidebar').classList.remove('open');
    }

    function toggleSidebar() { document.getElementById('sidebar').classList.toggle('open'); }

    // DATA v11.9
    let charts = {};
    function initCharts() {
      const ctx = document.getElementById('industryChart').getContext('2d');
      charts.industry = new Chart(ctx, {
        type: 'doughnut',
        data: { labels: ['Restaurant', 'Pharmacy', 'Retail', 'Bakery'], datasets: [{ data: [0,0,0,0], backgroundColor: ['#ef4444', '#10b981', '#3b82f6', '#f59e0b'] }] },
        options: { responsive:true, maintainAspectRatio:false, cutout:'70%', plugins:{ legend:{ position:'bottom', labels:{color:'#fff'} } } }
      });
    }

    async function loadData() {
      try {
        const [dashR, userR, logR, revR] = await Promise.all([
          fetch('/api/v2/admin-ops?action=dashboard'),
          fetch('/api/v2/admin-ops?action=users'),
          fetch('/api/v2/admin-ops?action=login-logs'),
          fetch('/api/v2/admin-ops?action=revenue')
        ]);
        const dash = await dashR.json();
        const users = await userR.json();
        const logs = await logR.json();
        const rev = await revR.json();

        document.getElementById('k-users').innerText = users.length;
        document.getElementById('k-active').innerText = users.filter(u=>u.status==='active').length;
        document.getElementById('k-revenue').innerText = '₹' + dash.revenue.toLocaleString();
        
        document.getElementById('provisionTableBody').innerHTML = users.map(u => `<tr><td><strong>${u.business_name}</strong></td><td>${u.industry}</td><td>${u.plan_type}</td><td><span class=\"status-tag ${u.status==='active'?'status-active':'status-inactive'}\">${u.status}</span></td><td><button style=\"color:var(--neon-blue); background:none; border:none;\" onclick=\"alert('ID: ${u.id}')\">View</button></td></tr>`).join('');
        document.getElementById('revenueTableBody').innerHTML = (rev.records || []).map(r => `<tr><td>${new Date(r.created_at).toLocaleDateString()}</td><td>${r.business_name}</td><td>${r.plan_type}</td><td>₹${r.amount}</td></tr>`).join('');
        document.getElementById('loginLogsBody').innerHTML = logs.map(l => `<tr><td>${l.username}</td><td><code>${l.ip_address}</code></td><td><span class=\"status-tag ${l.status==='success'?'status-active':'status-inactive'}\">${l.status}</span></td><td>${new Date(l.created_at).toLocaleTimeString()}</td></tr>`).join('');

        const c = { Restaurant:0, Pharmacy:0, Retail:0, Bakery:0 };
        users.forEach(u => { if(c[u.industry]!==undefined) c[u.industry]++; });
        charts.industry.data.datasets[0].data = [c.Restaurant, c.Pharmacy, c.Retail, c.Bakery];
        charts.industry.update();
      } catch(e) { console.error(e); }
    }

    document.addEventListener('DOMContentLoaded', () => { initCharts(); loadData(); });
  </script>
</MainLayout>
