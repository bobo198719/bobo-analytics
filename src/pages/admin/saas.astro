    window.handleSettingsClick = function(btn) {
      const isLocked = localStorage.getItem("sysLocked") !== "0";
      if(isLocked) {
        if(confirm("🔑 UNLOCK SYSTEM SETUP?\n\nThis requires Super-Admin authorization. Ensure you are in a secure environment.")) {
          localStorage.setItem("sysLocked", "0");
          refreshLockUI();
          toast("🔓 System Unlocked. Entering Setup...","success");
          switchTab('settings', btn);
        }
      } else {
        switchTab('settings', btn);
      }
    }

    window.lockSystemNow = function() {
      localStorage.setItem("sysLocked", "1");
      refreshLockUI();
      switchTab('dashboard', document.querySelectorAll('.menu-item')[0]);
      toast("🛡️ System Settings Locked.","success");
    }

    function refreshLockUI() {
      const isLocked = localStorage.getItem("sysLocked") !== "0";
      const icon = document.getElementById("sysLockIcon");
      const text = document.getElementById("sysSetupText");
      if(isLocked) {
        icon.innerText = "🔒";
        text.innerText = "System Setup (Locked)";
      } else {
        icon.innerText = "⚙️";
        text.innerText = "System Configuration";
      }
    }
    
    window.toggleTheme = function() {
      document.body.classList.toggle('light-theme');
      localStorage.setItem("theme", document.body.classList.contains('light-theme')?"light":"dark");
    }

    window.toggleSidebar = function() {
      document.querySelector('.sidebar').classList.toggle('collapsed');
      localStorage.setItem("sidebarCollapsed", document.querySelector('.sidebar').classList.contains('collapsed')?"1":"0");
    }

    window.switchRoleTab = function(type) {
