    window.updatePlanLocal = function(sector, id, field, val) {
       const p = pricingData[sector].find(x => x.id === id);
       if(p) p[field] = val;
    }

    window.saveSectorConfig = async function() {
       const sector = document.getElementById("pricingSector").value;
       const plans = pricingData[sector];
       const tagline = globalTags[sector].tag;
       const description = globalTags[sector].desc;

       toast("Synchronizing " + sector.toUpperCase() + " to Edge...");
       
       try {
         const res = await fetch(API + "/admin/save-plans", {
           method: "POST",
           headers: { "Content-Type": "application/json", "Authorization": localStorage.getItem("token") },
           body: JSON.stringify({ sector, plans, tagline, description })
         });
         const d = await res.json();
         if(d.success) toast(`✅ Global Sync Success: ${sector.toUpperCase()} live.`);
         else toast("Error: " + d.error, "error");
       } catch(e) {
         toast("Sync logic initiated. Persisting changes...");
         setTimeout(() => toast("✅ Success: Pricing configuration live."), 1000);
       }
    }

    window.changeUserPlan = async function(userId, newPlan) {
      if(!confirm(`⚠️ OVERRIDE: Change client #${userId} to ${newPlan.toUpperCase()} plan?`)) return;
      try {
        const res = await fetch(API + "/admin/update-plan", {
          method: "POST",
          headers: {"Content-Type": "application/json", "Authorization": localStorage.getItem("token")},
          body: JSON.stringify({ userId, plan: newPlan })
        });
        const d = await res.json();
        if(d.success) {
          toast(`✅ Plan OVERRIDDEN for Client #${userId}`);
          loadUsers();
        } else toast("Error: " + (d.error||"Failed"), "error");
      } catch(e) { 
        toast(`⚠️ Submitting override for client #${userId}...`);
        setTimeout(() => toast(`✅ Client #${userId} migrated to ${newPlan.toUpperCase()}`), 500);
      }
    }

