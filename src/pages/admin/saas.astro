---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Admin | Secure Master Console" hideNav={true}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');
    :root {
      --bg-dark: #050810;
      --sidebar-bg: #0c111d;
      --card-bg: #141c2d;
      --neon-blue: #3b82f6;
      --neon-green: #10b981;
      --neon-red: #ef4444;
      --neon-amber: #f59e0b;
      --border-color: rgba(255,255,255,0.08);
      --text-muted: #94a3b8;
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg-dark); color: #fff; display: flex; min-height: 100vh; overflow-x: hidden; }

    #authOverlay { position: fixed; inset: 0; background: rgba(5,8,16,0.98); z-index: 2000; display: flex; align-items: center; justify-content: center; }
    .auth-card { background: var(--card-bg); padding: 40px; border-radius: 24px; border: 1px solid var(--border-color); width: 400px; text-align: center; }
    .auth-input { width: 100%; padding: 14px; margin-bottom: 20px; border-radius: 12px; border: 1px solid var(--border-color); background: rgba(255,255,255,0.05); color: white; outline: none; font-size: 0.95rem; }
    .btn-primary { background: var(--neon-blue); color: white; border: none; padding: 14px 20px; border-radius: 12px; font-weight: 800; cursor: pointer; font-size: 0.95rem; }
    .btn-primary:hover { opacity: 0.85; }

    #dashboardContent { display: none; width: 100%; }

    .sidebar { width: 260px; height: 100vh; background: var(--sidebar-bg); padding: 30px 15px; position: fixed; left: 0; top: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; }
    .nav-menu { flex: 1; }
    .menu-item { padding: 14px 18px; margin-bottom: 6px; border-radius: 12px; cursor: pointer; transition: 0.2s; color: var(--text-muted); font-weight: 600; display: flex; align-items: center; gap: 12px; border: none; background: transparent; width: 100%; font-size: 0.95rem; }
    .menu-item.active { background: var(--neon-blue); color: white; }
    .menu-item:hover:not(.active) { background: rgba(255,255,255,0.05); color: #fff; }

    .main { margin-left: 260px; flex: 1; padding: 40px; }
    .container { max-width: 1300px; margin: 0 auto; }
    .section { display: none; }
    .section.active { display: block; animation: fadeIn 0.3s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 32px; }
    .card { background: var(--card-bg); padding: 24px; border-radius: 16px; border: 1px solid var(--border-color); }
    .card-label { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em; margin-bottom: 8px; }
    .value { font-size: 2.2rem; font-weight: 800; }

    .table-box { overflow-x: auto; border-radius: 16px; border: 1px solid var(--border-color); }
    table { width: 100%; border-collapse: collapse; }
    th { background: rgba(255,255,255,0.04); padding: 14px 18px; text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); font-weight: 700; white-space: nowrap; }
    td { padding: 14px 18px; border-top: 1px solid var(--border-color); font-size: 0.9rem; vertical-align: middle; }
    tr:hover td { background: rgba(255,255,255,0.02); }

    .badge { display: inline-block; padding: 3px 10px; border-radius: 99px; font-size: 0.72rem; font-weight: 700; }
    .badge-green { background: rgba(16,185,129,0.15); color: var(--neon-green); }
    .badge-red { background: rgba(239,68,68,0.15); color: var(--neon-red); }
    .badge-amber { background: rgba(245,158,11,0.15); color: var(--neon-amber); }
    .badge-blue { background: rgba(59,130,246,0.15); color: var(--neon-blue); }

    .pass-cell { display: flex; align-items: center; gap: 8px; white-space: nowrap; }
    .reveal-btn { background: rgba(255,255,255,0.06); border: 1px solid var(--border-color); color: var(--text-muted); padding: 3px 8px; border-radius: 6px; font-size: 0.7rem; cursor: pointer; }
    .reveal-btn:hover { background: rgba(255,255,255,0.12); color:#fff; }

    .btn-sm { padding: 6px 12px; border-radius: 8px; border: none; font-size: 0.78rem; font-weight: 700; cursor: pointer; transition: 0.15s; }
    .btn-reset { background: rgba(245,158,11,0.15); color: var(--neon-amber); }
    .btn-reset:hover { background: rgba(245,158,11,0.3); }

    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.75); z-index: 3000; display: none; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal { background: #1a2235; border-radius: 20px; border: 1px solid var(--border-color); padding: 36px; width: 440px; max-width: 95vw; }
    .modal h3 { margin: 0 0 6px; font-size: 1.2rem; }
    .modal > p { color: var(--text-muted); font-size: 0.85rem; margin: 0 0 24px; }
    .modal input { width: 100%; padding: 13px 16px; border-radius: 10px; border: 1px solid var(--border-color); background: rgba(255,255,255,0.05); color: white; font-size: 0.95rem; outline: none; margin-bottom: 12px; }
    .modal-actions { display: flex; gap: 10px; margin-top: 8px; }
    .btn-cancel { background: rgba(255,255,255,0.06); color: #fff; border: 1px solid var(--border-color); padding: 11px 18px; border-radius: 10px; font-weight: 700; cursor: pointer; }

    .search-bar { padding: 11px 16px; border-radius: 10px; border: 1px solid var(--border-color); background: rgba(255,255,255,0.04); color: white; font-size: 0.9rem; outline: none; width: 260px; }
    .search-bar::placeholder { color: var(--text-muted); }

    .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 12px; }
    .section-title { font-size: 1.5rem; font-weight: 800; margin: 0 0 24px; }
    .status-active { color: var(--neon-green); font-weight: bold; }
  </style>

  <!-- AUTH PORTAL -->
  <div id="authOverlay">
    <div class="auth-card">
      <h2 style="margin-bottom:10px;">🛡️ Master Vault OS</h2>
      <p style="color:var(--text-muted);margin-bottom:30px;">Production Security Enabled (v15.1)</p>
      <input id="email" class="auth-input" type="email" placeholder="Master Email" value="admin@bobo.com">
      <input id="password" class="auth-input" type="password" placeholder="Key Fragment">
      <button class="btn-primary" style="width:100%" onclick="login()">Authenticate Console</button>
      <p id="authError" style="color:var(--neon-red);margin-top:20px;font-size:0.85rem;font-weight:bold;"></p>
    </div>
  </div>

  <!-- RESET PASSWORD MODAL -->
  <div class="modal-overlay" id="resetModal">
    <div class="modal">
      <h3>🔑 Reset Password</h3>
      <p id="resetModalSubtitle">Set a new password for this user.</p>
      <input type="hidden" id="resetUserId" />
      <input type="password" id="newPassword" placeholder="New Password (min 6 chars)" />
      <input type="password" id="confirmPassword" placeholder="Confirm New Password" />
      <p id="resetError" style="color:var(--neon-red);font-size:0.82rem;min-height:18px;"></p>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="closeResetModal()">Cancel</button>
        <button class="btn-primary" onclick="submitReset()">Update Password</button>
      </div>
    </div>
  </div>

  <!-- MAIN DASHBOARD -->
  <div id="dashboardContent" style="width:100%;">
    <aside class="sidebar">
      <div>
        <h2 style="margin:0 0 4px 15px;">BOBO OS</h2>
        <div id="connStatus" style="color:var(--neon-green);font-size:0.65rem;padding-left:15px;margin-bottom:30px;">● CONNECTED TO SECURE NODE</div>
      </div>
      <nav class="nav-menu">
        <button class="menu-item active" onclick="switchTab('dashboard',this)"><span>📊</span> Dashboard Control</button>
        <button class="menu-item" onclick="switchTab('users',this)"><span>👥</span> User Management</button>
        <button class="menu-item" onclick="switchTab('tenants',this)"><span>🏢</span> Tenant Registry</button>
      </nav>
      <button class="menu-item" onclick="logout()" style="margin-top:auto;color:var(--neon-red);"><span>🚪</span> Destroy Session</button>
    </aside>

    <main class="main">
      <div class="container">

        <!-- DASHBOARD TAB -->
        <div id="dashboard" class="section active">
          <p class="section-title">Master Control Tower</p>
          <div class="kpi-grid">
            <div class="card">
              <div class="card-label">Total Users Created</div>
              <div id="kpi-users" class="value" style="color:var(--neon-blue);">0</div>
            </div>
            <div class="card">
              <div class="card-label">Active Deployments</div>
              <div id="kpi-active" class="value" style="color:var(--neon-green);">0</div>
            </div>
            <div class="card">
              <div class="card-label">Projected Revenue</div>
              <div id="kpi-revenue" class="value">₹0</div>
            </div>
            <div class="card">
              <div class="card-label">System Health</div>
              <div class="value" style="color:var(--neon-green);">100%</div>
            </div>
          </div>
          <div class="card"><canvas id="industryChart" style="height:320px;"></canvas></div>
        </div>

        <!-- USERS TAB -->
        <div id="users" class="section">
          <div class="topbar">
            <div>
              <p class="section-title" style="margin-bottom:4px;">User Management</p>
              <span style="color:var(--text-muted);font-size:0.85rem;">
                Total: <strong id="userCountBadge" style="color:#fff;">—</strong> registered accounts
              </span>
            </div>
            <input class="search-bar" id="userSearch" placeholder="🔍  Search by name, ID or username…" oninput="filterUsers()" />
          </div>
          <div class="table-box">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Business Name</th>
                  <th>Username / Login</th>
                  <th>Password</th>
                  <th>Industry</th>
                  <th>Plan</th>
                  <th>Status</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="usersTable">
                <tr><td colspan="9" style="text-align:center;padding:40px;color:var(--text-muted);">Loading…</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- TENANTS TAB -->
        <div id="tenants" class="section">
          <div class="topbar">
            <p class="section-title" style="margin-bottom:0;">Operational Registry</p>
            <button class="btn-primary btn-sm" onclick="addTenant()">+ Provision Node</button>
          </div>
          <div class="table-box">
            <table>
              <thead><tr><th>Node Name</th><th>Sector</th><th>Pulse</th><th>Revenue</th></tr></thead>
              <tbody id="tenantTable"></tbody>
            </table>
          </div>
        </div>

      </div>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    const API = "/api";
    let myChart = null;
    let allUsers = [];

    // ── AUTH ─────────────────────────────────────────────────────
    window.login = async function() {
      const email    = document.getElementById("email").value;
      const password = document.getElementById("password").value;
      const errorEl  = document.getElementById("authError");
      errorEl.innerText = "Authenticating…";
      try {
        const res  = await fetch(API + "/auth/login", {
          method: "POST",
          headers: {"Content-Type":"application/json"},
          body: JSON.stringify({ email, password, industry: "admin" })
        });
        const data = await res.json();
        if (data.token) {
          localStorage.setItem("token", data.token);
          location.reload();
        } else {
          errorEl.innerText = data.message || "Access denied.";
        }
      } catch(e) { errorEl.innerText = "Secure Node Offline. Try again."; }
    };

    window.logout = () => { localStorage.removeItem("token"); location.reload(); };

    function checkAuth() {
      if (localStorage.getItem("token")) {
        document.getElementById("authOverlay").style.display = "none";
        document.getElementById("dashboardContent").style.display = "flex";
        initSync();
      }
    }

    // ── TABS ──────────────────────────────────────────────────────
    window.switchTab = function(id, el) {
      document.querySelectorAll(".section").forEach(s => s.classList.remove("active"));
      document.getElementById(id).classList.add("active");
      document.querySelectorAll(".menu-item").forEach(m => m.classList.remove("active"));
      if (el) el.classList.add("active");
      if (id === "users") loadUsers();
    };

    // ── DASHBOARD ─────────────────────────────────────────────────
    async function initSync() {
      const token = localStorage.getItem("token");
      try {
        const [sR, tR] = await Promise.all([
          fetch(API + "/stats",   { headers: {"Authorization": token} }),
          fetch(API + "/tenants", { headers: {"Authorization": token} })
        ]);
        if (sR.status === 401) return logout();
        const stats   = await sR.json();
        const tenants = await tR.json();

        document.getElementById("kpi-users").innerText   = stats.users ?? stats.total ?? 0;
        document.getElementById("kpi-active").innerText  = stats.active ?? 0;
        document.getElementById("kpi-revenue").innerText = "₹" + (stats.revenue || 0).toLocaleString();

        document.getElementById("tenantTable").innerHTML = tenants.length
          ? tenants.map(t => `<tr><td><strong>${t.name}</strong></td><td>${t.industry}</td><td class="status-active">${t.status}</td><td>₹${(t.revenue||0).toLocaleString()}</td></tr>`).join("")
          : `<tr><td colspan="4" style="text-align:center;padding:30px;color:var(--text-muted);">No production nodes.</td></tr>`;

        updateChart(tenants);
      } catch(e) {
        document.getElementById("connStatus").innerText = "● VPS OFFLINE — RECOVERY MODE";
        document.getElementById("connStatus").style.color = "var(--neon-red)";
      }
    }

    // ── LOAD USERS ────────────────────────────────────────────────
    async function loadUsers() {
      const token = localStorage.getItem("token");
      const tbody = document.getElementById("usersTable");
      tbody.innerHTML = `<tr><td colspan="9" style="text-align:center;padding:40px;color:var(--text-muted);">Loading users…</td></tr>`;
      try {
        const res  = await fetch(API + "/admin/users", { headers: {"Authorization": token} });
        const data = await res.json();
        allUsers = Array.isArray(data) ? data : [];
        document.getElementById("userCountBadge").innerText = allUsers.length;
        document.getElementById("kpi-users").innerText = allUsers.length;
        renderUsers(allUsers);
      } catch(e) {
        tbody.innerHTML = `<tr><td colspan="9" style="text-align:center;padding:40px;color:var(--neon-red);">Failed to load — VPS offline.</td></tr>`;
      }
    }

    function renderUsers(list) {
      const tbody = document.getElementById("usersTable");
      if (!list.length) {
        tbody.innerHTML = `<tr><td colspan="9" style="text-align:center;padding:40px;color:var(--text-muted);">No users found.</td></tr>`;
        return;
      }
      tbody.innerHTML = list.map(u => {
        const planBadge = u.plan_type === "enterprise" ? "badge-blue" : u.plan_type === "pro" ? "badge-green" : "badge-amber";
        const statBadge = u.status === "active" ? "badge-green" : u.status === "suspended" ? "badge-red" : "badge-amber";
        const created   = u.created_at ? new Date(u.created_at).toLocaleDateString("en-IN") : "—";
        return `<tr>
          <td><code style="background:rgba(255,255,255,0.07);padding:2px 8px;border-radius:5px;font-size:0.8rem;">#${u.id}</code></td>
          <td><strong>${u.business_name || "—"}</strong></td>
          <td style="font-family:monospace;font-size:0.85rem;">${u.username}</td>
          <td>
            <div class="pass-cell">
              <span style="font-family:monospace;letter-spacing:2px;color:var(--text-muted);" id="pass-${u.id}">••••••••</span>
              <button class="reveal-btn" id="passbtn-${u.id}" onclick="togglePass(${u.id})">👁 Show</button>
            </div>
          </td>
          <td><span class="badge badge-blue">${u.industry || "—"}</span></td>
          <td><span class="badge ${planBadge}">${u.plan_type || "trial"}</span></td>
          <td><span class="badge ${statBadge}">${u.status}</span></td>
          <td style="color:var(--text-muted);font-size:0.82rem;">${created}</td>
          <td><button class="btn-sm btn-reset" onclick="openResetModal(${u.id},'${u.username}')">🔑 Reset Password</button></td>
        </tr>`;
      }).join("");
    }

    // ── SEARCH ────────────────────────────────────────────────────
    window.filterUsers = function() {
      const q = document.getElementById("userSearch").value.toLowerCase();
      renderUsers(allUsers.filter(u =>
        String(u.id).includes(q) ||
        (u.username||"").toLowerCase().includes(q) ||
        (u.business_name||"").toLowerCase().includes(q)
      ));
    };

    // ── PASS REVEAL ───────────────────────────────────────────────
    window.togglePass = function(id) {
      const el  = document.getElementById("pass-" + id);
      const btn = document.getElementById("passbtn-" + id);
      if (el.dataset.revealed === "true") {
        el.innerText = "••••••••";
        el.style.color = "var(--text-muted)";
        el.style.fontSize = "";
        el.dataset.revealed = "false";
        btn.innerText = "👁 Show";
      } else {
        el.innerText = "Stored as bcrypt hash — use Reset to set new";
        el.style.color = "var(--neon-amber)";
        el.style.fontSize = "0.7rem";
        el.dataset.revealed = "true";
        btn.innerText = "🔒 Hide";
      }
    };

    // ── RESET MODAL ───────────────────────────────────────────────
    window.openResetModal = function(id, username) {
      document.getElementById("resetUserId").value = id;
      document.getElementById("resetModalSubtitle").innerText = "Set new password for: " + username;
      document.getElementById("newPassword").value = "";
      document.getElementById("confirmPassword").value = "";
      document.getElementById("resetError").innerText = "";
      document.getElementById("resetModal").classList.add("open");
    };
    window.closeResetModal = () => document.getElementById("resetModal").classList.remove("open");

    window.submitReset = async function() {
      const id      = document.getElementById("resetUserId").value;
      const newPass = document.getElementById("newPassword").value;
      const confirm = document.getElementById("confirmPassword").value;
      const errEl   = document.getElementById("resetError");

      if (!newPass || newPass.length < 6) { errEl.innerText = "Password must be at least 6 characters."; return; }
      if (newPass !== confirm)             { errEl.innerText = "Passwords do not match."; return; }

      errEl.innerText = "Updating…";
      try {
        const res  = await fetch(API + "/admin/reset-password", {
          method: "POST",
          headers: {"Content-Type":"application/json","Authorization": localStorage.getItem("token")},
          body: JSON.stringify({ userId: id, newPassword: newPass })
        });
        const data = await res.json();
        if (data.success) {
          closeResetModal();
          loadUsers();
          alert("✅ Password successfully reset for user #" + id);
        } else {
          errEl.innerText = data.error || "Reset failed.";
        }
      } catch(e) { errEl.innerText = "VPS offline — reset unavailable right now."; }
    };

    // ── CHART ─────────────────────────────────────────────────────
    function updateChart(data) {
      const ctx = document.getElementById("industryChart"); if (!ctx) return;
      const s = { Restaurant:0, Bakery:0, Retail:0, Pharmacy:0, Healthcare:0, Other:0 };
      data.forEach(t => {
        const key = t.industry ? t.industry.charAt(0).toUpperCase() + t.industry.slice(1) : "Other";
        s[key] !== undefined ? s[key]++ : s["Other"]++;
      });
      if (myChart) myChart.destroy();
      myChart = new Chart(ctx, {
        type: "doughnut",
        data: {
          labels: Object.keys(s),
          datasets: [{
            data: Object.values(s).some(v=>v>0) ? Object.values(s) : [1,1,1,1,1,1],
            backgroundColor: ["#ef4444","#f59e0b","#3b82f6","#10b981","#8b5cf6","#64748b"],
            borderWidth: 0
          }]
        },
        options: { responsive:true, maintainAspectRatio:false, cutout:"72%", plugins:{ legend:{ position:"bottom", labels:{ color:"#fff", padding:20 } } } }
      });
    }

    document.addEventListener("DOMContentLoaded", checkAuth);
  </script>
</MainLayout>
