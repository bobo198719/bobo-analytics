---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Admin | SaaS Control Center" hideNav={true}>
  <style>
    :root {
      --bg-dark: #0b0f1a;
      --sidebar-bg: #0f172a;
      --card-bg: #111827;
      --neon-blue: #2563eb;
      --neon-green: #10b981;
      --neon-red: #ef4444;
      --border-color: #1f2937;
      --text-muted: #94a3b8;
    }

    body {
      margin: 0;
      font-family: 'Outfit', 'Inter', sans-serif;
      background: var(--bg-dark);
      color: #fff;
      display: flex;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* SIDEBAR */
    .sidebar {
      width: 240px;
      height: 100vh;
      background: var(--sidebar-bg);
      padding: 30px 15px;
      position: fixed;
      left: 0;
      top: 0;
      border-right: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      z-index: 1000;
      transition: transform 0.3s ease;
    }

    .sidebar h2 {
      margin-bottom: 40px;
      font-size: 1.4rem;
      font-weight: 900;
      letter-spacing: 1px;
      color: #fff;
      text-align: center;
    }

    .menu-item {
      padding: 12px 18px;
      margin-bottom: 8px;
      border-radius: 10px;
      cursor: pointer;
      transition: 0.3s;
      color: var(--text-muted);
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .menu-item:hover {
      background: rgba(255, 255, 255, 0.05);
      color: white;
    }

    .menu-item.active {
      background: var(--neon-blue);
      color: white;
      box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
    }

    /* MAIN AREA */
    .main {
      margin-left: 240px;
      flex: 1;
      padding: 40px;
      width: calc(100% - 240px);
      transition: margin 0.3s ease;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    /* SECTIONS */
    .section {
      display: none;
      animation: fadeIn 0.4s ease;
    }

    .section.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* KPI GRID */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .card {
      background: var(--card-bg);
      padding: 24px;
      border-radius: 12px;
      border: 1px solid var(--border-color);
      transition: 0.2s;
    }
    .card:hover { transform: translateY(-3px); }

    .card-label { font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; font-weight: bold; }
    .value { font-size: 28px; font-weight: 900; margin-top: 10px; }

    /* DATA TABLES */
    .table-box {
      background: var(--card-bg);
      padding: 20px;
      border-radius: 12px;
      border: 1px solid var(--border-color);
      overflow-x: auto;
    }

    table { width: 100%; border-collapse: collapse; min-width: 800px; }
    th { text-align: left; padding: 15px; color: var(--text-muted); font-size: 0.8rem; border-bottom: 1px solid var(--border-color); }
    td { padding: 15px; border-bottom: 1px solid var(--border-color); font-size: 0.9rem; }

    /* MOBILE TOGGLE */
    .mobile-nav {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 60px;
      background: var(--sidebar-bg);
      z-index: 1001;
      padding: 0 20px;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border-color);
    }

    .hamburger {
      font-size: 1.5rem;
      cursor: pointer;
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .sidebar {
        transform: translateX(-100%);
      }
      .sidebar.open {
        transform: translateX(0);
      }
      .main {
        margin-left: 0;
        width: 100%;
        padding: 80px 20px 20px 20px;
      }
      .mobile-nav {
        display: flex;
      }
      .kpi-grid { grid-template-columns: 1fr; }
    }

    /* MISC */
    .status-tag { padding: 4px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: bold; }
    .status-active { background: rgba(16, 185, 129, 0.1); color: var(--neon-green); }
    .status-inactive { background: rgba(239, 68, 68, 0.1); color: var(--neon-red); }
  </style>

  <!-- MOBILE HEADER -->
  <div class="mobile-nav">
    <div class="hamburger" onclick="toggleSidebar()">☰</div>
    <div style="font-weight: 800; font-size: 1.2rem;">BOBO ADMIN</div>
    <div style="font-size: 0.8rem; color: var(--neon-blue);">v11.8</div>
  </div>

  <!-- SIDEBAR -->
  <div class="sidebar" id="sidebar">
    <h2 style="margin-top:0;">BOBO ADMIN</h2>
    <div class="menu-item active" onclick="showSection('dashboard', this)"><span class="icon">📊</span> Dashboard</div>
    <div class="menu-item" onclick="showSection('tenants', this)"><span class="icon">🏢</span> Tenants</div>
    <div class="menu-item" onclick="showSection('billing', this)"><span class="icon">💸</span> Billing</div>
    <div class="menu-item" onclick="showSection('security', this)"><span class="icon">🛡️</span> Security Logs</div>
    <div class="menu-item" onclick="showSection('leads', this)"><span class="icon">🎯</span> Leads Queue</div>
  </div>

  <!-- MAIN AREA -->
  <div class="main">
    <div class="container">

      <!-- DASHBOARD SECTION -->
      <div id="dashboard" class="section active">
        <h1 style="margin:0 0 10px 0;">Dashboard Overview</h1>
        <p style="color:var(--text-muted); margin-bottom:30px;">Real-time system health and analytics.</p>

        <div class="kpi-grid">
          <div class="card">
            <div class="card-label">Total Users</div>
            <div class="value" id="k-users">0</div>
          </div>
          <div class="card">
            <div class="card-label">Active Nodes</div>
            <div class="value" id="k-active" style="color:var(--neon-green);">0</div>
          </div>
          <div class="card">
            <div class="card-label">Monthly Gross</div>
            <div class="value" id="k-revenue">₹0</div>
          </div>
          <div class="card">
            <div class="card-label">Threats</div>
            <div class="value" id="k-alerts" style="color:var(--neon-red);">0</div>
          </div>
        </div>

        <div class="table-box">
          <h3 style="margin-bottom:20px;">Industry Distribution</h3>
          <div style="height: 300px; position: relative;">
            <canvas id="industryChart"></canvas>
          </div>
        </div>
      </div>

      <!-- TENANTS SECTION -->
      <div id="tenants" class="section">
        <h1 style="margin-bottom:10px;">Tenant Management</h1>
        <p style="color:var(--text-muted); margin-bottom:30px;">Manage access and industry portals.</p>
        
        <div class="table-box">
          <table>
            <thead>
              <tr>
                <th>Business</th>
                <th>Industry</th>
                <th>Plan</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="provisionTableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- BILLING SECTION -->
      <div id="billing" class="section">
        <h1 style="margin-bottom:10px;">Revenue Ledger</h1>
        <p style="color:var(--text-muted); margin-bottom:30px;">Financial records and payment history.</p>

        <div class="table-box">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Client</th>
                <th>Plan</th>
                <th>Amount</th>
              </tr>
            </thead>
            <tbody id="revenueTableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- SECURITY SECTION -->
      <div id="security" class="section">
        <h1 style="margin-bottom:10px;">Security Operations</h1>
        <p style="color:var(--text-muted); margin-bottom:30px;">Brute force protection and login logs.</p>

        <div class="table-box">
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>IP Address</th>
                <th>Device</th>
                <th>Status</th>
                <th>Time</th>
              </tr>
            </thead>
            <tbody id="loginLogsBody"></tbody>
          </table>
        </div>
      </div>

      <!-- LEADS SECTION -->
      <div id="leads" class="section">
        <h1>Lead Management</h1>
        <div class="card">
          <p>No new leads in the last 24 hours.</p>
        </div>
      </div>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    // NAVIGATION LOGIC
    function showSection(sectionId, element) {
      document.querySelectorAll('.section').forEach(sec => sec.classList.remove('active'));
      document.getElementById(sectionId).classList.add('active');

      document.querySelectorAll('.menu-item').forEach(item => item.classList.remove('active'));
      element.classList.add('active');

      // Close sidebar on mobile
      if (window.innerWidth <= 900) {
        document.getElementById('sidebar').classList.remove('open');
      }
    }

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
    }

    // DATA FETCHING v11.8
    let charts = {};

    function initCharts() {
      const ctx = document.getElementById('industryChart').getContext('2d');
      charts.industry = new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: ['Restaurant', 'Pharmacy', 'Retail', 'Bakery'],
          datasets: [{
            data: [0, 0, 0, 0],
            backgroundColor: ['#ef4444', '#10b981', '#3b82f6', '#f59e0b'],
            borderWidth: 0
          }]
        },
        options: { responsive: true, maintainAspectRatio: false, cutout: '70%', plugins: { legend: { position: 'bottom', labels: { color: '#fff' } } } }
      });
    }

    async function loadData() {
      try {
        const [dashRes, userRes, logRes, revRes] = await Promise.all([
          fetch('/api/v2/admin-ops?action=dashboard'),
          fetch('/api/v2/admin-ops?action=users'),
          fetch('/api/v2/admin-ops?action=login-logs'),
          fetch('/api/v2/admin-ops?action=revenue')
        ]);

        const dash = await dashRes.json();
        const users = await userRes.json();
        const logs = await logRes.json();
        const rev = await revRes.json();

        // Update KPIs
        document.getElementById('k-users').innerText = users.length;
        document.getElementById('k-active').innerText = users.filter(u=>u.status==='active').length;
        document.getElementById('k-revenue').innerText = '₹' + dash.revenue.toLocaleString();
        
        const alerts = await (await fetch('/api/v2/admin-ops?action=security-alerts')).json();
        document.getElementById('k-alerts').innerText = alerts.length;

        // Populate Tables
        document.getElementById('provisionTableBody').innerHTML = users.map(u => `
          <tr>
            <td><strong>${u.business_name}</strong><br><small style="color:var(--text-muted)">@${u.username}</small></td>
            <td>${u.industry}</td>
            <td>${u.plan_type}</td>
            <td><span class="status-tag ${u.status==='active'?'status-active':'status-inactive'}">${u.status}</span></td>
            <td><button style="background:none; border:none; color:var(--neon-blue); cursor:pointer;" onclick="alert('Manage ${u.business_name}')">Manage</button></td>
          </tr>
        `).join('');

        document.getElementById('revenueTableBody').innerHTML = (rev.records || []).map(r => `
          <tr>
            <td>${new Date(r.created_at).toLocaleDateString()}</td>
            <td>${r.business_name}</td>
            <td>${r.plan_type}</td>
            <td>₹${r.amount}</td>
          </tr>
        `).join('');

        document.getElementById('loginLogsBody').innerHTML = logs.map(l => `
          <tr>
            <td>${l.username}</td>
            <td><code>${l.ip_address}</code></td>
            <td style="max-width:150px; overflow:hidden;">${l.device}</td>
            <td><span class="status-tag ${l.status==='success'?'status-active':'status-inactive'}">${l.status}</span></td>
            <td>${new Date(l.created_at).toLocaleTimeString()}</td>
          </tr>
        `).join('');

        // Update Charts
        const counts = { Restaurant:0, Pharmacy:0, Retail:0, Bakery:0 };
        users.forEach(u => { if(counts[u.industry]!==undefined) counts[u.industry]++; });
        charts.industry.data.datasets[0].data = [counts.Restaurant, counts.Pharmacy, counts.Retail, counts.Bakery];
        charts.industry.update();

      } catch (e) { console.error("Error loading dashboard data:", e); }
    }

    document.addEventListener('DOMContentLoaded', () => {
      initCharts();
      loadData();
    });
  </script>
</MainLayout>
