---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Bobo Admin | Secure Control Tower" hideNav={true}>
  <style>
    :root {
      --bg-dark: #050810;
      --sidebar-bg: #0c111d;
      --card-bg: #141c2d;
      --neon-blue: #3b82f6;
      --neon-green: #10b981;
      --neon-red: #ef4444;
      --border-color: rgba(255,255,255,0.08);
      --text-muted: #94a3b8;
    }

    body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg-dark); color: #fff; display: flex; min-height: 100vh; overflow-x: hidden; }

    /* AUTH OVERLAY */
    #authOverlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(5, 8, 16, 0.95); z-index: 2000;
      display: flex; align-items: center; justify-content: center;
      transition: 0.5s ease;
    }

    .auth-card {
      background: var(--card-bg); padding: 40px; border-radius: 24px; border: 1px solid var(--border-color);
      width: 400px; text-align: center; box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    .auth-input {
      width: 100%; padding: 14px; margin-bottom: 20px; border-radius: 12px; border: 1px solid var(--border-color);
      background: rgba(255,255,255,0.05); color: white; outline: none; transition: 0.3s;
    }

    .auth-input:focus { border-color: var(--neon-blue); box-shadow: 0 0 10px rgba(59,130,246,0.3); }

    .btn-primary {
      width: 100%; background: var(--neon-blue); color: white; border: none; padding: 14px;
      border-radius: 12px; font-weight: 800; cursor: pointer; transition: 0.3s;
    }

    .btn-primary:hover { transform: scale(1.02); box-shadow: 0 10px 20px rgba(59,130,246,0.3); }

    /* DASHBOARD CONTENT */
    #dashboardContent { display: none; width: 100%; }
    #dashboardContent.authed { display: flex; }

    /* SIDEBAR */
    .sidebar { width: 260px; height: 100vh; background: var(--sidebar-bg); padding: 30px 15px; position: fixed; left: 0; top: 0; border-right: 1px solid var(--border-color); display: flex; flex-direction: column; }
    .nav-menu { flex: 1; }
    .menu-item { padding: 14px 18px; margin-bottom: 6px; border-radius: 12px; cursor: pointer; transition: 0.2s; color: var(--text-muted); font-weight: 600; display: flex; align-items: center; gap: 12px; border: none; background: transparent; width: 100%; font-size: 0.95rem; }
    .menu-item:hover { background: rgba(255, 255, 255, 0.04); color: white; }
    .menu-item.active { background: var(--neon-blue); color: white; }

    /* MAIN */
    .main { margin-left: 260px; flex: 1; padding: 40px; width: calc(100% - 260px); }
    .container { max-width: 1200px; margin: 0 auto; }
    .section { display: none; }
    .section.active { display: block; animation: fadeIn 0.3s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

    /* KPI */
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 32px; }
    .card { background: var(--card-bg); padding: 24px; border-radius: 16px; border: 1px solid var(--border-color); }
    .card-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; margin-bottom: 8px; }
    .value { font-size: 2.2rem; font-weight: 800; }

    /* TABLES */
    .table-box { background: var(--card-bg); padding: 24px; border-radius: 16px; border: 1px solid var(--border-color); overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 700px; }
    th { text-align: left; padding: 12px 16px; color: var(--text-muted); font-size: 0.75rem; border-bottom: 1px solid var(--border-color); }
    td { padding: 16px; border-bottom: 1px solid var(--border-color); font-size: 0.95rem; }

    /* PAYMENT UI */
    .pay-banner { background: linear-gradient(135deg, #1e293b, #0c111d); padding: 30px; border-radius: 20px; text-align: center; border: 1px solid var(--neon-blue); }
    .btn-pay { background: var(--neon-blue); color: #fff; padding: 15px 30px; border-radius: 12px; font-weight: 800; cursor: pointer; border: none; font-size: 1.1rem; }

    .status-active { color: var(--neon-green); font-weight: bold; }
  </style>

  <!-- AUTH PORTAL -->
  <div id="authOverlay">
    <div class="auth-card">
      <h2 style="margin-bottom: 10px;">🛡️ Bobo OS Vault</h2>
      <p style="color:var(--text-muted); margin-bottom: 30px;">Authorized Access Only</p>
      <input id="email" class="auth-input" type="email" placeholder="Master Email">
      <input id="password" class="auth-input" type="password" placeholder="Access Key">
      <button class="btn-primary" onclick="login()">Authenticate Master Console</button>
      <p id="authError" style="color:var(--neon-red); margin-top:20px; font-size:0.85rem; font-weight:bold;"></p>
    </div>
  </div>

  <!-- DASHBOARD -->
  <div id="dashboardContent">
    <aside class="sidebar">
      <h2>BOBO OS</h2>
      <nav class="nav-menu">
        <button class="menu-item active" onclick="switchTab('dashboard', this)"><span>📊</span> Dashboard</button>
        <button class="menu-item" onclick="switchTab('tenants', this)"><span>🏢</span> Tenants Register</button>
        <button class="menu-item" onclick="switchTab('billing', this)"><span>💸</span> Subscription & Pay</button>
      </nav>
      <button class="menu-item" onclick="logout()" style="margin-top:auto; color:var(--neon-red)"><span>🚪</span> Sign Out</button>
    </aside>

    <main class="main">
      <div class="container">
        
        <div id="dashboard" class="section active">
          <h1>Master Control Tower</h1>
          <div class="kpi-grid">
            <div class="card"><div class="card-label">Total Users</div><div id="users" class="value">0</div></div>
            <div class="card"><div class="card-label">Active Nodes</div><div id="active" class="value" style="color:var(--neon-green)">0</div></div>
            <div class="card"><div class="card-label">Overall Revenue</div><div id="revenue" class="value">₹0</div></div>
            <div class="card"><div class="card-label">Security Alerts</div><div id="alerts" class="value" style="color:var(--neon-red)">0</div></div>
          </div>
          <div class="table-box">
             <h3>Ecosystem Distribution</h3>
             <div style="height:350px;"><canvas id="industryChart"></canvas></div>
          </div>
        </div>

        <div id="tenants" class="section">
          <h1>Tenant Registry</h1>
          <button class="btn-pay" onclick="addTenant()" style="margin-bottom:20px;">+ Provision Tenant</button>
          <div class="table-box">
            <table>
              <thead><tr><th>Establishment Name</th><th>Industry</th><th>Status</th><th>Yield</th></tr></thead>
              <tbody id="tenantTable"></tbody>
            </table>
          </div>
        </div>

        <div id="billing" class="section">
          <h1>SaaS Subscriptions</h1>
          <div class="pay-banner">
            <h2>Bobo OS Professional</h2>
            <p style="color:var(--text-muted); margin-bottom:24px;">Activate Advanced Monitoring and Enterprise Cloud Node Access.</p>
            <button class="btn-pay" onclick="payNow()">Subscribe Now ₹4,999 / yr</button>
          </div>
        </div>

      </div>
    </main>
  </div>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    const API = "http://localhost:5000/api";
    let myChart = null;

    // --- AUTH LOGIC ---
    window.login = async function() {
      const email = document.getElementById("email").value;
      const password = document.getElementById("password").value;
      const errorEl = document.getElementById("authError");

      try {
        const res = await fetch(API + "/login", {
          method: "POST",
          headers: {"Content-Type": "application/json"},
          body: JSON.stringify({ email, password })
        });
        const data = await res.json();
        
        if(data.token) {
          localStorage.setItem("token", data.token);
          checkAuth();
        } else {
          errorEl.innerText = data.error || "Authentication Failed.";
        }
      } catch (err) { errorEl.innerText = "Backend Connection Failure."; }
    }

    window.logout = function() {
      localStorage.removeItem("token");
      location.reload();
    }

    function checkAuth() {
      const token = localStorage.getItem("token");
      if(token) {
        document.getElementById("authOverlay").style.display = "none";
        document.getElementById("dashboardContent").classList.add("authed");
        fetchStats();
        fetchTenants();
      }
    }

    // --- DATA LOGIC ---
    window.switchTab = function(id, el) {
      document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
      document.getElementById(id).classList.add('active');
      document.querySelectorAll('.menu-item').forEach(m => m.classList.remove('active'));
      if(el) el.classList.add('active');
    };

    async function fetchStats() {
      const token = localStorage.getItem("token");
      const res = await fetch(API + "/stats", { headers: { "Authorization": token } });
      const data = await res.json();
      if(data.users !== undefined) {
        document.getElementById("users").innerText = data.users;
        document.getElementById("active").innerText = data.active;
        document.getElementById("revenue").innerText = "₹" + data.revenue.toLocaleString();
        document.getElementById("alerts").innerText = data.alerts;
      } else if(res.status === 401) logout();
    }

    async function fetchTenants() {
      const token = localStorage.getItem("token");
      const res = await fetch(API + "/tenants", { headers: { "Authorization": token } });
      const data = await res.json();
      
      let html = "";
      data.forEach(t => {
        html += `<tr><td><strong>${t.name}</strong></td><td>${t.industry}</td><td class="status-active">${t.status}</td><td>₹${t.revenue.toLocaleString()}</td></tr>`;
      });
      document.getElementById("tenantTable").innerHTML = html || '<tr><td colspan="4">No Records Found.</td></tr>';
      updateChart(data);
    }

    window.addTenant = async function() {
      const name = prompt("Establishment Name:");
      const industry = prompt("Industry:", "Restaurant");
      if(!name) return;
      const token = localStorage.getItem("token");
      await fetch(API + "/tenants", {
        method: "POST",
        headers: { "Content-Type": "application/json", "Authorization": token },
        body: JSON.stringify({ name, industry, status: "active", revenue: 5000 })
      });
      fetchTenants();
      fetchStats();
    }

    // --- PAYMENT (RAZORPAY) ---
    window.payNow = async function() {
      const token = localStorage.getItem("token");
      try {
        const res = await fetch(API + "/create-order", {
          method: "POST",
          headers: { "Content-Type": "application/json", "Authorization": token },
          body: JSON.stringify({ amount: 4999 })
        });
        const order = await res.json();

        const options = {
          key: "rzp_test_placeholder", // Change to actual key
          amount: order.amount,
          currency: "INR",
          name: "Bobo OS Enterprise",
          description: "SaaS Monitor Subscription",
          order_id: order.id,
          handler: function (response) {
            alert("✓ Payment Successful. Order ID: " + order.id);
          },
          theme: { color: "#3b82f6" }
        };
        const rzp = new window.Razorpay(options);
        rzp.open();
      } catch (e) { alert("Razorpay Sync Error. Check Backend logs."); }
    }

    // Chart Logic
    function updateChart(data) {
      const ctx = document.getElementById('industryChart');
      if(!ctx || !window.Chart) return;
      const ss = { Restaurant:0, Bakery:0, Retail:0, Pharmacy:0 };
      data.forEach(t => { if(ss[t.industry]!==undefined) ss[t.industry]++; });
      const final = Object.values(ss).some(v=>v>0) ? Object.values(ss) : [1,1,1,1];
      if(myChart) myChart.destroy();
      myChart = new Chart(ctx, { type:'doughnut', data:{ labels:Object.keys(ss), datasets:[{ data:final, backgroundColor:['#ef4444', '#f59e0b', '#3b82f6', '#10b981'], borderWidth:0 }] }, options:{ responsive:true, maintainAspectRatio:false, cutout:'75%', plugins:{ legend:{ position:'bottom', labels:{color:'#fff', padding:20} } } } });
    }

    // INIT
    document.addEventListener('DOMContentLoaded', checkAuth);
  </script>
</MainLayout>
