---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Download Bobo Analytics - Mobile & Desktop Apps">
  <section class="download-hero">
    <div class="hero-content">
      <span class="badge">FREE DOWNLOAD</span>
      <h1>Get <span class="gradient-text">Bobo Analytics</span> on Any Device</h1>
      <p>Install our Progressive Web App for a native app experience on mobile, tablet, and desktop. No app store required.</p>
      
      <div class="install-cta">
        <button id="installButton" class="btn-primary-large">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7,10 12,15 17,10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          Install App Now
        </button>
        <p class="install-note">Works on Android, iOS, Windows, Mac & Linux</p>
      </div>
    </div>
  </section>

  <section class="platforms">
    <div class="section-header">
      <h2>Installation Instructions</h2>
      <p>Choose your platform below for step-by-step installation</p>
    </div>

    <div class="platform-grid">
      <!-- Android -->
      <div class="platform-card">
        <div class="platform-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg>
        </div>
        <h3>Android</h3>
        <p>Install directly from Chrome browser</p>
        <ol class="steps">
          <li>Open Chrome browser</li>
          <li>Visit boboanalytics.com</li>
          <li>Tap the menu (3 dots)</li>
          <li>Select "Install App" or "Add to Home Screen"</li>
          <li>Tap "Install" to confirm</li>
        </ol>
        <button class="btn-platform" data-platform="android">
          Install for Android
        </button>
      </div>

      <!-- iOS -->
      <div class="platform-card">
        <div class="platform-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"></path><path d="M10 2c1 .5 2 2 2 5"></path></svg>
        </div>
        <h3>iPhone / iPad</h3>
        <p>Install via Safari browser</p>
        <ol class="steps">
          <li>Open Safari browser</li>
          <li>Visit boboanalytics.com</li>
          <li>Tap the Share button</li>
          <li>Scroll down and tap "Add to Home Screen"</li>
          <li>Tap "Add" to confirm</li>
        </ol>
        <button class="btn-platform" data-platform="ios">
          Install for iOS
        </button>
      </div>

      <!-- Windows -->
      <div class="platform-card">
        <div class="platform-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"></rect><line x1="8" x2="16" y1="21" y2="21"></line><line x1="12" x2="12" y1="17" y2="21"></line></svg>
        </div>
        <h3>Windows PC</h3>
        <p>Install from Chrome or Edge</p>
        <ol class="steps">
          <li>Open Chrome or Edge browser</li>
          <li>Visit boboanalytics.com</li>
          <li>Click the install icon in the URL bar</li>
          <li>Or click menu &gt; "Install Bobo Analytics"</li>
          <li>Click "Install" to confirm</li>
        </ol>
        <button class="btn-platform" data-platform="windows">
          Install for Windows
        </button>
      </div>

      <!-- Mac -->
      <div class="platform-card">
        <div class="platform-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"></rect><line x1="8" x2="16" y1="21" y2="21"></line><line x1="12" x2="12" y1="17" y2="21"></line></svg>
        </div>
        <h3>Mac</h3>
        <p>Install from Chrome or Safari</p>
        <ol class="steps">
          <li>Open Chrome or Safari</li>
          <li>Visit boboanalytics.com</li>
          <li>In Chrome: Click install icon in URL bar</li>
          <li>In Safari: File &gt; Add to Dock</li>
          <li>Confirm installation</li>
        </ol>
        <button class="btn-platform" data-platform="mac">
          Install for Mac
        </button>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="section-header">
      <h2>Why Install the App?</h2>
      <p>Get these benefits when you install Bobo Analytics</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
        </div>
        <h4>No App Store Required</h4>
        <p>Install directly from your browser in seconds. No downloads, no waiting.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="m17 5-5-3-5 3"></path><path d="m17 19-5 3-5-3"></path></svg>
        </div>
        <h4>Works Offline</h4>
        <p>Access your data and key features even without internet connection.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
        </div>
        <h4>Lightning Fast</h4>
        <p>Native-like performance with instant loading and smooth animations.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"></path><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path></svg>
        </div>
        <h4>Push Notifications</h4>
        <p>Get real-time alerts for orders, low stock, and important updates.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M3 9h18"></path><path d="M9 21V9"></path></svg>
        </div>
        <h4>Home Screen Access</h4>
        <p>Launch instantly from your home screen like any native app.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16,6 12,2 8,6"></polyline><line x1="12" x2="12" y1="2" y2="15"></line></svg>
        </div>
        <h4>Auto Updates</h4>
        <p>Always have the latest version - updates happen automatically.</p>
      </div>
    </div>
  </section>

  <section class="modules">
    <div class="section-header">
      <h2>All Modules Included</h2>
      <p>Full access to every Bobo Analytics module in one app</p>
    </div>

    <div class="modules-grid">
      <a href="/bakers-os" class="module-card">
        <span class="module-icon">Baker OS</span>
        <p>Complete bakery management</p>
      </a>
      <a href="/grocery-os" class="module-card">
        <span class="module-icon">Grocery OS</span>
        <p>Grocery store operations</p>
      </a>
      <a href="/restaurant-os" class="module-card">
        <span class="module-icon">Restaurant OS</span>
        <p>Restaurant management</p>
      </a>
      <a href="/retail-os" class="module-card">
        <span class="module-icon">Retail OS</span>
        <p>Retail store analytics</p>
      </a>
      <a href="/pharmacy-pos" class="module-card">
        <span class="module-icon">Pharmacy POS</span>
        <p>Pharmacy point of sale</p>
      </a>
      <a href="/dashboard" class="module-card">
        <span class="module-icon">Analytics</span>
        <p>Business intelligence</p>
      </a>
    </div>
  </section>

  <section class="final-cta">
    <h2>Ready to Get Started?</h2>
    <p>Install Bobo Analytics now and transform your business operations</p>
    <button id="installButtonBottom" class="btn-primary-large">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7,10 12,15 17,10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
      Install Free App
    </button>
  </section>

  <script is:inline>
    let deferredPrompt;
    const installButtons = document.querySelectorAll('#installButton, #installButtonBottom, .btn-platform');

    // Capture the install prompt
    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
      console.log('Install prompt captured');
      
      // Show install buttons
      installButtons.forEach(btn => {
        btn.classList.add('ready');
      });
    });

    // Handle install button clicks
    installButtons.forEach(button => {
      button.addEventListener('click', async () => {
        if (deferredPrompt) {
          deferredPrompt.prompt();
          const { outcome } = await deferredPrompt.userChoice;
          console.log(`User ${outcome} the install prompt`);
          deferredPrompt = null;
        } else {
          // Show manual instructions based on platform
          const platform = button.dataset.platform || detectPlatform();
          showInstructions(platform);
        }
      });
    });

    function detectPlatform() {
      const ua = navigator.userAgent.toLowerCase();
      if (/iphone|ipad|ipod/.test(ua)) return 'ios';
      if (/android/.test(ua)) return 'android';
      if (/mac/.test(ua)) return 'mac';
      if (/win/.test(ua)) return 'windows';
      return 'other';
    }

    function showInstructions(platform) {
      const messages = {
        ios: "To install on iOS:\n\n1. Open this site in Safari\n2. Tap the Share button\n3. Scroll down and tap 'Add to Home Screen'\n4. Tap 'Add' to confirm",
        android: "To install on Android:\n\n1. Open this site in Chrome\n2. Tap the menu (3 dots)\n3. Tap 'Install App' or 'Add to Home Screen'\n4. Tap 'Install' to confirm",
        windows: "To install on Windows:\n\n1. Open this site in Chrome or Edge\n2. Look for the install icon in the URL bar\n3. Click 'Install'\n4. Or use menu > 'Install Bobo Analytics'",
        mac: "To install on Mac:\n\n1. Open this site in Chrome\n2. Click the install icon in the URL bar\n3. Click 'Install'\n4. Or in Safari: File > Add to Dock",
        other: "To install this app:\n\n1. Use Chrome, Edge, or Safari browser\n2. Look for 'Install' option in your browser menu\n3. Follow the prompts to add to your device"
      };
      
      alert(messages[platform] || messages.other);
    }

    // Track successful installation
    window.addEventListener('appinstalled', () => {
      console.log('App successfully installed');
      deferredPrompt = null;
    });
  </script>
</MainLayout>

<style>
  .download-hero {
    padding: 120px 24px 80px;
    text-align: center;
    background: radial-gradient(circle at top, rgba(99, 102, 241, 0.2) 0%, transparent 60%);
    position: relative;
  }

  .hero-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .badge {
    display: inline-block;
    background: rgba(16, 185, 129, 0.2);
    color: #10b981;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 24px;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    line-height: 1.1;
    font-weight: 800;
    margin-bottom: 20px;
    letter-spacing: -0.03em;
  }

  .gradient-text {
    background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .download-hero > .hero-content > p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: 40px;
  }

  .install-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .btn-primary-large {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
    color: white;
    padding: 18px 40px;
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
  }

  .btn-primary-large:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(99, 102, 241, 0.4);
  }

  .install-note {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
  }

  .platforms, .features, .modules {
    padding: 80px 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-header h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .section-header p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.05rem;
  }

  .platform-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
  }

  .platform-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 32px;
    transition: all 0.3s ease;
  }

  .platform-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(99, 102, 241, 0.3);
    transform: translateY(-4px);
  }

  .platform-icon {
    color: #6366f1;
    margin-bottom: 20px;
  }

  .platform-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .platform-card > p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    margin-bottom: 20px;
  }

  .steps {
    list-style: none;
    padding: 0;
    margin: 0 0 24px 0;
    counter-reset: step;
  }

  .steps li {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    padding: 8px 0 8px 32px;
    position: relative;
    counter-increment: step;
  }

  .steps li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    width: 22px;
    height: 22px;
    background: rgba(99, 102, 241, 0.2);
    color: #6366f1;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .btn-platform {
    width: 100%;
    padding: 12px 20px;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.3);
    color: #6366f1;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-platform:hover {
    background: rgba(99, 102, 241, 0.2);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .feature-card {
    padding: 28px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
  }

  .feature-icon {
    width: 56px;
    height: 56px;
    background: rgba(99, 102, 241, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6366f1;
    margin-bottom: 16px;
  }

  .feature-card h4 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .feature-card p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
  }

  .module-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 28px 20px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    text-decoration: none;
    color: white;
    transition: all 0.3s ease;
  }

  .module-card:hover {
    background: rgba(99, 102, 241, 0.1);
    border-color: #6366f1;
    transform: translateY(-4px);
  }

  .module-icon {
    font-size: 1.1rem;
    font-weight: 700;
    color: #6366f1;
    margin-bottom: 8px;
  }

  .module-card p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
    text-align: center;
  }

  .final-cta {
    padding: 100px 24px;
    text-align: center;
    background: linear-gradient(to bottom, transparent, rgba(99, 102, 241, 0.1));
  }

  .final-cta h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 16px;
  }

  .final-cta p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.1rem;
    margin-bottom: 32px;
  }

  @media (max-width: 768px) {
    .download-hero {
      padding: 80px 20px 60px;
    }

    .platforms, .features, .modules {
      padding: 60px 20px;
    }

    .section-header {
      margin-bottom: 40px;
    }
  }
</style>
