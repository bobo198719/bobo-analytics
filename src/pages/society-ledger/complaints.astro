---
import SocietyLedgerLayout from "../../layouts/SocietyLedgerLayout.astro";

// Mock Complaints Data
const complaints = [
  { id: "CMP-401", flat: "A-102", category: "Plumbing", subject: "Water leakage in kitchen", priority: "High", date: "Today", status: "Open" },
  { id: "CMP-402", flat: "B-201", category: "Electrical", subject: "Common area light flickering", priority: "Medium", date: "Yesterday", status: "In-Progress" },
  { id: "CMP-403", flat: "C-105", category: "Lift", subject: "Lift B making grinding noise", priority: "Critical", date: "Today", status: "Open" },
  { id: "CMP-399", flat: "A-502", category: "Security", subject: "Late night noise from A-501", priority: "Low", date: "2 days ago", status: "Resolved" }
];
---

<SocietyLedgerLayout title="Complaint Hub | Society Ledger OS">
  <div class="flex justify-between items-end mb-10">
      <div>
          <h1 class="text-4xl font-black italic tracking-tighter uppercase leading-none mb-2">Complaint <span class="text-amber-600">Resolution Hub</span></h1>
          <p class="text-slate-400 text-[10px] font-black uppercase tracking-[0.2em] italic">Manage resident grievances and infrastructure maintenance tickets.</p>
      </div>
      <button class="bg-amber-600 text-white px-8 py-4 rounded-3xl text-[10px] font-black uppercase tracking-widest italic shadow-lg shadow-amber-600/20 hover:scale-105 transition-all">
          + File New Grievance
      </button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <div class="p-8 bg-white border border-slate-200 rounded-[32px] shadow-sm flex flex-col gap-4">
          <div class="w-12 h-12 bg-rose-50 text-rose-500 rounded-2xl flex items-center justify-center text-xl">⚠️</div>
          <div>
              <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-1">Open Tickets</span>
              <span class="text-3xl font-black italic tracking-tighter text-slate-900 leading-none">08</span>
          </div>
      </div>
      <div class="p-8 bg-white border border-slate-200 rounded-[32px] shadow-sm flex flex-col gap-4">
          <div class="w-12 h-12 bg-amber-50 text-amber-500 rounded-2xl flex items-center justify-center text-xl">⚙️</div>
          <div>
              <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-1">In-Progress</span>
              <span class="text-3xl font-black italic tracking-tighter text-slate-900 leading-none">03</span>
          </div>
      </div>
      <div class="p-8 bg-white border border-slate-200 rounded-[32px] shadow-sm flex flex-col gap-4">
          <div class="w-12 h-12 bg-emerald-50 text-emerald-500 rounded-2xl flex items-center justify-center text-xl">✅</div>
          <div>
              <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-1">Resolved (7 Days)</span>
              <span class="text-3xl font-black italic tracking-tighter text-slate-900 leading-none">24</span>
          </div>
      </div>
  </div>

  <div class="glass-card bg-white border border-slate-200 rounded-[40px] overflow-hidden shadow-sm">
      <table class="w-full text-left border-collapse">
          <thead>
              <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400">Node ID</th>
                  <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400">Resident / Flat</th>
                  <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400">Grievance Node</th>
                  <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400">Priority Level</th>
                  <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400">Sync Status</th>
                  <th class="p-8 text-right text-[10px] font-black uppercase tracking-widest text-slate-400">Action</th>
              </tr>
          </thead>
          <tbody>
              {complaints.map(c => (
                  <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors">
                      <td class="p-8 font-mono font-bold text-xs text-slate-300 italic">{c.id}</td>
                      <td class="p-8">
                          <div class="flex flex-col">
                              <span class="text-xs font-black text-slate-900 italic uppercase leading-none mb-1">Flat {c.flat}</span>
                              <span class="text-[8px] text-slate-400 font-black tracking-widest uppercase">Logged: {c.date}</span>
                          </div>
                      </td>
                      <td class="p-8">
                          <div class="flex flex-col">
                              <span class="text-[9px] font-black text-amber-600 uppercase tracking-[0.2em] italic mb-1">{c.category}</span>
                              <span class="text-sm font-bold text-slate-600 italic leading-snug">{c.subject}</span>
                          </div>
                      </td>
                      <td class="p-8">
                          <span class={`text-[8px] font-black uppercase tracking-[0.2em] px-3 py-1 rounded-full ${c.priority === 'Critical' ? 'bg-rose-500 text-white shadow-lg shadow-rose-500/20' : (c.priority === 'High' ? 'bg-orange-100 text-orange-600' : 'bg-slate-100 text-slate-400')}`}>
                              {c.priority}
                          </span>
                      </td>
                      <td class="p-8">
                          <div class="flex items-center gap-2">
                              <div class={`w-2 h-2 rounded-full ${c.status === 'Open' ? 'bg-rose-500 animate-pulse' : (c.status === 'In-Progress' ? 'bg-amber-500' : 'bg-emerald-500')}`}></div>
                              <span class="text-[10px] font-black uppercase tracking-widest text-slate-600 italic">{c.status}</span>
                          </div>
                      </td>
                      <td class="p-8 text-right">
                          <button class="bg-slate-900 text-white px-5 py-2 rounded-xl text-[8px] font-black uppercase tracking-widest italic hover:bg-emerald-600 transition-all">Assign Node</button>
                      </td>
                  </tr>
              ))}
          </tbody>
      </table>
  </div>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css">
</SocietyLedgerLayout>
