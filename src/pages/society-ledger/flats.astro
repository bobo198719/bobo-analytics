---
import SocietyLedgerLayout from "../../layouts/SocietyLedgerLayout.astro";

// Mock Residents Data
const residents = [
  { flat: "A-101", name: "Anish Kumar", phone: "+91 98765 43210", family: 4, type: "Owner", vehicle: "KA-01-MH-1234" },
  { flat: "A-102", name: "Rahul Sharma", phone: "+91 98222 11111", family: 3, type: "Tenant", vehicle: "DL-02-AB-5678" },
  { flat: "B-201", name: "Sita Ram", phone: "+91 91111 22222", family: 2, type: "Owner", vehicle: "MH-12-XY-9012" },
  { flat: "B-205", name: "Deepak Jha", phone: "+91 98888 77777", family: 5, type: "Owner", vehicle: "TS-09-PJ-4455" },
  { flat: "C-301", name: "Meera Nair", phone: "+91 90000 33333", family: 4, type: "Tenant", vehicle: "HR-26-CD-1122" }
];
---

<SocietyLedgerLayout title="Resident Management | Society Ledger OS">
  <div class="flex justify-between items-end mb-10">
      <div>
          <h1 class="text-4xl font-black italic tracking-tighter uppercase leading-none mb-2 text-black">Resident <span class="text-amber-800">Database</span></h1>
          <p class="text-black text-[10px] font-black uppercase tracking-[0.2em] italic">Manage owners, tenants, and occupancy nodes.</p>
      </div>
      <button class="bg-black text-white px-8 py-4 rounded-3xl text-[10px] font-black uppercase tracking-widest italic shadow-lg border-2 border-black hover:bg-slate-800 transition-all">
          + Onboard New Flat
      </button>
  </div>

  <div class="glass-card bg-white border border-slate-200 rounded-[32px] overflow-hidden shadow-sm">
      <table class="w-full text-left border-collapse">
          <thead>
              <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Flat ID</th>
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Resident Name</th>
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Contact Node</th>
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Node Type</th>
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Vehicle</th>
                  <th class="p-6 text-right text-[10px] font-black uppercase tracking-widest text-slate-400">Action</th>
              </tr>
          </thead>
          <tbody>
              {residents.map(r => (
                  <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors">
                      <td class="p-6">
                          <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-lg text-xs font-black italic border border-amber-200">{r.flat}</span>
                      </td>
                      <td class="p-6">
                          <div class="flex items-center gap-3">
                              <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center font-black text-[10px] text-slate-600 uppercase">{r.name[0]}</div>
                              <span class="text-sm font-bold text-slate-900">{r.name}</span>
                          </div>
                      </td>
                      <td class="p-6 text-xs font-semibold text-slate-500">{r.phone}</td>
                      <td class="p-6">
                          <span class={`text-[9px] font-black uppercase tracking-widest px-3 py-1 rounded-full ${r.type === 'Owner' ? 'bg-emerald-100 text-emerald-700' : 'bg-blue-100 text-blue-700'}`}>
                              {r.type}
                          </span>
                      </td>
                      <td class="p-6 text-xs font-mono font-bold text-slate-400">{r.vehicle}</td>
                      <td class="p-6 text-right">
                          <button class="text-slate-400 hover:text-amber-600 transition-colors"><i class="lucide-more-horizontal"></i></button>
                      </td>
                  </tr>
              ))}
          </tbody>
      </table>
  </div>
</SocietyLedgerLayout>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css">
