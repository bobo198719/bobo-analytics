---
import SocietyLedgerLayout from "../../layouts/SocietyLedgerLayout.astro";

// Mock Report Data
const reports = [
  { id: "REP-901", flat: "A-502", title: "Maintenance_Receipt_May26.pdf", size: "1.2 MB", type: "Receipt", date: "Today" },
  { id: "REP-902", flat: "B-201", title: "Maintenance_Receipt_May26.pdf", size: "1.1 MB", type: "Receipt", date: "Yesterday" },
  { id: "REP-903", flat: "ALL", title: "Monthly_Financial_Summary_May26.pdf", size: "4.5 MB", type: "Audit", date: "Today" },
  { id: "REP-899", flat: "C-105", title: "Maintenance_Receipt_Apr26.pdf", size: "1.2 MB", type: "Receipt", date: "1 week ago" }
];
---

<SocietyLedgerLayout title="PDF Reports & Receipts | Society Ledger OS">
  <div class="flex justify-between items-end mb-10">
      <div>
          <h1 class="text-4xl font-black italic tracking-tighter uppercase leading-none mb-2">Node <span class="text-amber-600">Reporting Engine</span></h1>
          <p class="text-slate-400 text-[10px] font-black uppercase tracking-[0.2em] italic">Automated PDF generation for maintenance receipts and ledger audits.</p>
      </div>
      <div class="flex gap-4">
          <button class="bg-slate-900 text-white px-8 py-4 rounded-3xl text-[10px] font-black uppercase tracking-widest italic shadow-lg shadow-slate-900/20 hover:scale-105 transition-all">
              Generate Audit Node
          </button>
          <button class="bg-amber-600 text-white px-8 py-4 rounded-3xl text-[10px] font-black uppercase tracking-widest italic shadow-lg shadow-amber-600/20 hover:scale-105 transition-all">
              + New Batch Receipt
          </button>
      </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      <div class="glass-card bg-white p-8 border border-slate-200 rounded-[32px] flex items-center gap-6 group hover:border-amber-500/30 transition-all cursor-pointer">
          <div class="text-3xl text-amber-500 group-hover:scale-110 transition-transform">📄</div>
          <div>
              <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest block">May Receipts</span>
              <span class="text-lg font-black italic text-slate-900 leading-none">98 / 120</span>
          </div>
      </div>
      <div class="glass-card bg-white p-8 border border-slate-200 rounded-[32px] flex items-center gap-6 group hover:border-emerald-500/30 transition-all cursor-pointer">
          <div class="text-3xl text-emerald-500 group-hover:scale-110 transition-transform">📊</div>
          <div>
              <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest block">Ledger Sync</span>
              <span class="text-lg font-black italic text-slate-900 leading-none">100% Secure</span>
          </div>
      </div>
      <div class="glass-card bg-white p-8 border border-slate-200 rounded-[32px] flex items-center gap-6 group hover:border-indigo-500/30 transition-all cursor-pointer">
          <div class="text-3xl text-indigo-500 group-hover:scale-110 transition-transform">🖨️</div>
          <div>
              <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest block">Printer Node</span>
              <span class="text-lg font-black italic text-slate-900 leading-none">Online</span>
          </div>
      </div>
      <div class="glass-card bg-white p-8 border border-slate-200 rounded-[32px] flex items-center gap-6 group hover:border-rose-500/30 transition-all cursor-pointer">
          <div class="text-3xl text-rose-500 group-hover:scale-110 transition-transform">☁️</div>
          <div>
              <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest block">Cloud Export</span>
              <span class="text-lg font-black italic text-slate-900 leading-none">Auto-Save</span>
          </div>
      </div>
  </div>

  <div class="glass-card bg-white border border-slate-200 rounded-[40px] overflow-hidden shadow-sm">
      <table class="w-full text-left border-collapse">
          <thead>
              <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400">Node ID</th>
                  <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400">Document Node</th>
                  <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400">Flat Targeting</th>
                  <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400">Node Type</th>
                  <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400">Sync Date</th>
                  <th class="p-8 text-right text-[10px] font-black uppercase tracking-widest text-slate-400">Action</th>
              </tr>
          </thead>
          <tbody>
              {reports.map(r => (
                  <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors">
                      <td class="p-8 font-mono font-bold text-xs text-slate-300 italic">{r.id}</td>
                      <td class="p-8">
                          <div class="flex items-center gap-4">
                              <i class="lucide-file-text text-amber-600"></i>
                              <div class="flex flex-col">
                                  <span class="text-[11px] font-bold text-slate-900 italic tracking-tight italic leading-none mb-1">{r.title}</span>
                                  <span class="text-[8px] text-slate-400 font-black tracking-widest uppercase">{r.size}</span>
                              </div>
                          </div>
                      </td>
                      <td class="p-8">
                          <span class="bg-slate-900 text-white px-3 py-1 rounded-lg text-[9px] font-black italic uppercase tracking-widest border border-white/10 group-hover:bg-amber-600 transition-all">{r.flat}</span>
                      </td>
                      <td class="p-8">
                         <span class={`text-[8px] font-black uppercase tracking-[0.2em] px-2 py-1 rounded-full ${r.type === 'Audit' ? 'bg-indigo-100 text-indigo-700' : 'bg-amber-100 text-amber-700'}`}>
                             {r.type}
                         </span>
                      </td>
                      <td class="p-8 text-[9px] font-black uppercase text-slate-400 tracking-widest italic">{r.date}</td>
                      <td class="p-8 text-right">
                          <div class="flex justify-end gap-3">
                              <button class="bg-slate-50 border border-slate-100 text-slate-500 p-2 rounded-xl hover:bg-white hover:text-amber-600 transition-all hover:shadow-sm"><i class="lucide-download"></i></button>
                              <button class="bg-slate-50 border border-slate-100 text-slate-500 p-2 rounded-xl hover:bg-white hover:text-emerald-600 transition-all hover:shadow-sm"><i class="lucide-printer"></i></button>
                              <button class="bg-slate-50 border border-slate-100 text-slate-500 p-2 rounded-xl hover:bg-white hover:text-rose-600 transition-all hover:shadow-sm"><i class="lucide-share-2"></i></button>
                          </div>
                      </td>
                  </tr>
              ))}
          </tbody>
      </table>
  </div>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css">
</SocietyLedgerLayout>
