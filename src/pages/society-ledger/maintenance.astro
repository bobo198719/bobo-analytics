---
import SocietyLedgerLayout from "../../layouts/SocietyLedgerLayout.astro";

// Mock Bill Data
const bills = [
  { flat: "A-101", billId: "#BILL-5561", amount: "₹2,500", status: "Paid", date: "May 01", pendingMonths: 0 },
  { flat: "A-102", billId: "#BILL-5562", amount: "₹2,500", status: "Overdue", date: "May 01", pendingMonths: 3 },
  { flat: "B-201", billId: "#BILL-5563", amount: "₹3,200", status: "Paid", date: "May 02", pendingMonths: 0 },
  { flat: "B-205", billId: "#BILL-5564", amount: "₹2,500", status: "Pending", date: "May 02", pendingMonths: 1 },
  { flat: "C-301", billId: "#BILL-5565", amount: "₹2,800", status: "Overdue", date: "May 03", pendingMonths: 5 }
];
---

<SocietyLedgerLayout title="Maintenance Billing | Society Ledger OS">
  <div class="flex justify-between items-end mb-10">
      <div>
          <h1 class="text-4xl font-black italic tracking-tighter uppercase leading-none mb-2 text-black">Maintenance <span class="text-amber-800">Billing Node</span></h1>
          <p class="text-black text-[10px] font-black uppercase tracking-[0.2em] italic">Automated monthly billing and resident collection tracking.</p>
      </div>
      <div class="flex gap-4">
          <select id="statusFilter" class="bg-white border-2 border-black rounded-3xl px-6 py-3 text-[10px] font-black uppercase tracking-widest italic outline-none cursor-pointer">
              <option value="all">All Records</option>
              <option value="Paid">Show Paid Only</option>
              <option value="Pending">Show Pending (1 Month)</option>
              <option value="Overdue">Show Defaulters (Critical)</option>
          </select>
          <button class="bg-black text-white px-8 py-4 rounded-3xl text-[10px] font-black uppercase tracking-widest italic shadow-lg border-2 border-black hover:bg-slate-800 transition-all">
              Generate Monthly Batch
          </button>
      </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
      <div class="p-8 bg-white border border-slate-200 rounded-[32px]">
          <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-1">Total Receivable</span>
          <span class="text-3xl font-black italic tracking-tighter text-slate-900 leading-none">₹2.45L</span>
      </div>
      <div class="p-8 bg-white border border-slate-200 rounded-[32px]">
          <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-1">Collected (May)</span>
          <span class="text-3xl font-black italic tracking-tighter text-emerald-600 leading-none">₹1.85L</span>
      </div>
      <div class="p-8 bg-white border border-slate-200 rounded-[32px]">
          <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-1">Pending Nodes</span>
          <span class="text-3xl font-black italic tracking-tighter text-amber-600 leading-none">22</span>
      </div>
      <div class="p-8 bg-white border border-slate-200 rounded-[32px]">
          <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-1">Defaulter Sum</span>
          <span class="text-3xl font-black italic tracking-tighter text-rose-600 leading-none">₹60.5K</span>
      </div>
  </div>

  <div class="glass-card bg-white border border-slate-200 rounded-[32px] overflow-hidden shadow-sm">
      <table class="w-full text-left border-collapse">
          <thead>
              <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Bill Node ID</th>
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Flat Target</th>
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Cycle Date</th>
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Base Amount</th>
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Pending Cycle</th>
                  <th class="p-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Sync Status</th>
                  <th class="p-6 text-right text-[10px] font-black uppercase tracking-widest text-slate-400">Action</th>
              </tr>
          </thead>
          <tbody>
               {bills.map(b => (
                  <tr class="bill-row border-b border-slate-50 hover:bg-slate-50 transition-colors" data-status={b.status}>
                      <td class="p-6 font-mono font-bold text-xs text-slate-400">{b.billId}</td>
                      <td class="p-6">
                          <span class="bg-slate-100 text-slate-700 px-3 py-1 rounded-lg text-xs font-black italic border border-slate-200">{b.flat}</span>
                      </td>
                      <td class="p-6 text-[10px] font-black uppercase text-slate-500 tracking-widest leading-none italic">{b.date}</td>
                      <td class="p-6 text-sm font-black italic text-slate-900 leading-none">{b.amount}</td>
                      <td class="p-6">
                          {b.pendingMonths > 0 ? (
                              <span class="text-[10px] font-black text-rose-600 bg-rose-50 px-2 py-1 rounded-lg">
                                  {b.pendingMonths} MOs Pending
                              </span>
                          ) : (
                              <span class="text-[10px] font-black text-emerald-600 bg-emerald-50 px-2 py-1 rounded-lg">
                                  Current
                              </span>
                          )}
                      </td>
                      <td class="p-6">
                          <span class={`text-[9px] font-black uppercase tracking-widest px-3 py-1 rounded-full text-white border-2 border-black`} style={`background-color: ${b.status === 'Paid' ? '#059669' : b.status === 'Pending' ? '#d97706' : '#ef4444'}`}>
                              {b.status === 'Overdue' ? 'Defaulter' : b.status}
                          </span>
                      </td>
                      <td class="p-6 text-right">
                          <button class="text-slate-400 hover:text-amber-600 transition-colors mr-4"><i class="lucide-printer"></i></button>
                      </td>
                  </tr>
              ))}
          </tbody>
      </table>
  </div>
</SocietyLedgerLayout>

<script is:inline>
  document.getElementById('statusFilter')?.addEventListener('change', (e) => {
      const status = e.target.value;
      const rows = document.querySelectorAll('.bill-row');
      
      rows.forEach(row => {
          if (status === 'all') {
              row.style.display = 'table-row';
          } else {
              row.style.display = row.getAttribute('data-status') === status ? 'table-row' : 'none';
          }
      });
  });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css">

