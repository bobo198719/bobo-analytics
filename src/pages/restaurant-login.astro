---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/restaurant.css";
---

<MainLayout title="Restaurant CRM Login | Bobo Analytics" hideNav={true}>
  <div class="auth-page bg-[#05081a] min-h-screen flex items-center justify-center p-6 relative font-['Plus_Jakarta_Sans']">
    <div class="absolute inset-0 pointer-events-none opacity-20">
       <div class="absolute top-0 left-0 w-[800px] h-[800px] bg-orange-500/10 blur-[150px] -ml-96 -mt-96 animate-pulse"></div>
    </div>

    <div class="login-card max-w-lg w-full bg-white/5 border border-white/10 p-12 md:p-16 rounded-[64px] shadow-2xl backdrop-blur-xl relative z-10 group transition-all hover:bg-white/[0.08]">
       <div class="text-center mb-12">
          <div class="w-20 h-20 bg-gradient-to-br from-orange-400 to-rose-600 rounded-3xl flex items-center justify-center text-4xl mx-auto mb-8 shadow-2xl shadow-orange-500/20 group-hover:scale-110 group-hover:rotate-3 transition-transform">🍽️</div>
          <h1 class="text-4xl font-black italic text-white uppercase tracking-tighter">Restaurant CRM Login</h1>
          <p class="text-white/40 text-[10px] font-black uppercase tracking-[0.3em] mt-2">Authenticated Cloud Terminal | Provisioned v4.0</p>
       </div>

       <form id="restaurantLoginForm" class="space-y-8">
          <div class="space-y-3">
             <label class="text-[10px] font-black uppercase text-white/30 tracking-[0.2em] ml-2 italic">Admin Identifier</label>
             <input type="text" id="adminId" placeholder="e.g. rest_admin" required class="w-full bg-[#05081a]/80 border border-white/10 p-5 rounded-2xl outline-none focus:border-orange-500 transition-all font-black" />
          </div>
          <div class="space-y-3">
             <label class="text-[10px] font-black uppercase text-white/30 tracking-[0.2em] ml-2 italic">Security Key</label>
             <input type="password" id="password" placeholder="••••••••" required class="w-full bg-[#05081a]/80 border border-white/10 p-5 rounded-2xl outline-none focus:border-orange-500 transition-all font-black" />
          </div>

          <div id="errorBox" class="text-rose-500 text-xs font-black uppercase tracking-widest text-center min-h-[1rem]"></div>

          <button type="submit" class="w-full py-6 bg-gradient-to-r from-orange-500 to-rose-600 rounded-3xl text-white font-black italic uppercase tracking-[0.2em] text-sm shadow-2xl shadow-orange-500/20 hover:scale-[1.02] active:scale-95 transition-all">
             Enter Restaurant Dashboard
          </button>
       </form>

       <footer class="mt-12 text-center">
          <a href="/crm-login" class="text-white/20 hover:text-white font-bold text-xs transition-colors italic uppercase tracking-widest">Abort & Exit Terminal</a>
       </footer>
    </div>
  </div>

  <script is:inline>
    const form = document.getElementById("restaurantLoginForm");
    const errorBox = document.getElementById("errorBox");

    form.onsubmit = async (e) => {
       e.preventDefault();
       const id = document.getElementById("adminId").value.trim();
       const pass = document.getElementById("password").value.trim();

       // Hardcoded as per USER_REQUEST Rule
       if (id === 'rest_admin' && pass === 'password123') {
          errorBox.innerText = "Provisioning Master Dashboard...";
          errorBox.style.color = "#10b981";
          
          // Fake Auth Persistence
          localStorage.setItem('restaurant_auth', 'true');
          
          setTimeout(() => {
             window.location.href = "/restaurant-dashboard";
          }, 800);
       } else {
          errorBox.innerText = "Invalid credentials";
          errorBox.style.color = "#f43f5e";
          
          // Animation shake
          form.style.animation = "shake 0.4s ease";
          setTimeout(() => form.style.animation = "", 400);
       }
    };
  </script>

  <style is:global>
    @keyframes shake {
       0%, 100% { transform: translateX(0); }
       25% { transform: translateX(-8px); }
       75% { transform: translateX(8px); }
    }
  </style>
</MainLayout>
