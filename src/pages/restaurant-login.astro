---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Restaurant CRM Login | Bobo Analytics">
  <div class="auth-page px-6">
    <div class="login-card max-w-md w-full relative group">
      <div class="absolute -top-10 -left-10 w-32 h-32 bg-orange-500 rounded-full blur-[80px] opacity-20 group-hover:opacity-30 transition-opacity"></div>
      
      <div class="brand text-center relative z-10">
        <div class="logo-orb mx-auto bg-gradient-to-br from-orange-400 to-rose-600 shadow-2xl shadow-orange-500/20">🍽️</div>
        <h1 class="text-3xl font-black italic mt-6 uppercase tracking-tight">Restaurant CRM</h1>
        <p class="text-white/40 text-xs font-bold uppercase tracking-widest mt-2">Gastronomy Management Engine</p>
      </div>

      <div class="auth-status mt-8" id="authStatus"></div>

      <form class="auth-form mt-8 space-y-6 relative z-10" id="loginForm">
        <div class="input-group">
          <label class="text-[10px] font-black uppercase text-white/30 tracking-widest block mb-3">Kitchen/Admin ID</label>
          <input 
            type="text" 
            id="username" 
            placeholder="e.g. rest_admin" 
            required 
            class="w-full bg-white/5 border border-white/10 p-5 rounded-2xl outline-none focus:border-orange-500 focus:bg-white/[0.08] transition-all text-sm font-bold placeholder:text-white/10"
          />
        </div>
        <div class="input-group">
          <label class="text-[10px] font-black uppercase text-white/30 tracking-widest block mb-3">Security Key</label>
          <input 
            type="password" 
            id="password" 
            placeholder="••••••••" 
            required 
            class="w-full bg-white/5 border border-white/10 p-5 rounded-2xl outline-none focus:border-orange-500 focus:bg-white/[0.08] transition-all text-sm font-bold placeholder:text-white/10"
          />
        </div>

        <button type="submit" class="w-full bg-gradient-to-r from-orange-500 to-rose-600 py-5 rounded-3xl font-black italic uppercase tracking-widest text-sm shadow-2xl shadow-orange-500/20 hover:scale-[1.02] active:scale-95 transition-all">
          Launch Intelligence
        </button>
      </form>

      <div class="auth-footer mt-10 text-center opacity-40 text-[10px] font-black uppercase tracking-widest">
          <a href="/crm-login" class="hover:text-orange-500 transition-colors">← Back to Portal Selection</a>
      </div>
    </div>
  </div>

  <style>
    .auth-page {
      min-height: 90vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: radial-gradient(circle at top left, rgba(249, 115, 22, 0.05), transparent),
                  radial-gradient(circle at bottom right, rgba(225, 29, 72, 0.05), transparent);
    }

    .login-card {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 48px;
      padding: 56px;
      backdrop-filter: blur(40px);
      box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.8);
    }

    .logo-orb {
      width: 80px;
      height: 80px;
      border-radius: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.2rem;
    }

    .error-msg {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      padding: 16px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 800;
      text-align: center;
      border: 1px solid rgba(239, 68, 68, 0.2);
    }
  </style>

  <script is:inline>
    const form = document.getElementById('loginForm');
    const authStatus = document.getElementById('authStatus');

    form.onsubmit = async (e) => {
      e.preventDefault();
      const user = document.getElementById('username').value.trim();
      const pass = document.getElementById('password').value.trim();
      
      authStatus.innerHTML = '<div class="text-[10px] font-black uppercase tracking-widest text-orange-500 text-center animate-pulse">Establishing Secure Uplink...</div>';

      try {
        const res = await fetch("/api/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ 
            username: user, 
            password: pass, 
            industry: 'restaurant' 
          })
        });
        
        const data = await res.json();
        
        if (res.ok) {
           authStatus.innerHTML = '<div class="text-[10px] font-black uppercase tracking-widest text-emerald-500 text-center">Auth Success. Provisioning OS Environment...</div>';
           localStorage.setItem('user', JSON.stringify(data.user));
           setTimeout(() => {
              window.location.href = '/restaurant-os';
           }, 1000);
        } else {
           authStatus.innerHTML = `<div class="error-msg">${data.message || 'Unauthorized Terminal Access.'}</div>`;
        }
      } catch (err) {
        authStatus.innerHTML = '<div class="error-msg">Network Isolation: Master Core Unreachable.</div>';
      }
    };
  </script>
</MainLayout>
