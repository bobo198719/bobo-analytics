---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/restaurant.css";
---

<MainLayout title="Grocery OS Login | Bobo Analytics" hideNav={true}>
  <div class="auth-page min-h-screen flex items-center justify-center p-6 relative font-['Plus_Jakarta_Sans'] text-white" style="background: url('/images/grocery-bg.png') no-repeat center center; background-size: cover;">
    
    <!-- Dark Theme Overlay -->
    <div class="absolute inset-0 bg-[#05081a]/75 backdrop-blur-[2px] pointer-events-none z-[0]"></div>
    
    <!-- Ambient Background Lighting -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden z-[1]">
       <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-emerald-600/20 rounded-full blur-[120px] -mr-64 -mt-64"></div>
       <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-green-400/10 rounded-full blur-[120px] -ml-64 -mb-64"></div>
    </div>

    <!-- Login Card -->
    <div class="login-card max-w-lg w-full bg-white/5 border border-white/10 p-12 md:p-16 rounded-[64px] shadow-2xl backdrop-blur-3xl relative z-10 group transition-all hover:bg-white/[0.08] hover:border-emerald-500/30 overflow-hidden">
       <!-- Glow Element -->
       <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 blur-[60px] -z-10 group-hover:bg-emerald-500/20 transition-all"></div>
       
       <div class="text-center mb-12">
          <div class="w-24 h-24 bg-gradient-to-br from-emerald-400 to-green-600 rounded-3xl flex items-center justify-center text-5xl mx-auto mb-8 shadow-2xl shadow-emerald-500/30 group-hover:scale-110 group-hover:rotate-3 transition-transform italic border border-white/10">B</div>
          <h1 class="text-3xl md:text-4xl font-black italic text-white uppercase tracking-tighter leading-none">Grocery <br /><span class="bg-gradient-to-r from-emerald-400 to-green-500 bg-clip-text text-transparent">Intelligence</span></h1>
          <p class="text-white/40 text-[10px] font-black uppercase tracking-[0.4em] mt-4 italic">Provisioned Node v8.4.1 | Secure Cloud</p>
       </div>

       <form id="loginForm" class="space-y-8">
          <div class="space-y-3">
             <label class="text-[10px] font-black uppercase text-white/30 tracking-[0.2em] ml-4 italic">Store ID / Terminal ID</label>
             <div class="relative">
                <i class="lucide-layout absolute left-5 top-1/2 -translate-y-1/2 text-white/20 text-xs"></i>
                <input type="text" id="storeId" placeholder="MAIN-STORE-01" required class="w-full bg-white/5 border border-white/10 p-5 pl-12 rounded-2xl outline-none focus:border-emerald-400 transition-all font-black text-xs uppercase" />
             </div>
          </div>
          <div class="space-y-3">
             <label class="text-[10px] font-black uppercase text-white/30 tracking-[0.2em] ml-4 italic">Operator Key</label>
             <div class="relative">
                <i class="lucide-lock absolute left-5 top-1/2 -translate-y-1/2 text-white/20 text-xs"></i>
                <input type="password" id="password" placeholder="••••••••" required class="w-full bg-white/5 border border-white/10 p-5 pl-12 rounded-2xl outline-none focus:border-emerald-400 transition-all font-black text-xs" />
             </div>
          </div>

          <div id="auth-status" class="text-rose-500 text-[10px] font-black uppercase tracking-widest text-center min-h-[1rem] italic"></div>

          <button type="submit" class="w-full py-6 bg-gradient-to-r from-emerald-500 to-green-600 rounded-3xl text-white font-black italic uppercase tracking-[0.3em] text-xs shadow-2xl shadow-emerald-600/30 hover:scale-[1.03] active:scale-95 transition-all">
             Launch Grocery OS
          </button>
       </form>

       <footer class="mt-12 text-center">
          <a href="/crm-login" class="text-white/10 hover:text-white font-black text-[8px] transition-colors italic uppercase tracking-[0.4em]">Abort Secure Handshake</a>
       </footer>
    </div>
  </div>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap');
    
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #05081a; margin: 0; }

    .shake { animation: shake 0.4s ease; }
    @keyframes shake {
       0%, 100% { transform: translateX(0); }
       25% { transform: translateX(-8px); }
       75% { transform: translateX(8px); }
    }
  </style>

  <!-- Lucide Icon Support -->
  <link rel="stylesheet" href="https://unpkg.com/lucide-static@latest/font/lucide.css">

  <script is:inline>
    const loginForm = document.getElementById('loginForm');
    const authStatus = document.getElementById('auth-status');

    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const storeId = document.getElementById('storeId').value;
      const pass = document.getElementById('password').value;
      
      authStatus.style.color = "#10b981"; // green
      authStatus.innerHTML = 'Validating Terminal...';

      try {
        const res = await fetch("/api/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ username: storeId, password: pass, industry: 'Grocery' })
        });
        const data = await res.json();
        
        if (res.ok) {
          localStorage.setItem('user', JSON.stringify(data.user));
          window.location.href = '/grocery-os';
        } else {
          authStatus.style.color = "#f43f5e"; // rose
          authStatus.innerHTML = data.message || 'Invalid Terminal ID or Key.';
          loginForm.classList.add('shake');
          setTimeout(() => loginForm.classList.remove('shake'), 400);
        }
      } catch (err) {
        authStatus.style.color = "#f43f5e";
        authStatus.innerHTML = 'Connection failed. Check terminal uplink.';
      }
    });
  </script>
</MainLayout>
