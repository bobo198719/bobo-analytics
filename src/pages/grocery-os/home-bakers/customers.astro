---
import GroceryOSLayout from "../../../layouts/GroceryOSLayout.astro";
import BakerSubNav from "../../../components/BakerSubNav.astro";

// Mock baker customers
const customers = [
  { id: 1, name: "Rahul Khanna", phone: "+91 99999 12345", email: "rahul@example.com", orders: 12, spent: "₹18,450", last: "2 days ago" },
  { id: 2, name: "Sneha Kapur", phone: "+91 88888 23456", email: "sneha@example.com", orders: 4, spent: "₹4,200", last: "1 week ago" },
  { id: 3, name: "Mohit Verma", phone: "+91 77777 34567", email: "mohit@example.com", orders: 8, spent: "₹12,800", last: "14 Mar 2024" },
  { id: 4, name: "Anjali Gupta", phone: "+91 66666 45678", email: "anjali@example.com", orders: 25, spent: "₹42,000", last: "Yesterday" }
];
---

<GroceryOSLayout title="Baker CRM | Bobo OS">
  <BakerSubNav active="customers" />
  <div class="header-flex">
      <div>
          <h1>Customer Database</h1>
          <p style="color: var(--text-muted);">Manage relationships and reward your loyal dessert lovers.</p>
      </div>
      <div class="hb-actions">
          <button class="hb-btn secondary">Broadcast WhatsApp</button>
          <button class="hb-btn primary">+ Add Lead</button>
      </div>
  </div>

  <div class="crm-stats grid-4">
      <div class="stat-card glass-card">
          <span class="sl">Total Customers</span>
          <span class="sv">184</span>
      </div>
      <div class="stat-card glass-card">
          <span class="sl">Repeat Rate</span>
          <span class="sv">72%</span>
      </div>
      <div class="stat-card glass-card">
          <span class="sl">High Value (VIP)</span>
          <span class="sv">42</span>
      </div>
      <div class="stat-card glass-card">
          <span class="sl">New this Month</span>
          <span class="sv">12</span>
      </div>
  </div>

  <div class="crm-table-card glass-card">
      <div class="table-header">
          <h3>Customer List</h3>
          <div class="table-tools">
              <input type="text" placeholder="Search customers..." />
              <button class="filter-btn">Filters</button>
          </div>
      </div>

      <table class="crm-table">
          <thead>
              <tr>
                  <th>Customer Name</th>
                  <th>Contact Info</th>
                  <th>Orders</th>
                  <th>Total Spent</th>
                  <th>Last Order</th>
                  <th>Engagement</th>
              </tr>
          </thead>
          <tbody>
              {customers.map(c => (
                  <tr>
                      <td>
                          <div class="c-info-cell">
                              <div class="c-avatar">{c.name[0]}</div>
                              <span class="c-name">{c.name}</span>
                          </div>
                      </td>
                      <td>
                          <div class="contact-cell">
                              <span class="c-phone">{c.phone}</span>
                              <span class="c-email">{c.email}</span>
                          </div>
                      </td>
                      <td><span class="o-count">{c.orders} Orders</span></td>
                      <td><span class="spent-val">{c.spent}</span></td>
                      <td><span class="last-val">{c.last}</span></td>
                      <td>
                          <div class="engage-actions">
                              <button class="e-btn wa" title="Quick WhatsApp">💬</button>
                              <button class="e-btn confirm" title="Update Status">🔔</button>
                              <button class="e-btn more">···</button>
                          </div>
                      </td>
                  </tr>
              ))}
          </tbody>
      </table>
  </div>

  <style>
      .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
      .hb-actions { display: flex; gap: 12px; }
      .hb-btn { padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; border: 1px solid var(--border); background: rgba(255,255,255,0.05); color: white; }
      .hb-btn.primary { background: #f472b6; border: none; }

      .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 32px; }
      .stat-card { padding: 24px; display: flex; flex-direction: column; gap: 8px; }
      .sl { font-size: 0.75rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; }
      .sv { font-size: 1.5rem; font-weight: 900; font-family: 'Outfit'; }

      .crm-table-card { padding: 32px; }
      .table-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
      .table-tools { display: flex; gap: 12px; }
      .table-tools input { background: rgba(255,255,255,0.05); border: 1px solid var(--border); padding: 10px 16px; border-radius: 10px; color: white; width: 240px; }
      .filter-btn { background: transparent; border: 1px solid var(--border); color: white; padding: 10px 16px; border-radius: 10px; font-weight: 700; cursor: pointer; }

      .crm-table { width: 100%; border-collapse: collapse; }
      .crm-table th { text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border); }
      .crm-table td { padding: 16px; border-bottom: 1px solid var(--border); font-size: 0.95rem; }

      .c-info-cell { display: flex; align-items: center; gap: 12px; }
      .c-avatar { width: 36px; height: 36px; background: rgba(244, 114, 182, 0.2); color: #f472b6; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.8rem; }
      .c-name { font-weight: 700; }

      .contact-cell { display: flex; flex-direction: column; gap: 2px; }
      .c-phone { font-weight: 600; font-size: 0.9rem; }
      .c-email { font-size: 0.75rem; color: var(--text-muted); }

      .o-count { font-weight: 700; color: #f472b6; font-size: 0.85rem; }
      .spent-val { font-weight: 800; font-family: 'Outfit'; }
      .last-val { font-size: 0.85rem; color: var(--text-muted); }

      .engage-actions { display: flex; gap: 8px; }
      .e-btn { width: 32px; height: 32px; border-radius: 8px; border: 1px solid var(--border); background: rgba(255,255,255,0.03); color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; }
      .e-btn.wa { color: #25d366; }
      .e-btn.confirm { color: #f472b6; }
  </style>
</GroceryOSLayout>
