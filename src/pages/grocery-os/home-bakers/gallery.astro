---
import GroceryOSLayout from "../../../layouts/GroceryOSLayout.astro";
import BakerSubNav from "../../../components/BakerSubNav.astro";

// Mock gallery items
const gallery = [
  { id: 1, name: "Celestial Wedding Cake", category: "Cakes", desc: "4-tier vanilla bean cake with gold leaf finish." },
  { id: 2, name: "Panda Themed Birthday", category: "Cakes", desc: "Cute fondant panda cake for kids." },
  { id: 3, name: "Galaxy Cupcake Set", category: "Cupcakes", desc: "Deep space colored buttercream with edible glitter." },
  { id: 4, name: "Rustic Chocolate Tart", category: "Pastries", desc: "70% dark chocolate ganache with hazelnut." },
  { id: 5, name: "Floral Brownie Box", category: "Brownies", desc: "Gooey brownies topped with edible flowers." },
  { id: 6, name: "Miniature Dessert Platter", category: "Dessert Boxes", desc: "Selection of 12 bite-sized treats." }
];
---

<GroceryOSLayout title="Baker Gallery | Bobo OS">
  <BakerSubNav active="gallery" />
  <div class="header-flex">
      <div>
          <h1>Baker Gallery</h1>
          <p style="color: var(--text-muted);">Showcase your best creations to potential clients.</p>
      </div>
      <div class="gallery-actions">
          <button class="hb-btn">+ Upload New Work</button>
      </div>
  </div>

  <div class="gallery-filters glass-card">
      <button class="g-filter active">All Works</button>
      <button class="g-filter">Wedding</button>
      <button class="g-filter">Birthdays</button>
      <button class="g-filter">Corporate</button>
      <button class="g-filter">Mini Desserts</button>
  </div>

  <div class="gallery-grid">
      {gallery.map(g => (
          <div class="gallery-card glass-card">
              <div class="g-img-box">
                  <div class="g-img-placeholder">🍰</div>
                  <span class="g-cat-tag">{g.category}</span>
                  <div class="g-overlay">
                      <button class="g-action-btn">View Large</button>
                      <button class="g-action-btn">Delete</button>
                  </div>
              </div>
              <div class="g-info">
                  <h3>{g.name}</h3>
                  <p>{g.desc}</p>
              </div>
          </div>
      ))}
  </div>

  <style>
      .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
      .hb-btn { background: #f472b6; border: none; color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; }

      .gallery-filters { display: flex; gap: 12px; padding: 16px; margin-bottom: 32px; overflow-x: auto; }
      .g-filter { background: transparent; border: 1px solid var(--border); color: var(--text-muted); padding: 8px 16px; border-radius: 10px; font-weight: 700; cursor: pointer; white-space: nowrap; }
      .g-filter.active { background: #f472b6; border-color: #f472b6; color: white; }

      .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
      .gallery-card { padding: 0; overflow: hidden; display: flex; flex-direction: column; transition: 0.3s; }
      .gallery-card:hover { transform: scale(1.02); border-color: #f472b6; }
      
      .g-img-box { height: 300px; background: rgba(244, 114, 182, 0.05); position: relative; display: flex; align-items: center; justify-content: center; font-size: 5rem; }
      .g-cat-tag { position: absolute; top: 16px; left: 16px; background: rgba(0,0,0,0.6); color: white; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; padding: 4px 12px; border-radius: 30px; backdrop-filter: blur(4px); }
      
      .g-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.5); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; opacity: 0; transition: 0.2s; }
      .gallery-card:hover .g-overlay { opacity: 1; }
      .g-action-btn { background: white; color: black; border: none; padding: 10px 20px; border-radius: 10px; font-weight: 700; font-size: 0.85rem; cursor: pointer; min-width: 120px; }
      .g-action-btn:last-child { background: #ef4444; color: white; }

      .g-info { padding: 24px; }
      .g-info h3 { font-family: 'Outfit'; margin-bottom: 8px; font-size: 1.25rem; }
      .g-info p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.5; }
  </style>
</GroceryOSLayout>
