---
import GroceryOSLayout from "../../../layouts/GroceryOSLayout.astro";
import BakerSubNav from "../../../components/BakerSubNav.astro";

// Mock data for Home Bakers Dashboard
const stats = [
  { label: "Total Orders", value: "1,248", change: "+12%", icon: "📦" },
  { label: "Orders Today", value: "18", change: "+5%", icon: "🔥" },
  { label: "Pending Orders", value: "42", change: "-2%", icon: "⏳" },
  { label: "Completed Orders", value: "1,188", change: "+15%", icon: "✅" },
  { label: "Monthly Revenue", value: "₹2,45,000", change: "+22%", icon: "💰" },
  { label: "Avg. Rating", value: "4.9", icon: "⭐" }
];

const topCakes = [
  { name: "Belgium Chocolate Truffle", sold: "245", revenue: "₹1,47,000", trend: "up" },
  { name: "Red Velvet Cheesecake", sold: "182", revenue: "₹91,000", trend: "up" },
  { name: "Blueberry Cupcake Box", sold: "156", revenue: "₹23,400", trend: "stable" },
  { name: "Gourmet Cookies Assorted", sold: "124", revenue: "₹18,600", trend: "down" }
];
---

<GroceryOSLayout title="Home Bakers Dashboard | Bobo OS">
  <BakerSubNav active="dashboard" />
  <div class="hb-header">
      <div>
          <span class="hb-badge">Home Bakers Module</span>
          <h1>Baker Intelligence Dashboard</h1>
          <p style="color: var(--text-muted);">Manage your home-based bakery business with AI-driven insights.</p>
      </div>
      <div class="hb-actions">
          <button class="hb-btn profile">View Public Profile</button>
          <button class="hb-btn primary">+ New Order</button>
      </div>
  </div>

  <!-- Stats Grid -->
  <div class="stats-grid">
      {stats.map(s => (
          <div class="stat-card glass-card">
              <div class="stat-icon">{s.icon}</div>
              <div class="stat-info">
                  <span class="stat-label">{s.label}</span>
                  <span class="stat-value">{s.value}</span>
                  {s.change && <span class={`stat-change ${s.change.startsWith('+') ? 'up' : 'down'}`}>{s.change} vs last month</span>}
              </div>
          </div>
      ))}
  </div>

  <div class="dashboard-content">
      <!-- Left: Charts & Trends -->
      <div class="charts-column">
          <div class="chart-card glass-card">
              <div class="chart-header">
                  <h3>Sales Trend (Last 7 Days)</h3>
                  <select class="chart-select">
                      <option>Daily</option>
                      <option>Weekly</option>
                  </select>
              </div>
              <div class="chart-mock">
                  <div class="bars">
                      {Array(7).fill(0).map((_, i) => <div class="bar" style={`height: ${Math.random() * 70 + 30}%`}></div>)}
                  </div>
                  <div class="labels">
                      <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                  </div>
              </div>
          </div>

          <div class="charts-row">
              <div class="chart-card glass-card half">
                  <h3>Top Selling Desserts</h3>
                  <div class="donut-mock">
                      <div class="donut-inner">
                          <span class="val">84%</span>
                          <span class="lab">Cakes</span>
                      </div>
                  </div>
                  <div class="legend">
                      <div class="leg-item"><span class="dot cakes"></span> Cakes (84%)</div>
                      <div class="leg-item"><span class="dot cookies"></span> Cookies (10%)</div>
                      <div class="leg-item"><span class="dot others"></span> Others (6%)</div>
                  </div>
              </div>

              <div class="chart-card glass-card half">
                  <h3>Repeat Orders</h3>
                  <div class="repeat-meter">
                      <div class="meter-bar">
                          <div class="meter-fill" style="width: 72%"></div>
                      </div>
                      <span class="repeat-val">72% Repeat Customers</span>
                  </div>
                  <p class="chart-desc">Your brand loyalty is strong. High repeat rate for Chocolate flavors.</p>
              </div>
          </div>
      </div>

      <!-- Right: Top Selling & Recent Activity -->
      <div class="activity-column">
          <div class="ranking-card glass-card">
              <h3>Top Selling Items</h3>
              <div class="ranking-list">
                  {topCakes.map(c => (
                      <div class="rank-item">
                          <div class="rank-info">
                              <span class="rank-name">{c.name}</span>
                              <span class="rank-meta">{c.sold} sold this month</span>
                          </div>
                          <div class="rank-stat">
                              <span class="rank-rev">{c.revenue}</span>
                              <span class={`rank-trend ${c.trend}`}>
                                  {c.trend === 'up' ? '↑' : c.trend === 'down' ? '↓' : '→'}
                              </span>
                          </div>
                      </div>
                  ))}
              </div>
          </div>

          <div class="recent-orders-card glass-card">
              <div class="card-header">
                  <h3>Live Orders</h3>
                  <a href="/grocery-os/home-bakers/orders" class="view-all">View All →</a>
              </div>
              <div class="order-mini-list">
                  <div class="order-mini-item">
                      <span class="om-id">#HB-1024</span>
                      <span class="om-name">Custom Birthday Cake</span>
                      <span class="om-status preparing">Preparing</span>
                  </div>
                  <div class="order-mini-item">
                      <span class="om-id">#HB-1025</span>
                      <span class="om-name">Box of 12 Cupcakes</span>
                      <span class="om-status ready">Ready</span>
                  </div>
                  <div class="order-mini-item">
                      <span class="om-id">#HB-1026</span>
                      <span class="om-name">Dark Chocolate Cookies</span>
                      <span class="om-status new">New</span>
                  </div>
              </div>
          </div>
      </div>
  </div>

  <style>
      .hb-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
      .hb-badge { background: rgba(244, 114, 182, 0.1); color: #f472b6; padding: 4px 12px; border-radius: 30px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px; display: inline-block; }
      .hb-actions { display: flex; gap: 12px; }
      .hb-btn { padding: 10px 20px; border-radius: 12px; font-weight: 700; cursor: pointer; transition: 0.2s; border: 1px solid var(--border); background: rgba(255,255,255,0.05); color: white; }
      .hb-btn.primary { background: #f472b6; border: none; }
      .hb-btn:hover { transform: translateY(-2px); }

      .stats-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px; margin-bottom: 32px; }
      .stat-card { padding: 20px; display: flex; align-items: center; gap: 16px; }
      .stat-icon { font-size: 1.5rem; width: 44px; height: 44px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; border-radius: 10px; }
      .stat-info { display: flex; flex-direction: column; }
      .stat-label { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; }
      .stat-value { font-size: 1.1rem; font-weight: 800; font-family: 'Outfit'; }
      .stat-change { font-size: 0.65rem; font-weight: 700; }
      .stat-change.up { color: var(--success); }
      .stat-change.down { color: var(--error); }

      .dashboard-content { display: grid; grid-template-columns: 1fr 400px; gap: 32px; }
      
      .charts-column { display: flex; flex-direction: column; gap: 32px; }
      .chart-card { padding: 32px; }
      .chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
      .chart-select { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 4px 8px; border-radius: 8px; font-size: 0.8rem; }
      
      .chart-mock { height: 200px; display: flex; flex-direction: column; }
      .bars { flex: 1; display: flex; align-items: flex-end; gap: 12px; margin-bottom: 12px; }
      .bar { flex: 1; background: #f472b6; border-radius: 4px 4px 0 0; opacity: 0.7; transition: 0.3s; }
      .bar:hover { opacity: 1; background: #ec4899; }
      .labels { display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); }

      .charts-row { display: flex; gap: 24px; }
      .chart-card.half { flex: 1; }

      .donut-mock { width: 120px; height: 120px; border-radius: 50%; border: 12px solid #f472b6; border-left-color: #fb923c; border-bottom-color: #94a3b8; margin: 20px auto; display: flex; align-items: center; justify-content: center; }
      .donut-inner { text-align: center; }
      .donut-inner .val { display: block; font-weight: 800; font-size: 1.2rem; }
      .donut-inner .lab { font-size: 0.7rem; color: var(--text-muted); }

      .legend { display: flex; flex-direction: column; gap: 8px; font-size: 0.8rem; }
      .leg-item { display: flex; align-items: center; gap: 8px; }
      .dot { width: 8px; height: 8px; border-radius: 50%; }
      .dot.cakes { background: #f472b6; }
      .dot.cookies { background: #fb923c; }
      .dot.others { background: #94a3b8; }

      .repeat-meter { margin: 24px 0; }
      .meter-bar { height: 12px; background: rgba(255,255,255,0.05); border-radius: 10px; overflow: hidden; margin-bottom: 8px; }
      .meter-fill { height: 100%; background: linear-gradient(90deg, #f472b6, #ec4899); border-radius: 10px; }
      .repeat-val { font-weight: 700; font-size: 0.9rem; }
      .chart-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; }

      .activity-column { display: flex; flex-direction: column; gap: 32px; }
      .ranking-card { padding: 32px; }
      .ranking-list { display: flex; flex-direction: column; gap: 16px; margin-top: 24px; }
      .rank-item { display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
      .rank-info { display: flex; flex-direction: column; }
      .rank-name { font-weight: 700; font-size: 0.95rem; }
      .rank-meta { font-size: 0.75rem; color: var(--text-muted); }
      .rank-stat { display: flex; flex-direction: column; align-items: flex-end; }
      .rank-rev { font-weight: 800; font-family: 'Outfit'; font-size: 1rem; }
      .rank-trend { font-weight: 800; font-size: 0.8rem; }
      .rank-trend.up { color: var(--success); }
      .rank-trend.down { color: var(--error); }
      .rank-trend.stable { color: var(--text-muted); }

      .recent-orders-card { padding: 32px; }
      .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
      .view-all { font-size: 0.8rem; color: #f472b6; font-weight: 700; text-decoration: none; }
      .order-mini-list { display: flex; flex-direction: column; gap: 12px; }
      .order-mini-item { display: flex; align-items: center; gap: 12px; padding: 12px; background: rgba(255,255,255,0.03); border-radius: 10px; font-size: 0.85rem; }
      .om-id { font-weight: 800; color: #f472b6; opacity: 0.8; }
      .om-name { flex: 1; font-weight: 600; }
      .om-status { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; padding: 2px 8px; border-radius: 30px; }
      .om-status.preparing { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
      .om-status.ready { background: rgba(16, 185, 129, 0.1); color: #10b981; }
      .om-status.new { background: rgba(244, 114, 182, 0.1); color: #f472b6; }
  </style>
</GroceryOSLayout>
