---
import GroceryOSLayout from "../../../layouts/GroceryOSLayout.astro";
import BakerSubNav from "../../../components/BakerSubNav.astro";

// Mock baker orders
const orders = [
  { id: "#HB-1024", customer: "Rahul Khanna", phone: "+91 99999 12345", product: "Custom Birthday Cake (2kg)", qty: 1, date: "15 Mar 2024", status: "Preparing", payment: "Paid" },
  { id: "#HB-1025", customer: "Sneha Kapur", phone: "+91 88888 23456", product: "Vanilla Funfetti (Box of 6)", qty: 2, date: "12 Mar 2024", status: "Ready", payment: "Pending" },
  { id: "#HB-1026", customer: "Mohit Verma", phone: "+91 77777 34567", product: "Sea Salt Dark Brownies", qty: 1, date: "14 Mar 2024", status: "New", payment: "Paid" },
  { id: "#HB-1027", customer: "Anjali Gupta", phone: "+91 66666 45678", product: "Red Velvet Jar Cake", qty: 4, date: "10 Mar 2024", status: "Delivered", payment: "Paid" }
];
---

<GroceryOSLayout title="Bakers Order Management | Bobo OS">
  <BakerSubNav active="orders" />
  <div class="header-flex">
      <div>
          <h1>Bakes & Orders</h1>
          <p style="color: var(--text-muted);">Track custom requests and daily deliveries.</p>
      </div>
      <div class="order-tabs">
          <button class="o-tab active">Current</button>
          <button class="o-tab">Upcoming</button>
          <button class="o-tab">Past</button>
      </div>
  </div>

  <div class="orders-table-card glass-card">
      <div class="table-header-row">
          <div class="search-box">
              <input type="text" placeholder="Search by name, ID or phone..." />
          </div>
          <div class="filter-row">
              <select><option>Status: All</option></select>
              <select><option>Payment: All</option></select>
          </div>
      </div>

      <table class="hb-order-table">
          <thead>
              <tr>
                  <th>Order ID</th>
                  <th>Customer</th>
                  <th>Product Details</th>
                  <th>Delivery Date</th>
                  <th>Status</th>
                  <th>Payment</th>
                  <th>Actions</th>
              </tr>
          </thead>
          <tbody>
              {orders.map(o => (
                  <tr>
                      <td><span class="o-id">{o.id}</span></td>
                      <td>
                          <div class="customer-cell">
                              <span class="c-name">{o.customer}</span>
                              <span class="c-phone">{o.phone}</span>
                          </div>
                      </td>
                      <td>
                          <div class="product-cell">
                              <span class="p-name">{o.product}</span>
                              <span class="p-qty">Qty: {o.qty}</span>
                          </div>
                      </td>
                      <td><span class="o-date">{o.date}</span></td>
                      <td><span class={`o-status ${o.status.toLowerCase()}`}>{o.status}</span></td>
                      <td><span class={`o-payment ${o.payment.toLowerCase()}`}>{o.payment}</span></td>
                      <td>
                          <div class="action-cell">
                              <button class="a-btn wa" title="Message on WhatsApp">💬</button>
                              <button class="a-btn view">View Details</button>
                          </div>
                      </td>
                  </tr>
              ))}
          </tbody>
      </table>
  </div>

  <div class="custom-requests glass-card">
      <div class="cr-header">
          <h3>Custom Cake Requests (Unconfirmed)</h3>
          <span class="cr-count">3 New Requests</span>
      </div>
      <div class="cr-list">
          <div class="cr-item">
              <div class="cr-img-box">🎂</div>
              <div class="cr-info">
                  <h4>Spider-man Themed Cake</h4>
                  <p>Birthday for 5 year old • 2.5kg • Vanilla with Nutella Filling</p>
                  <span class="cr-meta">Request by: Vikram S. • Delivery: 20 Mar</span>
              </div>
              <div class="cr-actions">
                  <button class="cr-btn accept">Accept & Quote</button>
                  <button class="cr-btn reject">Reject</button>
              </div>
          </div>
      </div>
  </div>

  <style>
      .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
      .order-tabs { display: flex; background: rgba(255,255,255,0.05); padding: 6px; border-radius: 14px; gap: 4px; }
      .o-tab { background: transparent; border: none; color: var(--text-muted); padding: 8px 16px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; }
      .o-tab.active { background: #f472b6; color: white; }

      .orders-table-card { padding: 32px; margin-bottom: 32px; }
      .table-header-row { display: flex; justify-content: space-between; margin-bottom: 32px; }
      .search-box input { min-width: 300px; background: rgba(255,255,255,0.05); border: 1px solid var(--border); padding: 12px; border-radius: 12px; color: white; }
      .filter-row { display: flex; gap: 12px; }
      .filter-row select { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 10px; border-radius: 10px; font-weight: 600; }

      .hb-order-table { width: 100%; border-collapse: collapse; }
      .hb-order-table th { text-align: left; padding: 16px; font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--border); }
      .hb-order-table td { padding: 20px 16px; border-bottom: 1px solid var(--border); }

      .o-id { font-weight: 800; color: #f472b6; }
      .customer-cell, .product-cell { display: flex; flex-direction: column; gap: 4px; }
      .c-name, .p-name { font-weight: 700; font-size: 0.95rem; }
      .c-phone, .p-qty { font-size: 0.8rem; color: var(--text-muted); }
      .o-date { font-weight: 600; font-size: 0.9rem; }

      .o-status { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; padding: 4px 10px; border-radius: 30px; }
      .o-status.new { background: rgba(244, 114, 182, 0.1); color: #f472b6; }
      .o-status.preparing { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
      .o-status.ready { background: rgba(16, 185, 129, 0.1); color: #10b981; }
      .o-status.delivered { background: rgba(107, 114, 128, 0.1); color: #9ca3af; }

      .o-payment { font-size: 0.75rem; font-weight: 700; }
      .o-payment.paid { color: #10b981; }
      .o-payment.pending { color: #fb923c; }

      .action-cell { display: flex; gap: 8px; }
      .a-btn { padding: 8px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 700; cursor: pointer; border: 1px solid var(--border); background: rgba(255,255,255,0.05); color: white; }
      .a-btn.wa { color: #10b981; }

      .custom-requests { padding: 32px; }
      .cr-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
      .cr-count { background: #ef4444; color: white; padding: 4px 12px; border-radius: 30px; font-size: 0.75rem; font-weight: 800; }
      
      .cr-item { display: flex; align-items: center; gap: 24px; padding: 20px; background: rgba(255,255,255,0.02); border-radius: 16px; border: 1px solid var(--border); }
      .cr-img-box { width: 60px; height: 60px; background: rgba(244, 114, 182, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 2rem; }
      .cr-info { flex: 1; }
      .cr-info h4 { font-family: 'Outfit'; margin-bottom: 4px; }
      .cr-info p { font-size: 0.85rem; color: rgba(255,255,255,0.8); margin-bottom: 4px; }
      .cr-meta { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; }
      
      .cr-actions { display: flex; gap: 12px; }
      .cr-btn { padding: 10px 20px; border-radius: 10px; font-weight: 700; font-size: 0.85rem; cursor: pointer; }
      .cr-btn.accept { background: #f472b6; border: none; color: white; }
      .cr-btn.reject { background: transparent; border: 1px solid #ef4444; color: #ef4444; }
  </style>
</GroceryOSLayout>
