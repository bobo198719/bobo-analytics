---
import GroceryOSLayout from "../../layouts/GroceryOSLayout.astro";

// Mock data for Grocery Products in POS
const categories = ["All", "Dairy", "Grains", "Snacks", "Beverages", "Household", "Baby", "Fresh"];
const products = [
  { id: 101, name: "Fresh Milk (1L)", price: 65, stock: 42, category: "Dairy", img: "/milk_grocery_item_1773286627780.png" },
  { id: 102, name: "Brown Bread", price: 45, stock: 12, category: "Grains", img: "/bread_grocery_item_1773286648879.png" },
  { id: 103, name: "Organic Eggs", price: 120, stock: 8, category: "Dairy", img: "/eggs_grocery_item_1773286672462.png" },
  { id: 104, name: "Potato Chips", price: 20, stock: 85, category: "Snacks", img: "/chips_grocery_item_1773286688650.png" },
  { id: 105, name: "Detergent", price: 350, stock: 15, category: "Household", img: "/detergent_grocery_item_1773286705195.png" },
  { id: 106, name: "Cola Soda", price: 40, stock: 56, category: "Beverages", img: "placeholder" },
  { id: 107, name: "Baby Diapers", price: 999, stock: 10, category: "Baby", img: "placeholder" },
  { id: 108, name: "Apple (1kg)", price: 180, stock: 25, category: "Fresh", img: "placeholder" },
  { id: 109, name: "Basmati Rice", price: 110, stock: 100, category: "Grains", img: "placeholder" }
];
---

<GroceryOSLayout title="POS Billing | Bobo Grocery OS">
  <div class="pos-layout">
    <!-- Left: Product Selection -->
    <div class="product-selection">
      <div class="pos-top-actions">
        <div class="barcode-search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2z"/><path d="M7 7h1v10H7z"/><path d="M10 7h2v10h-2z"/><path d="M14 7h1v10h-1z"/><path d="M17 7h2v10h-2z"/></svg>
            <input type="text" placeholder="Scan Barcode or Search (F1)..." id="pos-search" />
        </div>
        <div class="category-tabs">
            {categories.map(cat => (
                <button class={`cat-pill ${cat === 'All' ? 'active' : ''}`}>{cat}</button>
            ))}
        </div>
      </div>

      <div class="product-tiles-grid">
        {products.map(p => (
            <div class={`product-tile glass-card ${p.stock < 10 ? 'low-stock' : ''}`} data-id={p.id} data-name={p.name} data-price={p.price}>
                <div class="tile-img-box">
                    {p.img !== 'placeholder' ? (
                        <img src={p.img} alt={p.name} class="tile-img" />
                    ) : (
                        <div class="tile-placeholder">{p.name[0]}</div>
                    )}
                    {p.stock < 10 && <span class="stock-warn">Low</span>}
                </div>
                <div class="tile-info">
                    <span class="p-price">₹{p.price}</span>
                    <span class="p-name">{p.name}</span>
                    <div class="tile-footer">
                        <span class="p-cat">{p.category}</span>
                        <span class="p-qty">{p.stock} in stock</span>
                    </div>
                </div>
            </div>
        ))}
      </div>
    </div>

    <!-- Right: Bill / Cart -->
    <div class="bill-panel glass-card">
        <div class="bill-header">
            <h3>Current Bill</h3>
            <span class="order-id">#ORD-G8812</span>
        </div>

        <div class="customer-attach">
            <div class="cust-info">
                <span class="cust-label">Customer</span>
                <span class="cust-name">Walk-in Customer</span>
            </div>
            <button class="change-cust">Add Loyalty</button>
        </div>

        <div class="cart-items" id="cart-items">
            <div class="empty-cart">
                <div class="empty-icon">🛒</div>
                <p>Bag is empty. Scan items to start billing.</p>
            </div>
        </div>

        <div class="bill-summary">
            <div class="summary-row">
                <span>Subtotal</span>
                <span id="subtotal">₹0.00</span>
            </div>
            <div class="summary-row">
                <span>GST (5%)</span>
                <span id="tax">₹0.00</span>
            </div>
            <div class="summary-row discount">
                <span>Discount</span>
                <span id="discount">-₹0.00</span>
            </div>
            <div class="total-row">
                <span>Total Amount</span>
                <span id="total">₹0.00</span>
            </div>
        </div>

        <div class="payment-methods">
            <button class="pay-btn cash">
                <span class="p-icon">💵</span>
                <span>Cash</span>
            </button>
            <button class="pay-btn upi active">
                <span class="p-icon">📱</span>
                <span>UPI / QR</span>
            </button>
            <button class="pay-btn card">
                <span class="p-icon">💳</span>
                <span>Card</span>
            </button>
        </div>

        <button class="checkout-btn" id="checkout-btn">
            COMPLETE ORDER (F12)
        </button>
    </div>
  </div>

  <style>
    .pos-layout {
        display: grid;
        grid-template-columns: 1fr 420px;
        gap: 32px;
        height: calc(100vh - 160px);
    }

    .product-selection {
        display: flex;
        flex-direction: column;
        gap: 24px;
        overflow-y: auto;
        padding-right: 12px;
    }

    .pos-top-actions {
        display: flex;
        flex-direction: column;
        gap: 20px;
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--bg-dark);
        padding-bottom: 5px;
    }

    .barcode-search {
        position: relative;
    }

    .barcode-search input {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 2px solid var(--border);
        padding: 16px 16px 16px 54px;
        border-radius: 16px;
        color: white;
        font-size: 1.1rem;
        transition: 0.3s;
    }

    .barcode-search input:focus {
        border-color: var(--primary);
        background: rgba(16, 185, 129, 0.05);
        outline: none;
    }

    .barcode-search svg {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--primary);
    }

    .category-tabs {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 10px;
    }

    .cat-pill {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border);
        color: var(--text-muted);
        padding: 8px 20px;
        border-radius: 30px;
        white-space: nowrap;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.85rem;
        transition: 0.2s;
    }

    .cat-pill.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    .product-tiles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 20px;
    }

    .product-tile {
        padding: 16px;
        cursor: pointer;
        transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .product-tile:hover {
        transform: scale(1.03);
        border-color: var(--primary);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .tile-img-box {
        aspect-ratio: 1;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .tile-placeholder {
        font-size: 2rem;
        font-weight: 800;
        opacity: 0.2;
    }

    .stock-warn {
        position: absolute;
        top: 8px;
        right: 8px;
        background: var(--error);
        color: white;
        font-size: 0.7rem;
        font-weight: 800;
        padding: 2px 8px;
        border-radius: 4px;
        text-transform: uppercase;
    }

    .p-price {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--primary);
        font-family: 'Outfit', sans-serif;
    }

    .p-name {
        font-size: 0.95rem;
        font-weight: 600;
        color: white;
    }

    .tile-footer {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    /* Bill Panel */
    .bill-panel {
        display: flex;
        flex-direction: column;
        padding: 24px;
        background: rgba(15, 23, 42, 0.6);
    }

    .bill-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .order-id {
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 600;
    }

    .customer-attach {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 14px;
        margin-bottom: 24px;
    }

    .cust-label {
        display: block;
        font-size: 0.7rem;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 2px;
    }

    .cust-name {
        font-weight: 700;
        font-size: 0.95rem;
    }

    .change-cust {
        background: rgba(16, 185, 129, 0.1);
        border: none;
        color: var(--primary);
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
    }

    .cart-items {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 24px;
    }

    .empty-cart {
        margin: auto;
        text-align: center;
        color: var(--text-muted);
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 12px;
        opacity: 0.3;
    }

    .cart-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 12px;
    }

    .item-main {
        display: flex;
        flex-direction: column;
    }

    .item-name {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .item-price-unit {
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    .item-qty-control {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .qty-btn {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.05);
        color: white;
        cursor: pointer;
    }

    .bill-summary {
        border-top: 1px solid var(--border);
        padding-top: 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 32px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .total-row {
        display: flex;
        justify-content: space-between;
        padding-top: 12px;
        margin-top: 4px;
        border-top: 1px dashed var(--border);
        font-size: 1.4rem;
        font-weight: 800;
        color: white;
    }

    .payment-methods {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 24px;
    }

    .pay-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 14px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text-muted);
        cursor: pointer;
        transition: 0.2s;
    }

    .pay-btn.active {
        background: rgba(16, 185, 129, 0.1);
        border-color: var(--primary);
        color: var(--primary);
    }

    .p-icon { font-size: 1.25rem; }

    .checkout-btn {
        width: 100%;
        background: var(--primary);
        color: white;
        border: none;
        padding: 20px;
        border-radius: 16px;
        font-size: 1.2rem;
        font-weight: 800;
        cursor: pointer;
        transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .checkout-btn:hover {
        transform: scale(1.02);
        box-shadow: 0 15px 40px rgba(16, 185, 129, 0.3);
    }
  </style>

  <script is:inline>
    // Simple Cart Engine
    let cart = [];

    document.querySelectorAll('.product-tile').forEach(tile => {
        tile.addEventListener('click', () => {
            const id = tile.dataset.id;
            const name = tile.dataset.name;
            const price = parseFloat(tile.dataset.price);

            const existing = cart.find(i => String(i.id) === String(id));
            if(existing) {
                existing.qty++;
            } else {
                cart.push({ id, name, price, qty: 1 });
            }
            renderCart();
        });
    });

    function renderCart() {
        const cartEl = document.getElementById('cart-items');
        if(cart.length === 0) {
            cartEl.innerHTML = `<div class="empty-cart"><div class="empty-icon">🛒</div><p>Bag is empty. Scan items to start billing.</p></div>`;
            updateTotals(0);
            return;
        }

        cartEl.innerHTML = cart.map(item => `
            <div class="cart-item">
                <div class="item-main">
                    <span class="item-name">${item.name}</span>
                    <span class="item-price-unit">₹${item.price} x ${item.qty}</span>
                </div>
                <div class="item-qty-control">
                    <button class="qty-btn" onclick="updateQty('${item.id}', -1)">-</button>
                    <span style="font-weight: 700;">${item.qty}</span>
                    <button class="qty-btn" onclick="updateQty('${item.id}', 1)">+</button>
                    <span style="font-weight: 800; margin-left: 8px;">₹${(item.price * item.qty)}</span>
                </div>
            </div>
        `).join('');

        const subtotal = cart.reduce((acc, item) => acc + (item.price * item.qty), 0);
        updateTotals(subtotal);
    }

    // Global function to update quantities in cart
    window.updateQty = (id, delta) => {
        const item = cart.find(i => String(i.id) === String(id));
        if(item) {
            item.qty += delta;
            if(item.qty <= 0) {
                cart = cart.filter(i => String(i.id) !== String(id));
            }
            renderCart();
        }
    };

    function updateTotals(subtotal) {
        const tax = subtotal * 0.05;
        const total = subtotal + tax;

        document.getElementById('subtotal').innerText = `₹${subtotal.toFixed(2)}`;
        document.getElementById('tax').innerText = `₹${tax.toFixed(2)}`;
        document.getElementById('total').innerText = `₹${total.toFixed(2)}`;
    }

    document.getElementById('checkout-btn').addEventListener('click', () => {
        if(cart.length > 0) {
            alert('Order Placed! Generating GST Invoice...');
            cart = [];
            renderCart();
        }
    });

    // Keyboard Shortcuts
    window.addEventListener('keydown', (e) => {
        if(e.key === 'F12') {
            document.getElementById('checkout-btn').click();
        }
        if(e.key === 'F1') {
            document.getElementById('pos-search').focus();
        }
    });
  </script>
</GroceryOSLayout>
