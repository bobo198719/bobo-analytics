---
import GroceryOSLayout from "../../layouts/GroceryOSLayout.astro";

// Mock marketing campaigns
const campaigns = [
  { id: 1, title: "Breakfast Bonanza", type: "WhatsApp", status: "Active", reach: "1.2k", conversion: "12%", discount: "Buy 1 Get 1" },
  { id: 2, title: "Healthy Grains Sale", type: "SMS", status: "Scheduled", reach: "500", conversion: "0%", discount: "20% Off" },
  { id: 3, title: "Flash Sale: Dairy", type: "Email", status: "Completed", reach: "2.4k", conversion: "8%", discount: "15% Off" }
];
---

<GroceryOSLayout title="Marketing Automation | Bobo Grocery OS">
  <div class="header-flex">
      <div>
          <h1>Marketing Factory</h1>
          <p style="color: var(--text-muted);">Launch automated WhatsApp, SMS, and Email campaigns.</p>
      </div>
      <button class="add-btn">+ Create Campaign</button>
  </div>

  <div class="campaign-grid">
      <div class="tool-card glass-card">
          <div class="tool-icon">📱</div>
          <h3>WhatsApp Broadcast</h3>
          <p>Send massive product promotions directly to customer phones.</p>
          <button class="tool-btn">Open Messenger</button>
      </div>
      <div class="tool-card glass-card">
          <div class="tool-icon">✉️</div>
          <h3>Email Marketing</h3>
          <p>Deliver visually rich newsletters with automatic coupon codes.</p>
          <button class="tool-btn">Design Email</button>
      </div>
      <div class="tool-card glass-card">
          <div class="tool-icon">📢</div>
          <h3>SMS Alerts</h3>
          <p>Instant alerts for flash discounts and holiday special offers.</p>
          <button class="tool-btn">Draft SMS</button>
      </div>
  </div>

  <h2 style="margin: 40px 0 24px;">Ongoing Campaigns</h2>
  <div class="campaign-table glass-card">
      <table class="data-table">
          <thead>
              <tr>
                  <th>Campaign Title</th>
                  <th>Channel</th>
                  <th>Offer</th>
                  <th>Reach</th>
                  <th>Conversion</th>
                  <th>Status</th>
                  <th>Actions</th>
              </tr>
          </thead>
          <tbody>
              {campaigns.map(c => (
                  <tr>
                      <td><strong>{c.title}</strong></td>
                      <td>{c.type}</td>
                      <td><span class="offer-tag">{c.discount}</span></td>
                      <td>{c.reach} customers</td>
                      <td>{c.conversion}</td>
                      <td><span class={`status-badge ${c.status.toLowerCase()}`}>{c.status}</span></td>
                      <td><button class="view-btn">View Stats</button></td>
                  </tr>
              ))}
          </tbody>
      </table>
  </div>

  <style>
      .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
      .add-btn { background: var(--primary); border: none; color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; }

      .campaign-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
      .tool-card { padding: 32px; text-align: center; transition: 0.3s; }
      .tool-card:hover { transform: translateY(-5px); border-color: var(--primary); }
      .tool-icon { font-size: 2.5rem; margin-bottom: 20px; }
      .tool-card h3 { margin-bottom: 12px; font-family: 'Outfit'; }
      .tool-card p { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 24px; line-height: 1.5; }
      .tool-btn { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 10px 20px; border-radius: 10px; font-weight: 700; cursor: pointer; width: 100%; transition: 0.2s; }
      .tool-btn:hover { background: white; color: black; }

      .campaign-table { padding: 32px; }
      .data-table { width: 100%; border-collapse: collapse; }
      .data-table th { text-align: left; padding: 16px; font-size: 0.8rem; color: var(--text-muted); border-bottom: 1px solid var(--border); }
      .data-table td { padding: 16px; border-bottom: 1px solid var(--border); }

      .offer-tag { background: rgba(16, 185, 129, 0.1); color: var(--primary); padding: 4px 10px; border-radius: 6px; font-weight: 700; font-size: 0.8rem; }
      .status-badge { font-size: 0.75rem; font-weight: 800; padding: 4px 10px; border-radius: 30px; }
      .status-badge.active { background: rgba(16, 185, 129, 0.1); color: var(--success); }
      .status-badge.scheduled { background: rgba(59, 130, 246, 0.1); color: var(--secondary); }
      .status-badge.completed { background: rgba(255,255,255,0.05); color: var(--text-muted); }

      .view-btn { background: transparent; border: 1px solid var(--border); color: white; padding: 6px 12px; border-radius: 8px; cursor: pointer; }
  </style>
</GroceryOSLayout>
