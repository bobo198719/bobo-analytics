---
import GroceryOSLayout from "../../layouts/GroceryOSLayout.astro";
---

<GroceryOSLayout title="System Settings | Bobo Grocery OS">
  <div class="header-flex">
      <div>
          <h1>Global Settings</h1>
          <p style="color: var(--text-muted);">Configure your store terminals, tax rates, and API integrations.</p>
      </div>
      <button class="save-btn">Save Changes</button>
  </div>

  <div class="settings-grid">
      <div class="settings-sidebar glass-card">
          <button class="s-link active">General Info</button>
          <button class="s-link">Taxes & Billing</button>
          <button class="s-link">Terminals & POS</button>
          <button class="s-link">WhatsApp API</button>
          <button class="s-link">Employee Roles</button>
          <button class="s-link">Security</button>
      </div>

      <div class="settings-content glass-card">
          <div class="s-section">
              <h3>Store Information</h3>
              <div class="field-group">
                  <label>Legal Business Name</label>
                  <input type="text" value="Bobo Supermarket & Fresh" />
              </div>
              <div class="field-group">
                  <label>GSTIN Number</label>
                  <input type="text" value="27AAACBCA1234Z5" />
              </div>
              <div class="field-group">
                  <label>Primary Phone (for WhatsApp)</label>
                  <input type="text" value="+91 98765 43210" />
              </div>
          </div>

          <div class="s-section">
              <h3>Regional & Currency</h3>
              <div class="field-row">
                  <div class="field-group">
                      <label>Base Currency</label>
                      <select><option>INR (₹)</option></select>
                  </div>
                  <div class="field-group">
                      <label>Timezone</label>
                      <select><option>(GMT+05:30) India</option></select>
                  </div>
              </div>
          </div>

          <div class="s-section">
              <h3>Theme Customization</h3>
              <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 20px;">Instantly switch between 10 high-fidelity dashboard themes.</p>
              <div class="theme-grid" id="themeGrid">
                  <div class="theme-option" data-t="emerald"><span class="t-dot" style="background: #10b981"></span> Emerald Market</div>
                  <div class="theme-option" data-t="midnight"><span class="t-dot" style="background: #58a6ff"></span> Midnight Commerce</div>
                  <div class="theme-option" data-t="ocean"><span class="t-dot" style="background: #0ea5e9"></span> Ocean POS</div>
                  <div class="theme-option" data-t="sunrise"><span class="t-dot" style="background: #f97316"></span> Sunrise Store</div>
                  <div class="theme-option" data-t="minimal"><span class="t-dot" style="background: #0f172a"></span> Minimal POS</div>
                  <div class="theme-option" data-t="luxury"><span class="t-dot" style="background: #d4af37"></span> Luxury Commerce</div>
                  <div class="theme-option" data-t="pure"><span class="t-dot" style="background: #3b82f6"></span> Pure Retail</div>
                  <div class="theme-option" data-t="modern"><span class="t-dot" style="background: #ffffff"></span> Modern Business</div>
                  <div class="theme-option" data-t="neon"><span class="t-dot" style="background: #ff00ff"></span> Neon Retail</div>
                  <div class="theme-option" data-t="classic"><span class="t-dot" style="background: #636e72"></span> Classic ERP</div>
              </div>
          </div>

          <script is:inline>
              const currentTheme = localStorage.getItem('bobo_grocery_theme') || 'emerald';
              const options = document.querySelectorAll('.theme-option');
              
              options.forEach(opt => {
                  if(opt.dataset.t === currentTheme) opt.classList.add('active');
                  
                  opt.addEventListener('click', () => {
                      const t = opt.dataset.t;
                      document.documentElement.setAttribute('data-theme', t);
                      localStorage.setItem('bobo_grocery_theme', t);
                      
                      options.forEach(o => o.classList.remove('active'));
                      opt.classList.add('active');
                  });
              });
          </script>

      </div>
  </div>

  <style>
      .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
      .save-btn { background: var(--primary); border: none; color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; }

      .settings-grid { display: grid; grid-template-columns: 280px 1fr; gap: 24px; }
      .settings-sidebar { padding: 16px; display: flex; flex-direction: column; gap: 4px; height: fit-content; }
      .s-link { background: transparent; border: none; color: var(--text-muted); text-align: left; padding: 12px 16px; border-radius: 10px; font-weight: 600; cursor: pointer; transition: 0.2s; }
      .s-link:hover { background: rgba(255,255,255,0.05); color: white; }
      .s-link.active { background: rgba(16, 185, 129, 0.1); color: var(--primary); }

      .settings-content { padding: 40px; display: flex; flex-direction: column; gap: 40px; }
      .s-section h3 { font-family: 'Outfit'; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
      
      .field-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
      .field-group label { font-size: 0.85rem; font-weight: 600; color: var(--text-muted); }
      .field-group input, .field-group select { background: rgba(255,255,255,0.05); border: 1px solid var(--border); padding: 12px; border-radius: 10px; color: white; width: 100%; max-width: 480px; }

      .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 480px; }

      .theme-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; }
      .theme-option { background: rgba(255,255,255,0.03); border: 1px solid var(--border); padding: 12px 16px; border-radius: 12px; font-size: 0.85rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 10px; transition: 0.2s; }
      .theme-option:hover { border-color: var(--primary); background: rgba(255,255,255,0.08); }
      .theme-option.active { border-color: var(--primary); background: rgba(16, 185, 129, 0.1); color: var(--primary); }
      .t-dot { width: 10px; height: 10px; border-radius: 50%; }
  </style>
</GroceryOSLayout>
