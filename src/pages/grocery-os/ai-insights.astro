---
import GroceryOSLayout from "../../layouts/GroceryOSLayout.astro";

// Mock AI Data
const forecasts = [
  { item: "Fresh Milk (1L)", current: 42, suggested: 85, reason: "Local Festival (Weekend)", confidence: "94%" },
  { item: "Organic Eggs", current: 8, suggested: 50, reason: "Low stock alert + Demand surge", confidence: "88%" },
  { item: "Sourdough Bread", current: 12, suggested: 25, reason: "Historical Friday sales trend", confidence: "72%" }
];

const risks = [
  { item: "Detergent Liquid", risk: "Expiry", days: 15, impact: "₹4,200 loss", recommendation: "Bundled Offer (15% Off)" },
  { item: "Potato Chips", risk: "Slow Moving", days: 45, impact: "Store space opt.", recommendation: "Shift to Front Aisle" }
];
---

<GroceryOSLayout title="AI Store Manager | Bobo Grocery OS">
  <div class="ai-header">
      <div class="header-main">
          <div class="ai-badge">✨ AI Autopilot Active</div>
          <h1>Cognitive Commerce Dashboard</h1>
          <p style="color: var(--text-muted);">Predictive demand forecasting and automated retail operations.</p>
      </div>
      <div class="ai-controls">
          <button class="auto-btn">Settings</button>
          <button class="run-btn">Run Deep Analysis</button>
      </div>
  </div>

  <div class="prediction-grid">
      <!-- 1. Demand Forecast -->
      <div class="p-card glass-card">
          <div class="p-header">
              <h3>Demand Forecasting</h3>
              <span class="p-tag">Next 7 Days</span>
          </div>
          <div class="forecast-list">
              {forecasts.map(f => (
                  <div class="f-row">
                      <div class="f-item-info">
                          <span class="f-name">{f.item}</span>
                          <span class="f-reason">{f.reason}</span>
                      </div>
                      <div class="f-values">
                          <div class="v-box">
                              <span class="v-label">Stock</span>
                              <span class="v-val">{f.current}</span>
                          </div>
                          <div class="v-box highlight">
                              <span class="v-label">Suggested</span>
                              <span class="v-val">{f.suggested}</span>
                          </div>
                      </div>
                      <div class="f-conf">
                          <div class="conf-ring" style={`--p: ${f.confidence.replace('%','')}`}>
                              <span>{f.confidence}</span>
                          </div>
                      </div>
                      <button class="reorder-btn">Accept</button>
                  </div>
              ))}
          </div>
      </div>

      <!-- 2. Risk & Expiry -->
      <div class="p-card glass-card">
          <div class="p-header">
              <h3>Risk Intelligence</h3>
              <span class="p-tag danger">Alerts</span>
          </div>
          <div class="risk-stack">
              {risks.map(r => (
                  <div class="r-card">
                      <div class="r-top">
                          <span class="r-name">{r.item}</span>
                          <span class={`r-type ${r.risk.toLowerCase()}`}>{r.risk}</span>
                      </div>
                      <div class="r-body">
                          <div class="r-stat">
                              <span>Potential Loss</span>
                              <strong>{r.impact}</strong>
                          </div>
                          <div class="r-stat">
                              <span>Days Remaining</span>
                              <strong>{r.days} Days</strong>
                          </div>
                      </div>
                      <div class="r-recommendation">
                          <span class="rec-label">Smart Suggestion</span>
                          <p>{r.recommendation}</p>
                          <button class="apply-btn">Apply Strategy</button>
                      </div>
                  </div>
              ))}
          </div>
      </div>
  </div>

  <div class="bottom-insights-grid">
      <!-- Top Performers AI -->
      <div class="insight-panel glass-card">
          <h3>Market Basket Analysis</h3>
          <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 24px;">Customers who bought <strong>Grahams Bread</strong> are 80% likely to buy <strong>Fresh Milk</strong>.</p>
          <div class="correlation-map">
              <div class="c-node">
                  <div class="node-icon">🍞</div>
                  <span>Bread</span>
              </div>
              <div class="c-link">
                  <span class="link-val">80% Linkage</span>
                  <div class="link-line"></div>
              </div>
              <div class="c-node">
                  <div class="node-icon">🥛</div>
                  <span>Milk</span>
              </div>
          </div>
          <button class="promo-btn">Create Bundle Offer</button>
      </div>

      <!-- Supplier Price AI -->
      <div class="insight-panel glass-card">
          <h3>Best Buy Suggestion</h3>
          <div class="supplier-alert">
              <div class="s-alert-icon">💡</div>
              <div class="s-alert-text">
                  <strong>Rice (Basmati)</strong> is 15% cheaper with <strong>Global Grains</strong> today compared to your primary supplier.
              </div>
          </div>
          <div class="price-comparison-graph">
              <div class="compare-row">
                  <span>Current: India Mills</span>
                  <div class="bar-full"><div class="bar-fill" style="width: 100%">₹550</div></div>
              </div>
              <div class="compare-row highlight">
                  <span>AI Rec: Global Grains</span>
                  <div class="bar-full"><div class="bar-fill" style="width: 85%">₹468</div></div>
              </div>
          </div>
          <button class="switch-btn">Switch Supplier for PO #48</button>
      </div>
  </div>

  <style>
      .ai-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; }
      .ai-badge { display: inline-flex; align-items: center; padding: 4px 12px; background: rgba(16, 185, 129, 0.1); color: var(--primary); border-radius: 30px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 12px; }
      .ai-controls { display: flex; gap: 12px; }
      .auto-btn { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; }
      .run-btn { background: var(--primary); border: none; color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; box-shadow: 0 10px 30px rgba(16, 185, 129, 0.2); }

      .prediction-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 32px; margin-bottom: 32px; }
      .p-card { padding: 32px; }
      .p-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
      .p-tag { font-size: 0.75rem; font-weight: 700; background: rgba(255,255,255,0.05); padding: 4px 10px; border-radius: 30px; }
      .p-tag.danger { background: rgba(239, 68, 68, 0.1); color: var(--error); }

      .forecast-list { display: flex; flex-direction: column; gap: 20px; }
      .f-row { display: grid; grid-template-columns: 2fr 1.5fr 80px 100px; align-items: center; gap: 24px; padding: 20px; background: rgba(255,255,255,0.02); border-radius: 16px; border: 1px solid transparent; transition: 0.2s; }
      .f-row:hover { background: rgba(255,255,255,0.05); border-color: var(--primary); }
      
      .f-item-info { display: flex; flex-direction: column; }
      .f-name { font-weight: 700; font-size: 1.1rem; }
      .f-reason { font-size: 0.8rem; color: var(--text-muted); }

      .f-values { display: flex; gap: 16px; }
      .v-box { display: flex; flex-direction: column; background: rgba(255,255,255,0.05); padding: 8px 12px; border-radius: 10px; text-align: center; min-width: 60px; }
      .v-box.highlight { background: rgba(59, 130, 246, 0.1); color: var(--secondary); border: 1px solid rgba(59, 130, 246, 0.2); }
      .v-label { font-size: 0.65rem; text-transform: uppercase; font-weight: 700; opacity: 0.6; }
      .v-val { font-size: 1.1rem; font-weight: 800; font-family: 'Outfit'; }

      .conf-ring { width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 800; border: 3px solid var(--primary); position: relative; }
      
      .reorder-btn { background: var(--primary); color: white; border: none; padding: 10px; border-radius: 10px; font-size: 0.8rem; font-weight: 700; cursor: pointer; }

      .risk-stack { display: flex; flex-direction: column; gap: 24px; }
      .r-card { padding: 24px; background: rgba(255,255,255,0.02); border-radius: 20px; border: 1px solid var(--border); }
      .r-top { display: flex; justify-content: space-between; margin-bottom: 20px; }
      .r-name { font-weight: 800; font-size: 1.2rem; }
      .r-type { font-size: 0.7rem; font-weight: 800; background: rgba(239, 68, 68, 0.1); color: var(--error); padding: 4px 10px; border-radius: 30px; text-transform: uppercase; }
      
      .r-body { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
      .r-stat { display: flex; flex-direction: column; background: rgba(255,255,255,0.05); padding: 12px; border-radius: 12px; }
      .r-stat span { font-size: 0.75rem; color: var(--text-muted); }
      .r-stat strong { font-size: 1rem; color: white; margin-top: 4px; }

      .r-recommendation { background: rgba(16, 185, 129, 0.05); border-radius: 14px; padding: 16px; position: relative; }
      .rec-label { display: block; font-size: 0.7rem; color: var(--primary); font-weight: 800; text-transform: uppercase; margin-bottom: 8px; }
      .r-recommendation p { font-size: 0.85rem; line-height: 1.5; color: rgba(255,255,255,0.8); margin-bottom: 16px; }
      .apply-btn { width: 100%; background: white; color: black; border: none; padding: 10px; border-radius: 8px; font-weight: 700; font-size: 0.8rem; cursor: pointer; }

      .bottom-insights-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
      .insight-panel { padding: 32px; }
      
      .correlation-map { display: flex; align-items: center; justify-content: center; gap: 32px; margin: 32px 0; }
      .c-node { text-align: center; }
      .node-icon { font-size: 2.5rem; margin-bottom: 8px; }
      .c-link { flex: 1; text-align: center; }
      .link-val { display: block; font-size: 0.75rem; font-weight: 800; color: var(--secondary); margin-bottom: 8px; }
      .link-line { height: 4px; background: linear-gradient(90deg, var(--primary), var(--secondary)); border-radius: 10px; }

      .promo-btn { width: 100%; background: var(--secondary); border: none; color: white; padding: 14px; border-radius: 12px; font-weight: 700; cursor: pointer; }

      .supplier-alert { display: flex; gap: 16px; background: rgba(245, 158, 11, 0.1); border-radius: 16px; padding: 16px; margin-bottom: 32px; }
      .s-alert-icon { font-size: 1.5rem; }
      .s-alert-text { font-size: 0.85rem; line-height: 1.5; color: rgba(255,255,255,0.8); }

      .price-comparison-graph { display: flex; flex-direction: column; gap: 20px; margin-bottom: 32px; }
      .compare-row { display: flex; flex-direction: column; gap: 8px; }
      .compare-row span { font-size: 0.8rem; color: var(--text-muted); font-weight: 600; }
      .bar-full { height: 32px; background: rgba(255,255,255,0.05); border-radius: 8px; position: relative; overflow: hidden; }
      .bar-fill { height: 100%; background: rgba(255,255,255,0.2); display: flex; align-items: center; padding: 0 16px; font-size: 0.9rem; font-weight: 800; }
      .compare-row.highlight .bar-fill { background: var(--primary); color: white; }

      .switch-btn { width: 100%; background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 14px; border-radius: 12px; font-weight: 700; cursor: pointer; }
  </style>
</GroceryOSLayout>
