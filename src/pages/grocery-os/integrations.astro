---
import GroceryOSLayout from "../../layouts/GroceryOSLayout.astro";

const integrations = [
  { id: "wa", name: "WhatsApp Business API", provider: "Meta/Geni", status: "Connected", icon: "💬", desc: "Automated ordering, invoices, and customer support bot." },
  { id: "pg", name: "Razorpay / Stripe", provider: "Payments", status: "Configuration Needed", icon: "💳", desc: "Accept online payments for web orders and deliveries." },
  { id: "sms", name: "Twilio SMS", provider: "Twilio", status: "Inactive", icon: "📱", desc: "Send order updates and promotional alerts via SMS." },
  { id: "mail", name: "SendGrid", provider: "Email", status: "Connected", icon: "📧", desc: "Professional invoices and marketing campaign delivery." },
  { id: "pos", name: "Thermal Printer SDK", provider: "Hardware", status: "Local Link Active", icon: "🖨️", desc: "Direct printing from browser to POS thermal printer." }
];
---

<GroceryOSLayout title="Integrations | Bobo Grocery OS">
  <div class="int-header">
      <div>
          <h1 style="font-size: 2.5rem; font-weight: 800; font-family: 'Outfit'; letter-spacing: -0.02em;">Connected <span class="gradient-text">Ecosystem</span></h1>
          <p style="color: var(--text-muted); font-size: 1.1rem;">Bridge your grocery operations with 50+ global logistics, payment, and marketing providers.</p>
      </div>
      <div class="search-ints">
          <input type="text" placeholder="Search marketplace..." class="int-search" />
          <button class="add-int-btn">Explore Directory</button>
      </div>
  </div>

  <div class="integration-grid">
      {integrations.map(int => (
          <div class="int-card glass-card">
              <div class="int-top">
                  <div class="int-icon">{int.icon}</div>
                  <div class={`int-status-badge ${int.status.toLowerCase().replace(' ', '-')}`}>{int.status}</div>
              </div>
              <div class="int-content">
                  <h3>{int.name}</h3>
                  <p class="provider">{int.provider}</p>
                  <p class="desc">{int.desc}</p>
              </div>
              <div class="int-actions">
                  <button class="configure-btn">Configure API</button>
                  {int.id === 'wa' && <button class="bot-btn">Manage Bot</button>}
              </div>
          </div>
      ))}
  </div>

  <div class="webhook-section glass-card">
      <div class="panel-header">
          <h3>Webhooks & Developer API</h3>
          <p>Sync your store data with 3rd party apps using secure endpoints.</p>
      </div>
      <div class="api-key-box">
          <label>Secret API Key</label>
          <div class="key-input">
              <input type="password" value="sk_live_51Mxxxxxxxxxxxxxxxxxx" readonly />
              <button class="copy-btn">Copy</button>
          </div>
      </div>
  </div>

  <style>
      .gradient-text { background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
      .int-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px; }
      .search-ints { display: flex; gap: 12px; }
      .int-search { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 12px 20px; border-radius: 12px; width: 250px; outline: none; transition: 0.3s; }
      .int-search:focus { border-color: var(--primary); background: rgba(255,255,255,0.08); }
      .add-int-btn { background: var(--primary); border: none; color: white; padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; font-family: 'Outfit'; }

      .integration-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 32px; margin-bottom: 64px; }
      .int-card { padding: 40px; display: flex; flex-direction: column; gap: 24px; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid var(--border); overflow: hidden; position: relative; }
      .int-card::after { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, var(--primary) 0%, transparent 70%); opacity: 0; transition: 0.6s; pointer-events: none; }
      .int-card:hover { border-color: var(--primary); transform: translateY(-10px); box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5); }
      .int-card:hover::after { opacity: 0.05; }
      
      .int-top { display: flex; justify-content: space-between; align-items: flex-start; }
      .int-icon { font-size: 2.2rem; width: 72px; height: 72px; background: rgba(255,255,255,0.03); display: flex; align-items: center; justify-content: center; border-radius: 20px; border: 1px solid var(--border); }
      
      .int-status-badge { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; padding: 6px 12px; border-radius: 30px; letter-spacing: 0.05em; border: 1px solid transparent; }
      .int-status-badge.connected { background: rgba(16, 185, 129, 0.1); color: var(--success); border-color: rgba(16, 185, 129, 0.2); }
      .int-status-badge.configuration-needed { background: rgba(245, 158, 11, 0.1); color: var(--warning); border-color: rgba(245, 158, 11, 0.2); }
      .int-status-badge.inactive { background: rgba(255, 255, 255, 0.05); color: var(--text-muted); border-color: var(--border); }

      .int-content h3 { font-family: 'Outfit'; font-size: 1.4rem; margin-bottom: 6px; letter-spacing: -0.01em; }
      .provider { font-size: 0.75rem; color: var(--primary); font-weight: 800; text-transform: uppercase; margin-bottom: 16px; letter-spacing: 0.05em; }
      .desc { font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; }

      .int-actions { display: flex; gap: 12px; margin-top: auto; }
      .configure-btn { flex: 1; background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 12px; border-radius: 12px; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: 0.2s; }
      .configure-btn:hover { background: rgba(255,255,255,0.1); border-color: white; }
      .bot-btn { background: #25D366; border: none; color: white; padding: 12px 20px; border-radius: 12px; font-weight: 700; font-size: 0.9rem; cursor: pointer; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(37, 211, 102, 0.2); }

      .webhook-section { padding: 48px; border-radius: 32px; background: linear-gradient(135deg, rgba(16, 185, 129, 0.05) 0%, rgba(99, 102, 241, 0.05) 100%); border: 1px solid rgba(16, 185, 129, 0.1); }
      .panel-header h3 { font-family: 'Outfit'; font-size: 1.8rem; margin-bottom: 12px; letter-spacing: -0.02em; }
      .panel-header p { color: var(--text-muted); margin-bottom: 40px; font-size: 1.1rem; }
      
      .api-key-box { max-width: 600px; display: grid; gap: 24px; }
      .key-group { }
      .key-group label { display: block; font-size: 0.75rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; margin-bottom: 12px; letter-spacing: 0.05em; }
      .key-input { display: flex; gap: 12px; }
      .key-input input { flex: 1; background: #000; border: 1px solid var(--border); padding: 16px; border-radius: 14px; color: var(--primary); font-family: 'Fira Code', monospace; font-size: 0.9rem; }
      .copy-btn { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white; padding: 0 24px; border-radius: 14px; font-weight: 700; cursor: pointer; transition: 0.2s; }
      .copy-btn:hover { background: white; color: black; }
  </style>
</GroceryOSLayout>
